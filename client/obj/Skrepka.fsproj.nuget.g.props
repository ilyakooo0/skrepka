<?xml version="1.0" encoding="utf-8" standalone="no"?>
<Project ToolsVersion="14.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup Condition=" '$(ExcludeRestorePackageImports)' != 'true' ">
    <RestoreSuccess Condition=" '$(RestoreSuccess)' == '' ">True</RestoreSuccess>
    <RestoreTool Condition=" '$(RestoreTool)' == '' ">NuGet</RestoreTool>
    <ProjectAssetsFile Condition=" '$(ProjectAssetsFile)' == '' ">$(MSBuildThisFileDirectory)project.assets.json</ProjectAssetsFile>
    <NuGetPackageRoot Condition=" '$(NuGetPackageRoot)' == '' ">/Users/iko/.nuget/packages/</NuGetPackageRoot>
    <NuGetPackageFolders Condition=" '$(NuGetPackageFolders)' == '' ">/Users/iko/.nuget/packages/</NuGetPackageFolders>
    <NuGetProjectStyle Condition=" '$(NuGetProjectStyle)' == '' ">PackageReference</NuGetProjectStyle>
    <NuGetToolVersion Condition=" '$(NuGetToolVersion)' == '' ">7.0.0</NuGetToolVersion>
  </PropertyGroup>
  <ItemGroup Condition=" '$(ExcludeRestorePackageImports)' != 'true' ">
    <SourceRoot Include="/Users/iko/.nuget/packages/" />
  </ItemGroup>
  <ImportGroup Condition=" '$(TargetFramework)' == 'net10.0-ios' AND '$(ExcludeRestorePackageImports)' != 'true' ">
    <Import Project="$(NuGetPackageRoot)microsoft.net.illink.tasks/10.0.5/build/Microsoft.NET.ILLink.Tasks.props" Condition="Exists('$(NuGetPackageRoot)microsoft.net.illink.tasks/10.0.5/build/Microsoft.NET.ILLink.Tasks.props')" />
    <Import Project="$(NuGetPackageRoot)microsoft.maui.resizetizer/10.0.0/buildTransitive/Microsoft.Maui.Resizetizer.props" Condition="Exists('$(NuGetPackageRoot)microsoft.maui.resizetizer/10.0.0/buildTransitive/Microsoft.Maui.Resizetizer.props')" />
    <Import Project="$(NuGetPackageRoot)microsoft.maui.core/10.0.0/buildTransitive/Microsoft.Maui.Core.props" Condition="Exists('$(NuGetPackageRoot)microsoft.maui.core/10.0.0/buildTransitive/Microsoft.Maui.Core.props')" />
    <Import Project="$(NuGetPackageRoot)microsoft.maui.controls.build.tasks/10.0.0/buildTransitive/net6.0-ios10.0/Microsoft.Maui.Controls.Build.Tasks.props" Condition="Exists('$(NuGetPackageRoot)microsoft.maui.controls.build.tasks/10.0.0/buildTransitive/net6.0-ios10.0/Microsoft.Maui.Controls.Build.Tasks.props')" />
  </ImportGroup>
  <ImportGroup Condition=" '$(TargetFramework)' == 'net10.0-maccatalyst' AND '$(ExcludeRestorePackageImports)' != 'true' ">
    <Import Project="$(NuGetPackageRoot)microsoft.net.illink.tasks/10.0.5/build/Microsoft.NET.ILLink.Tasks.props" Condition="Exists('$(NuGetPackageRoot)microsoft.net.illink.tasks/10.0.5/build/Microsoft.NET.ILLink.Tasks.props')" />
    <Import Project="$(NuGetPackageRoot)microsoft.maui.resizetizer/10.0.0/buildTransitive/Microsoft.Maui.Resizetizer.props" Condition="Exists('$(NuGetPackageRoot)microsoft.maui.resizetizer/10.0.0/buildTransitive/Microsoft.Maui.Resizetizer.props')" />
    <Import Project="$(NuGetPackageRoot)microsoft.maui.core/10.0.0/buildTransitive/Microsoft.Maui.Core.props" Condition="Exists('$(NuGetPackageRoot)microsoft.maui.core/10.0.0/buildTransitive/Microsoft.Maui.Core.props')" />
    <Import Project="$(NuGetPackageRoot)microsoft.maui.controls.build.tasks/10.0.0/buildTransitive/net6.0-maccatalyst13.1/Microsoft.Maui.Controls.Build.Tasks.props" Condition="Exists('$(NuGetPackageRoot)microsoft.maui.controls.build.tasks/10.0.0/buildTransitive/net6.0-maccatalyst13.1/Microsoft.Maui.Controls.Build.Tasks.props')" />
  </ImportGroup>
  <PropertyGroup Condition=" '$(TargetFramework)' == 'net10.0-ios' AND '$(ExcludeRestorePackageImports)' != 'true' ">
    <PkgSodium_Core Condition=" '$(PkgSodium_Core)' == '' ">/Users/iko/.nuget/packages/sodium.core/1.4.0</PkgSodium_Core>
    <PkgMicrosoft_NET_ILLink_Tasks Condition=" '$(PkgMicrosoft_NET_ILLink_Tasks)' == '' ">/Users/iko/.nuget/packages/microsoft.net.illink.tasks/10.0.5</PkgMicrosoft_NET_ILLink_Tasks>
    <PkgMicrosoft_Maui_Controls Condition=" '$(PkgMicrosoft_Maui_Controls)' == '' ">/Users/iko/.nuget/packages/microsoft.maui.controls/10.0.0</PkgMicrosoft_Maui_Controls>
    <PkgFSharp_Core Condition=" '$(PkgFSharp_Core)' == '' ">/Users/iko/.nuget/packages/fsharp.core/9.0.100</PkgFSharp_Core>
    <PkgFabulous_MauiControls Condition=" '$(PkgFabulous_MauiControls)' == '' ">/Users/iko/.nuget/packages/fabulous.mauicontrols/9.0.0-pre9</PkgFabulous_MauiControls>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(TargetFramework)' == 'net10.0-maccatalyst' AND '$(ExcludeRestorePackageImports)' != 'true' ">
    <PkgSodium_Core Condition=" '$(PkgSodium_Core)' == '' ">/Users/iko/.nuget/packages/sodium.core/1.4.0</PkgSodium_Core>
    <PkgMicrosoft_NET_ILLink_Tasks Condition=" '$(PkgMicrosoft_NET_ILLink_Tasks)' == '' ">/Users/iko/.nuget/packages/microsoft.net.illink.tasks/10.0.5</PkgMicrosoft_NET_ILLink_Tasks>
    <PkgMicrosoft_Maui_Controls Condition=" '$(PkgMicrosoft_Maui_Controls)' == '' ">/Users/iko/.nuget/packages/microsoft.maui.controls/10.0.0</PkgMicrosoft_Maui_Controls>
    <PkgFSharp_Core Condition=" '$(PkgFSharp_Core)' == '' ">/Users/iko/.nuget/packages/fsharp.core/9.0.100</PkgFSharp_Core>
    <PkgFabulous_MauiControls Condition=" '$(PkgFabulous_MauiControls)' == '' ">/Users/iko/.nuget/packages/fabulous.mauicontrols/9.0.0-pre9</PkgFabulous_MauiControls>
  </PropertyGroup>
</Project>