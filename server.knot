-- GET /stats/peers: per-peer failure summary derived from `forwardFailures`,
-- including current backoff and pending forward queue depth.
handleStatsPeers : Text -> ({ok: Bool, peers: [{avgLatencyMs: Int, backoffMs: Int<Ms>, failures: Int, firstFailedAt: Int<Ms>, gossipEventsPerMin: Int, lastFailedAt: Int<Ms>, latencySamples: Int, maxLatencyMs: Int, pendingForwards: Int, retriable: Bool, server: Text}]} -> a) -> IO {r *forwardFailures, r *forwards, r *runtimeMaintenanceSecret, clock} a
handleStatsPeers = \authorization respond -> withMaintAuth authorization (yield (respond {
  peers: [],
  ok: False {}
})) (do
  t <- now
  failures <- *forwardFailures
  fwds <- *forwards
  yield (respond {
    peers: pluck failures (\f -> {
      f.server,
      f.failures,
      lastFailedAt: f.failedAt,
      f.firstFailedAt,
      backoffMs: retryBackoff f.failures,
      retriable: shouldRetryServer f.server t failures,
      pendingForwards: countWhere fwds (\x -> x.toServer == f.server),
      avgLatencyMs: 0,
      maxLatencyMs: 0,
      latencySamples: 0,
      gossipEventsPerMin: 0
    }),
    ok: True {}
  }))

-- GET /stats/key/{pubkey}: per-key footprint — message count, presence rows,
-- session count, queued forwards (with details), and active long-poll count.
handleStatsKey : PubkeyHex -> Text -> ({activePolls: Int, forwardDetails: [{createdAt: Int<Ms>, retries: Int, server: ServerName}], forwards: Int, messages: Int, ok: Bool, presence: [{expiresAt: Int<Ms>, server: AnyServerName}], sessions: Int} -> a) -> IO {r *activePolls, r *forwards, r *messages, r *presence, r *runtimeMaintenanceSecret, r *sessions, clock} a
handleStatsKey = \pubkey authorization respond -> withMaintAuth authorization (yield (respond {
  messages: 0,
  presence: [],
  sessions: 0,
  forwards: 0,
  forwardDetails: [],
  activePolls: 0,
  ok: False {}
})) (do
  t <- now
  msgs <- *messages
  pres <- *presence
  ses <- *sessions
  fwds <- *forwards
  aps <- *activePolls
  let myFwds = filter fwds (\x -> x.toKey == pubkey)
  yield (respond {
    messages: countWhere msgs (\x -> x.toKey == pubkey),
    presence: mapWhere pres (\x -> x.pubkey == pubkey && x.expiresAt > t) (\x -> {
      x.server,
      x.expiresAt
    }),
    sessions: countWhere ses (\x -> x.pubkey == pubkey),
    forwards: count myFwds,
    forwardDetails: pluck myFwds (\x -> {server: x.toServer, x.retries, x.createdAt}),
    activePolls: countWhere aps (\x -> x.pubkey == pubkey),
    ok: True {}
  }))

-- POST /stats/top-recipients: ranked list of pubkeys by mailbox depth.
-- `limit` defaults to 20, capped at 100, used to spot hot-spots / abuse.
handleTopRecipients : Int -> Text -> ({ok: Bool, recipients: [RecipientCount], total: Int} -> a) -> IO {r *messages, r *runtimeMaintenanceSecret} a
handleTopRecipients = \limit authorization respond -> withMaintAuth authorization (yield (respond {
  recipients: [],
  ok: False {},
  total: 0
})) (do
  msgs <- *messages
  let counts = pluck (pluck msgs (\m -> m.toKey)) (\pk -> {
    pubkey: pk,
    count: countWhere msgs (\m -> m.toKey == pk)
  })
  let cap = clamp 1 100 (if limit <= 0 then 20 else limit)
  let top = takeRelation cap (sortBy (\c -> 0 - c.count) counts)
  yield (respond {recipients: top, ok: True {}, total: count counts}))

-- GET /stats/forwards: per-destination forward queue summary — count, age of
-- oldest pending entry, and total accumulated retries.
handleStatsForwards : Text -> ({ok: Bool, servers: [{count: Int<u>, oldestAge: Int<Ms>, server: ServerName, totalRetries: Int}], total: Int} -> a) -> IO {r *forwards, r *runtimeMaintenanceSecret, clock} a
handleStatsForwards = \authorization respond -> withMaintAuth authorization (yield (respond {
  servers: [],
  ok: False {},
  total: 0
})) (do
  t <- now
  fwds <- *forwards
  yield (respond {
    servers: pluck (collectPeers fwds (\f -> f.toServer)) (\s -> (\svFwds -> {server: s, count: count svFwds, oldestAge: t - fold (\acc f -> min acc f.createdAt) t svFwds, totalRetries: fold (\acc f -> acc + f.retries) 0 svFwds}) (filter fwds (\f -> f.toServer == s))),
    ok: True {},
    total: count fwds
  }))

-- GET /stats/rates: same shape as /maintenance/rate-limits with an extra
-- scalePct field. Kept separate for backwards compatibility with older clients.
handleStatsRates : Text -> ({authGlobal: Int, challengeRate: Int, clientWriteRate: Int, federationRate: Int, globalRequest: Int, ipRate: Int, lookupRate: Int, ok: Bool, pairRate: Int, recvRate: Int, scalePct: Int, sendRate: Int} -> a) -> IO {r *runtimeMaintenanceSecret} a
handleStatsRates = \authorization respond -> do
  ok <- verifyMaintenanceAuth authorization
  let v = \x -> if ok then x else 0
  yield (respond {
    ok,
    scalePct: v 100,
    globalRequest: v maxGlobalRequestRate,
    ipRate: v maxIpRatePerIp,
    sendRate: v maxSendRatePerKey,
    federationRate: v maxFederationRatePerServer,
    authGlobal: v maxAuthGlobalRate,
    recvRate: v maxRecvRatePerKey,
    challengeRate: v maxChallengeRatePerKey,
    pairRate: v maxPairRatePerPair,
    lookupRate: v maxLookupRatePerKey,
    clientWriteRate: v maxClientWriteRatePerKey
  })

-- GET /metrics: Prometheus-style text exposition of the most useful gauges.
-- The `authorization` header is accepted but not validated here — operators
-- relying on auth must front this endpoint with a reverse proxy that enforces it.
handleMetrics : a -> ({metrics: Text, ok: Bool} -> b) -> IO {r *activePolls, r *drainPhase, r *forwards, r *messages, r *presence, r *sessions, r *startedAt, clock} b
handleMetrics = \authorization respond -> do
  t <- now
  msgs <- *messages
  ses <- *sessions
  pres <- *presence
  fwds <- *forwards
  aps <- *activePolls
  sa <- *startedAt
  dp <- *drainPhase
  yield (respond {
    metrics: fold (\acc r -> acc ++ r.k ++ " " ++ show r.v ++ "\n") "" [
      {k: "skrepka_messages_total", v: count msgs},
      {k: "skrepka_sessions_total", v: count ses},
      {k: "skrepka_presence_total", v: count pres},
      {k: "skrepka_forwards_total", v: count fwds},
      {k: "skrepka_active_polls", v: count aps},
      {k: "skrepka_uptime_seconds", v: (t - sa) / 1000},
      {k: "skrepka_draining", v: if dp > 0 then 1 else 0}
    ],
    ok: True {}
  })

-- ============================================
-- Dispatch
-- ============================================
-- Single match from generated request constructor (one per route entry above)
-- to the corresponding `handleXxx` function. Adding a new route means adding
-- a `route ... = NewReq` line, a `handleNewReq` definition, and a clause here.

-- Top-level request dispatcher: maps each generated request constructor to
-- its `handleXxx` function. Every route entry above must have a clause here.
serve = \req -> case req of
  ReqChallenge {pubkey, clientIp, respond} -> handleChallenge pubkey clientIp respond
  VerifyAuth {pubkey, challenge, signature, revokeOthers, clientIp, respond} -> handleVerifyAuth pubkey challenge signature revokeOthers clientIp respond
  RevokeSession {targetToken, authorization, clientIp, respond} -> handleRevoke targetToken authorization clientIp respond
  Logout {authorization, clientIp, respond} -> handleLogout authorization clientIp respond
  Poll {cursor, generation, authorization, clientIp, respond} -> handlePoll cursor generation authorization clientIp respond
  SendMessages {messages, authorization, clientIp, respond} -> handleSendMessages messages authorization clientIp respond
  MessageStatus {to, messageId, authorization, clientIp, respond} -> handleMessageStatus to messageId authorization clientIp respond
  AckMessages {messageIds, authorization, clientIp, respond} -> handleAckMessages messageIds authorization clientIp respond
  ListMessages {offset, authorization, clientIp, respond} -> handleListMessages offset authorization clientIp respond
  DeleteMessages {messageIds, authorization, clientIp, respond} -> handleDeleteMessages messageIds authorization clientIp respond
  LookupPresence {pubkey, authorization, clientIp, respond} -> handleLookupPresence pubkey authorization clientIp respond
  BatchLookupPresence {pubkeys, authorization, clientIp, respond} -> handleBatchLookupPresence pubkeys authorization clientIp respond
  RecvGossip {events, fromServer, requestTimestamp, authorization, respond} -> handleRecvGossip events fromServer requestTimestamp authorization respond
  ForwardMessage {toKey, encryptedBlob, messageId, fromServer, requestTimestamp, authorization, respond} -> handleForwardMessage toKey encryptedBlob messageId fromServer requestTimestamp authorization respond
  FederationBatchForward {forwards, fromServer, requestTimestamp, authorization, respond} -> handleFederationBatchForward forwards fromServer requestTimestamp authorization respond
  FederationPubkey {respond} -> handleFederationPubkey respond
  Prune {authorization, respond} -> handlePrune authorization respond
  Drain {phase, authorization, respond} -> handleDrain phase authorization respond
  Shutdown {authorization, respond} -> handleShutdown authorization respond
  Undrain {authorization, respond} -> handleUndrain authorization respond
  BlockPeer {server, authorization, respond} -> handleBlockPeer server authorization respond
  UnblockPeer {server, authorization, respond} -> handleUnblockPeer server authorization respond
  ListBlocked {authorization, respond} -> handleListBlocked authorization respond
  PingPeer {server, authorization, respond} -> handlePingPeer server authorization respond
  AdminListSessions {pubkey, authorization, respond} -> handleAdminListSessions pubkey authorization respond
  AdminRevokeSessions {pubkey, authorization, respond} -> handleAdminRevokeSessions pubkey authorization respond
  AdminListAllSessions {limit, authorization, respond} -> handleAdminListAllSessions limit authorization respond
  AdminPurgeMessages {pubkey, authorization, respond} -> handleAdminPurgeMessages pubkey authorization respond
  AdminRevokeIp {ip, authorization, respond} -> handleAdminRevokeIp ip authorization respond
  GetRateLimits {authorization, respond} -> handleGetRateLimits authorization respond
  SetRateLimits {globalRequest, ipRate, sendRate, federationRate, authGlobal, recvRate, challengeRate, pairRate, lookupRate, clientWriteRate, authorization, respond} -> handleSetRateLimits globalRequest ipRate sendRate federationRate authGlobal recvRate challengeRate pairRate lookupRate clientWriteRate authorization respond
  FlushNonces {authorization, respond} -> handleFlushNonces authorization respond
  AllowPeer {server, authorization, respond} -> handleAllowPeer server authorization respond
  UnallowPeer {server, authorization, respond} -> handleUnallowPeer server authorization respond
  ListAllowed {authorization, respond} -> handleListAllowed authorization respond
  Reconcile {authorization, respond} -> handleReconcile authorization respond
  RotateSecret {newSecret, authorization, respond} -> handleRotateSecret newSecret authorization respond
  GetConfig {authorization, respond} -> handleGetConfig authorization respond
  Health {authorization, respond} -> handleHealth authorization respond
  Stats {authorization, respond} -> handleStats authorization respond
  StatsPeers {authorization, respond} -> handleStatsPeers authorization respond
  StatsKey {pubkey, authorization, respond} -> handleStatsKey pubkey authorization respond
  TopRecipients {limit, authorization, respond} -> handleTopRecipients limit authorization respond
  StatsForwards {authorization, respond} -> handleStatsForwards authorization respond
  StatsRates {authorization, respond} -> handleStatsRates authorization respond
  Metrics {authorization, respond} -> handleMetrics authorization respond
  Ready {respond} -> handleReady respond

-- ============================================
-- Background loops
-- ============================================
-- `backgroundPrune` runs `pruneAndRetry` every `backgroundPruneInterval` ms
-- (skipped while drain phase >= 2). `pollHeartbeat` bumps `pollWakeup` every
-- `pollTimeoutMs` so long-poll holders unblock and return an empty heartbeat
-- response, keeping connections fresh.

-- Endless tick: every `backgroundPruneInterval` run `pruneAndRetry` (skipped
-- when drain phase >= 2) and bump `pruneCount` for /stats and /health.
backgroundPrune : IO {r *drainPhase, rw *activePolls, r *blockedPeers, rw *challenges, rw *deliveredIds, rw *forwardFailures, rw *forwards, rw *lastPresenceRefresh, rw *lastPrunedAt, rw *messages, rw *presence, rw *pruneCount, rw *sessions, clock} a
backgroundPrune = do
  sleep backgroundPruneInterval
  dp <- *drainPhase
  when (dp < 2) (do
    t <- now
    atomic (do pc <- *pruneCount; *pruneCount = pc + 1)
    pruneAndRetry t)
  backgroundPrune

-- Endless tick that bumps `pollWakeup` every `pollTimeoutMs` so any blocked
-- /poll holders unblock and return an empty heartbeat response.
pollHeartbeat : IO {rw *heartbeatCount, rw *lastHeartbeatAt, rw *pollWakeup, clock} a
pollHeartbeat = do
  sleep pollTimeoutMs
  t <- now
  atomic (do *pollWakeup = t; *lastHeartbeatAt = t; hc <- *heartbeatCount; *heartbeatCount = hc + 1)
  pollHeartbeat

-- ============================================
-- Entry Point
-- ============================================
-- Stamp `startedAt` and a fresh `serverGeneration` (used by clients to detect
-- server restarts and reset their poll cursor), spawn the two background
-- loops, and start the listener.

-- Entry point: stamp startup metadata, lazily generate the federation keypair
-- on first run, fork the background loops, and start the HTTP listener.
main : IO {| _} {}
main = do
  t <- now
  genJitter <- randomInt 1000000
  atomic (do *startedAt = t; *serverGeneration = t * 1000 + genJitter)
  priv <- *federationPrivateKeyHex
  when (priv == "") (do
    kp <- generateKeyPair
    atomic (do
      *federationPrivateKeyHex = bytesToHex kp.privateKey
      *federationPublicKeyHex = bytesToHex kp.publicKey)
    logInfo "Generated federation keypair on first startup")
  logInfo ("Skrepka relay server starting on " ++ bindHost ++ ":" ++ show listenPort ++ " ...")
  logInfo ("  federation: " ++ (if federationEnabled then "enabled" else "disabled"))
  fork backgroundPrune
  fork pollHeartbeat
  listenOn bindHost listenPort serve
