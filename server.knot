-- Suppresses latency metric recording during startup probe phase (prevents
-- unauthenticated probe results from skewing initial /stats readings)
*startupProbeActive : Bool

-- Total session count across all buckets (avoids O(16) recount on monitoring paths)
*totalSessionCount : Int

-- Auth-tier global rate limiting state
*authGlobalRateCount : Int
*authGlobalRatePrevCount : Int
*authGlobalRateWindowStart : Timestamp

-- Max concurrent background prune forks (prevents resource exhaustion from stuck recovery)
*activePruneForks : Int

-- Signal for drain timeout (set by forked timer, watched by STM retry in waitForInFlightDrain)
*drainTimedOut : Bool

-- Recent federation requests for replay detection (dedup by server+timestamp)
*recentFederationRequests : [RecentFederationRequest]

-- Pending verification tokens for federation callback auth (single-use, short-lived)
-- scope binds the token to a specific request type (gossip/forward/ack) to prevent cross-use
*pendingVerifications : [{token: Text, createdAt: Timestamp, scope: Text}]

-- Forward nonce dedup sharded into 16 buckets by pubkeyBucket(toKey).
-- Reduces hot-path scan in handleForwardMessage from O(100k) to O(6k).
*nonceBucket0 : [ForwardNonce]
*nonceBucket1 : [ForwardNonce]
*nonceBucket2 : [ForwardNonce]
*nonceBucket3 : [ForwardNonce]
*nonceBucket4 : [ForwardNonce]
*nonceBucket5 : [ForwardNonce]
*nonceBucket6 : [ForwardNonce]
*nonceBucket7 : [ForwardNonce]
*nonceBucket8 : [ForwardNonce]
*nonceBucket9 : [ForwardNonce]
*nonceBucket10 : [ForwardNonce]
*nonceBucket11 : [ForwardNonce]
*nonceBucket12 : [ForwardNonce]
*nonceBucket13 : [ForwardNonce]
*nonceBucket14 : [ForwardNonce]
*nonceBucket15 : [ForwardNonce]

-- Nonce eviction replay protection: per-bucket cutoff tracking.
-- Each bucket independently tracks the seenAt of its oldest retained nonce after LRU
-- eviction. Forwards with timestamps older than the *bucket-specific* cutoff are rejected.
-- Previous design used a single global cutoff, which incorrectly rejected valid forwards:
-- bucket 3 evicting nonces from 5 min ago would set a cutoff that also rejected forwards
-- for bucket 12 (which might have nonces from 30 days ago, all retained).
-- 0 = no eviction has occurred in this bucket, accept all timestamps.
*nonceEvictionCutoff0 : Timestamp
*nonceEvictionCutoff1 : Timestamp
*nonceEvictionCutoff2 : Timestamp
*nonceEvictionCutoff3 : Timestamp
*nonceEvictionCutoff4 : Timestamp
*nonceEvictionCutoff5 : Timestamp
*nonceEvictionCutoff6 : Timestamp
*nonceEvictionCutoff7 : Timestamp
*nonceEvictionCutoff8 : Timestamp
*nonceEvictionCutoff9 : Timestamp
*nonceEvictionCutoff10 : Timestamp
*nonceEvictionCutoff11 : Timestamp
*nonceEvictionCutoff12 : Timestamp
*nonceEvictionCutoff13 : Timestamp
*nonceEvictionCutoff14 : Timestamp
*nonceEvictionCutoff15 : Timestamp

-- Federation verify per-IP rate limiting (tighter than general IP rate)
*verifyIpRates : [IpRateEntry]

-- Per-peer gossip event volume rate limiting
*gossipEventRates : [GossipEventRateEntry]

-- Global federation connection counter (tracks total concurrent outbound connections)
*federationActiveConnections : Int

-- Blocked federation peers (managed at runtime via /maintenance/block and /maintenance/unblock)
*blockedPeers : [Text]

-- Allowed federation peers (when non-empty, only these servers can federate with us)
-- Managed via /maintenance/allow and /maintenance/unallow. Empty = open federation.
*allowedPeers : [Text]

-- Deferred ack cleanups: origin message reclamation queued by federation ack handlers,
-- processed by the prune cycle after ackGracePeriod elapses (replaces fork+sleep pattern).
*pendingAckCleanups : [{messageId: MessageIdHex, toKey: PubkeyHex, cleanupAfter: Timestamp}]

-- Cached successful verify callbacks per-server (short-lived, reduces outbound HTTP calls)
*verificationCache : [{server: Text, scope: Text, verifiedAt: Timestamp}]

-- Cached peer Ed25519 public keys for signature-based federation auth.
-- Fetched from GET /federation/pubkey on first contact, cached with peerKeyTtlMs TTL.
-- failedAt tracks last failed fetch to enforce peerKeyRefetchCooldownMs.
*peerPublicKeys : [{server: Text, pubkey: Text, fetchedAt: Timestamp, failedAt: Timestamp}]

-- Per-IP unique key tracking: detects when a single IP authenticates many distinct pubkeys
-- (key-rotation abuse bypassing per-key rate limits). Pruned with other rate limiters.
*uniqueKeyIpRates : [UniqueKeyIpEntry]

-- Sender expiration notifications: messages that expired unread, queued for the sender's next poll.
-- Populated during prune for locally-originated messages (senderKey != "").
*senderExpirations : [SenderExpiration]

-- Sender delivery receipts: messages polled/acked by the recipient, queued for the sender's next poll.
-- Populated during ackPolledMessages and handleAckMessages for locally-originated messages.
*senderDeliveries : [SenderDelivery]

-- Cancel notifications: messages retracted by the sender, queued for the recipient's next poll.
-- Populated during handleCancelMessage, handleFederationCancel, handleFederationBatchCancel.
*cancelNotifications : [CancelNotification]

-- Pending federation cancels: queued when cancel delivery to a remote server fails.
-- Retried during the prune cycle alongside forward retries and ack retries.
*pendingFederationCancels : [PendingFederationCancel]

-- Per-sender drop counters: tracks how many delivery receipts / expiration notifications
-- were evicted before the sender could poll them. Keyed by senderKey so each sender sees
-- only their own drops (not a global counter that conflates all senders). Drained on poll.
*droppedDeliveryReceipts : [{senderKey: Text, count: Int, lastUpdated: Timestamp}]
*droppedExpirationNotifs : [{senderKey: Text, count: Int, lastUpdated: Timestamp}]

-- Runtime maintenance secret: when non-empty, used instead of compile-time maintenanceSecret.
-- Set via /maintenance/rotate-secret to enable zero-downtime secret rotation.
-- Empty = use compile-time maintenanceSecret (default).
*runtimeMaintenanceSecret : Text

-- Runtime-configurable rate limit overrides (0 = use compile-time default).
-- Adjusted via /maintenance/rate-limits POST endpoint without recompile+restart.
*rateOverrideGlobalRequest : Int
*rateOverrideIpRate : Int
*rateOverrideSendRate : Int
*rateOverrideFederationRate : Int
*rateOverrideAuthGlobal : Int
*rateOverrideRecvRate : Int
*rateOverrideChallengeRate : Int
*rateOverridePairRate : Int
*rateOverrideLookupRate : Int
*rateOverrideClientWriteRate : Int

-- Runtime-configurable operational parameter overrides (0 = use compile-time default).
-- Adjusted via /maintenance/config POST endpoint without recompile+restart.
*configOverrideMaxMessagesPerRecipient : Int
*configOverrideMaxGossipHops : Int
*configOverridePollTimeoutMs : Int

-- Rate-limit rejection counters: track how many requests were rejected by each rate limiter.
-- Exposed via /stats for operators to tune rate limits without parsing logs.
-- Reset on each federation latency window reset (same cadence as other metrics).
*rateLimitedGlobal : Int
*rateLimitedIp : Int
*rateLimitedAuth : Int
*rateLimitedPerKey : Int
*rateLimitedFederation : Int

-- Cancel metrics: track message cancellation volume for operator visibility.
-- Reset with federation latency window (same cadence as other windowed metrics).
*clientCancelCount : Int
*federationCancelCount : Int

-- Monotonic counter bumped on any presence change (gossip, auth, logout, prune, restore, drain)
-- Polls compare against this to skip expensive presence lookups when nothing changed.
*presenceVersion : Timestamp

-- Active request counter: tracks concurrent requests for backpressure visibility.
-- Incremented at request start, decremented after handler completes.
-- If serveInner panics (Knot lacks try-finally), the counter leaks. The prune cycle
-- reconciles by checking lastRequestCompletedAt: if no request has completed in
-- 3x pollTimeoutMs but activeRequests > 0, the counter is reset.
*activeRequests : Int
*peakActiveRequests : Int
*lastRequestCompletedAt : Timestamp

-- Client operation latency tracking (for /stats, reset with federation latency window)
*clientPollLatencyTotal : Int<Ms>
*clientPollLatencyCount : Int
*clientPollLatencyMax : Int<Ms>
*clientSendLatencyTotal : Int<Ms>
*clientSendLatencyCount : Int
*clientSendLatencyMax : Int<Ms>

-- Client latency histogram buckets (poll and send): [0,50ms), [50,200ms), [200,1000ms), [1000+ms)
-- Approximates P50/P95/P99 for client-facing operations. Reset with federation latency window.
*clientPollLatencyBucket0 : Int
*clientPollLatencyBucket1 : Int
*clientPollLatencyBucket2 : Int
*clientPollLatencyBucket3 : Int
*clientSendLatencyBucket0 : Int
*clientSendLatencyBucket1 : Int
*clientSendLatencyBucket2 : Int
*clientSendLatencyBucket3 : Int

-- Client latency histogram thresholds (ms)
clientLatencyT1 : Int<Ms>
clientLatencyT1 = 50
clientLatencyT2 : Int<Ms>
clientLatencyT2 = 200
clientLatencyT3 : Int<Ms>
clientLatencyT3 = 1000

-- Auth (challenge + verify) latency tracking (for /stats, reset with latency window)
*clientAuthLatencyTotal : Int<Ms>
*clientAuthLatencyCount : Int
*clientAuthLatencyMax : Int<Ms>

-- Last time the background watchdog loop ran (for health check liveness detection)
*lastWatchdogAt : Timestamp

-- Cached health result: returned when /health is rate-limited instead of false all-healthy.
-- Updated on every successful (non-rate-limited) health check.
*cachedHealthOk : Bool
*cachedHealthPrune : Bool
*cachedHealthHeartbeat : Bool
*cachedHealthCapacity : Bool
*cachedHealthFederation : Bool
*cachedHealthWatchdog : Bool
*cachedHealthNonce : Bool
*cachedHealthCapacityWarning : Bool
*cachedHealthForwardQueue : Bool
-- Cached count of federation peers with active failure records (degraded connectivity)
*cachedHealthDegradedPeers : Int
-- Cached request pressure health (activeRequests < 90% of maxActiveRequests)
*cachedHealthRequestPressure : Bool
-- Cached count of destination servers with stale forward queues (updated during prune cycle).
-- Used by health checks to avoid scanning all 16 forward buckets on every /health request.
*cachedForwardStaleCount : Int

-- Cached adaptive rate scale factor (0-100%). Updated every prune cycle.
-- Avoids 3 STM reads per rate check on the hot path. 100 = no scaling (default).
*cachedAdaptiveScale : Int

-- Gossip send metrics (windowed, reset with federation latency metrics)
*gossipSendSuccess : Int
*gossipSendFail : Int

-- ============================================
-- Routes
-- ============================================

-- Authentication: Ed25519 challenge-response flow
-- 1. Client POSTs pubkey to /auth/challenge, gets a random challenge string
-- 2. Client signs the challenge with their private key and POSTs to /auth/verify
-- 3. Server verifies signature, returns a session token
route AuthApi where
  /auth
    POST {pubkey: PubkeyHex} /challenge headers {clientIp: Text}
      -> {challenge: Text, ok: Bool, expiresAt: Timestamp, retryAfterMs: Int, error: Text}
      = ReqChallenge
    POST {pubkey: PubkeyHex, challenge: Text, signature: SignatureHex, revokeOthers: Bool} /verify headers {clientIp: Text}
      -> {token: Text, expiresAt: Timestamp, error: Text}
      = VerifyAuth
    POST {targetToken: Text} /revoke headers {authorization: Text, clientIp: Text}
      -> {ok: Bool, authorized: Bool}
      = RevokeSession
    -- Voluntary disconnect: removes session and gossips offline if last session for this key
    POST {} /logout headers {authorization: Text, clientIp: Text}
      -> {ok: Bool, authorized: Bool}
      = Logout

-- Client-facing API (requires session token in Authorization header)
route ClientApi where
  -- Long-poll for new messages; cursor tracks last-seen receivedAt timestamp
  POST {cursor: Timestamp, generation: Int, watchKeys: [PubkeyHex]} /poll headers {authorization: Text, clientIp: Text}
    -> {events: [PollEvent], cursor: Timestamp, authorized: Bool, rateLimited: Bool, draining: Bool, generation: Int, presenceUpdates: [{pubkey: PubkeyHex, online: Bool}], heartbeat: Bool, retryAfterMs: Int, cursorReset: Bool, hasMore: Bool, cursorStale: Bool, messageExpirations: [{messageId: MessageIdHex, toKey: PubkeyHex, expiredAt: Timestamp}], messageDeliveries: [{messageId: MessageIdHex, toKey: PubkeyHex, deliveredAt: Timestamp}], droppedDeliveryReceipts: Int, droppedExpirationNotifs: Int, loadPct: Int, messageCancellations: [{messageId: MessageIdHex, cancelledAt: Timestamp}]}
    = Poll
  /messages
    -- Send an E2E encrypted message to a recipient pubkey.
    -- expiresInMs: optional sender-specified TTL in milliseconds (0 or negative = server default).
    -- Clamped to [minMessageTtl, unackedMessageMaxAge]. Allows ephemeral messages.
    -- priority: optional urgency level (0 = normal, higher = more urgent, clamped to [0, maxMessagePriority]).
    -- High-priority messages are forwarded first during federation retries.
    POST {to: PubkeyHex, encryptedBlob: BlobHex, timestamp: Timestamp, messageId: OptionalMessageId, expiresInMs: Int, priority: Int} / headers {authorization: Text, clientIp: Text}
      -> {status: MessageStatus, messageId: OptionalMessageId, retryAfterMs: Int, error: Text, loadPct: Int}
      = SendMessage
    -- Check delivery status of a sent message (caller must know recipient to prove ownership)
    POST {to: PubkeyHex, messageId: MessageIdHex} /status headers {authorization: Text, clientIp: Text}
      -> {status: Text, authorized: Bool}
      = MessageStatus
    -- Explicitly acknowledge received messages by ID (alternative to cursor-based ack in poll)
    POST {messageIds: [MessageIdHex]} /ack headers {authorization: Text, clientIp: Text}
      -> {ok: Bool, authorized: Bool, ackedCount: Int, error: Text}
      = AckMessages
    -- Send multiple messages in one request (auth checked once; each message rate-limited independently)
    POST {messages: [BatchMessage]} /batch headers {authorization: Text, clientIp: Text}
      -> {results: [BatchResult], authorized: Bool, retryAfterMs: Int}
      = SendBatch
    -- List pending messages without acking (useful after cursor loss or device migration).
    -- offset: skip the first N messages (for pagination, default 0).
    POST {offset: Int} /list headers {authorization: Text, clientIp: Text}
      -> {messages: [{messageId: MessageIdHex, timestamp: Timestamp, receivedAt: Timestamp}], authorized: Bool, count: Int, error: Text}
      = ListMessages
    -- Delete pending messages by ID (recipient-only; messages don't store sender pubkey)
    POST {messageIds: [MessageIdHex]} /delete headers {authorization: Text, clientIp: Text}
      -> {ok: Bool, authorized: Bool, deletedCount: Int, error: Text}
      = DeleteMessages
    -- Cancel (retract) a sent message before the recipient reads it.
    -- Caller provides messageId and recipient pubkey — knowing the messageId proves
    -- sender identity (either client-generated or returned only to the sender).
    -- Removes from recipient mailbox, cancels pending forwards, sends federation acks.
    POST {messageId: MessageIdHex, to: PubkeyHex} /cancel headers {authorization: Text, clientIp: Text}
      -> {ok: Bool, authorized: Bool, cancelled: Bool, error: Text}
      = CancelMessage
    -- Cancel (retract) multiple sent messages in one request.
    -- Each cancel is processed independently; partial success is possible.
    POST {cancels: [BatchCancelEntry]} /cancel-batch headers {authorization: Text, clientIp: Text}
      -> {results: [BatchCancelResult], authorized: Bool, error: Text}
      = CancelBatch
  -- Look up which server a pubkey is present on (for federation routing)
  GET /lookup/{pubkey: PubkeyHex} headers {authorization: Text, clientIp: Text}
    -> {server: AnyServerName, authorized: Bool, error: Text}
    = LookupPresence
  -- Batch lookup: look up presence for multiple pubkeys in one request
  POST {pubkeys: [PubkeyHex]} /lookup/batch headers {authorization: Text, clientIp: Text}
    -> {results: [{pubkey: PubkeyHex, server: AnyServerName}], authorized: Bool, error: Text}
    = BatchLookupPresence

-- Server-to-server federation API (authenticated via domain callback verification)
-- correlationId: optional trace ID for cross-server request tracing (empty = not provided).
-- Peers that don't support it send "" — logged when present but not enforced.
-- protocolVersion: federation protocol version of the sending server (0 = pre-versioning).
-- Older peers omit this field; Knot defaults missing Int fields to 0.
route FederationApi where
  /federation
    -- Receive presence gossip events from a peer server
    POST {events: [GossipEvent], hopsRemaining: Int, fromServer: ServerName, requestTimestamp: Timestamp, correlationId: Text, protocolVersion: Int} /gossip headers {authorization: Text}
      -> {ok: Bool, error: Text, retryAfterMs: Int}
      = RecvGossip
    -- Receive a forwarded message from a peer server on behalf of a sender.
    -- NOTE: senderKey is intentionally NOT included in the forward protocol. The sender's
    -- identity is inside the E2E encrypted blob — exposing it in plaintext would break the
    -- privacy model (the server never learns who sent a message). /messages/cancel for
    -- federated messages requires the client to include sender identity in the encrypted
    -- payload; the server cannot verify sender identity for federation-forwarded messages.
    POST {toKey: PubkeyHex, encryptedBlob: BlobHex, timestamp: Timestamp, originServer: ServerName, messageId: MessageIdHex, fromServer: ServerName, requestTimestamp: Timestamp, correlationId: Text, expiresAt: Timestamp, priority: Int, protocolVersion: Int} /forward headers {authorization: Text}
      -> {ok: Bool, error: Text, retryAfterMs: Int}
      = ForwardMessage
    -- Acknowledge delivery of messages back to the origin server
    POST {messageIds: [MessageIdHex], originServer: ServerName, fromServer: ServerName, requestTimestamp: Timestamp, correlationId: Text, protocolVersion: Int} /ack headers {authorization: Text}
      -> {ok: Bool, error: Text, ackedCount: Int, results: [{messageId: MessageIdHex, found: Bool}], retryAfterMs: Int}
      = FederationAck
    -- Cancel (retract) a previously forwarded message. The origin server sends this
    -- when the sender cancels a message via /messages/cancel. The receiving server
    -- deletes the message if it hasn't been polled by the recipient yet.
    -- Security: the handler checks msg.originServer == fromServer, and fromServer is
    -- authenticated via the verify callback (the receiver calls back to fromServer to
    -- confirm the token). A relay peer cannot forge fromServer because the callback
    -- would go to the wrong server, which wouldn't have the token. This prevents a
    -- malicious relay from cancelling messages it forwarded on behalf of the origin.
    POST {messageId: MessageIdHex, toKey: PubkeyHex, fromServer: ServerName, requestTimestamp: Timestamp, correlationId: Text, protocolVersion: Int} /cancel headers {authorization: Text}
      -> {ok: Bool, error: Text, cancelled: Bool, retryAfterMs: Int}
      = FederationCancel
    -- Batch cancel: cancel multiple previously forwarded messages in one request.
    POST {cancels: [{messageId: MessageIdHex, toKey: PubkeyHex}], fromServer: ServerName, requestTimestamp: Timestamp, correlationId: Text, protocolVersion: Int} /cancel-batch headers {authorization: Text}
      -> {ok: Bool, error: Text, results: [BatchCancelResult], retryAfterMs: Int}
      = FederationBatchCancel
    -- Batch forward: forward multiple messages in one request (reduces HTTP round-trips).
    -- Each message is processed independently; partial success is possible.
    -- Results are returned per-message so the sender knows which forwards succeeded.
    POST {forwards: [{toKey: PubkeyHex, encryptedBlob: BlobHex, timestamp: Timestamp, originServer: ServerName, messageId: MessageIdHex, expiresAt: Timestamp, priority: Int}], fromServer: ServerName, requestTimestamp: Timestamp, correlationId: Text, protocolVersion: Int} /forward-batch headers {authorization: Text}
      -> {ok: Bool, error: Text, results: [{messageId: MessageIdHex, ok: Bool}], retryAfterMs: Int}
      = FederationBatchForward
    -- Delivery receipt: destination server notifies origin that a federated message was
    -- polled/acked by the recipient. Origin server records it as a sender delivery receipt.
    -- Best-effort: failures are not retried (ack path already confirms delivery at the
    -- protocol level; receipts are a UX enhancement for sender-side delivery indicators).
    POST {messageIds: [MessageIdHex], toKeys: [PubkeyHex], fromServer: ServerName, requestTimestamp: Timestamp, correlationId: Text, protocolVersion: Int} /delivery-receipt headers {authorization: Text}
      -> {ok: Bool, error: Text, receivedCount: Int, retryAfterMs: Int}
      = FederationDeliveryReceipt

-- Federation callback verification: the receiving server calls back to the sender
-- to confirm a request token is genuine. No shared secret needed.
-- NOTE: Tokens are not bound to the caller's IP. A MITM that intercepts a token
-- can replay it from a different IP within the 30-second TTL (verificationTokenExpiry).
-- Mitigations: (1) tokens are single-use (consumed on first verify), (2) per-IP rate
-- limiting (verifyIpRates) constrains brute-force probing, (3) the verify cache
-- (verificationCacheMs=2s) limits the replay window after the first legitimate verify.
-- Binding to IP would break federation through NAT/proxy topologies where the
-- verifying server's egress IP differs from the initial request's source IP.
route FederationVerifyApi where
  POST {token: Text, scope: Text} /federation/verify headers {clientIp: Text} -> {ok: Bool} = VerifyToken

-- Ed25519 federation public key endpoint: peers fetch this to verify signed requests.
-- Unauthenticated (like /health and /ready). Rate-limited via health rate limiter.
route FederationPubkeyApi where
  GET /federation/pubkey -> {pubkey: Text, ok: Bool} = FederationPubkey

-- Triggers pruning of expired state and retry of pending federation ops
route MaintenanceApi where
  POST {} /maintenance/prune headers {authorization: Text}
    -> {ok: Bool}
    = Prune
  -- phase: 0 or 2 = full drain (backward compat), 1 = soft drain (auth-only block)
  POST {phase: Int} /maintenance/drain headers {authorization: Text}
    -> {ok: Bool, drained: Int, phase: Int}
    = Drain
  POST {} /maintenance/undrain headers {authorization: Text}
    -> {ok: Bool}
    = Undrain
  -- Graceful shutdown: triggers full drain + sets shutdown flag so background loops exit.
  -- Call this instead of drain when the process should stop after flush completes.
  POST {} /maintenance/shutdown headers {authorization: Text}
    -> {ok: Bool, drained: Int}
    = Shutdown
  -- Block a federation peer (rejects all inbound/outbound federation with this server)
  POST {server: ServerName} /maintenance/block headers {authorization: Text}
    -> {ok: Bool, blocked: Int}
    = BlockPeer
  -- Unblock a previously blocked peer
  POST {server: ServerName} /maintenance/unblock headers {authorization: Text}
    -> {ok: Bool, unblocked: Bool}
    = UnblockPeer
  -- List currently blocked peers
  GET /maintenance/blocked headers {authorization: Text}
    -> {peers: [Text], ok: Bool}
    = ListBlocked
  -- Test federation connectivity to a specific peer via verify callback round-trip
  POST {server: ServerName} /maintenance/ping headers {authorization: Text}
    -> {ok: Bool, latencyMs: Int, error: Text}
    = PingPeer
  -- List sessions for a specific pubkey (admin debugging)
  GET /maintenance/sessions/{pubkey: PubkeyHex} headers {authorization: Text}
    -> {sessions: [{token: Text, expiresAt: Timestamp, ip: Text, createdAt: Timestamp}], count: Int, ok: Bool}
    = AdminListSessions
  -- Revoke all sessions for a specific pubkey (abuse response)
  POST {pubkey: PubkeyHex} /maintenance/sessions/revoke-all headers {authorization: Text}
    -> {ok: Bool, revokedCount: Int}
    = AdminRevokeSessions
  -- Purge all pending messages for a specific pubkey (inbox bombing response)
  POST {pubkey: PubkeyHex} /maintenance/messages/purge headers {authorization: Text}
    -> {ok: Bool, purgedCount: Int}
    = AdminPurgeMessages
  -- Revoke all sessions from a specific IP address (key-rotation abuse response)
  POST {ip: Text} /maintenance/sessions/revoke-ip headers {authorization: Text}
    -> {ok: Bool, revokedCount: Int, affectedKeys: Int}
    = AdminRevokeIp
  -- List all active session pubkeys grouped by IP (admin debugging, abuse investigation).
  -- Helps detect suspicious multi-key activity without knowing the pubkey in advance.
  -- limit: max entries to return (default 100, capped at 500). 0 = default.
  POST {limit: Int} /maintenance/sessions/list headers {authorization: Text}
    -> {sessions: [{pubkey: PubkeyHex, count: Int, ips: [Text], latestExpiry: Timestamp}], ok: Bool, total: Int}
    = AdminListAllSessions
  -- Read current effective rate limits (compile-time defaults + runtime overrides)
  GET /maintenance/rate-limits headers {authorization: Text}
    -> {ok: Bool, globalRequest: Int, ipRate: Int, sendRate: Int, federationRate: Int, authGlobal: Int, recvRate: Int, challengeRate: Int, pairRate: Int, lookupRate: Int, clientWriteRate: Int}
    = GetRateLimits
  -- Update rate limits at runtime (0 = reset to compile-time default)
  POST {globalRequest: Int, ipRate: Int, sendRate: Int, federationRate: Int, authGlobal: Int, recvRate: Int, challengeRate: Int, pairRate: Int, lookupRate: Int, clientWriteRate: Int} /maintenance/rate-limits headers {authorization: Text}
    -> {ok: Bool}
    = SetRateLimits
  -- Flush forward nonces (recovery from corruption or capacity issues)
  POST {} /maintenance/nonces/flush headers {authorization: Text}
    -> {ok: Bool, flushedCount: Int}
    = FlushNonces
  -- Allow a federation peer (when allowlist is non-empty, only allowed peers can federate)
  POST {server: ServerName} /maintenance/allow headers {authorization: Text}
    -> {ok: Bool, allowed: Int}
    = AllowPeer
  -- Remove a server from the federation allowlist
  POST {server: ServerName} /maintenance/unallow headers {authorization: Text}
    -> {ok: Bool, removed: Bool}
    = UnallowPeer
  -- List currently allowed federation peers (empty = open federation)
  GET /maintenance/allowed headers {authorization: Text}
    -> {peers: [Text], ok: Bool}
    = ListAllowed
  -- Force counter reconciliation (message counts, presence, sessions).
  -- Returns drift values; non-zero means counters were corrected.
  POST {} /maintenance/reconcile headers {authorization: Text}
    -> {ok: Bool, messageDrift: Int, presenceDrift: Int, sessionDrift: Int}
    = Reconcile
  -- Rotate maintenance secret at runtime (zero-downtime rotation).
  -- Authenticated with the current secret; sets a new runtime secret that overrides
  -- the compile-time default. Pass empty newSecret to revert to compile-time secret.
  POST {newSecret: Text} /maintenance/rotate-secret headers {authorization: Text}
    -> {ok: Bool, error: Text}
    = RotateSecret
  -- Read current effective operational config (compile-time defaults + runtime overrides)
  GET /maintenance/config headers {authorization: Text}
    -> {ok: Bool, maxMessagesPerRecipient: Int, maxGossipHops: Int, pollTimeoutMs: Int}
    = GetConfig
  -- Update operational config at runtime (0 = reset to compile-time default)
  POST {maxMessagesPerRecipient: Int, maxGossipHops: Int, pollTimeoutMs: Int} /maintenance/config headers {authorization: Text}
    -> {ok: Bool}
    = SetConfig

route HealthApi where
  GET /health headers {authorization: Text} -> {ok: Bool, version: Text, pruneHealthy: Bool, heartbeatHealthy: Bool, capacityHealthy: Bool, capacityWarning: Bool, federationHealthy: Bool, watchdogHealthy: Bool, nonceHealthy: Bool, forwardQueueHealthy: Bool, requestPressureHealthy: Bool, draining: Bool, degradedPeers: Int} = Health

-- Returns counts of in-memory collections (requires maintenance secret)
-- TODO: If Knot adds raw text response support, add a /metrics endpoint
-- returning Prometheus exposition format for direct integration with standard
-- monitoring stacks. Currently /stats returns JSON which requires a custom scraper.
-- Stats response grouped into nested objects for monitoring dashboard ergonomics.
-- BREAKING CHANGE from flat format — existing scrapers must update field paths.
route StatsApi where
  GET /stats headers {authorization: Text}
    -> {ok: Bool, version: Text, capacity: {sessions: Int, sessionsMax: Int, sessionsPct: Int, messages: Int, messagesMax: Int, messagesPct: Int, totalMessageCount: Int, presence: Int, presenceMax: Int, presencePct: Int, forwards: Int, forwardsMax: Int, forwardsPct: Int, challenges: Int, challengesMax: Int, ackedIds: Int, ackedIdsMax: Int, ackOverflow: Int, ackOverflowMax: Int, deliveredIds: Int, deliveredIdsMax: Int, forwardNonces: Int, forwardNoncesMax: Int, activePolls: Int, activePollsMax: Int, recipientCounts: Int, messageBucketMax: Int, messageBucketMin: Int}, federation: {enabled: Bool, inFlight: Int, hungSlots: Int, avgLatencyMs: Int, maxLatencyMs: Int, callCount: Int, slowVerifies: Int, verifyFailures: Int, forwardFailures: Int, oldestForwardAge: Int, oldestAckAge: Int, recentGossip: Int, blockedPeers: Int, drainCompletedAt: Timestamp, forwardServers: Int, maxForwardQueueDepth: Int, topFailingPeers: [{server: Text, failures: Int}], pendingCancels: Int, gossipSuccess: Int, gossipFail: Int, latencyBuckets: {lt100: Int, lt500: Int, lt2000: Int, gte2000: Int}}, rates: {send: Int, challenge: Int, federation: Int, federationPair: Int, global: Int, ip: Int, lookup: Int, recv: Int, pair: Int, gossipEvent: Int, verifyIp: Int, uniqueKeyIp: Int, pendingAckCleanups: Int, senderExpirations: Int, senderDeliveries: Int, rejectedGlobal: Int, rejectedIp: Int, rejectedAuth: Int, rejectedPerKey: Int, rejectedFederation: Int, clientCancels: Int, federationCancels: Int}, timing: {pruneCount: Int, pruneRunning: Timestamp, heartbeatCount: Int, uptime: Int, lastPruneAt: Timestamp, lastHeartbeatAt: Timestamp, draining: Bool, drainPhase: Int, totalEntries: Int, activeRequests: Int, peakActiveRequests: Int, pollAvgMs: Int, pollMaxMs: Int, pollCount: Int, pollLatencyBuckets: {lt50: Int, lt200: Int, lt1000: Int, gte1000: Int}, sendAvgMs: Int, sendMaxMs: Int, sendCount: Int, sendLatencyBuckets: {lt50: Int, lt200: Int, lt1000: Int, gte1000: Int}, authAvgMs: Int, authMaxMs: Int, authCount: Int}}
    = Stats
  GET /stats/peers headers {authorization: Text}
    -> {peers: [PeerStatus], ok: Bool}
    = StatsPeers
  GET /stats/key/{pubkey: PubkeyHex} headers {authorization: Text}
    -> {messages: Int, presence: [KeyPresenceEntry], sessions: Int, forwards: Int, forwardDetails: [{server: Text, retries: Int, createdAt: Timestamp}], activePolls: Int, ok: Bool}
    = StatsKey
  -- Top recipients by pending message count (for abuse investigation — find inbox-bombing targets).
  -- limit: max recipients to return (default 20, capped at 100). 0 = default.
  POST {limit: Int} /stats/top-recipients headers {authorization: Text}
    -> {recipients: [RecipientCount], ok: Bool, total: Int}
    = TopRecipients
  -- Per-server forward queue breakdown: shows pending forwards grouped by destination server.
  -- Use to identify which peers have queue buildup (unreachable or slow peers).
  GET /stats/forwards headers {authorization: Text}
    -> {servers: [{server: Text, count: Int, oldestAge: Int, totalRetries: Int}], ok: Bool, total: Int}
    = StatsForwards
  -- Effective rate limits after adaptive scaling: shows the current scale factor and
  -- each rate limit as it's actually applied (compile-time default * runtime override * adaptive scale).
  -- Helps operators understand why requests are being rejected under load.
  GET /stats/rates headers {authorization: Text}
    -> {ok: Bool, scalePct: Int, globalRequest: Int, ipRate: Int, sendRate: Int, federationRate: Int, authGlobal: Int, recvRate: Int, challengeRate: Int, pairRate: Int, lookupRate: Int, clientWriteRate: Int}
    = StatsRates

-- Prometheus-compatible metrics endpoint. Returns key metrics in a JSON field containing
-- Prometheus exposition format text. A lightweight scraper/adapter extracts the "metrics"
-- field and serves it as text/plain to Prometheus. This is the best we can do since Knot
-- routes always return JSON (no raw text response support).
-- Rate-limited via health rate limiter (same as /ready and /federation/pubkey).
route MetricsApi where
  GET /metrics headers {authorization: Text} -> {metrics: Text, ok: Bool} = Metrics

-- Readiness probe: returns false during startup warmup (before first prune completes),
-- true once the server is fully operational. Unlike /health, this is unauthenticated
-- and doesn't check subsystem liveness — it only indicates whether the server has
-- completed initialization. Use for Kubernetes readinessProbe or load balancer warmup.
route ReadyApi where
  GET /ready -> {ready: Bool} = Ready

route Api = AuthApi | ClientApi | FederationApi | FederationVerifyApi | FederationPubkeyApi | MaintenanceApi | HealthApi | StatsApi | MetricsApi | ReadyApi

-- ============================================
-- Helpers
-- ============================================

-- Structured log helpers (severity-prefixed for operator filtering)
logInfo = \msg -> println ("[INFO] " ++ msg)
logWarn = \msg -> println ("[WARN] " ++ msg)
logError = \msg -> println ("[ERROR] " ++ msg)

-- JSON structured log helper for machine-parseable events.
-- Outputs: {"level":"<level>","event":"<event>","msg":"<message>"}
-- Use for key operational events that monitoring pipelines need to parse
-- (rate limit rejections, federation failures, capacity warnings).
-- Plain-text logInfo/logWarn/logError remain for human-readable context.
-- Values are escaped (quotes and backslashes) to produce valid JSON even
-- when msg contains user-controlled data (e.g., error strings, server names).
logEvent = \level event msg -> println ("{\"level\":\"" ++ escapeJsonString level ++ "\",\"event\":\"" ++ escapeJsonString event ++ "\",\"msg\":\"" ++ escapeJsonString msg ++ "\"}")

-- Structured key=value logging: formats message as "k1=v1 k2=v2 ..." for consistent
-- machine-parseable log entries. Wraps logEvent with key-value pair formatting.
-- Use for events where individual fields need to be extracted by log pipelines.
logKV = \level event kvs ->
  logEvent level event (joinKVPairs kvs)

joinKVPairs = \kvs -> fold (\acc kv -> if acc == "" then kv else acc ++ " " ++ kv) "" kvs

-- Log a warning when a federation peer sends a request with an older protocol version.
-- protocolVersion == 0 means pre-versioning peer (field missing). Only logs once per
-- request — callers invoke this before delegating to the handler.
warnOldProtocol = \fromServer pv ->
  when (pv > 0 && pv < federationProtocolVersion)
    (logWarn ("federation: peer " ++ fromServer ++ " using protocol v" ++ show pv ++ " (current: v" ++ show federationProtocolVersion ++ ")"))

-- Log per-server detail for stale in-flight entries (hung connection debugging).
-- Emits one structured event per server with slot count and duration.
logStaleInFlight = \entries t ->
  case headOf entries of
    Nothing {} -> yield {}
    Just {value: r} -> do
      logEvent "error" "stale_inflight" (r.server ++ " " ++ show r.count ++ " slots hung for " ++ show (t - r.firstStartedAt) ++ "ms")
      logStaleInFlight (do e <- entries; where e.server != r.server; yield e) t

-- Fast path: check if a string contains only safe JSON characters (hex digits,
-- alphanumerics, common punctuation). If so, no escaping is needed.
-- Returns False on the first unsafe character. Tail-recursive (TCO-safe in Knot).
isJsonSafe : Text -> Bool
isJsonSafe = \s ->
  if s == "" then True {}
  else let c = take 1 s in
    if contains c "0123456789abcdefABCDEF_-.:/ " then isJsonSafe (drop 1 s)
    else if contains c "ghijklmnopqrstuvwxyzGHIJKLMNOPQRSTUVWXYZ" then isJsonSafe (drop 1 s)
    else False {}

-- Escape special characters for safe JSON string embedding.
-- Handles: backslash, double quote, and control characters (\n, \r, \t).
-- Non-printable characters outside this set are stripped (same allowlist as
-- stripNonPrintable) to prevent log injection via error strings from federation peers.
-- Fast path: strings containing only safe chars (hex, alphanumeric, common punctuation)
-- are returned unchanged, avoiding O(n) per-character recursion for validated types.
-- Uses an accumulator parameter for tail recursion (TCO-safe in Knot):
-- the recursive call is in tail position, not wrapped by ++.
escapeJsonString : Text -> Text
escapeJsonString = \s ->
  if s == "" then ""
  else if isJsonSafe s then s
  else escapeJsonStringAcc s ""

escapeJsonStringAcc : Text -> Text -> Text
escapeJsonStringAcc = \s acc ->
  if s == "" then acc
  else let c = take 1 s in
    if c == "\\" then escapeJsonStringAcc (drop 1 s) (acc ++ "\\\\")
    else if c == "\"" then escapeJsonStringAcc (drop 1 s) (acc ++ "\\\"")
    else if c == "\n" then escapeJsonStringAcc (drop 1 s) (acc ++ "\\n")
    else if c == "\r" then escapeJsonStringAcc (drop 1 s) (acc ++ "\\r")
    else if c == "\t" then escapeJsonStringAcc (drop 1 s) (acc ++ "\\t")
    else if contains c printableAscii then escapeJsonStringAcc (drop 1 s) (acc ++ c)
    else escapeJsonStringAcc (drop 1 s) acc

any : [a] -> (a -> Bool) -> Bool
any = \xs pred -> fold (\acc x -> if acc then acc else pred x) (False {}) xs
none : [a] -> (a -> Bool) -> Bool
none = \xs pred -> not (any xs pred)
when = \cond action -> if cond then action else yield {}
whenOk = \result action -> case result of
  Ok _ -> action
  Err _ -> yield {}
clamp = \lo hi x -> if x < lo then lo else if x > hi then hi else x
-- Union that skips empty lists (avoids allocation overhead on empty buckets).
-- When one side is empty, returns the other without copying.
unionNE = \a b -> if count a == 0 then b else if count b == 0 then a else union a b
min = \a b -> if a < b then a else b
max = \a b -> if a > b then a else b

-- Per-sender drop counter helpers: increment a per-key counter and drain it for a specific key.
-- Used to track per-sender delivery receipt / expiration notification drops.
-- LRU eviction: when at capacity, evict the entry least recently updated (oldest lastUpdated).
-- Previous strategy evicted by lowest count, which could discard active senders with few drops.
incrementDropCounter = \entries key n t ->
  if any entries (\e -> e.senderKey == key)
    then do e <- entries; yield (if e.senderKey == key then {senderKey: e.senderKey, count: e.count + n, lastUpdated: t} else e)
    else if count entries >= maxDroppedCountEntries
      then union (evictOneOldest entries (\e -> e.lastUpdated)) [{senderKey: key, count: n, lastUpdated: t}]
      else union entries [{senderKey: key, count: n, lastUpdated: t}]

drainDropCounter = \entries key ->
  case headOf (do e <- entries; where e.senderKey == key; yield e) of
    Nothing {} -> {count: 0, remaining: entries}
    Just {value: e} -> {count: e.count, remaining: do x <- entries; where x.senderKey != key; yield x}

-- Queue a cancel notification for a recipient. Called when a message is cancelled
-- so the recipient's next poll delivers the retraction. Per-key cap prevents one
-- targeted recipient from consuming the whole notification queue.
queueCancelNotification : PubkeyHex -> MessageIdHex -> Timestamp -> IO ()
queueCancelNotification = \toKey messageId t -> atomic do
  cn <- *cancelNotifications
  let forKey = count (do c <- cn; where c.toKey == toKey; yield c)
  if forKey >= maxCancelNotificationsPerKey then yield {}
  else do
    let updated = union cn [{toKey: toKey, messageId: messageId, cancelledAt: t}]
    set *cancelNotifications = if count updated > maxCancelNotifications
      then evictOneOldest updated (\c -> c.cancelledAt)
      else updated

-- Batch version: queue cancel notifications for multiple entries at once.
queueCancelNotificationBatch = \entries t ->
  case headOf entries of
    Nothing {} -> yield {}
    Just {value: e} -> do
      let rest = do x <- entries; where x.messageId != e.messageId || x.toKey != e.toKey; yield x
      queueCancelNotification e.toKey e.messageId t
      queueCancelNotificationBatch rest t

-- NOTE: fold always traverses the full list even after finding the first element.
-- This is O(n) where O(1) suffices, but Knot lacks list destructuring (case xs of
-- (x : rest) -> ...) that would allow short-circuit. Used pervasively on hot paths
-- (sendMessageCore, handleForwardMessage, gossip). If Knot adds list pattern matching
-- or a built-in head/uncons primitive, replace this to eliminate the O(n) overhead.
headOf = \items -> fold (\acc x -> case acc of
  Nothing {} -> Just {value: x}
  _ -> acc) Nothing {} items

maxBy = \items getKey -> fold (\acc x -> case acc of
  Nothing {} -> Just {value: x}
  Just {value: v} -> if getKey x > getKey v then Just {value: x} else acc) Nothing {} items

minBy = \items getKey -> fold (\acc x -> case acc of
  Nothing {} -> Just {value: x}
  Just {value: v} -> if getKey x < getKey v then Just {value: x} else acc) Nothing {} items

-- Hex encoding utilities for token generation
hexDigit : Int -> Text
hexDigit = \n -> take 1 (drop (clamp 0 15 n) "0123456789abcdef")

byteToHex : Int -> Text
byteToHex = \n -> hexDigit (n / 16) ++ hexDigit (n - (n / 16) * 16)

-- Encode a 24-bit integer as 6 hex characters (3 bytes)
intTo3Hex : Int -> Text
intTo3Hex = \n ->
  let b0 = n / 65536 in
  let r0 = n - b0 * 65536 in
  let b1 = r0 / 256 in
  let b2 = r0 - b1 * 256 in
  byteToHex b0 ++ byteToHex b1 ++ byteToHex b2

-- Generate a random hex token (n chunks of 3 bytes each = 6n hex chars)
genTokenN = \n -> if n <= 0 then yield "" else do
  chunk <- randomInt 16777216
  rest <- genTokenN (n - 1)
  yield (intTo3Hex chunk ++ rest)

-- Token generation parameters (linked to safeCompareLen for consistency)
tokenChunks = 8
tokenHexLen = 6 * tokenChunks -- 48; each chunk produces 6 hex chars (3 bytes)

-- Default token: tokenChunks chunks = tokenHexLen hex chars = 24 bytes of randomness
genToken = genTokenN tokenChunks

tooLong : Text -> Int -> Bool
tooLong = \s maxLen -> drop maxLen s != ""

-- Sanitize correlationId: truncate to maxCorrelationIdLen and strip non-printable characters
-- to prevent log injection attacks. A malicious peer could inject fake [ERROR] entries or
-- use ANSI escape codes to manipulate terminal output. Only printable ASCII (0x20-0x7E)
-- is kept; all other bytes (null, control chars, escape sequences, DEL, high bytes) are
-- stripped. This is stricter than the original \n/\r/\t filter.
sanitizeCorrelationId : Text -> Text
sanitizeCorrelationId = \cid -> stripNonPrintable (take maxCorrelationIdLen cid)

-- Printable ASCII characters (0x20 through 0x7E): space, symbols, digits, letters, punctuation.
-- Used as an allowlist by stripNonPrintable. Excludes DEL (0x7F) and all control chars (0x00-0x1F).
printableAscii : Text
printableAscii = " !\"#$%&'()*+,-./0123456789:;<=>?@ABCDEFGHIJKLMNOPQRSTUVWXYZ[\\]^_`abcdefghijklmnopqrstuvwxyz{|}~"

-- Strip all non-printable characters from a string (allowlist approach).
-- Keeps only characters in the printable ASCII range (0x20-0x7E).
-- Uses an accumulator parameter for tail recursion (TCO-safe in Knot):
-- the recursive call is in tail position, not wrapped by ++.
stripNonPrintable : Text -> Text
stripNonPrintable = \s -> stripNonPrintableAcc s ""

stripNonPrintableAcc : Text -> Text -> Text
stripNonPrintableAcc = \s acc ->
  if s == "" then acc
  else let c = take 1 s in
    if contains c printableAscii then stripNonPrintableAcc (drop 1 s) (acc ++ c)
    else stripNonPrintableAcc (drop 1 s) acc

isHexChar : Text -> Bool
isHexChar = \c -> contains c "0123456789abcdef"

-- Validates that a string is composed of valid hex character pairs.
-- Recursive with drop 2 per call; the recursive call is in tail position so
-- Knot's TCO compiles it to a loop. Max depth is bounded by isValidBoundedHex's
-- tooLong check: maxBlobLen/2 = 32768 frames for the largest input (BlobHex).
-- If TCO is ever disabled, this would stack overflow on large blobs.
isValidHexPairs : Text -> Bool
isValidHexPairs = \s ->
  if s == "" then True {}
  else if drop 1 s == "" then False {}
  else if isHexChar (take 1 s) && isHexChar (take 1 (drop 1 s)) then isValidHexPairs (drop 2 s)
  else False {}

isValidHex : Text -> Bool
isValidHex = \s -> s != "" && isValidHexPairs s

normalizeHex : Text -> Text
normalizeHex = \s -> bytesToHex (bytesFromHex s)

isDigitChar : Text -> Bool
isDigitChar = \c -> contains c "0123456789"

isAllowedServerChar : Text -> Bool
isAllowedServerChar = \c -> contains c "0123456789abcdefghijklmnopqrstuvwxyz-.:"

containsBadUrlChar : Text -> Bool
containsBadUrlChar = \s -> any (chars s) (\c -> not (isAllowedServerChar c))

-- Carrier-grade NAT range: 100.64.0.0/10 (RFC 6598)
isCgnatRange : Text -> Bool
isCgnatRange = \s ->
  take 4 s == "100."
  && let d4 = take 1 (drop 4 s) in
  let d5 = take 1 (drop 5 s) in
  let d6 = take 1 (drop 6 s) in
  let d7 = take 1 (drop 7 s) in
  let twoDigitOctet = d6 == "." && isAllDigitsOrDotsUntilColonOrEnd (drop 7 s) in
  let threeDigitOctet = d7 == "." && isAllDigitsOrDotsUntilColonOrEnd (drop 8 s) in
  ((contains d4 "789" && isDigitChar d5 && twoDigitOctet)
  || (d4 == "6" && contains d5 "456789" && twoDigitOctet)
  || (d4 == "1" && contains d5 "01" && isDigitChar d6 && threeDigitOctet)
  || (d4 == "1" && d5 == "2" && contains d6 "01234567" && threeDigitOctet))

containsMultipleColons : Text -> Bool
containsMultipleColons = \s -> count (do c <- chars s; where c == ":"; yield c) > 1

hasPatternAfterDot : (Text -> Bool) -> Text -> Bool
hasPatternAfterDot = \pred s ->
  if s == "" then False {}
  else if take 1 s == "." && pred (drop 1 s) then True {}
  else hasPatternAfterDot pred (drop 1 s)

isOctalStart : Text -> Bool
isOctalStart = \s -> take 1 s == "0" && isDigitChar (take 1 (drop 1 s)) && isAllDigitsOrDotsUntilColonOrEnd (drop 2 s)
hasOctalOctet : Text -> Bool
hasOctalOctet = \s -> isOctalStart s || hasPatternAfterDot isOctalStart s

-- Detect percent-encoded characters (e.g., %31%32%37.0.0.1 = 127.0.0.1)
-- Blocks URL-encoded hostnames that could bypass isBadServerName SSRF protection.
containsPercentEncoding : Text -> Bool
containsPercentEncoding = \s ->
  if s == "" then False {}
  else if take 1 s == "%" && isHexChar (take 1 (drop 1 s)) && isHexChar (take 1 (drop 2 s)) then True {}
  else containsPercentEncoding (drop 1 s)

-- Detect double percent-encoding (%25XX -> %XX after one decode pass).
-- If any proxy in the path decodes once, the second layer resolves to a private IP.
-- Example: %2531%2532%2537.0.0.1 -> %31%32%37.0.0.1 -> 127.0.0.1
containsDoubleEncoding : Text -> Bool
containsDoubleEncoding = \s ->
  if s == "" then False {}
  else if take 3 s == "%25" then True {}
  else containsDoubleEncoding (drop 1 s)

isHexStart : Text -> Bool
isHexStart = \s -> take 2 s == "0x" || take 2 s == "0X"
hasHexPrefix : Text -> Bool
hasHexPrefix = \s -> isHexStart s || hasPatternAfterDot isHexStart s

isAllDigitsOrDotsUntilColonOrEnd : Text -> Bool
isAllDigitsOrDotsUntilColonOrEnd = \s ->
  if s == "" then True {}
  else if take 1 s == ":" then True {}
  else if isDigitChar (take 1 s) || take 1 s == "." then isAllDigitsOrDotsUntilColonOrEnd (drop 1 s)
  else False {}

isTrailingDots : Text -> Bool
isTrailingDots = \s ->
  if s == "" then True {}
  else if take 1 s == ":" then True {}
  else if take 1 s == "." then isTrailingDots (drop 1 s)
  else False {}

stripTrailingDot : Text -> Text
stripTrailingDot = \s ->
  if s == "" then ""
  else if take 1 s == "." && isTrailingDots (drop 1 s) then stripTrailingDot (drop 1 s)
  else take 1 s ++ stripTrailingDot (drop 1 s)

normalizeServerName : Text -> Text
normalizeServerName = \s -> toLower (stripTrailingDot s)

serverHostN : Text
serverHostN = normalizeServerName serverHost
isLocalServer : Text -> Bool
isLocalServer = \s -> s == serverHostN

containsSuffixN : Text -> Int -> Text -> Bool
containsSuffixN = \suffix suffixLen s ->
  if s == "" then False {}
  else if take suffixLen s == suffix && (drop suffixLen s == "" || take 1 (drop suffixLen s) == ":") then True {}
  else containsSuffixN suffix suffixLen (drop 1 s)

containsSuffix : Text -> Text -> Bool
containsSuffix = \suffix s -> containsSuffixN suffix (count (chars suffix)) s

is172Private : Text -> Bool
is172Private = \sn ->
  take 4 sn == "172."
  && let d1 = take 1 (drop 4 sn) in
  let d2 = take 1 (drop 5 sn) in
  take 1 (drop 6 sn) == "."
  && isDigitChar (take 1 (drop 7 sn))
  && ((d1 == "1" && contains d2 "6789")
    || (d1 == "2" && isDigitChar d2)
    || (d1 == "3" && contains d2 "01"))

isHighOctetPrefix : Text -> Bool
isHighOctetPrefix = \sn ->
  take 1 sn == "2"
  && let d2 = take 1 (drop 1 sn) in
  let d3 = take 1 (drop 2 sn) in
  take 1 (drop 3 sn) == "."
  && isDigitChar (take 1 (drop 4 sn))
  && ((d2 == "2" && contains d3 "456789")
    || (contains d2 "34" && isDigitChar d3)
    || (d2 == "5" && contains d3 "012345"))

matchesHostname : Text -> Text -> Bool
matchesHostname = \sn name ->
  let nameLen = count (chars name) in
  take nameLen sn == name && (drop nameLen sn == "" || take 1 (drop nameLen sn) == ":")

matchesHostnameOrSubdomain : Text -> Text -> Bool
matchesHostnameOrSubdomain = \sn name ->
  matchesHostname sn name || containsSuffix ("." ++ name) sn

hasDotBeforePort : Text -> Bool
hasDotBeforePort = \s ->
  if s == "" then False {}
  else if take 1 s == ":" then False {}
  else if take 1 s == "." then True {}
  else hasDotBeforePort (drop 1 s)

-- DNS rebinding / SSRF protection: reject server names that resolve to private/reserved addresses.
-- Blocks localhost, private RFC1918 ranges, link-local, loopback, CGNAT, documentation ranges,
-- IPv6 shorthand, octal/hex IP tricks, bare IPs without dots, and .arpa domains.
isBadServerName : Text -> Bool
isBadServerName = \sn ->
  let fc = take 1 sn in
  fc == ""
  || fc == "."
  || fc == ":"
  || containsBadUrlChar sn
  || not (hasDotBeforePort sn)
  || matchesHostnameOrSubdomain sn "localhost"
  || matchesHostname sn "localhost.localdomain"
  || matchesHostnameOrSubdomain sn "local"
  || containsSuffix ".localhost" sn -- RFC 6761: foo.localhost resolves to loopback
  || matchesHostnameOrSubdomain sn "internal"
  || matchesHostnameOrSubdomain sn "metadata"
  || take 4 sn == "127." || take 3 sn == "10."
  || take 8 sn == "192.168."
  || take 8 sn == "169.254." -- link-local; also covers AWS EC2 metadata endpoint 169.254.169.254
  || take 2 sn == "0." || fc == "["
  || is172Private sn
  || take 7 sn == "198.18." || take 7 sn == "198.19."
  || take 8 sn == "192.0.0."
  || take 8 sn == "192.0.2."
  || take 10 sn == "192.88.99."
  || take 11 sn == "198.51.100."
  || take 10 sn == "203.0.113."
  || take 2 sn == "::"
  || isCgnatRange sn
  || containsMultipleColons sn
  || hasOctalOctet sn
  || hasHexPrefix sn
  || (isDigitChar fc && isAllDigitsOrDotsUntilColonOrEnd sn)
  || isHighOctetPrefix sn
  || containsSuffix ".arpa" sn
  || containsSuffix ".onion" sn
  || containsSuffix ".i2p" sn
  || containsSuffix ".corp" sn
  || containsSuffix ".home" sn
  || containsSuffix ".lan" sn
  || containsSuffix ".intranet" sn
  || containsSuffix ".test" sn
  || containsSuffix ".example" sn
  || containsSuffix ".invalid" sn
  || containsPercentEncoding sn
  || containsDoubleEncoding sn
  -- Kubernetes / service mesh internal DNS
  || containsSuffix ".svc" sn
  || containsSuffix ".cluster.local" sn
  -- HashiCorp Consul service discovery
  || containsSuffix ".consul" sn
  || containsSuffix ".node.consul" sn
  || containsSuffix ".service.consul" sn
  -- Cloud provider internal DNS (SSRF targets for metadata/internal services)
  || containsSuffix ".compute.internal" sn -- GCP internal DNS
  || containsSuffix ".ec2.internal" sn -- AWS EC2 internal DNS
  || containsSuffix ".amazonaws.com" sn -- AWS service endpoints (S3, SQS, etc.)
  || matchesHostname sn "metadata.google.internal" -- GCP metadata server
  || containsSuffix ".internal.cloudapp.net" sn -- Azure VM internal DNS
  || matchesHostname sn "metadata.azure.com" -- Azure Instance Metadata Service (IMDS v2)
  -- NOTE: Unicode/IDN defense is provided by containsBadUrlChar above, which rejects
  -- any character not in [0-9a-z-.:]  via isAllowedServerChar. This blocks homoglyph
  -- attacks (e.g., Greek omicron in "lοcalhost") assuming Knot's Text type preserves
  -- Unicode codepoints in take/contains operations. If Knot ever normalizes Unicode
  -- (NFKC/NFC) before comparison, add an explicit ASCII-range byte check here.

-- Look up a non-expired session matching the given token (constant-time comparison).
-- Caller passes the appropriate session bucket (sharded by token prefix).
authenticateSession : [Session] -> Text -> Timestamp -> AuthResult
authenticateSession = \sessions token t ->
  case headOf (do s <- sessions; where s.expiresAt > t && t - s.createdAt < maxSessionLifetime && safeCompare s.token token; yield s) of
    Nothing {} -> Unauthorized {}
    Just {value: s} -> Authorized {pubkey: s.pubkey, ip: s.ip}

-- Fast re-authentication for poll Phase 3: pre-filters by known pubkey before
-- running safeCompare. Reduces safeCompare calls from O(bucket_size) to
-- O(sessions_for_key_in_bucket) (~1-2 vs ~600). Safe in this context because
-- the pubkey was already verified in Phase 1.
-- Theoretical race: if the session is revoked between Phase 1 and Phase 3 and a
-- new session with the same token is created for a different pubkey, the pre-filter
-- would miss it. This requires guessing a 24-byte (192-bit) random token, which is
-- computationally infeasible (2^-192 collision probability).
reauthenticateSession : [Session] -> Text -> PubkeyHex -> Timestamp -> Bool
reauthenticateSession = \sessions token pubkey t ->
  any sessions (\s -> s.pubkey == pubkey && s.expiresAt > t && t - s.createdAt < maxSessionLifetime && safeCompare s.token token)

-- Extract bearer token from "Authorization: Bearer <token>" header.
-- Rejects empty tokens early to avoid unnecessary session bucket scans.
extractToken = \authHeader ->
  let token = drop 7 authHeader in
  if toLower (take 7 authHeader) == "bearer " && token != "" && not (tooLong token maxTokenLen)
    then Just {value: token}
    else Nothing {}

-- Constant-time secret comparison (prevents timing attacks on maintenance secret)
verifySecret : Text -> Text -> Bool
verifySecret = \token secret ->
  secret != "" && safeCompare token secret

verifyAuthWith : (Text -> Bool) -> Text -> Bool
verifyAuthWith = \check authorization ->
  case extractToken authorization of
    Nothing {} -> False {}
    Just {value: token} -> check token

-- Check maintenance auth: tries runtime secret first (if set), then compile-time secret.
-- This allows zero-downtime rotation: set the new secret via /maintenance/rotate-secret,
-- then update the compile-time config and restart at convenience.
verifyMaintenanceAuth : Text -> IO Bool
verifyMaintenanceAuth = \authorization -> do
  runtimeSecret <- *runtimeMaintenanceSecret
  let checkSecret = if runtimeSecret != "" then runtimeSecret else maintenanceSecret
  yield (verifyAuthWith (\token -> verifySecret token checkSecret) authorization)

-- Check if a server is on the blocklist
isBlockedPeer : Text -> [Text] -> Bool
isBlockedPeer = \server blocked -> any blocked (\b -> b == server)

-- Check if a server passes the allowlist (empty allowlist = all allowed)
isAllowedByAllowlist : Text -> [Text] -> Bool
isAllowedByAllowlist = \server allowed -> count allowed == 0 || any allowed (\a -> a == server)

-- Split text at the first colon. Returns {before, after}. Used to parse "Signed <sig>:<nonce>".
-- Safe: signature hex and nonce are both [0-9a-f]+ (no colons), so exactly one colon separates them.
splitOnColon : Text -> {before: Text, after: Text}
splitOnColon = \s -> splitOnColonInner s 0

splitOnColonInner : Text -> Int -> {before: Text, after: Text}
splitOnColonInner = \s pos ->
  if drop pos s == "" then {before: s, after: ""}
  else if take 1 (drop pos s) == ":" then {before: take pos s, after: drop (pos + 1) s}
  else splitOnColonInner s (pos + 1)

-- Generate a single-use token for outbound federation auth.
-- scope binds the token to a request type ("gossip", "forward", "ack") so a token
-- issued for one operation cannot authorize a different one.
-- When signing is enabled, includes a random nonce in the signed message to prevent
-- replay attacks (two requests with the same timestamp+scope produce different signatures).
-- Format: "Signed <sig>:<nonce>" — backward compatible (old format has no colon).
generateFederationAuth : Text -> Timestamp -> IO {network} Text
generateFederationAuth = \scope requestTimestamp ->
  if serverFederationPrivateKeyHex != ""
    then do
      nonce <- genTokenN tokenChunks
      let message = textToBytes (scope ++ "|" ++ show requestTimestamp ++ "|" ++ serverHostN ++ "|" ++ nonce)
      let sig = sign (bytesFromHex serverFederationPrivateKeyHex) message
      yield ("Signed " ++ bytesToHex sig ++ ":" ++ nonce)
    else do
      token <- genToken
      t <- now
      atomic do
        pending <- *pendingVerifications
        let updated = union pending [{token: token, createdAt: t, scope: scope}]
        set *pendingVerifications = if count updated > maxPendingVerifications
          then evictOneOldest updated (\p -> p.createdAt)
          else updated
      yield ("Bearer " ++ token)

-- Verify an inbound federation token. Checks a short-lived per-server cache first
-- to reduce outbound HTTP calls (a peer sending N requests/second would otherwise
-- force N verify callbacks). Cache hit means the server was verified within the last
-- verificationCacheMs — the token itself is still single-use (consumed on first verify),
-- but subsequent requests from the same server in the same window are trusted.
-- No retry: a failed verify rejects the request. The peer's federation rate limit + circuit breaker
-- handle unreliable peers; retrying here doubles verify traffic and blocks with a 1s sleep per op,
-- which a malicious peer can exploit for amplification.
-- Adaptive verify cache TTL: scales with recent request volume from a peer.
-- Peers sending many requests/second benefit from longer cache (fewer callbacks).
-- Uses peerLatencies.count as a proxy for request volume (tracks verify calls per window).
-- Returns TTL in ms between verificationCacheMinMs and verificationCacheMaxMs.
adaptiveVerifyCacheTtl : Text -> [{server: Text, totalMs: Int, count: Int, maxMs: Int, windowStart: Timestamp}] -> Int<Ms>
adaptiveVerifyCacheTtl = \server peerLats ->
  case headOf (do p <- peerLats; where p.server == server; yield p) of
    Nothing {} -> verificationCacheMinMs
    Just {value: p} ->
      -- Scale: 0-5 calls = min, 50+ calls = max, linear interpolation between
      let scale = clamp 0 100 (p.count * 100 / 50)
      in verificationCacheMinMs + (verificationCacheMaxMs - verificationCacheMinMs) * scale / 100

verifyFederationCallback : Text -> Text -> Text -> IO {network} Bool
verifyFederationCallback = \fromServer authorization scope ->
    case extractToken authorization of
      Nothing {} -> yield (False {})
      Just {value: token} -> do
        -- Check verify cache: skip the outbound HTTP call if we recently verified this server+scope
        t <- now
        cached <- atomic do
          cache <- *verificationCache
          peerLats <- *peerLatencies
          let cacheTtl = adaptiveVerifyCacheTtl fromServer peerLats
          yield (any cache (\c -> c.server == fromServer && c.scope == scope && t - c.verifiedAt < cacheTtl))
        if cached then yield (True {})
        else do
        startTime <- now
        result <- fetchFederation fromServer (VerifyToken {token: token, scope: scope})
        endTime <- now
        let verifyLatency = endTime - startTime
        when (verifyLatency > federationVerifyTimeoutMs) (do
          logWarn ("federation: slow verify callback to " ++ fromServer ++ " (" ++ show verifyLatency ++ "ms, threshold: " ++ show federationVerifyTimeoutMs ++ "ms)")
          atomic do
            svc <- *slowVerifyCount
            set *slowVerifyCount = svc + 1)
        case result of
          Err e -> do
            logWarn ("federation: verify callback to " ++ fromServer ++ " failed: " ++ show e)
            atomic do
              vfc <- *verifyFailCount
              set *verifyFailCount = vfc + 1
            yield (False {})
          Ok r -> do
            when r.ok (atomic do
              cache <- *verificationCache
              peerLats <- *peerLatencies
              let cacheTtl = adaptiveVerifyCacheTtl fromServer peerLats
              let cleaned = do c <- cache; where t - c.verifiedAt < cacheTtl; yield c
              let updated = union cleaned [{server: fromServer, scope: scope, verifiedAt: t}]
              set *verificationCache = if count updated > maxVerificationCache
                then evictOneOldest updated (\c -> c.verifiedAt)
                else updated)
            yield r.ok

-- ============================================
-- Session Bucket Helpers
-- ============================================
-- Sessions are sharded into 16 buckets by the first hex char of the token.
-- This reduces auth scan from O(n) to O(n/16) on the hot path.

tokenBucket : Text -> Int
tokenBucket = \token -> clamp 0 15 (hexCharIndex (take 1 token))

readSessionBucket : Int -> IO [Session]
readSessionBucket = \b ->
  if b == 0 then do s <- *sessionBucket0; yield s
  else if b == 1 then do s <- *sessionBucket1; yield s
  else if b == 2 then do s <- *sessionBucket2; yield s
  else if b == 3 then do s <- *sessionBucket3; yield s
  else if b == 4 then do s <- *sessionBucket4; yield s
  else if b == 5 then do s <- *sessionBucket5; yield s
  else if b == 6 then do s <- *sessionBucket6; yield s
  else if b == 7 then do s <- *sessionBucket7; yield s
  else if b == 8 then do s <- *sessionBucket8; yield s
  else if b == 9 then do s <- *sessionBucket9; yield s
  else if b == 10 then do s <- *sessionBucket10; yield s
  else if b == 11 then do s <- *sessionBucket11; yield s
  else if b == 12 then do s <- *sessionBucket12; yield s
  else if b == 13 then do s <- *sessionBucket13; yield s
  else if b == 14 then do s <- *sessionBucket14; yield s
  else do s <- *sessionBucket15; yield s

writeSessionBucket : Int -> [Session] -> IO ()
writeSessionBucket = \b sessions ->
  if b == 0 then set *sessionBucket0 = sessions
  else if b == 1 then set *sessionBucket1 = sessions
  else if b == 2 then set *sessionBucket2 = sessions
  else if b == 3 then set *sessionBucket3 = sessions
  else if b == 4 then set *sessionBucket4 = sessions
  else if b == 5 then set *sessionBucket5 = sessions
  else if b == 6 then set *sessionBucket6 = sessions
  else if b == 7 then set *sessionBucket7 = sessions
  else if b == 8 then set *sessionBucket8 = sessions
  else if b == 9 then set *sessionBucket9 = sessions
  else if b == 10 then set *sessionBucket10 = sessions
  else if b == 11 then set *sessionBucket11 = sessions
  else if b == 12 then set *sessionBucket12 = sessions
  else if b == 13 then set *sessionBucket13 = sessions
  else if b == 14 then set *sessionBucket14 = sessions
  else set *sessionBucket15 = sessions

-- Read all 16 session buckets (for per-key operations, prune, stats).
-- Right-nested union is intentional: union copies the left operand, so right-nesting
-- copies small buckets onto the growing accumulator (O(n) total), while left-nesting
-- would copy the growing accumulator repeatedly (O(n * 16)).
readAllSessions : IO [Session]
readAllSessions = do
  s0 <- *sessionBucket0
  s1 <- *sessionBucket1
  s2 <- *sessionBucket2
  s3 <- *sessionBucket3
  s4 <- *sessionBucket4
  s5 <- *sessionBucket5
  s6 <- *sessionBucket6
  s7 <- *sessionBucket7
  s8 <- *sessionBucket8
  s9 <- *sessionBucket9
  s10 <- *sessionBucket10
  s11 <- *sessionBucket11
  s12 <- *sessionBucket12
  s13 <- *sessionBucket13
  s14 <- *sessionBucket14
  s15 <- *sessionBucket15
  yield (unionNE s0 (unionNE s1 (unionNE s2 (unionNE s3 (unionNE s4 (unionNE s5 (unionNE s6 (unionNE s7 (unionNE s8 (unionNE s9 (unionNE s10 (unionNE s11 (unionNE s12 (unionNE s13 (unionNE s14 s15)))))))))))))))

-- Count sessions across all 16 buckets without materializing the full list
countAllSessions : IO Int
countAllSessions = do
  s0 <- *sessionBucket0
  s1 <- *sessionBucket1
  s2 <- *sessionBucket2
  s3 <- *sessionBucket3
  s4 <- *sessionBucket4
  s5 <- *sessionBucket5
  s6 <- *sessionBucket6
  s7 <- *sessionBucket7
  s8 <- *sessionBucket8
  s9 <- *sessionBucket9
  s10 <- *sessionBucket10
  s11 <- *sessionBucket11
  s12 <- *sessionBucket12
  s13 <- *sessionBucket13
  s14 <- *sessionBucket14
  s15 <- *sessionBucket15
  yield (count s0 + count s1 + count s2 + count s3 + count s4 + count s5 + count s6 + count s7 + count s8 + count s9 + count s10 + count s11 + count s12 + count s13 + count s14 + count s15)

-- Short-circuit scan: check if any session bucket contains a session for the given pubkey.
-- Stops reading buckets as soon as one matching session is found (O(n/16) best case
-- vs O(n) for readAllSessions when the user has sessions in early buckets).
hasSessionForKey : PubkeyHex -> Int -> IO Bool
hasSessionForKey = \pubkey b ->
  if b > 15 then yield (False {})
  else do
    bucket <- readSessionBucket b
    if any bucket (\s -> s.pubkey == pubkey) then yield (True {})
    else hasSessionForKey pubkey (b + 1)

-- Check if a pubkey has any non-expired session across all buckets (short-circuits on first match).
-- Fast-path: returns False immediately when totalSessionCount is 0, avoiding 16 bucket reads.
hasActiveSessionForKey : PubkeyHex -> Timestamp -> Int -> IO Bool
hasActiveSessionForKey = \pubkey t b ->
  if b > 15 then yield (False {})
  else do
    bucket <- readSessionBucket b
    if any bucket (\s -> s.pubkey == pubkey && s.expiresAt > t) then yield (True {})
    else hasActiveSessionForKey pubkey t (b + 1)

-- Filter a list of pubkeys to those with active (non-expired) sessions.
-- Checks each key independently (short-circuits per key), avoids materializing all sessions.
-- Fast-path: returns empty list when no sessions exist (totalSessionCount == 0).
filterActiveSessionKeys : [PubkeyHex] -> Timestamp -> IO [PubkeyHex]
filterActiveSessionKeys = \keys t ->
  totalSessions <- *totalSessionCount
  if totalSessions == 0 then yield []
  else case headOf keys of
    Nothing {} -> yield []
    Just {value: k} -> do
      let rest = do x <- keys; where x != k; yield x
      hasActive <- hasActiveSessionForKey k t 0
      remaining <- filterActiveSessionKeys rest t
      if hasActive then yield (union [k] remaining) else yield remaining

-- Collect all sessions for a specific pubkey across all buckets without materializing the full
-- session list. Each bucket is read independently (O(n/16) per bucket), avoiding the O(n)
-- readAllSessions union. Used by handleAdminListSessions.
collectSessionsForKey : PubkeyHex -> Int -> IO [Session]
collectSessionsForKey = \pubkey b ->
  if b > 15 then yield []
  else do
    bucket <- readSessionBucket b
    let matching = do s <- bucket; where s.pubkey == pubkey; yield s
    rest <- collectSessionsForKey pubkey (b + 1)
    yield (union matching rest)

-- Count sessions for a specific pubkey across all buckets (avoids materializing full session list).
-- Used in verify fast path to skip readAllSessions.
countSessionsForKey : PubkeyHex -> IO Int
countSessionsForKey = \pubkey -> countSessionsInBucket pubkey 0

countSessionsInBucket : PubkeyHex -> Int -> IO Int
countSessionsInBucket = \pubkey b ->
  if b > 15 then yield 0
  else do
    bucket <- readSessionBucket b
    let n = count (do s <- bucket; where s.pubkey == pubkey; yield s)
    rest <- countSessionsInBucket pubkey (b + 1)
    yield (n + rest)

-- Remove all sessions for a pubkey across all 16 buckets, returning total revoked.
-- Each bucket is filtered in-place (avoids readAllSessions + writeAllSessions repartition).
revokeSessionsForKey : PubkeyHex -> Int -> IO Int
revokeSessionsForKey = \pubkey b ->
  if b > 15 then yield 0
  else do
    bucket <- readSessionBucket b
    let kept = do s <- bucket; where s.pubkey != pubkey; yield s
    let removed = count bucket - count kept
    when (removed > 0) (writeSessionBucket b kept)
    rest <- revokeSessionsForKey pubkey (b + 1)
    yield (removed + rest)

-- Apply a filter/transform to every session bucket and return the total count.
-- Combines transform + count in one pass, avoiding a redundant 16-bucket traversal.
pruneAndCountAllSessions : ([Session] -> [Session]) -> IO Int
pruneAndCountAllSessions = \f -> pruneAndCountSessionBucket f 0

pruneAndCountSessionBucket : ([Session] -> [Session]) -> Int -> IO Int
pruneAndCountSessionBucket = \f b ->
  if b > 15 then yield 0
  else do
    bucket <- readSessionBucket b
    let pruned = f bucket
    writeSessionBucket b pruned
    rest <- pruneAndCountSessionBucket f (b + 1)
    yield (count pruned + rest)

-- Apply a filter/transform to every session bucket
transformAllSessionBuckets : ([Session] -> [Session]) -> IO ()
transformAllSessionBuckets = \f -> do
  b0 <- *sessionBucket0; set *sessionBucket0 = f b0
  b1 <- *sessionBucket1; set *sessionBucket1 = f b1
  b2 <- *sessionBucket2; set *sessionBucket2 = f b2
  b3 <- *sessionBucket3; set *sessionBucket3 = f b3
  b4 <- *sessionBucket4; set *sessionBucket4 = f b4
  b5 <- *sessionBucket5; set *sessionBucket5 = f b5
  b6 <- *sessionBucket6; set *sessionBucket6 = f b6
  b7 <- *sessionBucket7; set *sessionBucket7 = f b7
  b8 <- *sessionBucket8; set *sessionBucket8 = f b8
  b9 <- *sessionBucket9; set *sessionBucket9 = f b9
  b10 <- *sessionBucket10; set *sessionBucket10 = f b10
  b11 <- *sessionBucket11; set *sessionBucket11 = f b11
  b12 <- *sessionBucket12; set *sessionBucket12 = f b12
  b13 <- *sessionBucket13; set *sessionBucket13 = f b13
  b14 <- *sessionBucket14; set *sessionBucket14 = f b14
  b15 <- *sessionBucket15; set *sessionBucket15 = f b15

-- Single-pass partition of sessions by token bucket and write to all 16 buckets.
-- Mirrors writeAllPresence for the session sharding scheme.
writeAllSessions : [Session] -> IO ()
writeAllSessions = \sessions -> do
  let partitioned = fold (\acc s ->
    let b = tokenBucket s.token in
    {b0: if b == 0 then union [s] acc.b0 else acc.b0,
     b1: if b == 1 then union [s] acc.b1 else acc.b1,
     b2: if b == 2 then union [s] acc.b2 else acc.b2,
     b3: if b == 3 then union [s] acc.b3 else acc.b3,
     b4: if b == 4 then union [s] acc.b4 else acc.b4,
     b5: if b == 5 then union [s] acc.b5 else acc.b5,
     b6: if b == 6 then union [s] acc.b6 else acc.b6,
     b7: if b == 7 then union [s] acc.b7 else acc.b7,
     b8: if b == 8 then union [s] acc.b8 else acc.b8,
     b9: if b == 9 then union [s] acc.b9 else acc.b9,
     b10: if b == 10 then union [s] acc.b10 else acc.b10,
     b11: if b == 11 then union [s] acc.b11 else acc.b11,
     b12: if b == 12 then union [s] acc.b12 else acc.b12,
     b13: if b == 13 then union [s] acc.b13 else acc.b13,
     b14: if b == 14 then union [s] acc.b14 else acc.b14,
     b15: if b == 15 then union [s] acc.b15 else acc.b15})
    {b0: [], b1: [], b2: [], b3: [], b4: [], b5: [], b6: [], b7: [], b8: [], b9: [], b10: [], b11: [], b12: [], b13: [], b14: [], b15: []} sessions
  writeSessionBucket 0 partitioned.b0
  writeSessionBucket 1 partitioned.b1
  writeSessionBucket 2 partitioned.b2
  writeSessionBucket 3 partitioned.b3
  writeSessionBucket 4 partitioned.b4
  writeSessionBucket 5 partitioned.b5
  writeSessionBucket 6 partitioned.b6
  writeSessionBucket 7 partitioned.b7
  writeSessionBucket 8 partitioned.b8
  writeSessionBucket 9 partitioned.b9
  writeSessionBucket 10 partitioned.b10
  writeSessionBucket 11 partitioned.b11
  writeSessionBucket 12 partitioned.b12
  writeSessionBucket 13 partitioned.b13
  writeSessionBucket 14 partitioned.b14
  writeSessionBucket 15 partitioned.b15

-- Evict the single oldest session across all 16 buckets, writing only the affected bucket.
-- Two-pass: pass 1 finds the bucket containing the global minimum expiresAt,
-- pass 2 removes the oldest entry from that bucket. Avoids readAllSessions + writeAllSessions.
evictOldestSessionFromBuckets : Int -> Maybe {bucketIdx: Int, minExpiry: Timestamp} -> IO ()
evictOldestSessionFromBuckets = \b candidate ->
  if b > 15
    then case candidate of
      Nothing {} -> yield {}
      Just {value: c} -> do
        bucket <- readSessionBucket c.bucketIdx
        writeSessionBucket c.bucketIdx (evictOneOldest bucket (\s -> s.expiresAt))
    else do
      bucket <- readSessionBucket b
      let bucketMin = minBy bucket (\s -> s.expiresAt)
      let newCandidate = case bucketMin of
            Nothing {} -> candidate
            Just {value: s} -> case candidate of
              Nothing {} -> Just {bucketIdx: b, minExpiry: s.expiresAt}
              Just {value: c} -> if s.expiresAt < c.minExpiry then Just {bucketIdx: b, minExpiry: s.expiresAt} else candidate
      evictOldestSessionFromBuckets (b + 1) newCandidate

-- ============================================
-- Presence Bucket Helpers
-- ============================================
-- Presence is sharded into 16 buckets by the first hex char of the pubkey.
-- Hot-path operations (send, lookup, poll) scan only one bucket (~1/16 of entries).

readPresenceBucket : Int -> IO [PresenceEntry]
readPresenceBucket = \b ->
  if b == 0 then do s <- *presenceBucket0; yield s
  else if b == 1 then do s <- *presenceBucket1; yield s
  else if b == 2 then do s <- *presenceBucket2; yield s
  else if b == 3 then do s <- *presenceBucket3; yield s
  else if b == 4 then do s <- *presenceBucket4; yield s
  else if b == 5 then do s <- *presenceBucket5; yield s
  else if b == 6 then do s <- *presenceBucket6; yield s
  else if b == 7 then do s <- *presenceBucket7; yield s
  else if b == 8 then do s <- *presenceBucket8; yield s
  else if b == 9 then do s <- *presenceBucket9; yield s
  else if b == 10 then do s <- *presenceBucket10; yield s
  else if b == 11 then do s <- *presenceBucket11; yield s
  else if b == 12 then do s <- *presenceBucket12; yield s
  else if b == 13 then do s <- *presenceBucket13; yield s
  else if b == 14 then do s <- *presenceBucket14; yield s
  else do s <- *presenceBucket15; yield s

writePresenceBucket : Int -> [PresenceEntry] -> IO ()
writePresenceBucket = \b entries ->
  if b == 0 then set *presenceBucket0 = entries
  else if b == 1 then set *presenceBucket1 = entries
  else if b == 2 then set *presenceBucket2 = entries
  else if b == 3 then set *presenceBucket3 = entries
  else if b == 4 then set *presenceBucket4 = entries
  else if b == 5 then set *presenceBucket5 = entries
  else if b == 6 then set *presenceBucket6 = entries
  else if b == 7 then set *presenceBucket7 = entries
  else if b == 8 then set *presenceBucket8 = entries
  else if b == 9 then set *presenceBucket9 = entries
  else if b == 10 then set *presenceBucket10 = entries
  else if b == 11 then set *presenceBucket11 = entries
  else if b == 12 then set *presenceBucket12 = entries
  else if b == 13 then set *presenceBucket13 = entries
  else if b == 14 then set *presenceBucket14 = entries
  else set *presenceBucket15 = entries

readAllPresence : IO [PresenceEntry]
readAllPresence = do
  p0 <- *presenceBucket0
  p1 <- *presenceBucket1
  p2 <- *presenceBucket2
  p3 <- *presenceBucket3
  p4 <- *presenceBucket4
  p5 <- *presenceBucket5
  p6 <- *presenceBucket6
  p7 <- *presenceBucket7
  p8 <- *presenceBucket8
  p9 <- *presenceBucket9
  p10 <- *presenceBucket10
  p11 <- *presenceBucket11
  p12 <- *presenceBucket12
  p13 <- *presenceBucket13
  p14 <- *presenceBucket14
  p15 <- *presenceBucket15
  yield (unionNE p0 (unionNE p1 (unionNE p2 (unionNE p3 (unionNE p4 (unionNE p5 (unionNE p6 (unionNE p7 (unionNE p8 (unionNE p9 (unionNE p10 (unionNE p11 (unionNE p12 (unionNE p13 (unionNE p14 p15)))))))))))))))

countAllPresence : IO Int
countAllPresence = do
  p0 <- *presenceBucket0
  p1 <- *presenceBucket1
  p2 <- *presenceBucket2
  p3 <- *presenceBucket3
  p4 <- *presenceBucket4
  p5 <- *presenceBucket5
  p6 <- *presenceBucket6
  p7 <- *presenceBucket7
  p8 <- *presenceBucket8
  p9 <- *presenceBucket9
  p10 <- *presenceBucket10
  p11 <- *presenceBucket11
  p12 <- *presenceBucket12
  p13 <- *presenceBucket13
  p14 <- *presenceBucket14
  p15 <- *presenceBucket15
  yield (count p0 + count p1 + count p2 + count p3 + count p4 + count p5 + count p6 + count p7 + count p8 + count p9 + count p10 + count p11 + count p12 + count p13 + count p14 + count p15)

-- Read only the presence buckets at the given indices (avoids reading all 16)
readSelectedPresenceBuckets : [Int] -> IO [PresenceEntry]
readSelectedPresenceBuckets = \buckets ->
  case headOf buckets of
    Nothing {} -> yield []
    Just {value: b} -> do
      let rest = do x <- buckets; where x != b; yield x
      entries <- readPresenceBucket b
      remaining <- readSelectedPresenceBuckets rest
      yield (union entries remaining)

-- Write presence entries to only the specified bucket indices. Entries are filtered
-- by pubkeyBucket so each bucket gets only its entries. Unspecified buckets are untouched.
writeSelectedPresenceBuckets : [Int] -> [PresenceEntry] -> IO ()
writeSelectedPresenceBuckets = \buckets entries ->
  case headOf buckets of
    Nothing {} -> yield {}
    Just {value: b} -> do
      let rest = do x <- buckets; where x != b; yield x
      let bucketEntries = do e <- entries; where pubkeyBucket e.pubkey == b; yield e
      writePresenceBucket b bucketEntries
      writeSelectedPresenceBuckets rest entries

-- Single-pass partitioning: each entry's bucket is computed once (vs 16x in the list-comprehension approach).
-- The per-element 16-field record allocation is unavoidable without Knot-level indexed arrays:
-- the alternative (16 list-comprehension passes, each computing pubkeyBucket) is O(16n) bucket
-- computations vs O(n) here, and sortBy-based splitting is O(n log n) vs O(n) here.
-- This pattern is optimal given Knot's current data structure primitives.
writeAllPresence : [PresenceEntry] -> IO ()
writeAllPresence = \entries -> do
  let partitioned = fold (\acc p ->
    let b = pubkeyBucket p.pubkey in
    {b0: if b == 0 then union [p] acc.b0 else acc.b0,
     b1: if b == 1 then union [p] acc.b1 else acc.b1,
     b2: if b == 2 then union [p] acc.b2 else acc.b2,
     b3: if b == 3 then union [p] acc.b3 else acc.b3,
     b4: if b == 4 then union [p] acc.b4 else acc.b4,
     b5: if b == 5 then union [p] acc.b5 else acc.b5,
     b6: if b == 6 then union [p] acc.b6 else acc.b6,
     b7: if b == 7 then union [p] acc.b7 else acc.b7,
     b8: if b == 8 then union [p] acc.b8 else acc.b8,
     b9: if b == 9 then union [p] acc.b9 else acc.b9,
     b10: if b == 10 then union [p] acc.b10 else acc.b10,
     b11: if b == 11 then union [p] acc.b11 else acc.b11,
     b12: if b == 12 then union [p] acc.b12 else acc.b12,
     b13: if b == 13 then union [p] acc.b13 else acc.b13,
     b14: if b == 14 then union [p] acc.b14 else acc.b14,
     b15: if b == 15 then union [p] acc.b15 else acc.b15})
    {b0: [], b1: [], b2: [], b3: [], b4: [], b5: [], b6: [], b7: [], b8: [], b9: [], b10: [], b11: [], b12: [], b13: [], b14: [], b15: []} entries
  writePresenceBucket 0 partitioned.b0
  writePresenceBucket 1 partitioned.b1
  writePresenceBucket 2 partitioned.b2
  writePresenceBucket 3 partitioned.b3
  writePresenceBucket 4 partitioned.b4
  writePresenceBucket 5 partitioned.b5
  writePresenceBucket 6 partitioned.b6
  writePresenceBucket 7 partitioned.b7
  writePresenceBucket 8 partitioned.b8
  writePresenceBucket 9 partitioned.b9
  writePresenceBucket 10 partitioned.b10
  writePresenceBucket 11 partitioned.b11
  writePresenceBucket 12 partitioned.b12
  writePresenceBucket 13 partitioned.b13
  writePresenceBucket 14 partitioned.b14
  writePresenceBucket 15 partitioned.b15

transformAllPresenceBuckets : ([PresenceEntry] -> [PresenceEntry]) -> IO ()
transformAllPresenceBuckets = \f -> do
  b0 <- *presenceBucket0; set *presenceBucket0 = f b0
  b1 <- *presenceBucket1; set *presenceBucket1 = f b1
  b2 <- *presenceBucket2; set *presenceBucket2 = f b2
  b3 <- *presenceBucket3; set *presenceBucket3 = f b3
  b4 <- *presenceBucket4; set *presenceBucket4 = f b4
  b5 <- *presenceBucket5; set *presenceBucket5 = f b5
  b6 <- *presenceBucket6; set *presenceBucket6 = f b6
  b7 <- *presenceBucket7; set *presenceBucket7 = f b7
  b8 <- *presenceBucket8; set *presenceBucket8 = f b8
  b9 <- *presenceBucket9; set *presenceBucket9 = f b9
  b10 <- *presenceBucket10; set *presenceBucket10 = f b10
  b11 <- *presenceBucket11; set *presenceBucket11 = f b11
  b12 <- *presenceBucket12; set *presenceBucket12 = f b12
  b13 <- *presenceBucket13; set *presenceBucket13 = f b13
  b14 <- *presenceBucket14; set *presenceBucket14 = f b14
  b15 <- *presenceBucket15; set *presenceBucket15 = f b15

-- Scan presence buckets for local entries nearing expiry.
-- Supports partial scans (startBucket to endBucket) for round-robin refresh:
-- instead of scanning all 16 buckets every refresh cycle, the caller can
-- scan 4 buckets per cycle, cycling through all 16 over 4 refresh intervals.
findNearExpiryPresence : Int -> Int -> Timestamp -> IO [PresenceEntry]
findNearExpiryPresence = \b endBucket t ->
  if b > endBucket then yield []
  else do
    bucket <- readPresenceBucket b
    let nearExpiry = do p <- bucket; where isLocalServer p.server && p.expiresAt > t && p.expiresAt - t < presenceRefreshThreshold; yield p
    rest <- findNearExpiryPresence (b + 1) endBucket t
    yield (union nearExpiry rest)

-- ============================================
-- Message Bucket Helpers
-- ============================================
-- Messages are sharded into 16 buckets by the first hex char of the recipient pubkey.
-- This reduces poll/send/ack scans from O(n) to O(n/16) on the hot path.

readMessageBucket : Int -> IO [Message]
readMessageBucket = \b ->
  if b == 0 then do s <- *messageBucket0; yield s
  else if b == 1 then do s <- *messageBucket1; yield s
  else if b == 2 then do s <- *messageBucket2; yield s
  else if b == 3 then do s <- *messageBucket3; yield s
  else if b == 4 then do s <- *messageBucket4; yield s
  else if b == 5 then do s <- *messageBucket5; yield s
  else if b == 6 then do s <- *messageBucket6; yield s
  else if b == 7 then do s <- *messageBucket7; yield s
  else if b == 8 then do s <- *messageBucket8; yield s
  else if b == 9 then do s <- *messageBucket9; yield s
  else if b == 10 then do s <- *messageBucket10; yield s
  else if b == 11 then do s <- *messageBucket11; yield s
  else if b == 12 then do s <- *messageBucket12; yield s
  else if b == 13 then do s <- *messageBucket13; yield s
  else if b == 14 then do s <- *messageBucket14; yield s
  else do s <- *messageBucket15; yield s

writeMessageBucket : Int -> [Message] -> IO ()
writeMessageBucket = \b msgs ->
  if b == 0 then set *messageBucket0 = msgs
  else if b == 1 then set *messageBucket1 = msgs
  else if b == 2 then set *messageBucket2 = msgs
  else if b == 3 then set *messageBucket3 = msgs
  else if b == 4 then set *messageBucket4 = msgs
  else if b == 5 then set *messageBucket5 = msgs
  else if b == 6 then set *messageBucket6 = msgs
  else if b == 7 then set *messageBucket7 = msgs
  else if b == 8 then set *messageBucket8 = msgs
  else if b == 9 then set *messageBucket9 = msgs
  else if b == 10 then set *messageBucket10 = msgs
  else if b == 11 then set *messageBucket11 = msgs
  else if b == 12 then set *messageBucket12 = msgs
  else if b == 13 then set *messageBucket13 = msgs
  else if b == 14 then set *messageBucket14 = msgs
  else set *messageBucket15 = msgs

-- Read all 16 message buckets (for cold-path operations: federation ack, forward candidates, stats).
-- Uses unionNE to skip empty buckets (avoids allocation overhead on sparse servers).
readAllMessages : IO [Message]
readAllMessages = do
  m0 <- *messageBucket0
  m1 <- *messageBucket1
  m2 <- *messageBucket2
  m3 <- *messageBucket3
  m4 <- *messageBucket4
  m5 <- *messageBucket5
  m6 <- *messageBucket6
  m7 <- *messageBucket7
  m8 <- *messageBucket8
  m9 <- *messageBucket9
  m10 <- *messageBucket10
  m11 <- *messageBucket11
  m12 <- *messageBucket12
  m13 <- *messageBucket13
  m14 <- *messageBucket14
  m15 <- *messageBucket15
  yield (unionNE m0 (unionNE m1 (unionNE m2 (unionNE m3 (unionNE m4 (unionNE m5 (unionNE m6 (unionNE m7 (unionNE m8 (unionNE m9 (unionNE m10 (unionNE m11 (unionNE m12 (unionNE m13 (unionNE m14 m15)))))))))))))))

-- Apply a filter/transform to every message bucket
transformAllMessageBuckets : ([Message] -> [Message]) -> IO ()
transformAllMessageBuckets = \f -> do
  b0 <- *messageBucket0; set *messageBucket0 = f b0
  b1 <- *messageBucket1; set *messageBucket1 = f b1
  b2 <- *messageBucket2; set *messageBucket2 = f b2
  b3 <- *messageBucket3; set *messageBucket3 = f b3
  b4 <- *messageBucket4; set *messageBucket4 = f b4
  b5 <- *messageBucket5; set *messageBucket5 = f b5
  b6 <- *messageBucket6; set *messageBucket6 = f b6
  b7 <- *messageBucket7; set *messageBucket7 = f b7
  b8 <- *messageBucket8; set *messageBucket8 = f b8
  b9 <- *messageBucket9; set *messageBucket9 = f b9
  b10 <- *messageBucket10; set *messageBucket10 = f b10
  b11 <- *messageBucket11; set *messageBucket11 = f b11
  b12 <- *messageBucket12; set *messageBucket12 = f b12
  b13 <- *messageBucket13; set *messageBucket13 = f b13
  b14 <- *messageBucket14; set *messageBucket14 = f b14
  b15 <- *messageBucket15; set *messageBucket15 = f b15

-- Read only the message buckets at the given indices (avoids reading all 16)
readSelectedBuckets : [Int] -> IO [Message]
readSelectedBuckets = \buckets ->
  case headOf buckets of
    Nothing {} -> yield []
    Just {value: b} -> do
      let rest = do x <- buckets; where x != b; yield x
      msgs <- readMessageBucket b
      remaining <- readSelectedBuckets rest
      yield (union msgs remaining)

-- Transform only the message buckets at the given indices
transformSelectedBuckets : [Int] -> ([Message] -> [Message]) -> IO ()
transformSelectedBuckets = \buckets f ->
  case headOf buckets of
    Nothing {} -> yield {}
    Just {value: b} -> do
      let rest = do x <- buckets; where x != b; yield x
      msgs <- readMessageBucket b
      writeMessageBucket b (f msgs)
      transformSelectedBuckets rest f

-- Collect unique bucket indices for a set of pubkeys
-- O(1) per step with union [b] acc (set, order irrelevant, max 16 entries)
uniqueBucketsFor = \items getKey ->
  fold (\acc x ->
    let b = pubkeyBucket (getKey x) in
    if any acc (\i -> i == b) then acc else union [b] acc) [] items

-- Prune a single message bucket and atomically adjust shared counters.
-- Each bucket prune decrements totalMessageCount and its rcBucket by exactly
-- what was removed, preserving concurrent modifications from poll-ack or send.
-- Uses per-message expiresAt (respects sender-specified TTL).
-- Also queues expiration notifications for locally-originated messages (senderKey != "")
-- so the sender can learn their message expired unread via the next poll response.
pruneMessageBucket = \b t -> atomic do
  bucket <- readMessageBucket b
  let kept = do m <- bucket; where m.expiresAt > t; yield m
  let removedCount = count bucket - count kept
  writeMessageBucket b kept
  if removedCount > 0 then do
    tc <- *totalMessageCount
    set *totalMessageCount = max 0 (tc - removedCount)
    rc <- readRcBucket b
    let removed = do m <- bucket; where m.expiresAt <= t; yield m
    writeRcBucket b (batchDecrementRecipientCounts rc (countByRecipient removed))
    -- Queue expiration notifications for locally-originated messages with known sender
    let localExpired = do m <- removed; where m.senderKey != "" && m.originServer == ""; yield {senderKey: m.senderKey, messageId: m.messageId, toKey: m.toKey, expiredAt: t}
    when (count localExpired > 0) (do
      se <- *senderExpirations
      -- Per-key cap: limit expirations per sender to prevent one noisy key from dominating the queue
      let perKeyCapped = fold (\acc e ->
        let existingForKey = count (do x <- se; where x.senderKey == e.senderKey; yield x)
          + count (do x <- acc; where x.senderKey == e.senderKey; yield x)
        in if existingForKey >= maxSenderExpirationsPerKey then acc else union acc [e]) [] localExpired
      let perKeyDropped = count localExpired - count perKeyCapped
      let combined = union se perKeyCapped
      let overCap = count combined > maxSenderExpirations
      if overCap then do
        -- Batch eviction: evict 2% of capacity to amortize O(n) scan cost
        let evictCount = max 1 (count combined - maxSenderExpirations + maxSenderExpirations / 50)
        let eviction = evictSmallest combined evictCount (\e -> e.expiredAt)
        set *senderExpirations = eviction.kept
        den <- *droppedExpirationNotifs
        let denAfterCap = fold (\acc ev -> incrementDropCounter acc ev.senderKey 1 t) den eviction.evicted
        -- Also record per-key drops for senders that hit maxSenderExpirationsPerKey
        let perKeyDroppedEntries = do e <- localExpired; where none perKeyCapped (\c -> c.messageId == e.messageId && c.toKey == e.toKey); yield e
        set *droppedExpirationNotifs = fold (\acc e -> incrementDropCounter acc e.senderKey 1 t) denAfterCap perKeyDroppedEntries
      else do
        set *senderExpirations = combined
        when (perKeyDropped > 0) (do
          den <- *droppedExpirationNotifs
          let perKeyDroppedEntries = do e <- localExpired; where none perKeyCapped (\c -> c.messageId == e.messageId && c.toKey == e.toKey); yield e
          set *droppedExpirationNotifs = fold (\acc e -> incrementDropCounter acc e.senderKey 1 t) den perKeyDroppedEntries))
  else yield {}

-- Prune all 16 message buckets with concurrency: fork non-empty buckets, then wait
-- for all forks to complete via a counter-based barrier before returning. This ensures
-- forward retries (which run after pruning) see fully pruned message state.
-- Each bucket's atomic block only contends on *totalMessageCount (a single Int);
-- rcBuckets and message buckets are per-bucket and independent.
*pendingBucketPrunes : Int

pruneMessageBucketsConcurrent = \b t ->
  if b > 15 then do
    -- Wait for all forked bucket prunes to complete via STM retry barrier.
    -- Each fork decrements *pendingBucketPrunes; when it reaches 0, all are done.
    atomic do
      pending <- *pendingBucketPrunes
      if pending > 0 then retry else yield {}
  else do
    bucket <- readMessageBucket b
    if count bucket == 0 then pruneMessageBucketsConcurrent (b + 1) t
    else do
      atomic do
        p <- *pendingBucketPrunes
        set *pendingBucketPrunes = p + 1
      fork (do
        pruneMessageBucket b t
        atomic do
          p <- *pendingBucketPrunes
          set *pendingBucketPrunes = max 0 (p - 1))
      pruneMessageBucketsConcurrent (b + 1) t

-- Per-bucket message reconciliation: reads one bucket per atomic block instead of all 16
-- at once, reducing lock contention during reconciliation. Each pubkey maps to exactly one
-- bucket, so per-bucket recipient counts are disjoint — each bucket's counts are written
-- to the corresponding rcBucket without overlap.
-- Delta-based counter adjustment: snapshots totalMessageCount before scanning, computes the
-- drift (actual - snapshot), then applies the drift atomically to the live counter. This is
-- commutative with concurrent sendMessageCore: if sendMessageCore increments by N between our
-- snapshot and final adjustment, the live counter becomes (snapshot + N + drift) = (actual + N),
-- which is correct. The old approach overwrote with the absolute recount, losing concurrent N.
-- Per-bucket atomic reconciliation: each bucket is reconciled independently, computing
-- its own delta and applying it to totalMessageCount atomically. This is safe with
-- concurrent prune decrements: if a forked pruneMessageBucket modifies totalMessageCount
-- between our bucket N and bucket N+1, each bucket's delta is applied independently and
-- the shared counter converges. The old snapshot-then-delta approach could overcorrect
-- when concurrent decrements occurred between snapshot and final write.
reconcileMessageCountsDelta : IO Int
reconcileMessageCountsDelta = reconcileMessageCountsPerBucket 0 0

reconcileMessageCountsPerBucket = \b totalDrift ->
  if b > 15 then yield totalDrift
  else do
    bucketDrift <- atomic do
      bucket <- readMessageBucket b
      let counts = countByRecipient bucket
      let actual = fold (\a c -> a + c.count) 0 counts
      -- Read current rcBucket to compute drift vs what's tracked
      oldCounts <- readRcBucket b
      let tracked = fold (\a c -> a + c.count) 0 oldCounts
      writeRcBucket b counts
      -- Apply per-bucket drift to totalMessageCount atomically
      let drift = actual - tracked
      when (drift != 0) (do
        stored <- *totalMessageCount
        set *totalMessageCount = max 0 (stored + drift))
      yield drift
    reconcileMessageCountsPerBucket (b + 1) (totalDrift + bucketDrift)

-- ============================================
-- Recipient Count Helpers
-- ============================================
-- Per-recipient message counts avoid O(n) scan of all messages on send/forward.
-- Sharded into 16 buckets (rcBucket0-15) by pubkeyBucket, reducing scan from
-- O(unique_recipients) to O(unique_recipients/16). Each pubkey maps to exactly
-- one bucket, so lookups never cross shards.
-- TODO: If Knot adds a map/dictionary type, replace [RecipientCount] with a
-- Map<PubkeyHex, Int> for O(1) lookups.

getRecipientCount : PubkeyHex -> [RecipientCount] -> Int
getRecipientCount = \pubkey counts ->
  fold (\acc c -> if c.pubkey == pubkey then c.count else acc) 0 counts

-- Single-pass recipient count adjustment: fold once instead of any + list comprehension (O(n) vs O(2n))
adjustRecipientCount : [RecipientCount] -> PubkeyHex -> Int -> [RecipientCount]
adjustRecipientCount = \counts pubkey delta ->
  if delta == 0 then counts
  else let result = fold (\acc c ->
    if c.pubkey == pubkey
      then if c.count + delta > 0
        then {items: union acc.items [{pubkey: c.pubkey, count: c.count + delta}], found: True {}}
        else {items: acc.items, found: True {}}
      else {items: union acc.items [c], found: acc.found})
    {items: [], found: False {}} counts
  in if result.found then result.items
    else if delta > 0 then union counts [{pubkey: pubkey, count: delta}]
    else counts

-- Count items per toKey using sort-then-scan: O(n log n) sort + O(n) linear scan.
-- Replaces the previous O(n*k) fold-with-any approach. For a bucket with 6000 messages
-- and 500 unique recipients, this reduces comparisons from ~3M to ~80k.
-- sortBy groups equal toKeys together; countSortedGroups scans consecutive equal keys.
countByRecipient = \items ->
  let sorted = sortBy (\m -> m.toKey) items in
  countSortedGroups sorted

-- Single-pass fold over sorted items: counts consecutive runs of the same toKey.
-- O(n) total: one fold step per item, O(1) prepend per group boundary.
-- Replaces the previous headOf+filter pattern which was O(n) per step = O(n²) total.
-- Uses "union [new] acc" (prepend, O(1)) instead of "union acc [new]" (copy, O(k)).
countSortedGroups = \items ->
  let result = fold (\acc m ->
    if acc.currentKey == ""
      then {currentKey: m.toKey, currentCount: 1, groups: acc.groups}
    else if m.toKey == acc.currentKey
      then {currentKey: acc.currentKey, currentCount: acc.currentCount + 1, groups: acc.groups}
    else {currentKey: m.toKey, currentCount: 1, groups: union [{pubkey: acc.currentKey, count: acc.currentCount}] acc.groups})
    {currentKey: "", currentCount: 0, groups: []} items
  in if result.currentKey == "" then result.groups
    else union [{pubkey: result.currentKey, count: result.currentCount}] result.groups

-- Batch-decrement recipient counts: subtract per-key removal counts in a single pass
-- instead of calling adjustRecipientCount in a loop.
batchDecrementRecipientCounts : [RecipientCount] -> [RecipientCount] -> [RecipientCount]
batchDecrementRecipientCounts = \counts removedCounts ->
  do c <- counts; let adj = c.count - getRecipientCount c.pubkey removedCounts; where adj > 0; yield {pubkey: c.pubkey, count: adj}

-- Recipient count bucket helpers (sharded by pubkeyBucket, same as messages)
readRcBucket : Int -> IO [RecipientCount]
readRcBucket = \b ->
  if b == 0 then do s <- *rcBucket0; yield s
  else if b == 1 then do s <- *rcBucket1; yield s
  else if b == 2 then do s <- *rcBucket2; yield s
  else if b == 3 then do s <- *rcBucket3; yield s
  else if b == 4 then do s <- *rcBucket4; yield s
  else if b == 5 then do s <- *rcBucket5; yield s
  else if b == 6 then do s <- *rcBucket6; yield s
  else if b == 7 then do s <- *rcBucket7; yield s
  else if b == 8 then do s <- *rcBucket8; yield s
  else if b == 9 then do s <- *rcBucket9; yield s
  else if b == 10 then do s <- *rcBucket10; yield s
  else if b == 11 then do s <- *rcBucket11; yield s
  else if b == 12 then do s <- *rcBucket12; yield s
  else if b == 13 then do s <- *rcBucket13; yield s
  else if b == 14 then do s <- *rcBucket14; yield s
  else do s <- *rcBucket15; yield s

writeRcBucket : Int -> [RecipientCount] -> IO ()
writeRcBucket = \b counts ->
  if b == 0 then set *rcBucket0 = counts
  else if b == 1 then set *rcBucket1 = counts
  else if b == 2 then set *rcBucket2 = counts
  else if b == 3 then set *rcBucket3 = counts
  else if b == 4 then set *rcBucket4 = counts
  else if b == 5 then set *rcBucket5 = counts
  else if b == 6 then set *rcBucket6 = counts
  else if b == 7 then set *rcBucket7 = counts
  else if b == 8 then set *rcBucket8 = counts
  else if b == 9 then set *rcBucket9 = counts
  else if b == 10 then set *rcBucket10 = counts
  else if b == 11 then set *rcBucket11 = counts
  else if b == 12 then set *rcBucket12 = counts
  else if b == 13 then set *rcBucket13 = counts
  else if b == 14 then set *rcBucket14 = counts
  else set *rcBucket15 = counts

-- Count total recipients across all 16 rc buckets (for stats)
countAllRcEntries : Int -> IO Int
countAllRcEntries = \b ->
  if b > 15 then yield 0
  else do
    bucket <- readRcBucket b
    rest <- countAllRcEntries (b + 1)
    yield (count bucket + rest)

-- Merge two sorted-by-count-desc lists, keeping only the top N by count.
-- O(n+m) merge pass + O(result) truncation. Used by topRecipientsByBucket.
mergeTopN : [RecipientCount] -> [RecipientCount] -> Int -> [RecipientCount]
mergeTopN = \acc newItems limit ->
  let combined = fold (\a c ->
    if any a (\x -> x.pubkey == c.pubkey) then a
    else union a [c]) acc newItems
  in let sorted = sortBy (\c -> 0 - c.count) combined
  in takeRelation limit sorted

-- Top-N recipients by message count, scanning one rcBucket at a time.
-- Avoids materializing all 16 rcBuckets into a single list (O(16 * bucket_size)
-- vs O(total_recipients)). Each bucket's entries are merged into a running top-N.
topRecipientsByBucket : Int -> Int -> [RecipientCount] -> IO [RecipientCount]
topRecipientsByBucket = \b limit acc ->
  if b > 15 then yield acc
  else do
    bucket <- readRcBucket b
    let merged = mergeTopN acc bucket limit
    topRecipientsByBucket (b + 1) limit merged

-- Sum total message count from rcBuckets (cheap: sums .count fields, doesn't scan messages)
sumRcBucketTotals : Int -> IO Int
sumRcBucketTotals = \b ->
  if b > 15 then yield 0
  else do
    bucket <- readRcBucket b
    let bucketTotal = fold (\acc c -> acc + c.count) 0 bucket
    rest <- sumRcBucketTotals (b + 1)
    yield (bucketTotal + rest)

-- Check message dedup only (without counting — count comes from rcBuckets)
checkMessageDup : [Message] -> Text -> PubkeyHex -> Bool
checkMessageDup = \messages messageId toKey ->
  messageId != "" && any messages (\m -> m.messageId == messageId && m.toKey == toKey)

-- ============================================
-- Forward Nonce Bucket Helpers
-- ============================================
-- Forward nonces sharded into 16 buckets by pubkeyBucket(toKey).
-- Hot-path (handleForwardMessage, sendMessageCore) scans one bucket (~1/16 of nonces).

readNonceBucket : Int -> IO [ForwardNonce]
readNonceBucket = \b ->
  if b == 0 then do s <- *nonceBucket0; yield s
  else if b == 1 then do s <- *nonceBucket1; yield s
  else if b == 2 then do s <- *nonceBucket2; yield s
  else if b == 3 then do s <- *nonceBucket3; yield s
  else if b == 4 then do s <- *nonceBucket4; yield s
  else if b == 5 then do s <- *nonceBucket5; yield s
  else if b == 6 then do s <- *nonceBucket6; yield s
  else if b == 7 then do s <- *nonceBucket7; yield s
  else if b == 8 then do s <- *nonceBucket8; yield s
  else if b == 9 then do s <- *nonceBucket9; yield s
  else if b == 10 then do s <- *nonceBucket10; yield s
  else if b == 11 then do s <- *nonceBucket11; yield s
  else if b == 12 then do s <- *nonceBucket12; yield s
  else if b == 13 then do s <- *nonceBucket13; yield s
  else if b == 14 then do s <- *nonceBucket14; yield s
  else do s <- *nonceBucket15; yield s

writeNonceBucket : Int -> [ForwardNonce] -> IO ()
writeNonceBucket = \b nonces ->
  if b == 0 then set *nonceBucket0 = nonces
  else if b == 1 then set *nonceBucket1 = nonces
  else if b == 2 then set *nonceBucket2 = nonces
  else if b == 3 then set *nonceBucket3 = nonces
  else if b == 4 then set *nonceBucket4 = nonces
  else if b == 5 then set *nonceBucket5 = nonces
  else if b == 6 then set *nonceBucket6 = nonces
  else if b == 7 then set *nonceBucket7 = nonces
  else if b == 8 then set *nonceBucket8 = nonces
  else if b == 9 then set *nonceBucket9 = nonces
  else if b == 10 then set *nonceBucket10 = nonces
  else if b == 11 then set *nonceBucket11 = nonces
  else if b == 12 then set *nonceBucket12 = nonces
  else if b == 13 then set *nonceBucket13 = nonces
  else if b == 14 then set *nonceBucket14 = nonces
  else set *nonceBucket15 = nonces

readAllNonces : IO [ForwardNonce]
readAllNonces = do
  n0 <- *nonceBucket0
  n1 <- *nonceBucket1
  n2 <- *nonceBucket2
  n3 <- *nonceBucket3
  n4 <- *nonceBucket4
  n5 <- *nonceBucket5
  n6 <- *nonceBucket6
  n7 <- *nonceBucket7
  n8 <- *nonceBucket8
  n9 <- *nonceBucket9
  n10 <- *nonceBucket10
  n11 <- *nonceBucket11
  n12 <- *nonceBucket12
  n13 <- *nonceBucket13
  n14 <- *nonceBucket14
  n15 <- *nonceBucket15
  yield (unionNE n0 (unionNE n1 (unionNE n2 (unionNE n3 (unionNE n4 (unionNE n5 (unionNE n6 (unionNE n7 (unionNE n8 (unionNE n9 (unionNE n10 (unionNE n11 (unionNE n12 (unionNE n13 (unionNE n14 n15)))))))))))))))

countAllNonces : Int -> IO Int
countAllNonces = \b ->
  if b > 15 then yield 0
  else do
    bucket <- readNonceBucket b
    rest <- countAllNonces (b + 1)
    yield (count bucket + rest)

-- Write nonces to all 16 buckets via single-pass partitioning
writeAllNonces : [ForwardNonce] -> IO ()
writeAllNonces = \nonces -> do
  let partitioned = fold (\acc n ->
    let b = pubkeyBucket n.toKey in
    {b0: if b == 0 then union [n] acc.b0 else acc.b0,
     b1: if b == 1 then union [n] acc.b1 else acc.b1,
     b2: if b == 2 then union [n] acc.b2 else acc.b2,
     b3: if b == 3 then union [n] acc.b3 else acc.b3,
     b4: if b == 4 then union [n] acc.b4 else acc.b4,
     b5: if b == 5 then union [n] acc.b5 else acc.b5,
     b6: if b == 6 then union [n] acc.b6 else acc.b6,
     b7: if b == 7 then union [n] acc.b7 else acc.b7,
     b8: if b == 8 then union [n] acc.b8 else acc.b8,
     b9: if b == 9 then union [n] acc.b9 else acc.b9,
     b10: if b == 10 then union [n] acc.b10 else acc.b10,
     b11: if b == 11 then union [n] acc.b11 else acc.b11,
     b12: if b == 12 then union [n] acc.b12 else acc.b12,
     b13: if b == 13 then union [n] acc.b13 else acc.b13,
     b14: if b == 14 then union [n] acc.b14 else acc.b14,
     b15: if b == 15 then union [n] acc.b15 else acc.b15})
    {b0: [], b1: [], b2: [], b3: [], b4: [], b5: [], b6: [], b7: [], b8: [], b9: [], b10: [], b11: [], b12: [], b13: [], b14: [], b15: []} nonces
  writeNonceBucket 0 partitioned.b0
  writeNonceBucket 1 partitioned.b1
  writeNonceBucket 2 partitioned.b2
  writeNonceBucket 3 partitioned.b3
  writeNonceBucket 4 partitioned.b4
  writeNonceBucket 5 partitioned.b5
  writeNonceBucket 6 partitioned.b6
  writeNonceBucket 7 partitioned.b7
  writeNonceBucket 8 partitioned.b8
  writeNonceBucket 9 partitioned.b9
  writeNonceBucket 10 partitioned.b10
  writeNonceBucket 11 partitioned.b11
  writeNonceBucket 12 partitioned.b12
  writeNonceBucket 13 partitioned.b13
  writeNonceBucket 14 partitioned.b14
  writeNonceBucket 15 partitioned.b15

-- Prune nonces across all 16 buckets (used by flush and restore)
pruneAllNonceBuckets : Int -> Timestamp -> IO ()
pruneAllNonceBuckets = \b t ->
  if b > 15 then yield {}
  else do
    bucket <- readNonceBucket b
    writeNonceBucket b (do n <- bucket; where t - n.seenAt < forwardNonceRetention; yield n)
    pruneAllNonceBuckets (b + 1) t

-- Round-robin nonce pruning: scan 4 of 16 buckets per call.
-- With 60-day retention and 30-second prune intervals, full coverage every ~2 minutes
-- is sufficient. Reduces prune cycle cost by 75% vs scanning all 16 buckets.
pruneNonceBucketsRoundRobin : Timestamp -> IO ()
pruneNonceBucketsRoundRobin = \t -> do
  group <- *noncePruneGroup
  let startBucket = (group * 4) - ((group * 4) / 16) * 16
  pruneNonceBucketRange startBucket (startBucket + 3) t
  set *noncePruneGroup = if group >= 3 then 0 else group + 1

pruneNonceBucketRange : Int -> Int -> Timestamp -> IO ()
pruneNonceBucketRange = \b endB t ->
  if b > endB || b > 15 then yield {}
  else do
    bucket <- readNonceBucket b
    let pruned = do n <- bucket; where t - n.seenAt < forwardNonceRetention; yield n
    when (count pruned < count bucket) (writeNonceBucket b pruned)
    pruneNonceBucketRange (b + 1) endB t

-- Per-bucket nonce eviction cutoff read/write helpers.
readNonceCutoff : Int -> IO Timestamp
readNonceCutoff = \b ->
  if b == 0 then do s <- *nonceEvictionCutoff0; yield s
  else if b == 1 then do s <- *nonceEvictionCutoff1; yield s
  else if b == 2 then do s <- *nonceEvictionCutoff2; yield s
  else if b == 3 then do s <- *nonceEvictionCutoff3; yield s
  else if b == 4 then do s <- *nonceEvictionCutoff4; yield s
  else if b == 5 then do s <- *nonceEvictionCutoff5; yield s
  else if b == 6 then do s <- *nonceEvictionCutoff6; yield s
  else if b == 7 then do s <- *nonceEvictionCutoff7; yield s
  else if b == 8 then do s <- *nonceEvictionCutoff8; yield s
  else if b == 9 then do s <- *nonceEvictionCutoff9; yield s
  else if b == 10 then do s <- *nonceEvictionCutoff10; yield s
  else if b == 11 then do s <- *nonceEvictionCutoff11; yield s
  else if b == 12 then do s <- *nonceEvictionCutoff12; yield s
  else if b == 13 then do s <- *nonceEvictionCutoff13; yield s
  else if b == 14 then do s <- *nonceEvictionCutoff14; yield s
  else do s <- *nonceEvictionCutoff15; yield s

writeNonceCutoff : Int -> Timestamp -> IO ()
writeNonceCutoff = \b val ->
  if b == 0 then set *nonceEvictionCutoff0 = val
  else if b == 1 then set *nonceEvictionCutoff1 = val
  else if b == 2 then set *nonceEvictionCutoff2 = val
  else if b == 3 then set *nonceEvictionCutoff3 = val
  else if b == 4 then set *nonceEvictionCutoff4 = val
  else if b == 5 then set *nonceEvictionCutoff5 = val
  else if b == 6 then set *nonceEvictionCutoff6 = val
  else if b == 7 then set *nonceEvictionCutoff7 = val
  else if b == 8 then set *nonceEvictionCutoff8 = val
  else if b == 9 then set *nonceEvictionCutoff9 = val
  else if b == 10 then set *nonceEvictionCutoff10 = val
  else if b == 11 then set *nonceEvictionCutoff11 = val
  else if b == 12 then set *nonceEvictionCutoff12 = val
  else if b == 13 then set *nonceEvictionCutoff13 = val
  else if b == 14 then set *nonceEvictionCutoff14 = val
  else set *nonceEvictionCutoff15 = val

-- Reset all 16 per-bucket nonce eviction cutoffs to 0 (accept all timestamps).
-- Called by nonce flush to clear stale cutoffs when all nonces are removed.
resetAllNonceCutoffs : Int -> IO ()
resetAllNonceCutoffs = \b ->
  if b > 15 then yield {}
  else do
    writeNonceCutoff b 0
    resetAllNonceCutoffs (b + 1)

-- Record a forward nonce and handle capacity eviction with LRU logging.
-- Usable inside or outside atomic blocks (reads/writes nonce bucket refs).
-- Returns eviction info for deferred logging when called inside atomic.
updateForwardNonce : Int -> MessageIdHex -> PubkeyHex -> Timestamp -> IO {lruEvicted: Int, oldestRetainedAge: Int}
updateForwardNonce = \nb messageId toKey t -> do
  fwdNonces <- readNonceBucket nb
  let updatedNonces = union fwdNonces [{messageId: messageId, toKey: toKey, seenAt: t}]
  let evictedNonces = if count updatedNonces > maxNoncesPerBucket
        then evictNonces updatedNonces maxNoncesPerBucket forwardNonceRetention t
        else updatedNonces
  let lruEvicted = count updatedNonces - count evictedNonces
  let oldestRetainedAge = if lruEvicted > 0
        then case minBy evictedNonces (\n -> n.seenAt) of Nothing {} -> 0; Just {value: n} -> t - n.seenAt
        else 0
  writeNonceBucket nb evictedNonces
  -- Update per-bucket nonce eviction cutoff: set to the oldest retained nonce in this bucket.
  -- Per-bucket cutoffs are correct because each forward is checked against its own bucket's
  -- cutoff (keyed by pubkeyBucket(toKey)). The previous global cutoff was wrong: bucket 3
  -- evicting recent nonces would tighten the cutoff for bucket 12 (with older retained nonces).
  when (lruEvicted > 0) (do
    let bucketMin = case minBy evictedNonces (\n -> n.seenAt) of Nothing {} -> 0; Just {value: n} -> n.seenAt
    writeNonceCutoff nb bucketMin)
  yield {lruEvicted: lruEvicted, oldestRetainedAge: oldestRetainedAge}

-- Log nonce LRU eviction if any occurred. Call outside atomic blocks.
logNonceEviction : Int -> Int -> Int -> IO ()
logNonceEviction = \nb lruEvicted oldestRetainedAge ->
  when (lruEvicted > 0) (do
    let level = if oldestRetainedAge < messageMaxAge then "error" else "warn"
    logKV level "nonce_lru_eviction" ["bucket=" ++ show nb, "evicted=" ++ show lruEvicted, "capacity=" ++ show maxNoncesPerBucket, "oldestRetainedMs=" ++ show oldestRetainedAge])

-- Full record-and-log helper for use outside atomic blocks.
-- Wraps updateForwardNonce in atomic to prevent lost nonces from concurrent calls.
-- Without this, two concurrent sendMessageCore calls (via handleSendMessage) can both
-- read the same nonce bucket, each append their nonce, and the second write silently
-- drops the first nonce — reopening a replay window for that message.
-- Safe when called from inside an existing atomic block (Knot atomic is reentrant).
recordForwardNonce : MessageIdHex -> PubkeyHex -> Timestamp -> IO ()
recordForwardNonce = \messageId toKey t -> do
  let nb = pubkeyBucket toKey
  result <- atomic do updateForwardNonce nb messageId toKey t
  logNonceEviction nb result.lruEvicted result.oldestRetainedAge

-- ============================================
-- Forward Bucket Helpers
-- ============================================
-- Forwards sharded into 16 buckets by pubkeyBucket(toKey).

readFwdBucket : Int -> IO [ForwardEntry]
readFwdBucket = \b ->
  if b == 0 then do s <- *fwdBucket0; yield s
  else if b == 1 then do s <- *fwdBucket1; yield s
  else if b == 2 then do s <- *fwdBucket2; yield s
  else if b == 3 then do s <- *fwdBucket3; yield s
  else if b == 4 then do s <- *fwdBucket4; yield s
  else if b == 5 then do s <- *fwdBucket5; yield s
  else if b == 6 then do s <- *fwdBucket6; yield s
  else if b == 7 then do s <- *fwdBucket7; yield s
  else if b == 8 then do s <- *fwdBucket8; yield s
  else if b == 9 then do s <- *fwdBucket9; yield s
  else if b == 10 then do s <- *fwdBucket10; yield s
  else if b == 11 then do s <- *fwdBucket11; yield s
  else if b == 12 then do s <- *fwdBucket12; yield s
  else if b == 13 then do s <- *fwdBucket13; yield s
  else if b == 14 then do s <- *fwdBucket14; yield s
  else do s <- *fwdBucket15; yield s

writeFwdBucket : Int -> [ForwardEntry] -> IO ()
writeFwdBucket = \b fwds ->
  if b == 0 then set *fwdBucket0 = fwds
  else if b == 1 then set *fwdBucket1 = fwds
  else if b == 2 then set *fwdBucket2 = fwds
  else if b == 3 then set *fwdBucket3 = fwds
  else if b == 4 then set *fwdBucket4 = fwds
  else if b == 5 then set *fwdBucket5 = fwds
  else if b == 6 then set *fwdBucket6 = fwds
  else if b == 7 then set *fwdBucket7 = fwds
  else if b == 8 then set *fwdBucket8 = fwds
  else if b == 9 then set *fwdBucket9 = fwds
  else if b == 10 then set *fwdBucket10 = fwds
  else if b == 11 then set *fwdBucket11 = fwds
  else if b == 12 then set *fwdBucket12 = fwds
  else if b == 13 then set *fwdBucket13 = fwds
  else if b == 14 then set *fwdBucket14 = fwds
  else set *fwdBucket15 = fwds

readAllForwards : IO [ForwardEntry]
readAllForwards = do
  f0 <- *fwdBucket0
  f1 <- *fwdBucket1
  f2 <- *fwdBucket2
  f3 <- *fwdBucket3
  f4 <- *fwdBucket4
  f5 <- *fwdBucket5
  f6 <- *fwdBucket6
  f7 <- *fwdBucket7
  f8 <- *fwdBucket8
  f9 <- *fwdBucket9
  f10 <- *fwdBucket10
  f11 <- *fwdBucket11
  f12 <- *fwdBucket12
  f13 <- *fwdBucket13
  f14 <- *fwdBucket14
  f15 <- *fwdBucket15
  yield (unionNE f0 (unionNE f1 (unionNE f2 (unionNE f3 (unionNE f4 (unionNE f5 (unionNE f6 (unionNE f7 (unionNE f8 (unionNE f9 (unionNE f10 (unionNE f11 (unionNE f12 (unionNE f13 (unionNE f14 f15)))))))))))))))

countAllForwards : Int -> IO Int
countAllForwards = \b ->
  if b > 15 then yield 0
  else do
    bucket <- readFwdBucket b
    rest <- countAllForwards (b + 1)
    yield (count bucket + rest)

-- Compute min and max message counts across all 16 buckets (for stats bucket skew detection).
-- Returns {bucketMin, bucketMax}. O(16) bucket reads.
messageBucketMinMax : IO {bucketMin: Int, bucketMax: Int}
messageBucketMinMax = messageBucketMinMaxInner 0 999999999 0

messageBucketMinMaxInner : Int -> Int -> Int -> IO {bucketMin: Int, bucketMax: Int}
messageBucketMinMaxInner = \b currentMin currentMax ->
  if b > 15 then yield {bucketMin: if currentMin == 999999999 then 0 else currentMin, bucketMax: currentMax}
  else do
    bucket <- readMessageBucket b
    let c = count bucket
    messageBucketMinMaxInner (b + 1) (min currentMin c) (max currentMax c)

-- Compute forward stats per-bucket without materializing all forwards into one list.
-- Returns total count, oldest age, unique server count, and max per-server queue depth.
computeForwardStats : Int -> Timestamp -> IO {totalCount: Int, oldestAge: Int, serverCount: Int, maxDepth: Int, serverCounts: [{server: Text, count: Int}]}
computeForwardStats = \b t -> computeForwardStatsInner b t {totalCount: 0, oldestAge: 0, serverCount: 0, maxDepth: 0, serverCounts: []}

computeForwardStatsInner = \b t acc ->
  if b > 15 then yield acc
  else do
    bucket <- readFwdBucket b
    let bucketCount = count bucket
    let bucketOldest = case minBy bucket (\x -> x.createdAt) of Nothing {} -> 0; Just {value: x} -> t - x.createdAt
    -- Aggregate per-server counts: merge this bucket's servers into the running totals
    let updatedServerCounts = fold (\sc f ->
      if any sc (\s -> s.server == f.toServer)
        then do s <- sc; yield (if s.server == f.toServer then {server: s.server, count: s.count + 1} else s)
        else union sc [{server: f.toServer, count: 1}]) acc.serverCounts bucket
    let newMaxDepth = fold (\mx s -> max mx s.count) acc.maxDepth updatedServerCounts
    computeForwardStatsInner (b + 1) t {totalCount: acc.totalCount + bucketCount, oldestAge: max acc.oldestAge bucketOldest, serverCount: count updatedServerCounts, maxDepth: newMaxDepth, serverCounts: updatedServerCounts}

-- Lightweight scan: find the oldest forward entry age across all 16 buckets.
-- O(n) total, no allocation (just tracks max age). Used by health check.
oldestForwardAgeAcrossBuckets : Int -> Timestamp -> Int -> IO Int
oldestForwardAgeAcrossBuckets = \b t acc ->
  if b > 15 then yield acc
  else do
    bucket <- readFwdBucket b
    let bucketOldest = case minBy bucket (\x -> x.createdAt) of Nothing {} -> 0; Just {value: x} -> t - x.createdAt
    oldestForwardAgeAcrossBuckets (b + 1) t (max acc bucketOldest)

-- Count distinct destination servers with stale forward queues (oldest entry > healthForwardQueueMaxAge).
-- Scans all 16 buckets, tracking unique stale servers across buckets.
-- O(total_forwards) scan with O(servers) memory. Used by health check for per-server awareness.
countStaleForwardServers : Int -> Timestamp -> [Text] -> IO Int
countStaleForwardServers = \b t seen ->
  if b > 15
    then yield (count seen)
    else do
      bucket <- readFwdBucket b
      -- Find servers in this bucket with entries older than the threshold
      let newStale = fold (\sacc f ->
        let age = t - f.createdAt in
        if age > healthForwardQueueMaxAge && none sacc (\s -> s == f.toServer) && none seen (\s -> s == f.toServer)
          then union [f.toServer] sacc
          else sacc) [] bucket
      countStaleForwardServers (b + 1) t (union seen newStale)

-- Remove forward entries matching a server and message IDs, scanning per-bucket.
-- Only rewrites buckets that actually changed (avoids writeAllForwards repartitioning).
-- Returns all removed forward entries across all buckets.
-- Batches the totalForwardCount decrement into a single atomic write at the end
-- to reduce STM contention (vs per-bucket decrements contending on the shared counter).
removeForwardsByServer = \server messageIds b acc ->
  if b > 15 then do
    let totalRemoved = count acc
    when (totalRemoved > 0) (atomic do
      tfc <- *totalForwardCount
      set *totalForwardCount = max 0 (tfc - totalRemoved))
    yield acc
  else do
    removed <- atomic do
      bucket <- readFwdBucket b
      let matched = do f <- bucket; where f.toServer == server && any messageIds (\mid -> f.messageId == mid); yield f
      when (count matched > 0) (
        writeFwdBucket b (do f <- bucket; where not (f.toServer == server && any messageIds (\mid -> f.messageId == mid)); yield f))
      yield matched
    removeForwardsByServer server messageIds (b + 1) (if count removed > 0 then union acc removed else acc)

-- Read only the forward buckets at the given indices (avoids reading all 16)
readSelectedFwdBuckets : [Int] -> IO [ForwardEntry]
readSelectedFwdBuckets = \buckets ->
  case headOf buckets of
    Nothing {} -> yield []
    Just {value: b} -> do
      let rest = do x <- buckets; where x != b; yield x
      entries <- readFwdBucket b
      remaining <- readSelectedFwdBuckets rest
      yield (union entries remaining)

-- Write forward entries to only the specified bucket indices. Entries are filtered
-- by pubkeyBucket so each bucket gets only its entries. Unspecified buckets are untouched.
writeSelectedFwdBuckets : [Int] -> [ForwardEntry] -> IO ()
writeSelectedFwdBuckets = \buckets entries ->
  case headOf buckets of
    Nothing {} -> yield {}
    Just {value: b} -> do
      let rest = do x <- buckets; where x != b; yield x
      let bucketEntries = do e <- entries; where pubkeyBucket e.toKey == b; yield e
      writeFwdBucket b bucketEntries
      writeSelectedFwdBuckets rest entries

writeAllForwards : [ForwardEntry] -> IO ()
writeAllForwards = \fwds -> do
  let partitioned = fold (\acc f ->
    let b = pubkeyBucket f.toKey in
    {b0: if b == 0 then union [f] acc.b0 else acc.b0,
     b1: if b == 1 then union [f] acc.b1 else acc.b1,
     b2: if b == 2 then union [f] acc.b2 else acc.b2,
     b3: if b == 3 then union [f] acc.b3 else acc.b3,
     b4: if b == 4 then union [f] acc.b4 else acc.b4,
     b5: if b == 5 then union [f] acc.b5 else acc.b5,
     b6: if b == 6 then union [f] acc.b6 else acc.b6,
     b7: if b == 7 then union [f] acc.b7 else acc.b7,
     b8: if b == 8 then union [f] acc.b8 else acc.b8,
     b9: if b == 9 then union [f] acc.b9 else acc.b9,
     b10: if b == 10 then union [f] acc.b10 else acc.b10,
     b11: if b == 11 then union [f] acc.b11 else acc.b11,
     b12: if b == 12 then union [f] acc.b12 else acc.b12,
     b13: if b == 13 then union [f] acc.b13 else acc.b13,
     b14: if b == 14 then union [f] acc.b14 else acc.b14,
     b15: if b == 15 then union [f] acc.b15 else acc.b15})
    {b0: [], b1: [], b2: [], b3: [], b4: [], b5: [], b6: [], b7: [], b8: [], b9: [], b10: [], b11: [], b12: [], b13: [], b14: [], b15: []} fwds
  writeFwdBucket 0 partitioned.b0
  writeFwdBucket 1 partitioned.b1
  writeFwdBucket 2 partitioned.b2
  writeFwdBucket 3 partitioned.b3
  writeFwdBucket 4 partitioned.b4
  writeFwdBucket 5 partitioned.b5
  writeFwdBucket 6 partitioned.b6
  writeFwdBucket 7 partitioned.b7
  writeFwdBucket 8 partitioned.b8
  writeFwdBucket 9 partitioned.b9
  writeFwdBucket 10 partitioned.b10
  writeFwdBucket 11 partitioned.b11
  writeFwdBucket 12 partitioned.b12
  writeFwdBucket 13 partitioned.b13
  writeFwdBucket 14 partitioned.b14
  writeFwdBucket 15 partitioned.b15

-- ============================================
-- AckedIds Bucket Helpers
-- ============================================
readAckedBucket : Int -> IO [AckedEntry]
readAckedBucket = \b ->
  if b == 0 then do s <- *ackedBucket0; yield s else if b == 1 then do s <- *ackedBucket1; yield s
  else if b == 2 then do s <- *ackedBucket2; yield s else if b == 3 then do s <- *ackedBucket3; yield s
  else if b == 4 then do s <- *ackedBucket4; yield s else if b == 5 then do s <- *ackedBucket5; yield s
  else if b == 6 then do s <- *ackedBucket6; yield s else if b == 7 then do s <- *ackedBucket7; yield s
  else if b == 8 then do s <- *ackedBucket8; yield s else if b == 9 then do s <- *ackedBucket9; yield s
  else if b == 10 then do s <- *ackedBucket10; yield s else if b == 11 then do s <- *ackedBucket11; yield s
  else if b == 12 then do s <- *ackedBucket12; yield s else if b == 13 then do s <- *ackedBucket13; yield s
  else if b == 14 then do s <- *ackedBucket14; yield s else do s <- *ackedBucket15; yield s

writeAckedBucket : Int -> [AckedEntry] -> IO ()
writeAckedBucket = \b entries ->
  if b == 0 then set *ackedBucket0 = entries else if b == 1 then set *ackedBucket1 = entries
  else if b == 2 then set *ackedBucket2 = entries else if b == 3 then set *ackedBucket3 = entries
  else if b == 4 then set *ackedBucket4 = entries else if b == 5 then set *ackedBucket5 = entries
  else if b == 6 then set *ackedBucket6 = entries else if b == 7 then set *ackedBucket7 = entries
  else if b == 8 then set *ackedBucket8 = entries else if b == 9 then set *ackedBucket9 = entries
  else if b == 10 then set *ackedBucket10 = entries else if b == 11 then set *ackedBucket11 = entries
  else if b == 12 then set *ackedBucket12 = entries else if b == 13 then set *ackedBucket13 = entries
  else if b == 14 then set *ackedBucket14 = entries else set *ackedBucket15 = entries

readAllAcked : IO [AckedEntry]
readAllAcked = do
  a0 <- *ackedBucket0; a1 <- *ackedBucket1; a2 <- *ackedBucket2; a3 <- *ackedBucket3
  a4 <- *ackedBucket4; a5 <- *ackedBucket5; a6 <- *ackedBucket6; a7 <- *ackedBucket7
  a8 <- *ackedBucket8; a9 <- *ackedBucket9; a10 <- *ackedBucket10; a11 <- *ackedBucket11
  a12 <- *ackedBucket12; a13 <- *ackedBucket13; a14 <- *ackedBucket14; a15 <- *ackedBucket15
  yield (unionNE a0 (unionNE a1 (unionNE a2 (unionNE a3 (unionNE a4 (unionNE a5 (unionNE a6 (unionNE a7 (unionNE a8 (unionNE a9 (unionNE a10 (unionNE a11 (unionNE a12 (unionNE a13 (unionNE a14 a15)))))))))))))))

writeAllAcked : [AckedEntry] -> IO ()
writeAllAcked = \entries -> do
  let p = fold (\acc e -> let b = pubkeyBucket e.toKey in
    {b0: if b == 0 then union [e] acc.b0 else acc.b0, b1: if b == 1 then union [e] acc.b1 else acc.b1,
     b2: if b == 2 then union [e] acc.b2 else acc.b2, b3: if b == 3 then union [e] acc.b3 else acc.b3,
     b4: if b == 4 then union [e] acc.b4 else acc.b4, b5: if b == 5 then union [e] acc.b5 else acc.b5,
     b6: if b == 6 then union [e] acc.b6 else acc.b6, b7: if b == 7 then union [e] acc.b7 else acc.b7,
     b8: if b == 8 then union [e] acc.b8 else acc.b8, b9: if b == 9 then union [e] acc.b9 else acc.b9,
     b10: if b == 10 then union [e] acc.b10 else acc.b10, b11: if b == 11 then union [e] acc.b11 else acc.b11,
     b12: if b == 12 then union [e] acc.b12 else acc.b12, b13: if b == 13 then union [e] acc.b13 else acc.b13,
     b14: if b == 14 then union [e] acc.b14 else acc.b14, b15: if b == 15 then union [e] acc.b15 else acc.b15})
    {b0: [], b1: [], b2: [], b3: [], b4: [], b5: [], b6: [], b7: [], b8: [], b9: [], b10: [], b11: [], b12: [], b13: [], b14: [], b15: []} entries
  writeAckedBucket 0 p.b0; writeAckedBucket 1 p.b1; writeAckedBucket 2 p.b2; writeAckedBucket 3 p.b3
  writeAckedBucket 4 p.b4; writeAckedBucket 5 p.b5; writeAckedBucket 6 p.b6; writeAckedBucket 7 p.b7
  writeAckedBucket 8 p.b8; writeAckedBucket 9 p.b9; writeAckedBucket 10 p.b10; writeAckedBucket 11 p.b11
  writeAckedBucket 12 p.b12; writeAckedBucket 13 p.b13; writeAckedBucket 14 p.b14; writeAckedBucket 15 p.b15

countAllAcked : Int -> IO Int
countAllAcked = \b -> if b > 15 then yield 0 else do
  bucket <- readAckedBucket b; rest <- countAllAcked (b + 1); yield (count bucket + rest)

-- Per-bucket pruning for acked entries (avoids readAllAcked/writeAllAcked repartitioning).
-- Each bucket is pruned in its own atomic block to reduce lock contention with poll-ack paths.
pruneAllAckedBuckets : Int -> Timestamp -> IO ()
pruneAllAckedBuckets = \b retainCutoff ->
  if b > 15 then yield {}
  else do
    atomic do
      bucket <- readAckedBucket b
      writeAckedBucket b (do a <- bucket; where a.ackedAt > retainCutoff; yield a)
    pruneAllAckedBuckets (b + 1) retainCutoff

-- Per-bucket pruning for forward entries (avoids readAllForwards/writeAllForwards repartitioning).
-- Each bucket is pruned in its own atomic block to reduce lock contention with sendMessageCore.
-- Returns the total count of surviving entries for totalForwardCount reconciliation.
pruneAllFwdBuckets : Int -> Timestamp -> Bool -> Int -> IO Int
pruneAllFwdBuckets = \b retainCutoff fedEnabled acc ->
  if b > 15 then yield acc
  else do
    kept <- atomic do
      bucket <- readFwdBucket b
      let pruned = if not fedEnabled then []
        else do f <- bucket; where f.createdAt > retainCutoff; yield f
      writeFwdBucket b pruned
      yield (count pruned)
    pruneAllFwdBuckets (b + 1) retainCutoff fedEnabled (acc + kept)

-- Find the oldest (minimum) ackedAt timestamp across all 16 acked buckets.
-- Returns 0 if no acked entries exist. Avoids materializing all buckets into one list.
computeOldestAckedAt : Int -> IO Timestamp
computeOldestAckedAt = \b -> if b > 15 then yield 0 else do
  bucket <- readAckedBucket b
  let bucketMin = case minBy bucket (\x -> x.ackedAt) of Nothing {} -> 0; Just {value: x} -> x.ackedAt
  restMin <- computeOldestAckedAt (b + 1)
  yield (if bucketMin == 0 then restMin else if restMin == 0 then bucketMin else min bucketMin restMin)

-- ============================================
-- DeliveredIds Bucket Helpers
-- ============================================
readDelivBucket : Int -> IO [DeliveredEntry]
readDelivBucket = \b ->
  if b == 0 then do s <- *delivBucket0; yield s else if b == 1 then do s <- *delivBucket1; yield s
  else if b == 2 then do s <- *delivBucket2; yield s else if b == 3 then do s <- *delivBucket3; yield s
  else if b == 4 then do s <- *delivBucket4; yield s else if b == 5 then do s <- *delivBucket5; yield s
  else if b == 6 then do s <- *delivBucket6; yield s else if b == 7 then do s <- *delivBucket7; yield s
  else if b == 8 then do s <- *delivBucket8; yield s else if b == 9 then do s <- *delivBucket9; yield s
  else if b == 10 then do s <- *delivBucket10; yield s else if b == 11 then do s <- *delivBucket11; yield s
  else if b == 12 then do s <- *delivBucket12; yield s else if b == 13 then do s <- *delivBucket13; yield s
  else if b == 14 then do s <- *delivBucket14; yield s else do s <- *delivBucket15; yield s

writeDelivBucket : Int -> [DeliveredEntry] -> IO ()
writeDelivBucket = \b entries ->
  if b == 0 then set *delivBucket0 = entries else if b == 1 then set *delivBucket1 = entries
  else if b == 2 then set *delivBucket2 = entries else if b == 3 then set *delivBucket3 = entries
  else if b == 4 then set *delivBucket4 = entries else if b == 5 then set *delivBucket5 = entries
  else if b == 6 then set *delivBucket6 = entries else if b == 7 then set *delivBucket7 = entries
  else if b == 8 then set *delivBucket8 = entries else if b == 9 then set *delivBucket9 = entries
  else if b == 10 then set *delivBucket10 = entries else if b == 11 then set *delivBucket11 = entries
  else if b == 12 then set *delivBucket12 = entries else if b == 13 then set *delivBucket13 = entries
  else if b == 14 then set *delivBucket14 = entries else set *delivBucket15 = entries

readAllDelivered : IO [DeliveredEntry]
readAllDelivered = do
  d0 <- *delivBucket0; d1 <- *delivBucket1; d2 <- *delivBucket2; d3 <- *delivBucket3
  d4 <- *delivBucket4; d5 <- *delivBucket5; d6 <- *delivBucket6; d7 <- *delivBucket7
  d8 <- *delivBucket8; d9 <- *delivBucket9; d10 <- *delivBucket10; d11 <- *delivBucket11
  d12 <- *delivBucket12; d13 <- *delivBucket13; d14 <- *delivBucket14; d15 <- *delivBucket15
  yield (unionNE d0 (unionNE d1 (unionNE d2 (unionNE d3 (unionNE d4 (unionNE d5 (unionNE d6 (unionNE d7 (unionNE d8 (unionNE d9 (unionNE d10 (unionNE d11 (unionNE d12 (unionNE d13 (unionNE d14 d15)))))))))))))))

writeAllDelivered : [DeliveredEntry] -> IO ()
writeAllDelivered = \entries -> do
  let p = fold (\acc e -> let b = pubkeyBucket e.toKey in
    {b0: if b == 0 then union [e] acc.b0 else acc.b0, b1: if b == 1 then union [e] acc.b1 else acc.b1,
     b2: if b == 2 then union [e] acc.b2 else acc.b2, b3: if b == 3 then union [e] acc.b3 else acc.b3,
     b4: if b == 4 then union [e] acc.b4 else acc.b4, b5: if b == 5 then union [e] acc.b5 else acc.b5,
     b6: if b == 6 then union [e] acc.b6 else acc.b6, b7: if b == 7 then union [e] acc.b7 else acc.b7,
     b8: if b == 8 then union [e] acc.b8 else acc.b8, b9: if b == 9 then union [e] acc.b9 else acc.b9,
     b10: if b == 10 then union [e] acc.b10 else acc.b10, b11: if b == 11 then union [e] acc.b11 else acc.b11,
     b12: if b == 12 then union [e] acc.b12 else acc.b12, b13: if b == 13 then union [e] acc.b13 else acc.b13,
     b14: if b == 14 then union [e] acc.b14 else acc.b14, b15: if b == 15 then union [e] acc.b15 else acc.b15})
    {b0: [], b1: [], b2: [], b3: [], b4: [], b5: [], b6: [], b7: [], b8: [], b9: [], b10: [], b11: [], b12: [], b13: [], b14: [], b15: []} entries
  writeDelivBucket 0 p.b0; writeDelivBucket 1 p.b1; writeDelivBucket 2 p.b2; writeDelivBucket 3 p.b3
  writeDelivBucket 4 p.b4; writeDelivBucket 5 p.b5; writeDelivBucket 6 p.b6; writeDelivBucket 7 p.b7
  writeDelivBucket 8 p.b8; writeDelivBucket 9 p.b9; writeDelivBucket 10 p.b10; writeDelivBucket 11 p.b11
  writeDelivBucket 12 p.b12; writeDelivBucket 13 p.b13; writeDelivBucket 14 p.b14; writeDelivBucket 15 p.b15

countAllDelivered : Int -> IO Int
countAllDelivered = \b -> if b > 15 then yield 0 else do
  bucket <- readDelivBucket b; rest <- countAllDelivered (b + 1); yield (count bucket + rest)

-- Per-bucket pruning for delivered entries (avoids readAllDelivered/writeAllDelivered repartitioning).
pruneAllDeliveredBuckets : Int -> Timestamp -> IO ()
pruneAllDeliveredBuckets = \b retainCutoff ->
  if b > 15 then yield {}
  else do
    atomic do
      bucket <- readDelivBucket b
      writeDelivBucket b (do d <- bucket; where d.deliveredAt > retainCutoff; yield d)
    pruneAllDeliveredBuckets (b + 1) retainCutoff

-- ============================================
-- Federation In-Flight Tracking
-- ============================================
-- Tracks outstanding federation fetches per server. Servers with hung requests
-- (older than federationFetchTimeoutMs) are skipped to prevent slot exhaustion.

markFederationInFlight = \server -> do
  t <- now
  atomic do
    inFlight <- *federationInFlight
    let existing = headOf (do r <- inFlight; where r.server == server; yield r)
    case existing of
      Nothing {} -> set *federationInFlight =
        let updated = union inFlight [{server: server, count: 1, firstStartedAt: t}] in
        if count updated > maxFederationInFlight then evictOneOldest updated (\r -> r.firstStartedAt) else updated
      Just {} -> set *federationInFlight = do r <- inFlight; yield (if r.server == server then {server: r.server, count: r.count + 1, firstStartedAt: r.firstStartedAt} else r)

clearFederationInFlight = \server -> atomic do
  inFlight <- *federationInFlight
  set *federationInFlight = do r <- inFlight; yield (if r.server == server then {server: r.server, count: max 0 (r.count - 1), firstStartedAt: if r.count <= 1 then 0 else r.firstStartedAt} else r)

hasHungFederationRequest : Text -> Timestamp -> [FederationInFlightEntry] -> Bool
hasHungFederationRequest = \server t inFlight ->
  any inFlight (\r -> r.server == server && r.count > 0 && r.firstStartedAt > 0 && t - r.firstStartedAt >= federationFetchTimeoutMs)

-- Wrapper around fetch for federation calls: tracks in-flight state, global connection count,
-- logs slow responses, and records latency metrics.
-- NOTE: If fetch panics (runtime error), in-flight and connection counters leak until
-- pruneExpired reclaims them (stale threshold: 1.5x federationFetchTimeoutMs). Knot
-- lacks try-finally, so this safety net in pruneExpired is the cleanup mechanism.
fetchFederation = \server request -> do
  -- Acquire global federation connection slot
  atomic do
    ac <- *federationActiveConnections
    set *federationActiveConnections = ac + 1
  markFederationInFlight server
  startTime <- now
  result <- fetch (federationUrl server) request
  clearFederationInFlight server
  -- Release global federation connection slot
  atomic do
    ac <- *federationActiveConnections
    set *federationActiveConnections = max 0 (ac - 1)
  endTime <- now
  let latency = endTime - startTime
  when (latency > federationFetchTimeoutMs)
    (logWarn ("federation: slow response from " ++ server ++ " (" ++ show latency ++ "ms)"))
  -- Skip latency recording during startup probes (unauthenticated, expected to fail)
  probing <- *startupProbeActive
  when (not probing) (atomic do
    total <- *federationLatencyTotal
    cnt <- *federationLatencyCount
    mx <- *federationLatencyMax
    set *federationLatencyTotal = total + latency
    set *federationLatencyCount = cnt + 1
    set *federationLatencyMax = if latency > mx then latency else mx
    -- Histogram bucket increment
    if latency < federationLatencyT1 then do b <- *federationLatencyBucket0; set *federationLatencyBucket0 = b + 1
    else if latency < federationLatencyT2 then do b <- *federationLatencyBucket1; set *federationLatencyBucket1 = b + 1
    else if latency < federationLatencyT3 then do b <- *federationLatencyBucket2; set *federationLatencyBucket2 = b + 1
    else do b <- *federationLatencyBucket3; set *federationLatencyBucket3 = b + 1
    -- Per-peer latency tracking
    peerLats <- *peerLatencies
    let peerEntry = headOf (do p <- peerLats; where p.server == server; yield p)
    let isNewWindow = case peerEntry of Nothing {} -> True {}; Just {value: p} -> endTime - p.windowStart >= federationLatencyWindowMs
    let updatedPeers = if isNewWindow
      then union (do p <- peerLats; where p.server != server; yield p) [{server: server, totalMs: latency, count: 1, maxMs: latency, windowStart: endTime}]
      else do p <- peerLats; yield (if p.server == server then {server: p.server, totalMs: p.totalMs + latency, count: p.count + 1, maxMs: max p.maxMs latency, windowStart: p.windowStart} else p)
    set *peerLatencies = if count updatedPeers > maxPeerLatencyEntries then evictOneOldest updatedPeers (\p -> p.windowStart) else updatedPeers)
  yield result

clampTtl : Int<S> -> Int<S>
clampTtl = clamp 1 maxPresenceTtl

clampTimestamp : Timestamp -> Timestamp -> Timestamp
clampTimestamp = \timestamp t -> clamp (t - messageMaxAge) t timestamp

-- Compute effective message TTL: 0 = server default, otherwise clamp to [minMessageTtl, unackedMessageMaxAge].
-- Returns the TTL in milliseconds to add to receivedAt for expiresAt.
-- Compute effective message TTL: 0 or negative = server default, otherwise clamp.
effectiveMessageTtl : Int<Ms> -> Int<Ms>
effectiveMessageTtl = \expiresInMs ->
  if expiresInMs <= 0 then unackedMessageMaxAge
  else clamp minMessageTtl unackedMessageMaxAge expiresInMs

-- Ensure strictly monotonic timestamps for message ordering
nextSeqTs : Timestamp -> Timestamp -> Timestamp
nextSeqTs = \t seqCounter -> if t > seqCounter then t else seqCounter + 1

-- Deduplicate message IDs, preserving order, capped at maxMessageIds.
-- O(n^2) due to `any acc` inside fold, but bounded by maxMessageIds = 100,
-- so worst case is 10,000 comparisons (acceptable for the hot path).
dedupMessageIds : [MessageIdHex] -> [MessageIdHex]
dedupMessageIds = \messageIds ->
  let capped = takeRelation maxMessageIds messageIds in
  fold (\acc mid ->
    if any acc (\a -> a == mid) then acc
    else union [mid] acc) [] capped


-- Constant-time comparison iteration count. Must be >= the longest secret
-- compared: session tokens are tokenHexLen (48) hex chars, but maintenance
-- secrets can be up to maxTokenLen (256) chars (validated by extractToken).
-- Using maxTokenLen + 16 ensures full comparison for all accepted inputs.
safeCompareLen = maxTokenLen + 16

-- Constant-time string comparison to prevent timing side-channels.
-- Always iterates safeCompareLen characters regardless of input length;
-- rejects empty strings. Tracks both character mismatches and length
-- mismatch (one string ended before the other) within the loop itself,
-- avoiding variable-time count(chars) calls that would leak string length.
safeCompareLoop : Text -> Text -> Int -> Int -> Int -> Int
safeCompareLoop = \s1 s2 n diff lenDiff ->
  if n <= 0
    then diff + lenDiff
    else
      let c1 = take 1 s1 in
      let c2 = take 1 s2 in
      let newDiff = diff + (if c1 == c2 then 0 else 1) in
      let endMismatch = if c1 == "" then (if c2 == "" then 0 else 1) else (if c2 == "" then 1 else 0) in
      safeCompareLoop (drop 1 s1) (drop 1 s2) (n - 1) newDiff (lenDiff + endMismatch)

safeCompare : Text -> Text -> Bool
safeCompare = \a b ->
  if take 1 a == "" || take 1 b == "" then False {}
  else safeCompareLoop a b safeCompareLen 0 0 == 0

-- Constant-time IP binding check: returns True if IPs match or no binding is configured.
-- When a session was created with an IP (behind a proxy), requests without an IP header
-- are rejected — prevents bypass if the proxy is removed mid-session.
-- Uses safeCompareLoop to prevent timing side-channels on IP comparison.
-- Uses maxIpLen (45) instead of maxServerNameLen (128) to avoid wasted iterations.
matchIp : Text -> Text -> Bool
matchIp = \clientIp sessionIp ->
  if sessionIp == "" then True {} -- no binding configured for this session
  else if clientIp == "" then False {} -- session has IP but request doesn't — proxy disappeared
  else safeCompareLoop clientIp sessionIp maxIpLen 0 0 == 0

-- Generic sliding-window rate limiter using the sliding window counter algorithm.
-- Instead of a fixed window that resets abruptly (allowing 2x burst at boundaries),
-- interpolates between the current and previous window's counts:
--   effectiveCount = prevCount * (1 - elapsed/windowMs) + count
-- This smoothly transitions between windows, preventing boundary bursts.
-- Callers provide match/create/update/rotate functions for their entry type.
-- Uses a direct fold for entry lookup (avoids materializing a filtered intermediate list).
checkRateWindow = \entries matchKey makeNew updateCount rotateWindow getCount getPrevCount maxRate windowMs maxEntries t ->
  let entry = fold (\acc r -> case acc of Just _ -> acc; Nothing {} -> if matchKey r then Just {value: r} else acc) Nothing {} entries in
  let isNewWindow = case entry of Nothing {} -> True {}; Just {value: r} -> t - r.windowStart >= windowMs in
  -- Sliding window interpolation: weight previous window's count by remaining fraction
  let elapsed = case entry of Nothing {} -> 0; Just {value: r} -> t - r.windowStart in
  let prevWeight = case entry of Nothing {} -> 0; Just {value: r} -> if isNewWindow then 0 else getPrevCount r * (windowMs - elapsed) / windowMs in
  let currentCount = case entry of Nothing {} -> 0; Just {value: r} -> if isNewWindow then 0 else getCount r in
  let effectiveCount = prevWeight + currentCount in
  if effectiveCount >= maxRate
    then let retryMs = case entry of Nothing {} -> windowMs; Just {value: r} -> max 0 (windowMs - elapsed)
      in {limited: True {}, entries: entries, retryAfterMs: retryMs}
    else
      let newEntries = if isNewWindow
        then let prevCount = case entry of Nothing {} -> 0; Just {value: r} -> getCount r
          in union (do r <- entries; where not (matchKey r); yield r) [rotateWindow (makeNew t) prevCount]
        else do r <- entries; yield (if matchKey r then updateCount r else r)
      in {limited: False {}, entries: if count newEntries > maxEntries then (do r <- newEntries; where t - r.windowStart < windowMs * 2; yield r) else newEntries, retryAfterMs: 0}

-- Rate limiter helpers: wrap common checkRateWindow patterns to reduce boilerplate.
-- Each returns {limited, entries, retryAfterMs} — caller reads/writes the mutable ref.
checkPubkeyRate = \rates pubkey maxRate windowMs maxEntries t ->
  checkRateWindow rates (\r -> r.pubkey == pubkey)
    (\ts -> {pubkey: pubkey, windowStart: ts, count: 1, prevCount: 0})
    (\r -> {pubkey: r.pubkey, windowStart: r.windowStart, count: r.count + 1, prevCount: r.prevCount})
    (\r pc -> {pubkey: r.pubkey, windowStart: r.windowStart, count: r.count, prevCount: pc})
    (\r -> r.count) (\r -> r.prevCount)
    maxRate windowMs maxEntries t

checkIpRate = \rates ip maxRate windowMs maxEntries t ->
  checkRateWindow rates (\r -> r.ip == ip)
    (\ts -> {ip: ip, windowStart: ts, count: 1, prevCount: 0})
    (\r -> {ip: r.ip, windowStart: r.windowStart, count: r.count + 1, prevCount: r.prevCount})
    (\r pc -> {ip: r.ip, windowStart: r.windowStart, count: r.count, prevCount: pc})
    (\r -> r.count) (\r -> r.prevCount)
    maxRate windowMs maxEntries t

checkServerRate = \rates server maxRate windowMs maxEntries t ->
  checkRateWindow rates (\r -> r.server == server)
    (\ts -> {server: server, windowStart: ts, count: 1, prevCount: 0})
    (\r -> {server: r.server, windowStart: r.windowStart, count: r.count + 1, prevCount: r.prevCount})
    (\r pc -> {server: r.server, windowStart: r.windowStart, count: r.count, prevCount: pc})
    (\r -> r.count) (\r -> r.prevCount)
    maxRate windowMs maxEntries t

checkPairRate = \rates sender recipient maxRate windowMs maxEntries t ->
  checkRateWindow rates (\r -> r.sender == sender && r.recipient == recipient)
    (\ts -> {sender: sender, recipient: recipient, windowStart: ts, count: 1, prevCount: 0})
    (\r -> {sender: r.sender, recipient: r.recipient, windowStart: r.windowStart, count: r.count + 1, prevCount: r.prevCount})
    (\r pc -> {sender: r.sender, recipient: r.recipient, windowStart: r.windowStart, count: r.count, prevCount: pc})
    (\r -> r.count) (\r -> r.prevCount)
    maxRate windowMs maxEntries t

-- Per-IP unique key rate check: tracks distinct pubkeys per IP per window.
-- Returns True if the IP has authenticated too many unique keys (key-rotation abuse).
checkUniqueKeyIpRate : [UniqueKeyIpEntry] -> Text -> PubkeyHex -> Timestamp -> {limited: Bool, entries: [UniqueKeyIpEntry]}
checkUniqueKeyIpRate = \entries ip pubkey t ->
  if ip == "" then {limited: False {}, entries: entries}
  else
    let entry = headOf (do r <- entries; where r.ip == ip; yield r) in
    let isNewWindow = case entry of Nothing {} -> True {}; Just {value: r} -> t - r.windowStart >= uniqueKeyIpWindowMs in
    if isNewWindow
      then {limited: False {}, entries: union (do r <- entries; where r.ip != ip; yield r) [{ip: ip, keys: [pubkey], windowStart: t}]}
      else case entry of
        Nothing {} -> {limited: False {}, entries: entries}
        Just {value: r} ->
          let alreadyTracked = any r.keys (\k -> k == pubkey) in
          if alreadyTracked then {limited: False {}, entries: entries}
          else if count r.keys >= maxUniqueKeysPerIp
            then {limited: True {}, entries: entries}
            else {limited: False {}, entries: do e <- entries; yield (if e.ip == ip then {ip: e.ip, keys: union [pubkey] e.keys, windowStart: e.windowStart} else e)}

checkServerRecipientRate = \rates server recipient maxRate windowMs maxEntries t ->
  checkRateWindow rates (\r -> r.server == server && r.recipient == recipient)
    (\ts -> {server: server, recipient: recipient, windowStart: ts, count: 1, prevCount: 0})
    (\r -> {server: r.server, recipient: r.recipient, windowStart: r.windowStart, count: r.count + 1, prevCount: r.prevCount})
    (\r pc -> {server: r.server, recipient: r.recipient, windowStart: r.windowStart, count: r.count, prevCount: pc})
    (\r -> r.count) (\r -> r.prevCount)
    maxRate windowMs maxEntries t

-- Extract the item with the smallest key and return both the item and remaining list
extractOldest = \items getKey ->
  fold (\acc x ->
    case acc.candidate of
      Nothing {} -> {candidate: Just {value: x}, items: acc.items}
      Just {value: c} ->
        if getKey x < getKey c
          then {candidate: Just {value: x}, items: union acc.items [c]}
          else {candidate: acc.candidate, items: union acc.items [x]}
    ) {candidate: Nothing {}, items: []} items

-- Remove the single item with the smallest key value (LRU-style eviction).
-- Single-pass: first fold finds the min key, second fold filters it out.
-- Two passes over the data but O(1) intermediate state (just the min key),
-- vs extractOldest which builds a full items list during the fold.
evictOneOldest = \items getKey ->
  let minResult = fold (\acc x -> case acc of
    Nothing {} -> Just {value: getKey x}
    Just {value: v} -> if getKey x < v then Just {value: getKey x} else acc) Nothing {} items
  in case minResult of
    Nothing {} -> items
    Just {value: minKey} ->
      let r = fold (\acc x ->
        if not acc.done && getKey x == minKey then {items: acc.items, done: True {}}
        else {items: union acc.items [x], done: acc.done}) {items: [], done: False {}} items
      in r.items

-- Remove the first item matching a predicate. O(n) single pass.
removeFirstMatch = \items pred ->
  let r = fold (\acc x ->
    if not acc.done && pred x then {items: acc.items, done: True {}}
    else {items: union acc.items [x], done: acc.done}
  ) {items: [], done: False {}} items
  in r.items

-- Remove the N items with the smallest key value.
-- Single-pass fold maintaining N candidates with smallest keys, then diff.
-- O(n*k) time — avoids the O(k*n²) cost of recursive extractOldest + list rebuilding.
evictSmallest = \items n getKey ->
  if n <= 0 then {kept: items, evicted: []}
  else if count items <= n then {kept: [], evicted: items}
  else
    let result = fold (\acc x ->
      if count acc.evict < n
        then {evict: union acc.evict [x], maxKey: if getKey x > acc.maxKey then getKey x else acc.maxKey}
        else if getKey x >= acc.maxKey then acc
        else
          let without = removeFirstMatch acc.evict (\e -> getKey e == acc.maxKey) in
          let newEvict = union without [x] in
          let newMax = fold (\m e -> if getKey e > m then getKey e else m) (getKey x) newEvict in
          {evict: newEvict, maxKey: newMax}
    ) {evict: [], maxKey: 0} items
    in {kept: diff items result.evict, evicted: result.evict}

-- Single-pass eviction by timestamp cutoff: keeps items where getKey >= cutoff.
-- O(n) vs O(n*k) for evictSmallest. Used for forward nonce eviction on the hot path.
evictByCutoff = \items cutoff getKey ->
  do x <- items; where getKey x >= cutoff; yield x

-- Evict nonces with fallback: first try expired-nonce eviction (O(n)), then if still
-- over capacity, evict oldest entries to create 5% headroom via evictSmallest.
-- Headroom prevents re-triggering eviction on the next insert: by evicting down to 95%
-- of maxCount, we amortize the O(n*k) evictSmallest cost across ~5% of capacity inserts
-- instead of paying it on every single insert when at the boundary.
-- Minimizes replay window: expired nonces are removed first (no window), and the
-- headroom-based fallback creates a bounded window proportional to the eviction count.
evictNonces = \items maxCount retention t ->
  let afterExpired = evictByCutoff items (t - retention) (\n -> n.seenAt) in
  if count afterExpired <= maxCount then afterExpired
  else let headroom = max 1 (maxCount / 20) in -- 5% headroom
       let evictCount = count afterExpired - maxCount + headroom in
       (evictSmallest afterExpired evictCount (\n -> n.seenAt)).kept

-- Enforce per-key capacity: if a key has >= maxPerKey items, evict the oldest for that key.
-- Also prunes expired items.
capPerKey = \items matchKey maxPerKey getExpiry t ->
  let active = do x <- items; where getExpiry x > t; yield x in
  let forKey = do x <- active; where matchKey x; yield x in
  if count forKey >= maxPerKey
    then let others = diff active forKey in
         union others (evictOneOldest forKey getExpiry)
    else active

-- Enforce global capacity: if at maxCount, evict the single oldest item
capGlobal = \items maxCount getKey ->
  if count items >= maxCount
    then evictOneOldest items getKey
    else items

-- Two-tier capacity enforcement: per-key first, then global
capPerKeyAndGlobal = \items matchKey maxPerKey getExpiry t maxGlobal ->
  capGlobal (capPerKey items matchKey maxPerKey getExpiry t) maxGlobal getExpiry

removeOneForKey = \items pubkey ->
  let forKey = do x <- items; where x.pubkey == pubkey; yield x in
  let others = do x <- items; where x.pubkey != pubkey; yield x in
  union others (evictOneOldest forKey (\x -> x.startedAt))

-- Extract unique remote (non-local) server names from a list of items.
-- O(n*k) where k = unique servers; acceptable since k is typically small (<20).
-- Knot lacks efficient set/map types, so fold-with-any is the best available approach.
-- NOTE: `union [s] acc` prepends (O(1) per step) vs `union acc [s]` which copies
-- acc (O(|acc|) per step). Since this is a set (order doesn't matter), prepend is
-- preferred for large collections. All set-accumulating folds use this pattern.
collectPeerServers : [a] -> (a -> Text) -> [Text]
collectPeerServers = \items getServer ->
  fold (\acc item ->
    let s = getServer item in
    if isLocalServer s then acc
    else if any acc (\a -> a == s) then acc
    else union [s] acc) [] items

samePubkeyServer = \a b -> a.pubkey == b.pubkey && a.server == b.server
pubkeyServer = \e -> {pubkey: e.pubkey, server: e.server}

-- Upsert items by key, keeping the fresher entry on conflict (last-write-wins by freshness).
-- union [e] filtered prepends (O(1)) vs union filtered [e] which copies filtered (O(|acc|)).
mergeByKey = \sameKey getFreshness initial items ->
  fold (\acc e ->
    if any acc (\a -> sameKey a e && getFreshness a >= getFreshness e)
      then acc
      else union [e]
        (do a <- acc; where not (sameKey a e); yield a)) initial items

-- Merge presence entries by (pubkey, server), keeping the one with the latest expiresAt.
-- Deterministic tiebreaker: when two entries for the same (pubkey, server) have equal
-- expiresAt, prefer the one with the lexicographically smaller server name. Without a
-- tiebreaker, the merge result depends on arrival order, causing presence oscillation
-- when two peers gossip the same pubkey simultaneously with the same expiry.
mergeByPubkeyServer = \initial items ->
  fold (\acc e ->
    if any acc (\a -> samePubkeyServer a e && (a.expiresAt > e.expiresAt || (a.expiresAt == e.expiresAt && a.server <= e.server)))
      then acc
      else union [e]
        (do a <- acc; where not (samePubkeyServer a e); yield a)) initial items

-- Keep entries from setA that are not superseded by a newer-timestamped entry in setB.
-- Deterministic tiebreaker: when timestamps are equal, the entry with the lexicographically
-- smaller server name wins (consistent with mergeByPubkeyServer).
resolveByTimestamp = \setA setB ->
  do e <- setA; where none setB (\o -> samePubkeyServer o e && (o.timestamp > e.timestamp || (o.timestamp == e.timestamp && o.server < e.server))); yield e

-- Remove presence entries that have a corresponding offline event with a newer timestamp
removeOffline = \presenceSet trustedOffline t ->
  diff presenceSet (do
    p <- presenceSet
    o <- trustedOffline
    where samePubkeyServer p o && min o.timestamp t > p.timestamp
    yield p)

-- Cap presence table after gossip merge. If over capacity, only allow updates to
-- existing entries and reclaim slots from expired ones for new entries.
capGossipPresence = \args ->
  if count args.afterOffline <= maxPresenceEntries
    then {finalPresence: args.afterOffline, appliedOnline: args.appliedOnline, withinCapacity: True {}}
    else
      let updatesOnly = existingPresenceUpdates args.trustedDeduped args.presence in
      let updatesOnlyMerged = mergeByPubkeyServer args.presence updatesOnly in
      let updatesOnlyAfterOffline = removeOffline updatesOnlyMerged args.trustedOffline args.t in
      let reclaimSlots = maxPresenceEntries - count updatesOnlyAfterOffline in
      let newEntries = newPresenceEntries args.trustedDeduped args.presence in
      let reclaimedEntries = takeRelation reclaimSlots newEntries in
      {finalPresence: union updatesOnlyAfterOffline reclaimedEntries,
       appliedOnline: union
        (appliedOnlineKeys updatesOnly args.presence)
        (do e <- reclaimedEntries; yield (pubkeyServer e)),
       withinCapacity: False {}}

hasMessage : MessageIdHex -> PubkeyHex -> [{messageId: MessageIdHex, toKey: PubkeyHex | a}] -> Bool
hasMessage = \mid toKey items -> any items (\x -> x.messageId == mid && x.toKey == toKey)

-- Validate incoming gossip events: reject local-server events, future timestamps,
-- and already-expired entries. Clamp TTLs and split into online/offline buckets.
-- Timestamp clamping: compute expiresAt from min(timestamp, now) instead of raw timestamp.
-- A peer can send timestamp close to t + clockSkewTolerance (within tolerance), which would
-- inflate effective presence lifetime by up to clockSkewTolerance ms. Clamping to now removes
-- this inflation: the peer's declared TTL is honored, but the expiry clock starts from now,
-- not from a future timestamp.
-- Filter seenBy entries to only known peers + ourselves. Unknown entries are dropped
-- to prevent gossip suppression attacks (a malicious peer injecting arbitrary server
-- names into seenBy to block propagation to those servers).
filterSeenBy : [Text] -> [Text] -> [Text]
filterSeenBy = \seenBy knownPeers ->
  do s <- seenBy; where s == serverHostN || any knownPeers (\p -> p == s); yield s

validGossipEvents : [GossipEvent] -> Timestamp -> {online: [ValidGossipEntry], offline: [ValidGossipEntry]}
validGossipEvents = \events t ->
  let validate = \e ->
    if not (isLocalServer e.server) && e.timestamp <= t + clockSkewTolerance
      then let ttl = clampTtl e.ttl in
           let effectiveTs = min e.timestamp t in
           let expiresAt = effectiveTs + ttl * 1000 in
           if expiresAt > t
             then [{pubkey: e.pubkey, server: e.server, expiresAt: expiresAt, timestamp: e.timestamp, ttl: ttl}]
             else []
      else []
  in fold (\acc e ->
    case e.eventType of
      GossipOnline {} -> {online: union acc.online (validate e), offline: acc.offline}
      GossipOffline {} -> {online: acc.online, offline: union acc.offline (validate e)}
      _ -> acc) {online: [], offline: []} events

-- Execute an action for each server, forking up to maxFederationConcurrency
-- and processing the remainder sequentially to bound resource usage.
sendToEach : [ServerName] -> (ServerName -> (a {})) -> a {}
sendToEach = \servers action -> sendToEachN servers action maxFederationConcurrency

sendToEachN = \servers action remaining ->
  case headOf servers of
    Nothing {} -> yield {}
    Just {value: server} -> do
      let rest = do s <- servers; where s != server; yield s
      -- Check global federation connection cap: fall back to sequential when at limit
      globalActive <- *federationActiveConnections
      let effectiveRemaining = if globalActive >= maxGlobalFederationConcurrency then 0 else remaining
      if effectiveRemaining > 0
        then do
          fork (action server)
          sendToEachN rest action (effectiveRemaining - 1)
        else do
          action server
          sendToEachN rest action 0

-- Per-bucket presence pruning: prune a single presence bucket atomically.
-- Returns expired local entries (for offline gossip), peer servers in kept entries,
-- all peer servers (before pruning), and count of removed entries.
prunePresenceBucketN = \b t -> atomic do
  bucket <- readPresenceBucket b
  let kept = do x <- bucket; where x.expiresAt > t; yield x
  let expired = do x <- bucket; where x.expiresAt <= t; yield x
  -- Expired local entries: only those without a surviving local presence entry for the same key
  -- (all entries for a pubkey live in the same bucket, so this per-bucket check is complete)
  let expiredLocal = do x <- expired; where isLocalServer x.server && none kept (\k -> k.pubkey == x.pubkey && isLocalServer k.server); yield x
  writePresenceBucket b kept
  yield {expiredLocal: expiredLocal, keptPeerServers: collectPeerServers kept (\p -> p.server), allPeerServers: collectPeerServers bucket (\p -> p.server), removedCount: count expired}

-- Recursively prune all 16 presence buckets and aggregate results.
-- Collects raw server lists from each bucket; deduplication is done once
-- at the end by the caller (pruneExpired) to avoid O(n*k) per-bucket merges.
prunePresenceBuckets = \b t ->
  if b > 15 then yield {expiredLocal: [], keptPeerServers: [], allPeerServers: [], totalRemoved: 0}
  else do
    r <- prunePresenceBucketN b t
    rest <- prunePresenceBuckets (b + 1) t
    yield {expiredLocal: union r.expiredLocal rest.expiredLocal,
           keptPeerServers: union r.keptPeerServers rest.keptPeerServers,
           allPeerServers: union r.allPeerServers rest.allPeerServers,
           totalRemoved: r.removedCount + rest.totalRemoved}

-- Remove all expired entries from every collection. Returns expired local presence
-- entries (for broadcasting offline gossip) and the set of peer servers known before pruning.
pruneExpired = \t -> do
  -- Prune presence per-bucket (16 smaller atomic blocks instead of one large one).
  -- Each bucket is independent: all entries for a pubkey hash to the same bucket,
  -- so per-bucket before/after comparison is equivalent to the global check.
  presenceResults <- prunePresenceBuckets 0 t
  -- Dedup peer servers once after collecting from all 16 buckets (O(n) total
  -- vs O(n*k) if deduped per-bucket during aggregation).
  let dedupServers = \servers -> fold (\acc s -> if any acc (\x -> x == s) then acc else union [s] acc) [] servers
  let keptPeers = dedupServers presenceResults.keptPeerServers
  let allPeers = dedupServers presenceResults.allPeerServers
  atomic do
    tpc <- *totalPresenceCount
    set *totalPresenceCount = max 0 (tpc - presenceResults.totalRemoved)
    set *knownPeerServers = keptPeers
    when (presenceResults.totalRemoved > 0) (set *presenceVersion = t)
  let presenceResult = {expiredLocal: presenceResults.expiredLocal, peerServers: allPeers}
  -- Prune auth state (challenges in their own block; sessions counted during transform)
  atomic do
    challenges <- *challenges
    set *challenges = do x <- challenges; where x.expiresAt > t; yield x
  -- Prune sessions and count in a single pass (avoids redundant 16-bucket traversal).
  -- pruneAndCountAllSessions applies the filter to each bucket and sums the survivors.
  sessionCount <- pruneAndCountAllSessions (\bucket -> do x <- bucket; where x.expiresAt > t && t - x.createdAt < maxSessionLifetime; yield x)
  atomic do
    set *totalSessionCount = sessionCount
  -- Prune messages across all 16 buckets concurrently. Each bucket prune is atomic
  -- and touches only its own message bucket + rcBucket. The only shared write is
  -- *totalMessageCount (a single Int), so STM contention is minimal.
  -- Fork first 15 buckets; run the last one in the foreground to bound concurrency.
  -- Uses per-message expiresAt instead of a global cutoff, so sender-specified TTLs
  -- are respected during pruning.
  pruneMessageBucketsConcurrent 0 t
  -- Prune federation state (split into per-collection blocks to reduce lock contention
  -- with poll-ack paths that write to ackedIds/deliveredIds concurrently).
  let retainCutoff = t - messageMaxAge
  -- Forwards: per-bucket pruning (same pattern as acked/delivered).
  -- Each bucket is pruned in its own atomic block to reduce lock contention
  -- with sendMessageCore which writes to forward buckets on the hot path.
  fwdSurvivorCount <- pruneAllFwdBuckets 0 retainCutoff federationEnabled 0
  atomic do set *totalForwardCount = fwdSurvivorCount
  -- Cache forward queue stale count after pruning (forward buckets are clean now).
  -- Health checks read this cached value instead of scanning all 16 buckets each time.
  fwdStale <- countStaleForwardServers 0 t []
  atomic do set *cachedForwardStaleCount = fwdStale
  -- AckedIds: per-bucket pruning (each bucket in its own atomic block to reduce lock
  -- contention with poll-ack paths that write to ackedIds concurrently).
  pruneAllAckedBuckets 0 retainCutoff
  -- DeliveredIds: per-bucket pruning (same pattern as acked)
  pruneAllDeliveredBuckets 0 retainCutoff
  -- Overflow + failures: smaller collections, grouped together.
  -- Stale peer cleanup: servers still in knownPeerServers (have active presence) keep
  -- their failure records for the full maxServerDowntime (24h). Servers with no presence
  -- are pruned aggressively after 1h — they have no local keys to forward to and their
  -- failure records just inflate circuit breaker counts.
  atomic do
    forwardFailures <- *forwardFailures
    peers <- *knownPeerServers
    let isKnown = \server -> any peers (\p -> p == server)
    set *forwardFailures = do f <- forwardFailures; where (if isKnown f.server then t - f.failedAt < maxServerDowntime else t - f.failedAt < sessionExpiry); yield f
    ackOverflow <- *ackOverflow
    set *ackOverflow = do a <- ackOverflow; where a.ackedAt > retainCutoff; yield a
  -- Prune rate limiters (split into smaller atomic blocks to reduce lock contention).
  -- Retention is 2x windowMs because the sliding window algorithm uses prevCount from the
  -- previous window for interpolation. Pruning at 1x windowMs discards prevCount prematurely,
  -- allowing a brief 2x burst at the next window boundary — the exact problem sliding windows
  -- solve. The entry rotates to a new window (resetting count, storing prevCount) at 1x; the
  -- old prevCount is only irrelevant after 2x when the new window itself rotates.
  atomic do
    sendRates <- *sendRates
    set *sendRates = do r <- sendRates; where t - r.windowStart < sendRateWindowMs * 2; yield r
    challengeRates <- *challengeRates
    set *challengeRates = do r <- challengeRates; where t - r.windowStart < challengeRateWindowMs * 2; yield r
    revokeRates <- *revokeRates
    set *revokeRates = do r <- revokeRates; where t - r.windowStart < revokeRateWindowMs * 2; yield r
    recvRates <- *recvRates
    set *recvRates = do r <- recvRates; where t - r.windowStart < recvRateWindowMs * 2; yield r
    pairRates <- *pairRates
    set *pairRates = do r <- pairRates; where t - r.windowStart < pairRateWindowMs * 2; yield r
    -- Reset auth-tier global rate window
    authWS <- *authGlobalRateWindowStart
    when (t - authWS >= authGlobalRateWindowMs) (do
      set *authGlobalRateWindowStart = t
      set *authGlobalRateCount = 0)
    -- Reset health rate window
    healthWS <- *healthRateWindowStart
    when (t - healthWS >= healthRateWindowMs) (do
      set *healthRateWindowStart = t
      set *healthRateCount = 0)
  atomic do
    federationRates <- *federationRates
    set *federationRates = do r <- federationRates; where t - r.windowStart < federationRateWindowMs * 2; yield r
    federationPairRates <- *federationPairRates
    set *federationPairRates = do r <- federationPairRates; where t - r.windowStart < federationPairRateWindowMs * 2; yield r
    ipRates <- *ipRates
    set *ipRates = do r <- ipRates; where t - r.windowStart < ipRateWindowMs * 2; yield r
    lookupRates <- *lookupRates
    set *lookupRates = do r <- lookupRates; where t - r.windowStart < lookupRateWindowMs * 2; yield r
    clientWriteRates <- *clientWriteRates
    set *clientWriteRates = do r <- clientWriteRates; where t - r.windowStart < clientWriteRateWindowMs * 2; yield r
    verifyIpRates <- *verifyIpRates
    set *verifyIpRates = do r <- verifyIpRates; where t - r.windowStart < verifyRateWindowMs * 2; yield r
    uniqueKeyIpRates <- *uniqueKeyIpRates
    set *uniqueKeyIpRates = do r <- uniqueKeyIpRates; where t - r.windowStart < uniqueKeyIpWindowMs * 2; yield r
  atomic do
    activePolls <- *activePolls
    effPollTimeout <- effectivePollTimeoutMs
    set *activePolls = do p <- activePolls; where t - p.startedAt < effPollTimeout * 3; yield p
    recentGossip <- *recentGossip
    set *recentGossip = do r <- recentGossip; where t - r.seenAt < gossipDedupWindow; yield r
    -- Clean up stale in-flight entries: remove zeroed entries and reset leaked slots
    -- where the forked task died without calling clearFederationInFlight.
    -- Uses 1.25x timeout threshold so leaked slots are reclaimed promptly
    -- after the skip-hung-server logic (at 1x) has already taken effect.
    -- Tighter than the original 1.5x to reduce the window where panicked
    -- fetches hold federation slots hostage.
    inFlight <- *federationInFlight
    let staleThreshold = federationFetchTimeoutMs * 5 / 4
    let staleInFlight = do r <- inFlight; where r.count > 0 && r.firstStartedAt > 0 && t - r.firstStartedAt >= staleThreshold; yield r
    when (count staleInFlight > 0) (do
      logWarn ("pruneExpired: cleaning " ++ show (count staleInFlight) ++ " stale in-flight entries (leaked slots)")
      -- Per-server detail for debugging hung connections: log which peers are stuck and for how long
      logStaleInFlight staleInFlight t)
    -- Also warn about connections approaching the stale threshold (early detection)
    let hungThreshold = federationFetchTimeoutMs
    let hungInFlight = do r <- inFlight; where r.count > 0 && r.firstStartedAt > 0 && t - r.firstStartedAt >= hungThreshold && t - r.firstStartedAt < staleThreshold; yield r
    when (count hungInFlight > 0)
      (logEvent "warn" "hung_federation" ("connections approaching stale threshold: " ++ show (count hungInFlight) ++ " slots"))
    set *federationInFlight = do r <- inFlight; where r.count > 0 && (r.firstStartedAt == 0 || t - r.firstStartedAt < staleThreshold); yield r
    -- Prune stale federation replay dedup entries
    recentFedReqs <- *recentFederationRequests
    set *recentFederationRequests = do r <- recentFedReqs; where t - r.seenAt < clockSkewTolerance * 2; yield r
    -- Prune expired federation verification tokens
    pending <- *pendingVerifications
    set *pendingVerifications = do p <- pending; where t - p.createdAt < verificationTokenExpiry; yield p
    -- Prune expired peer public key cache entries
    peerKeys <- *peerPublicKeys
    set *peerPublicKeys = do k <- peerKeys; where t - k.fetchedAt < peerKeyTtlMs; yield k
    -- Prune expired forward nonces (round-robin: 4 of 16 buckets per cycle)
    pruneNonceBucketsRoundRobin t
    -- Prune gossip event rate entries
    gossipEventRates <- *gossipEventRates
    set *gossipEventRates = do r <- gossipEventRates; where t - r.windowStart < gossipEventRateWindowMs * 2; yield r
    -- Prune stale deferred ack cleanups (older than messageMaxAge are never useful)
    pendingCleanups <- *pendingAckCleanups
    set *pendingAckCleanups = do c <- pendingCleanups; where t - c.cleanupAfter < messageMaxAge; yield c
    -- Prune old pending federation cancel entries (same retention as other dedup state)
    pendingCancels <- *pendingFederationCancels
    set *pendingFederationCancels = do c <- pendingCancels; where t - c.createdAt < messageMaxAge; yield c
    -- Prune old sender expiration notifications. Uses unackedMessageMaxAge (7 days)
    -- instead of sessionExpiry (1 hour) so mobile clients that don't poll for days
    -- still receive expiration notifications on their next poll.
    senderExp <- *senderExpirations
    set *senderExpirations = do e <- senderExp; where t - e.expiredAt < unackedMessageMaxAge; yield e
    -- Prune old sender delivery receipts (same retention as expirations)
    senderDel <- *senderDeliveries
    set *senderDeliveries = do d <- senderDel; where t - d.deliveredAt < unackedMessageMaxAge; yield d
    -- Prune old cancel notifications (same retention as delivery receipts)
    cancelNotifs <- *cancelNotifications
    set *cancelNotifications = do c <- cancelNotifs; where t - c.cancelledAt < unackedMessageMaxAge; yield c
    -- Prune stale per-sender drop counters. Without this, drop counters for senders who
    -- disconnect permanently persist until capacity eviction pushes them out. Same retention
    -- as delivery receipts since drop counters track lost receipts/expirations.
    ddr <- *droppedDeliveryReceipts
    set *droppedDeliveryReceipts = do d <- ddr; where t - d.lastUpdated < unackedMessageMaxAge; yield d
    den <- *droppedExpirationNotifs
    set *droppedExpirationNotifs = do d <- den; where t - d.lastUpdated < unackedMessageMaxAge; yield d
    -- Reconcile global federation connection counter with actual in-flight state
    -- (self-heals drift from leaked slots where a forked task died without decrementing)
    inFlightRec <- *federationInFlight
    set *federationActiveConnections = fold (\acc r -> acc + r.count) 0 inFlightRec
  yield presenceResult


-- Skip the first N items of a list (list equivalent of Text's drop).
-- O(n) single pass: fold counts items and only starts accumulating after N.
skipRelation = \n items ->
  let r = fold (\acc e ->
    if acc.skipped < n then {skipped: acc.skipped + 1, result: acc.result}
    else {skipped: acc.skipped, result: union acc.result [e]})
    {skipped: 0, result: []} items
  in r.result

splitAtN = \items n ->
  fold (\acc e ->
    if acc.n < n then {n: acc.n + 1, batch: union acc.batch [e], rest: acc.rest}
    else {n: acc.n, batch: acc.batch, rest: union acc.rest [e]})
    {n: 0, batch: [], rest: []} items

forEachBatch = \items batchSize process ->
  if count items == 0 then yield {}
  else do
    let split = splitAtN items batchSize
    process split.batch
    forEachBatch split.rest batchSize process

sendBatchedGossipToServer : ServerName -> [GossipEvent] -> Int -> IO {network} {}
sendBatchedGossipToServer = \server allEvents hops -> do
  -- Check backoff before sending: skip servers that recently failed (same backoff as forwards).
  -- Without this, gossip to a dead peer generates unbounded log spam every refresh cycle.
  t0 <- now
  failures <- *forwardFailures
  inFlight <- *federationInFlight
  blocked <- *blockedPeers
  if not (shouldRetryServerEx server t0 failures inFlight blocked) then yield {}
  else do
  -- Filter out events this server has already seen (via seenBy tracking).
  -- Add ourselves and the target server to seenBy so downstream relays skip both.
  -- Cap seenBy at maxSeenByLen and filter to known peers (defense-in-depth against spoofed seenBy).
  knownPeersForSeen <- *knownPeerServers
  let unseen = do e <- allEvents; where none e.seenBy (\s -> s == server); yield {eventType: e.eventType, pubkey: e.pubkey, server: e.server, timestamp: e.timestamp, ttl: e.ttl, seenBy: filterSeenBy (takeRelation maxSeenByLen (union e.seenBy [server])) knownPeersForSeen}
  if count unseen == 0 then yield {}
  else forEachBatch unseen maxGossipEvents (\batch -> do
    t <- now
    auth <- generateFederationAuth "gossip" t
    corrId <- genTokenN 1
    result <- fetchFederation server (RecvGossip {
      authorization: auth,
      events: batch, hopsRemaining: hops, fromServer: serverHostN,
      requestTimestamp: t, correlationId: corrId, protocolVersion: federationProtocolVersion})
    case result of
      Err e -> do
        logWarn ("federation: gossip to " ++ server ++ " failed: " ++ show e)
        recordFailure server
        atomic do gs <- *gossipSendFail; set *gossipSendFail = gs + 1
      Ok _ -> do
        clearFailure server
        atomic do gs <- *gossipSendSuccess; set *gossipSendSuccess = gs + 1)

-- Sends gossip events to each peer server. Per-server seenBy filtering happens inside
-- sendBatchedGossipToServer: if all events for a server are already in its seenBy list,
-- the function returns immediately without making an HTTP call. Pre-filtering the target
-- list here would save only function call overhead and complicate the seenBy set logic
-- (seenBy is per-event, not per-batch), so we rely on the per-server early-exit instead.
sendBatchedGossip : [ServerName] -> [GossipEvent] -> Int -> IO {network} {}
sendBatchedGossip = \peerServers allEvents hops ->
  sendToEach peerServers (\server -> sendBatchedGossipToServer server allEvents hops)

broadcastOfflineGossip = \t peerServers expiredLocal ->
  when (federationEnabled && count peerServers > 0 && count expiredLocal > 0) (do
    failures <- *forwardFailures
    if isFederationCircuitOpen failures t
      then logWarn ("federation: circuit breaker open, skipping offline gossip broadcast")
      else do
    let cappedExpired = takeRelation maxPresenceEntries expiredLocal
    when (count expiredLocal > maxPresenceEntries)
      (logWarn ("gossip: capped offline broadcast to " ++ show maxPresenceEntries ++ " entries (had " ++ show (count expiredLocal) ++ ")"))
    let gossipEvents = mergeByKey (\a b -> a.pubkey == b.pubkey) (\x -> x.timestamp) [] (offlineGossipEvents cappedExpired)
    sendBatchedGossip peerServers gossipEvents gossipOriginHops)


-- Build re-broadcast gossip events from validated entries. The seenBy list includes
-- the fromServer (who sent us these events) and ourselves (serverHostN), so downstream
-- peers that already have this gossip via either path won't receive it again.
-- Optimization: pre-extract unique pubkeys from appliedKeys for a fast-path rejection.
-- Entries whose pubkey doesn't appear in any appliedKey skip the full samePubkeyServer
-- check (two-field comparison). Helps when entries contain many pubkeys not in appliedKeys.
effectiveGossipEvents = \entries appliedKeys eventType seenBy ->
  let appliedPubkeys = fold (\acc a -> if any acc (\p -> p == a.pubkey) then acc else union [a.pubkey] acc) [] appliedKeys
  in do
    e <- entries
    where any appliedPubkeys (\pk -> pk == e.pubkey)
    where any appliedKeys (\a -> samePubkeyServer a e)
    yield {eventType: eventType, pubkey: e.pubkey, server: e.server, timestamp: e.timestamp, ttl: e.ttl, seenBy: seenBy}

mergeGossipPresence = \presence deduped trustedOffline fromServer t ->
  let trustedDeduped = trustedGossipEntries deduped presence fromServer t in
  let appliedOnline = appliedOnlineKeys trustedDeduped presence in
  let merged = mergeByPubkeyServer presence trustedDeduped in
  let afterOffline = removeOffline merged trustedOffline t in
  let appliedOffline = do p <- diff merged afterOffline; yield (pubkeyServer p) in
  let capResult = capGossipPresence {afterOffline: afterOffline, appliedOnline: appliedOnline, trustedDeduped: trustedDeduped, presence: presence, trustedOffline: trustedOffline, t: t} in
  {finalPresence: capResult.finalPresence,
   appliedKeys: union capResult.appliedOnline appliedOffline,
   gossipPeerServers: collectPeerServers capResult.finalPresence (\p -> p.server),
   withinCapacity: capResult.withinCapacity}


-- Adaptive rate limiting: scale rate limits down when the server is under heavy load.
-- Returns a scaling factor from 0 to 100 (percentage of full rate to allow).
-- 100% at <=80% utilization, linearly decreasing to 10% at 100% utilization.
-- Uses the highest utilization across messages, sessions, and presence as the
-- bottleneck metric. 10% floor prevents complete lockout (admin can still act).
adaptiveRateScale : Int -> Int -> Int -> Int
adaptiveRateScale = \msgCount sessCount presCount ->
  let msgPct = if maxMessages > 0 then msgCount * 100 / maxMessages else 0 in
  let sessPct = if maxSessions > 0 then sessCount * 100 / maxSessions else 0 in
  let presPct = if maxPresenceEntries > 0 then presCount * 100 / maxPresenceEntries else 0 in
  let peak = max msgPct (max sessPct presPct) in
  if peak <= 80 then 100
  else max 10 (100 - (peak - 80) * 90 / 20)

-- Apply adaptive scaling to a base rate limit. Reads cached counters (O(1), no bucket scans)
-- and scales the rate proportionally. Returns at least 1 to prevent division-by-zero in callers.
-- Apply adaptive scaling to a base rate limit. Reads cached scale factor (O(1), updated
-- every prune cycle) instead of 3 counter reads per call. Returns at least 1 to prevent
-- division-by-zero in callers.
adaptiveRate : Int -> IO Int
adaptiveRate = \baseRate -> do
  scale <- *cachedAdaptiveScale
  let effectiveScale = if scale <= 0 then 100 else scale
  yield (max 1 (baseRate * effectiveScale / 100))

-- Effective rate limit readers: return runtime override if set (> 0), else compile-time default.
-- All per-key and global rates are scaled by adaptiveRate under high utilization.
effectiveGlobalRequestRate = do
  o <- *rateOverrideGlobalRequest
  adaptiveRate (if o > 0 then o else maxGlobalRequestRate)

effectiveIpRate = do
  o <- *rateOverrideIpRate
  adaptiveRate (if o > 0 then o else maxIpRatePerIp)

effectiveSendRate = do
  o <- *rateOverrideSendRate
  adaptiveRate (if o > 0 then o else maxSendRatePerKey)

effectiveFederationRate = do
  o <- *rateOverrideFederationRate
  -- Federation rates are NOT adaptively scaled: throttling federation under load
  -- prevents ack delivery, causing origin servers to retry (amplification loop).
  yield (if o > 0 then o else maxFederationRatePerServer)

effectiveAuthGlobalRate = do
  o <- *rateOverrideAuthGlobal
  adaptiveRate (if o > 0 then o else maxAuthGlobalRate)

effectiveRecvRate = do
  o <- *rateOverrideRecvRate
  adaptiveRate (if o > 0 then o else maxRecvRatePerKey)

effectiveChallengeRate = do
  o <- *rateOverrideChallengeRate
  adaptiveRate (if o > 0 then o else maxChallengeRatePerKey)

effectivePairRate = do
  o <- *rateOverridePairRate
  adaptiveRate (if o > 0 then o else maxPairRatePerPair)

effectiveLookupRate = do
  o <- *rateOverrideLookupRate
  adaptiveRate (if o > 0 then o else maxLookupRatePerKey)

effectiveClientWriteRate = do
  o <- *rateOverrideClientWriteRate
  adaptiveRate (if o > 0 then o else maxClientWriteRatePerKey)

-- Effective operational parameter readers: return runtime override if set (> 0), else compile-time default.
-- These are NOT adaptively scaled (they are capacity limits, not rate limits).
effectiveMaxMessagesPerRecipient = do
  o <- *configOverrideMaxMessagesPerRecipient
  yield (if o > 0 then o else maxMessagesPerRecipient)

effectiveMaxGossipHops = do
  o <- *configOverrideMaxGossipHops
  yield (if o > 0 then o else maxGossipHops)

effectivePollTimeoutMs = do
  o <- *configOverridePollTimeoutMs
  yield (if o > 0 then o else pollTimeoutMs)

checkFederationRate = \server t -> atomic do
  federationRates <- *federationRates
  fedRate <- effectiveFederationRate
  let result = checkServerRate federationRates server fedRate federationRateWindowMs maxFederationRateEntries t
  set *federationRates = result.entries
  when result.limited (do
    rlf <- *rateLimitedFederation
    set *rateLimitedFederation = rlf + 1)
  yield result.limited

checkGlobalRate = \t -> atomic do
  windowStart <- *globalRateWindowStart
  rateCount <- *globalRateCount
  prevCount <- *globalRatePrevCount
  effectiveRate <- effectiveGlobalRequestRate
  let elapsed = t - windowStart
  if elapsed >= globalRateWindowMs
    then do
      set *globalRateWindowStart = t
      set *globalRatePrevCount = rateCount
      set *globalRateCount = 1
      yield (False {})
    else do
      -- Sliding window: interpolate previous window's count
      let prevWeight = prevCount * (globalRateWindowMs - elapsed) / globalRateWindowMs
      if prevWeight + rateCount >= effectiveRate
        then do
          rlg <- *rateLimitedGlobal
          set *rateLimitedGlobal = rlg + 1
          yield (True {})
        else do
          set *globalRateCount = rateCount + 1
          yield (False {})

-- Auth-tier global rate limiting (shared budget for challenge + verify + revoke)
checkAuthGlobalRate = \t -> atomic do
  windowStart <- *authGlobalRateWindowStart
  rateCount <- *authGlobalRateCount
  prevCount <- *authGlobalRatePrevCount
  authRate <- effectiveAuthGlobalRate
  let elapsed = t - windowStart
  if elapsed >= authGlobalRateWindowMs
    then do
      set *authGlobalRateWindowStart = t
      set *authGlobalRatePrevCount = rateCount
      set *authGlobalRateCount = 1
      yield (False {})
    else do
      let prevWeight = prevCount * (authGlobalRateWindowMs - elapsed) / authGlobalRateWindowMs
      if prevWeight + rateCount >= authRate
        then do
          rla <- *rateLimitedAuth
          set *rateLimitedAuth = rla + 1
          yield (True {})
        else do
          set *authGlobalRateCount = rateCount + 1
          yield (False {})

-- Health endpoint rate limiting (separate from global rate so monitoring doesn't starve real requests)
checkHealthRate = \t -> atomic do
  windowStart <- *healthRateWindowStart
  rateCount <- *healthRateCount
  prevCount <- *healthRatePrevCount
  let elapsed = t - windowStart
  if elapsed >= healthRateWindowMs
    then do
      set *healthRateWindowStart = t
      set *healthRatePrevCount = rateCount
      set *healthRateCount = 1
      yield (False {})
    else do
      let prevWeight = prevCount * (healthRateWindowMs - elapsed) / healthRateWindowMs
      if prevWeight + rateCount >= maxHealthRate
        then yield (True {})
        else do
          set *healthRateCount = rateCount + 1
          yield (False {})

-- IP-based rate limiting; skips if clientIp header is empty (no reverse proxy)
checkClientIpRate = \ip t ->
  if ip == "" then yield (False {})
  else atomic do
    ipRates <- *ipRates
    ipRate <- effectiveIpRate
    let result = checkIpRate ipRates ip ipRate ipRateWindowMs maxIpRateEntries t
    set *ipRates = result.entries
    when result.limited (do
      rli <- *rateLimitedIp
      set *rateLimitedIp = rli + 1)
    yield result.limited

-- Combined pre-auth gate: drain check, global rate, IP rate. Returns "" if all pass.
-- Blocks at drainPhase >= 1 (soft drain blocks new auth; existing sessions still work).
checkPreAuth = \clientIp t -> do
  dp <- *drainPhase
  if dp >= 1 then yield "draining"
  else do
    globalLimited <- checkGlobalRate t
    if globalLimited then yield "global_rate_limited"
    else do
      ipLimited <- checkClientIpRate clientIp t
      if ipLimited then yield "ip_rate_limited"
      else yield ""

-- ============================================
-- Ed25519 Federation Signing
-- ============================================
-- When serverFederationPrivateKeyHex is configured, outbound federation requests are
-- signed with Ed25519 instead of using random tokens + verify callbacks. Inbound
-- requests with "Signed" auth are verified locally using the sender's cached public key.
-- "Bearer" auth falls back to the existing verify callback for backward compatibility.

-- GET /federation/pubkey: Return this server's Ed25519 federation public key.
-- Unauthenticated. Rate-limited via health rate limiter (same as /ready).
handleFederationPubkey = \respond -> do
  t <- now
  healthLimited <- checkHealthRate t
  if healthLimited then yield (respond {pubkey: "", ok: False {}})
  else yield (respond {pubkey: serverFederationPublicKeyHex, ok: serverFederationPublicKeyHex != ""})

-- Fetch and cache a peer's Ed25519 public key for signature verification.
-- Returns the hex-encoded public key, or "" if unavailable.
-- Checks cache first (peerKeyTtlMs TTL), fetches from /federation/pubkey on miss.
-- Enforces peerKeyRefetchCooldownMs between re-fetch attempts to prevent DoS.
fetchPeerPublicKey : Text -> Timestamp -> IO {network} Text
fetchPeerPublicKey = \server t -> do
  cached <- atomic do
    keys <- *peerPublicKeys
    yield (headOf (do k <- keys; where k.server == server; yield k))
  case cached of
    Just {value: entry} ->
      if t - entry.fetchedAt < peerKeyTtlMs && entry.pubkey != ""
        then yield entry.pubkey
        else if entry.failedAt > 0 && t - entry.failedAt < peerKeyRefetchCooldownMs
          then yield ""
          else fetchAndCachePeerKey server t
    Nothing {} -> fetchAndCachePeerKey server t

-- Fetch a peer's public key from /federation/pubkey and cache the result.
-- On failure, caches the failure timestamp to enforce cooldown.
fetchAndCachePeerKey : Text -> Timestamp -> IO {network} Text
fetchAndCachePeerKey = \server t -> do
  result <- fetchFederation server (FederationPubkey {})
  case result of
    Err e -> do
      logWarn ("federation: pubkey fetch from " ++ server ++ " failed: " ++ show e)
      atomic do
        keys <- *peerPublicKeys
        let updated = union (do k <- keys; where k.server != server; yield k) [{server: server, pubkey: "", fetchedAt: t, failedAt: t}]
        set *peerPublicKeys = if count updated > maxPeerPublicKeys then evictOneOldest updated (\k -> k.fetchedAt) else updated
      yield ""
    Ok r ->
      if r.ok && r.pubkey != "" then do
        atomic do
          keys <- *peerPublicKeys
          let updated = union (do k <- keys; where k.server != server; yield k) [{server: server, pubkey: r.pubkey, fetchedAt: t, failedAt: 0}]
          set *peerPublicKeys = if count updated > maxPeerPublicKeys then evictOneOldest updated (\k -> k.fetchedAt) else updated
        yield r.pubkey
      else do
        atomic do
          keys <- *peerPublicKeys
          let updated = union (do k <- keys; where k.server != server; yield k) [{server: server, pubkey: "", fetchedAt: t, failedAt: t}]
          set *peerPublicKeys = if count updated > maxPeerPublicKeys then evictOneOldest updated (\k -> k.fetchedAt) else updated
        yield ""

-- Verify an inbound Ed25519 signed federation request.
-- Reconstructs the signed message from (scope, requestTimestamp, fromServer),
-- fetches the peer's public key (cached), and verifies the signature.
-- Verify signature without nonce (backward compatible with old peers).
verifyFederationSignature : Text -> Text -> Text -> Timestamp -> IO {network} Bool
verifyFederationSignature = \fromServer signatureHex scope requestTimestamp -> do
  t <- now
  pubkeyHex <- fetchPeerPublicKey fromServer t
  if pubkeyHex == "" then yield (False {})
  else do
    let message = textToBytes (scope ++ "|" ++ show requestTimestamp ++ "|" ++ fromServer)
    yield (verify (bytesFromHex pubkeyHex) message (bytesFromHex signatureHex))

-- Verify signature with nonce (new format: prevents replay of same-millisecond requests).
verifyFederationSignatureWithNonce : Text -> Text -> Text -> Text -> Timestamp -> IO {network} Bool
verifyFederationSignatureWithNonce = \fromServer signatureHex nonce scope requestTimestamp -> do
  t <- now
  pubkeyHex <- fetchPeerPublicKey fromServer t
  if pubkeyHex == "" then yield (False {})
  else do
    let message = textToBytes (scope ++ "|" ++ show requestTimestamp ++ "|" ++ fromServer ++ "|" ++ nonce)
    yield (verify (bytesFromHex pubkeyHex) message (bytesFromHex signatureHex))

-- Federation auth wrapper. Intentionally does NOT call checkPreAuth because:
-- (a) Soft drain (phase 1) blocks new client auth but must not block federation —
--     peers need to deliver messages and acks to existing recipients during drain.
-- (b) Federation has its own rate limiting via checkFederationRate (per-server)
--     and checkGlobalRate (shared with client routes), so IP rate limiting is redundant.
-- (c) Federation routes don't carry a ClientIp header (peer-to-peer, not client-facing),
--     so IP-based rate limiting doesn't apply.
withFederationAuth = \authorization t respond fromServer scope requestTimestamp precondition clearOnAuth action -> do
  -- Check blocklist and allowlist before spending resources on verification
  blocked <- *blockedPeers
  if isBlockedPeer fromServer blocked
    then do
      logWarn ("federation: blocked peer " ++ fromServer ++ " rejected")
      yield (respond {ok: False {}, error: "blocked", retryAfterMs: 0})
    else do
  allowed <- *allowedPeers
  if not (isAllowedByAllowlist fromServer allowed)
    then do
      logWarn ("federation: peer " ++ fromServer ++ " not in allowlist, rejected")
      yield (respond {ok: False {}, error: "not_allowed", retryAfterMs: 0})
    else do
  -- Dispatch on auth scheme: "Signed " = Ed25519 signature, "Bearer " = verify callback
  -- New format "Signed <sig>:<nonce>" includes a random nonce to prevent replay of
  -- same-millisecond requests. Old format "Signed <sig>" (no colon) is backward compatible.
  verified <- if take 7 authorization == "Signed "
    then do
      let payload = drop 7 authorization
      if payload == "" || tooLong payload (maxSignatureLen + 25)
        then yield (False {})
        else
          let parts = splitOnColon payload in
          if parts.after != ""
            then verifyFederationSignatureWithNonce fromServer parts.before parts.after scope requestTimestamp
            else verifyFederationSignature fromServer payload scope requestTimestamp
    else verifyFederationCallback fromServer authorization scope
  if not verified
    then yield (respond {ok: False {}, error: "unauthorized", retryAfterMs: 0})
    -- Replay protection: reject requests with timestamps too far from local clock.
    -- requestTimestamp == 0 means the peer doesn't support this field yet (accept).
    else if requestTimestamp > 0 && (requestTimestamp > t + clockSkewTolerance || requestTimestamp < t - clockSkewTolerance)
    then do
      logWarn ("federation: clock skew " ++ show (t - requestTimestamp) ++ "ms from " ++ fromServer ++ ", rejecting (tolerance: " ++ show clockSkewTolerance ++ "ms)")
      yield (respond {ok: False {}, error: "clock_skew", retryAfterMs: 0})
    else if not precondition
    then yield (respond {ok: False {}, error: "invalid_request", retryAfterMs: 0})
    else do
      -- Replay detection: reject duplicate (server, timestamp) pairs within the skew window
      replayDetected <- if requestTimestamp > 0
        then atomic do
          recent <- *recentFederationRequests
          let isDup = any recent (\r -> r.server == fromServer && r.timestamp == requestTimestamp)
          if isDup then yield (True {})
          else do
            let cleaned = do r <- recent; where t - r.seenAt < clockSkewTolerance * 2; yield r
            let updated = union cleaned [{server: fromServer, timestamp: requestTimestamp, seenAt: t}]
            set *recentFederationRequests = if count updated > maxRecentFederationRequests then evictOneOldest updated (\r -> r.seenAt) else updated
            yield (False {})
        else yield (False {})
      if replayDetected
        then do
          logWarn ("federation: replay detected from " ++ fromServer ++ " (timestamp: " ++ show requestTimestamp ++ ")")
          yield (respond {ok: False {}, error: "replay_detected", retryAfterMs: 0})
        else do
      globalLimited <- checkGlobalRate t
      if globalLimited
        then do
          effGlobal <- effectiveGlobalRequestRate
          logEvent "warn" "rate_limited_federation_global" ("peer=" ++ fromServer ++ " limit=" ++ show effGlobal)
          -- retryAfterMs provides a structured hint so peers can make smarter retry decisions.
          -- Error string still includes the value for backward compatibility with pre-v14 peers.
          yield (respond {ok: False {}, error: "rate_limited", retryAfterMs: globalRateWindowMs})
        else do
          rateLimited <- checkFederationRate fromServer t
          if rateLimited
            then do
              effFed <- effectiveFederationRate
              logEvent "warn" "rate_limited_federation_per_server" ("peer=" ++ fromServer ++ " limit=" ++ show effFed)
              yield (respond {ok: False {}, error: "rate_limited", retryAfterMs: federationRateWindowMs})
            else do
              when clearOnAuth (clearFailure fromServer)
              action

withSessionAuth = \authorization t clientIp onUnauth onAuth -> do
  case extractToken authorization of
    Nothing {} -> onUnauth
    Just {value: token} -> do
      let bucket = tokenBucket token
      sessions <- readSessionBucket bucket
      case authenticateSession sessions token t of
        Unauthorized {} -> onUnauth
        Authorized {pubkey, ip} ->
          if not (matchIp clientIp ip)
            then onUnauth
            else do
              -- Sliding window: refresh session expiry when within half of sessionExpiry.
              -- Avoids rewriting the session bucket on every authenticated request (reduces
              -- write contention on hot paths like rapid ack/delete sequences). Sessions
              -- still stay alive as long as the client is active within any sessionExpiry window.
              -- Uses pubkey pre-filter to find the matching session's expiry without safeCompare,
              -- since pubkey was already verified by authenticateSession above.
              let needsRefresh = any sessions (\s -> s.pubkey == pubkey && s.expiresAt - t < sessionExpiry / 3)
              when needsRefresh
                -- Pubkey pre-filter on safeCompare: only runs constant-time comparison for
                -- sessions matching the authenticated pubkey (typically 1-2 per bucket),
                -- skipping the expensive safeCompare for all unrelated sessions (~600/bucket).
                (writeSessionBucket bucket (do s <- sessions; yield (if s.pubkey == pubkey && s.expiresAt - t < sessionExpiry / 3 && safeCompare s.token token then {token: s.token, pubkey: s.pubkey, expiresAt: t + sessionExpiry, ip: s.ip, createdAt: s.createdAt} else s)))
              onAuth pubkey

-- Check if a pubkey has no remaining sessions and, if so, clean up local presence.
-- Must be called inside an atomic block after the session has already been removed.
-- Returns {pubkey, gossipOffline, peerServers} indicating whether offline gossip is needed.
checkLastSessionCleanup : PubkeyHex -> Timestamp -> IO {pubkey: PubkeyHex, gossipOffline: Bool, peerServers: [Text]}
checkLastSessionCleanup = \pubkey t -> do
  hasRemaining <- hasSessionForKey pubkey 0
  if not hasRemaining
    then do
      let pb = pubkeyBucket pubkey
      presenceBkt <- readPresenceBucket pb
      let kept = do p <- presenceBkt; where p.pubkey != pubkey || not (isLocalServer p.server); yield p
      writePresenceBucket pb kept
      let removedCount = count presenceBkt - count kept
      tpc <- *totalPresenceCount
      set *totalPresenceCount = max 0 (tpc - removedCount)
      set *presenceVersion = t
      peerServers <- *knownPeerServers
      yield {pubkey: pubkey, gossipOffline: True {}, peerServers: peerServers}
    else yield {pubkey: pubkey, gossipOffline: False {}, peerServers: []}

-- If the last session was removed, gossip offline to federation peers.
-- Skips gossip during drain (handleDrain already broadcast offline for all local keys).
gossipOfflineIfLastSession : {pubkey: PubkeyHex, gossipOffline: Bool, peerServers: [Text]} -> Text -> IO {network} ()
gossipOfflineIfLastSession = \r label -> do
  when r.gossipOffline (do
    t <- now
    dp <- *drainPhase
    if dp >= 2
      then logInfo (label ++ ": last session for " ++ r.pubkey ++ " (drain active, skipping redundant offline gossip)")
      else do
        logInfo (label ++ ": last session for " ++ r.pubkey ++ ", gossiping offline")
        when (federationEnabled && count r.peerServers > 0)
          (fork (sendBatchedGossip r.peerServers [{eventType: GossipOffline {}, pubkey: r.pubkey, server: serverHostN, timestamp: t, ttl: offlineGossipMinTtl, seenBy: [serverHostN]}] gossipOriginHops)))

removeForward = \mid srv toKey -> atomic do
  let b = pubkeyBucket toKey
  fwdBkt <- readFwdBucket b
  let kept = forwardsExcluding fwdBkt srv [mid]
  writeFwdBucket b kept
  let removed = count fwdBkt - count kept
  when (removed > 0) (do
    tfc <- *totalForwardCount
    set *totalForwardCount = max 0 (tfc - removed))

-- Reclaim origin messages after federation ack confirms delivery.
-- Batched by message bucket: all entries for the same bucket are processed in one
-- atomic block (reduces transaction overhead compared to one-per-entry).
ackCleanupForwards = \entries t ->
  let bucketIds = uniqueBucketsFor entries (\e -> e.toKey) in
  ackCleanupByBucket bucketIds entries t

-- Two-pass ack cleanup: first filter entries to those eligible for cleanup,
-- then single-pass filter messages. Avoids O(entries * messages) nested scan
-- from the fold-with-shrinking-accumulator pattern.
ackCleanupByBucket = \bucketIds entries t -> case headOf bucketIds of
  Nothing {} -> yield {}
  Just {value: b} -> do
    let remainingBuckets = do x <- bucketIds; where x != b; yield x
    let bucketEntries = do e <- entries; where pubkeyBucket e.toKey == b; yield e
    atomic do
      -- All entries in this batch share pubkeyBucket == b, so only that presence bucket is needed
      bucketPresence <- readPresenceBucket b
      fwdBkt <- readFwdBucket b
      msgs <- readMessageBucket b
      tc <- *totalMessageCount
      rc <- readRcBucket b
      -- Phase 1: filter to entries eligible for cleanup (no local presence, no pending forwards)
      let eligible = do rf <- bucketEntries
            where not (any bucketPresence (\p -> p.pubkey == rf.toKey && isLocalServer p.server && p.expiresAt > t))
            where not (any fwdBkt (\f -> f.messageId == rf.messageId && f.toKey == rf.toKey))
            yield rf
      -- Phase 2: single pass over messages — remove those matching any eligible entry past grace period
      let shouldRemove = \m -> any eligible (\rf -> m.messageId == rf.messageId && m.toKey == rf.toKey && t - m.receivedAt >= ackGracePeriod)
      let cleanMsgs = do m <- msgs; where not (shouldRemove m); yield m
      let removedMsgs = do m <- msgs; where shouldRemove m; yield m
      let removedCount = count removedMsgs
      let newRc = fold (\accRc m -> adjustRecipientCount accRc m.toKey (0 - 1)) rc removedMsgs
      writeMessageBucket b cleanMsgs
      set *totalMessageCount = max 0 (tc - removedCount)
      writeRcBucket b newRc
    ackCleanupByBucket remainingBuckets entries t

pow2 : Int -> Int
pow2 = \n -> if n <= 0 then 1 else 2 * pow2 (n - 1)

-- Exponential backoff: base * 2^(failures-1), capped at retryBackoffMax
retryBackoff : Int -> Int<Ms>
retryBackoff = \failures ->
  min retryBackoffMax (retryBackoffBase * pow2 (max 0 (failures - 1)))

-- Exponential backoff with deterministic per-server jitter to prevent thundering herd
-- when multiple peers recover simultaneously. Jitter derived from first hex char of
-- server name (0-15) adds 0-47% of base delay, spreading retries across the window.
retryBackoffFor : Int -> Text -> Int<Ms>
retryBackoffFor = \failures server ->
  let base = retryBackoff failures in
  let jitterFrac = hexCharIndex (take 1 server) in
  min retryBackoffMax (base + base * jitterFrac / 32)

shouldRetryServer : Text -> Timestamp -> [ForwardFailure] -> Bool
shouldRetryServer = \server t failures ->
  case headOf (do f <- failures; where f.server == server; yield f) of
    Nothing {} -> True {}
    Just {value: f} -> t - f.firstFailedAt < maxServerDowntime && t - f.failedAt >= retryBackoffFor f.failures server

-- Extended retry check: also skip servers with hung in-flight requests or on the blocklist
shouldRetryServerEx : Text -> Timestamp -> [ForwardFailure] -> [FederationInFlightEntry] -> [Text] -> Bool
shouldRetryServerEx = \server t failures inFlight blocked ->
  not (isBlockedPeer server blocked) && shouldRetryServer server t failures && not (hasHungFederationRequest server t inFlight)

-- Global circuit breaker: returns True when too many peers are failing simultaneously,
-- indicating a likely local network issue rather than individual peer problems.
-- When tripped, all outbound federation is paused until the next prune cycle.
isFederationCircuitOpen : [ForwardFailure] -> Timestamp -> Bool
isFederationCircuitOpen = \failures t ->
  federationCircuitBreakerThreshold > 0
  && count (do f <- failures; where t - f.firstFailedAt < maxServerDowntime; yield f) >= federationCircuitBreakerThreshold

recordFailure = \server -> do
  t <- now
  -- Random jitter (0-25% of base backoff) prevents synchronized retries when
  -- multiple operations to the same peer fail in quick succession. Shifts failedAt
  -- forward, delaying when shouldRetryServer allows the next attempt. Combined with
  -- the deterministic per-server spread in retryBackoffFor, this breaks both
  -- cross-server and same-server retry correlation (thundering herd).
  jitter <- randomInt (retryBackoffBase / 4)
  atomic do
    failures <- *forwardFailures
    let existing = headOf (do f <- failures; where f.server == server; yield f)
    let updated = case existing of
      Nothing {} -> union failures [{server: server, failedAt: t + jitter, failures: 1, firstFailedAt: t}]
      Just {value: f} -> union (do x <- failures; where x.server != server; yield x) [{server: server, failedAt: t + jitter, failures: min (f.failures + 1) 10, firstFailedAt: f.firstFailedAt}]
    set *forwardFailures = if count updated > maxForwardFailures then evictOneOldest updated (\x -> x.failedAt) else updated

clearFailure = \server -> do
  t <- now
  atomic do
    failures <- *forwardFailures
    set *forwardFailures = do f <- failures; where f.server != server; yield f
    set *lastFederationSuccessAt = t

-- Atomically increment a forward entry's retry count; drop if maxForwardRetries exceeded
incrementForwardRetries = \messageId toServer toKey -> atomic do
  let b = pubkeyBucket toKey
  fwdBkt <- readFwdBucket b
  let shouldDrop = any fwdBkt (\f -> f.messageId == messageId && f.toServer == toServer && f.retries + 1 >= maxForwardRetries)
  if shouldDrop
    then do
      writeFwdBucket b (do f <- fwdBkt; where not (f.messageId == messageId && f.toServer == toServer); yield f)
      tfc <- *totalForwardCount
      set *totalForwardCount = max 0 (tfc - 1)
      logKV "warn" "federation_forward_dropped" ["messageId=" ++ messageId, "server=" ++ toServer, "retries=" ++ show maxForwardRetries]
    else writeFwdBucket b (do f <- fwdBkt; yield (if f.messageId == messageId && f.toServer == toServer then {messageId: f.messageId, toServer: f.toServer, createdAt: f.createdAt, toKey: f.toKey, encryptedBlob: f.encryptedBlob, timestamp: f.timestamp, originServer: f.originServer, retries: f.retries + 1, expiresAt: f.expiresAt, priority: f.priority, senderKey: f.senderKey} else f))

-- Retry forwards for a server using batch forward (1 HTTP round-trip per batch of maxBatchSize).
-- Falls back to single forward if the peer returns an HTTP-level error (old peer without batch support).
retryForwardsForServer : [ForwardEntry] -> Int -> IO {network} {}
retryForwardsForServer = \entries remaining ->
  if remaining <= 0 || count entries == 0 then yield {}
  else do
    t <- now
    -- Pre-filter expired forwards: avoids wasting bandwidth on messages the recipient
    -- would discard. Expired entries are cleaned up by the next prune cycle.
    let liveEntries = do f <- entries; where f.expiresAt > t; yield f
    let expiredCount = count entries - count liveEntries
    when (expiredCount > 0) (logInfo ("federation: skipped " ++ show expiredCount ++ " expired forwards during retry"))
    if count liveEntries == 0 then yield {}
    else do
    let server = case headOf liveEntries of Just {value: f} -> f.toServer; Nothing {} -> ""
    forEachBatch liveEntries maxBatchSize (\batch -> do
      t <- now
      auth <- generateFederationAuth "forward-batch" t
      corrId <- genTokenN 1
      let batchPayload = do f <- batch; yield {toKey: f.toKey, encryptedBlob: f.encryptedBlob, timestamp: f.timestamp, originServer: f.originServer, messageId: f.messageId, expiresAt: f.expiresAt, priority: f.priority}
      result <- fetchFederation server (FederationBatchForward {
        forwards: batchPayload, fromServer: serverHostN,
        requestTimestamp: t, authorization: auth, correlationId: corrId, protocolVersion: federationProtocolVersion})
      case result of
        Err e -> do
          logKV "warn" "federation_batch_forward_failed" ["server=" ++ server, "batchSize=" ++ show (count batch), "error=" ++ show e]
          recordFailure server
          -- HTTP-level failure (connectivity, timeout): don't increment per-message retries.
          -- The messages weren't rejected — the server was unreachable. Server backoff
          -- (via recordFailure) handles retry scheduling. Per-message retries are only
          -- burned on application-level rejections (Ok with per-message results).
          yield {}
        Ok response -> do
          if response.ok then do
            clearFailure server
            -- Process per-message results: remove succeeded, increment retries for failed
            retryForwardsBatchResults batch response.results server
          else do
            logKV "warn" "federation_batch_forward_rejected" ["server=" ++ server, "error=" ++ response.error]
            -- Application-level batch rejection (old peer, invalid request): fall back to
            -- sequential single-message forwards instead of burning retries. The peer likely
            -- doesn't support /federation/forward-batch, so individual forwards may succeed.
            retryForwardsSingle batch server)

-- Increment retry counts for all entries in a failed batch
retryForwardsBatchIncrement = \batch server ->
  case headOf batch of
    Nothing {} -> yield {}
    Just {value: f} -> do
      let rest = do x <- batch; where x.messageId != f.messageId; yield x
      incrementForwardRetries f.messageId server f.toKey
      retryForwardsBatchIncrement rest server

-- Fallback: send forwards individually when batch forward is rejected (old peer).
-- Each message gets its own auth token and HTTP round-trip. On success, removes the
-- forward entry; on failure, increments retries (same as batch per-message failure).
retryForwardsSingle = \batch server ->
  case headOf batch of
    Nothing {} -> yield {}
    Just {value: f} -> do
      let rest = do x <- batch; where x.messageId != f.messageId; yield x
      t <- now
      auth <- generateFederationAuth ("forward:" ++ f.messageId) t
      corrId <- genTokenN 1
      result <- fetchFederation server (ForwardMessage {
        toKey: f.toKey, encryptedBlob: f.encryptedBlob,
        timestamp: f.timestamp, originServer: f.originServer, messageId: f.messageId,
        fromServer: serverHostN, requestTimestamp: t,
        authorization: auth, correlationId: corrId,
        expiresAt: f.expiresAt, priority: f.priority, protocolVersion: federationProtocolVersion})
      case result of
        Err e -> do
          logKV "warn" "federation_single_forward_failed" ["server=" ++ server, "messageId=" ++ f.messageId, "error=" ++ show e]
          recordFailure server
        Ok response ->
          if response.ok then do
            removeForward f.messageId server f.toKey
            clearFailure server
          else incrementForwardRetries f.messageId server f.toKey
      retryForwardsSingle rest server

-- Process per-message results from a batch forward response
retryForwardsBatchResults = \batch results server ->
  case headOf batch of
    Nothing {} -> yield {}
    Just {value: f} -> do
      let rest = do x <- batch; where x.messageId != f.messageId; yield x
      let msgResult = headOf (do r <- results; where r.messageId == f.messageId; yield r)
      case msgResult of
        Just {value: r} ->
          if r.ok then do
            removeForward f.messageId server f.toKey
            retryForwardsBatchResults rest results server
          else do
            incrementForwardRetries f.messageId server f.toKey
            retryForwardsBatchResults rest results server
        Nothing {} -> do
          -- No result for this message (shouldn't happen) — increment retry
          incrementForwardRetries f.messageId server f.toKey
          retryForwardsBatchResults rest results server

-- Collect forwards from all 16 buckets, but only for eligible servers.
-- Reads one bucket at a time to avoid materializing all forwards simultaneously.
collectEligibleForwards : Int -> [Text] -> IO [ForwardEntry]
collectEligibleForwards = \b eligibleServers ->
  if b > 15 then yield []
  else do
    bucket <- readFwdBucket b
    let eligible = do f <- bucket; where any eligibleServers (\s -> s == f.toServer); yield f
    rest <- collectEligibleForwards (b + 1) eligibleServers
    yield (unionNE eligible rest)

-- Retry all pending forwards, respecting per-server backoff. Skips servers that failed recently.
-- Circuit breaker: skips entirely when too many peers are failing (likely local network issue).
-- Per-bucket: reads forward buckets one at a time, collecting only entries for eligible servers,
-- instead of materializing all forwards into memory via readAllForwards.
-- Half-open circuit breaker probe: when the circuit is open, pick the peer with the
-- oldest failure and send a lightweight gossip probe. If it succeeds, clear the failure
-- record and re-evaluate the circuit. This allows faster recovery than waiting for
-- maxServerDowntime to expire on each peer independently.
circuitBreakerProbe : [ForwardFailure] -> Timestamp -> IO {network} ()
circuitBreakerProbe = \failures t -> do
  -- Pick the peer whose last failure is oldest (most likely to have recovered)
  let activeFailures = do f <- failures; where t - f.firstFailedAt < maxServerDowntime; yield f
  case minBy activeFailures (\f -> f.failedAt) of
    Nothing {} -> yield {}
    Just {value: candidate} -> do
      logInfo ("federation: circuit breaker half-open probe to " ++ candidate.server)
      probeStart <- now
      auth <- generateFederationAuth "gossip" probeStart
      result <- fetchFederation candidate.server (RecvGossip {
        authorization: auth,
        events: [], hopsRemaining: 1, fromServer: serverHostN,
        requestTimestamp: probeStart, correlationId: "", protocolVersion: federationProtocolVersion})
      case result of
        Err e -> logWarn ("federation: half-open probe to " ++ candidate.server ++ " failed: " ++ show e)
        Ok _ -> do
          logInfo ("federation: half-open probe to " ++ candidate.server ++ " succeeded, clearing failure")
          clearFailure candidate.server

retryPendingForwardsFromBuckets : IO {network} {}
retryPendingForwardsFromBuckets = do
  t <- now
  failures <- *forwardFailures
  if isFederationCircuitOpen failures t
    then do
      logWarn ("federation: circuit breaker open (" ++ show (count failures) ++ " peers failing), skipping forward retries")
      logEvent "warn" "circuit_breaker_open" (show (count failures) ++ " peers failing")
      -- Half-open: probe one peer to detect recovery
      circuitBreakerProbe failures t
    else do
  inFlight <- *federationInFlight
  blocked <- *blockedPeers
  -- Discover servers with pending forwards per-bucket (reuses computeForwardStats which
  -- reads one bucket at a time), then filter to eligible servers before reading entries.
  fwdStats <- computeForwardStats 0 t
  let allServers = do sc <- fwdStats.serverCounts; yield sc.server
  let eligibleServers = do s <- allServers; where shouldRetryServerEx s t failures inFlight blocked; yield s
  if count eligibleServers == 0 then yield {}
  else do
  -- Read only entries for eligible servers (per-bucket, streaming)
  eligibleForwards <- collectEligibleForwards 0 eligibleServers
  -- Ramp-up for recovering peers: limit forwards per server based on recent failure history.
  -- A server with N prior failures gets min(maxBatchSize * 2^(clearCycles), all) forwards per cycle,
  -- where clearCycles = time since last failure / prune interval. This prevents overwhelming
  -- a just-recovered peer with thousands of queued forwards in a single burst.
  let rampUpLimit = \server ->
        case headOf (do f <- failures; where f.server == server; yield f) of
          Nothing {} -> maxForwardsPerServer -- no failure record: full speed
          Just {value: f} ->
            let cyclesSinceFailure = (t - f.failedAt) / backgroundPruneInterval in
            min maxForwardsPerServer (maxBatchSize * pow2 (min 10 cyclesSinceFailure))
  -- Apply per-server ramp-up: cap entries per server
  let rampedForwards = fold (\acc server ->
    let serverFwds = do f <- eligibleForwards; where f.toServer == server; yield f
    in let limit = rampUpLimit server
    in union acc (takeRelation limit serverFwds)) [] eligibleServers
  -- Prioritize forwards for recipients with active polls (currently online).
  -- These keys will receive the message sooner, improving delivery latency.
  -- Forwards for offline keys are retried after online-key forwards complete.
  activePolls <- *activePolls
  let onlineForwards = do f <- rampedForwards; where any activePolls (\p -> p.pubkey == f.toKey); yield f
  let offlineForwards = do f <- rampedForwards; where none activePolls (\p -> p.pubkey == f.toKey); yield f
  -- Sort by effective priority descending (higher priority first) within each group.
  -- Penalty by retry count: messages with many retries are deprioritized so fresh
  -- messages aren't blocked behind likely-failing ones. A fresh priority-5 (score -5)
  -- beats a retry-6 priority-5 (score 1).
  let sortedOnline = sortBy (\f -> 0 - f.priority + f.retries) onlineForwards
  let sortedOffline = sortBy (\f -> 0 - f.priority + f.retries) offlineForwards
  let prioritizedForwards = union sortedOnline sortedOffline
  -- Prioritize servers that have online-key forwards first
  let onlineServers = collectPeerServers onlineForwards (\x -> x.toServer)
  let offlineOnlyServers = do s <- eligibleServers; where none onlineServers (\os -> os == s); yield s
  let prioritizedServers = union onlineServers offlineOnlyServers
  sendForwardsPartitioned prioritizedForwards prioritizedServers maxForwardRetriesPerServer

-- When a remote key comes online, create forward entries for queued messages and send them
forwardQueuedMessages = \targets t -> do
  newForwards <- atomic do
    -- Read only the forward buckets needed for target pubkeys (not all 16).
    -- All entries for a pubkey hash to the same bucket, so dedup is per-bucket complete.
    let neededFwdBuckets = uniqueBucketsFor targets (\target -> target.pubkey)
    forwards <- readSelectedFwdBuckets neededFwdBuckets
    -- Read only the presence buckets needed for target pubkeys (not all 16)
    let targetPresenceBuckets = uniqueBucketsFor targets (\target -> target.pubkey)
    relevantPresence <- readSelectedPresenceBuckets targetPresenceBuckets
    let localOnline = localOnlineKeys relevantPresence t
    let remoteTargets = remoteOnlyTargets targets localOnline
    -- Read only the message buckets containing target pubkeys (not all 16)
    let neededBuckets = uniqueBucketsFor remoteTargets (\target -> target.pubkey)
    relevantMessages <- readSelectedBuckets neededBuckets
    let candidates = forwardCandidates remoteTargets relevantMessages forwards t
    totalFwdCount <- *totalForwardCount
    -- Per-key, per-server, and per-sender-per-key caps: filter candidates to respect all limits.
    -- Per-sender cap prevents a single sender from monopolizing a recipient's forward queue.
    let perKeyCapped = fold (\acc c ->
      let existingForKey = count (do f <- forwards; where f.toKey == c.toKey; yield f)
        + count (do a <- acc; where a.toKey == c.toKey; yield a)
      in let existingForServer = count (do f <- forwards; where f.toServer == c.toServer; yield f)
        + count (do a <- acc; where a.toServer == c.toServer; yield a)
      in let existingForSenderKey = if c.senderKey != "" then count (do f <- forwards; where f.senderKey == c.senderKey && f.toKey == c.toKey; yield f) + count (do a <- acc; where a.senderKey == c.senderKey && a.toKey == c.toKey; yield a) else 0
      in if existingForKey >= maxForwardsPerKey || existingForServer >= maxForwardsPerServer || (c.senderKey != "" && existingForSenderKey >= maxForwardsPerSenderPerKey) then acc else union acc [c]) [] candidates
    let capped = takeRelation (maxForwardsEntries - totalFwdCount) perKeyCapped
    -- Write back only the affected forward buckets (not all 16)
    let combined = union forwards capped
    writeSelectedFwdBuckets neededFwdBuckets combined
    set *totalForwardCount = totalFwdCount + count capped
    yield capped
  let servers = collectPeerServers newForwards (\x -> x.toServer)
  failures <- *forwardFailures
  if isFederationCircuitOpen failures t
    then logWarn ("federation: circuit breaker open, skipping queued message forwarding")
    else do
  inFlight <- *federationInFlight
  blocked <- *blockedPeers
  let eligibleServers = do s <- servers; where shouldRetryServerEx s t failures inFlight blocked; yield s
  let eligibleForwards = do f <- newForwards; where any eligibleServers (\s -> s == f.toServer); yield f
  sendForwardsPartitioned eligibleForwards eligibleServers maxForwardRetriesPerServer

fetchFederationAck = \origin messageIds -> do
  t <- now
  auth <- generateFederationAuth "ack" t
  corrId <- genTokenN 1
  fetchFederation origin (FederationAck {
    authorization: auth,
    messageIds: messageIds,
    originServer: origin, fromServer: serverHostN,
    requestTimestamp: t, correlationId: corrId, protocolVersion: federationProtocolVersion})

-- Per-bucket ack retry increment: scans only the buckets containing entries from the batch.
-- Each bucket is processed in its own atomic block to reduce lock contention.
-- Drops entries exceeding maxAckRetries to deliveredIds. Returns total dropped count.
incrementAckRetriesPerBucket = \bucketIds server batch droppedAcc ->
  case headOf bucketIds of
    Nothing {} -> yield droppedAcc
    Just {value: b} -> do
      let remainingBuckets = do x <- bucketIds; where x != b; yield x
      bucketDropped <- atomic do
        bucket <- readAckedBucket b
        let isTarget = \a -> a.originServer == server && hasMessage a.messageId a.toKey batch
        let toDrop = do a <- bucket; where isTarget a && a.retries + 1 >= maxAckRetries; yield a
        let dropCount = count toDrop
        writeAckedBucket b (do a <- bucket
          where not (isTarget a && a.retries + 1 >= maxAckRetries)
          yield (if isTarget a then {messageId: a.messageId, toKey: a.toKey, ackedAt: a.ackedAt, originServer: a.originServer, retries: a.retries + 1} else a))
        when (dropCount > 0) (do
          delivBkt <- readDelivBucket b
          let newDelivered = do d <- toDrop; yield {messageId: d.messageId, toKey: d.toKey, deliveredAt: d.ackedAt}
          let combined = union delivBkt newDelivered
          writeDelivBucket b (if count combined > maxDeliveredIds then (evictSmallest combined (count combined - maxDeliveredIds) (\d -> d.deliveredAt)).kept else combined))
        yield dropCount
      incrementAckRetriesPerBucket remainingBuckets server batch (droppedAcc + bucketDropped)

-- Per-bucket ack removal on success: only rewrites buckets containing matched entries.
removeAckedPerBucket = \bucketIds server batch ->
  case headOf bucketIds of
    Nothing {} -> yield {}
    Just {value: b} -> do
      let remainingBuckets = do x <- bucketIds; where x != b; yield x
      atomic do
        bucket <- readAckedBucket b
        writeAckedBucket b (do a <- bucket; where not (a.originServer == server && hasMessage a.messageId a.toKey batch); yield a)
      removeAckedPerBucket remainingBuckets server batch

sendBatchedAcksToServer : [{messageId: MessageIdHex, toKey: PubkeyHex, originServer: ServerName, | a}] -> ServerName -> IO {network} {}
sendBatchedAcksToServer = \serverAcks server ->
  forEachBatch serverAcks maxMessageIds (\batch -> do
    result <- fetchFederationAck server (do a <- batch; yield a.messageId)
    case result of
      Err e -> do
        logWarn ("federation: ack to " ++ server ++ " failed: " ++ show e)
        recordFailure server
        -- Increment retry counters per-bucket; drop entries exceeding maxAckRetries to deliveredIds.
        -- Only touches buckets containing entries from this batch (vs readAllAcked scanning all 16).
        let affectedBuckets = uniqueBucketsFor batch (\a -> a.toKey)
        dropped <- incrementAckRetriesPerBucket affectedBuckets server batch 0
        when (dropped > 0)
          (logWarn ("federation: dropped " ++ show dropped ++ " ack entries to " ++ server ++ " after " ++ show maxAckRetries ++ " retries"))
      Ok _ -> do
        clearFailure server
        -- Remove acked entries per-bucket (vs readAllAcked/writeAllAcked repartitioning all 16)
        let affectedBuckets = uniqueBucketsFor batch (\a -> a.toKey)
        removeAckedPerBucket affectedBuckets server batch)

-- Send delivery acknowledgments back to origin servers and remove acked entries on success
sendAcksAndClean : [{messageId: MessageIdHex, toKey: PubkeyHex, originServer: ServerName, | a}] -> IO {network} {}
sendAcksAndClean = \pendingAcks ->
  if count pendingAcks == 0 then yield {}
  else do
  let servers = collectPeerServers pendingAcks (\a -> a.originServer)
  t <- now
  failures <- *forwardFailures
  if isFederationCircuitOpen failures t
    then logWarn ("federation: circuit breaker open, skipping ack retries")
    else do
  inFlight <- *federationInFlight
  blocked <- *blockedPeers
  let eligibleServers = do s <- servers; where shouldRetryServerEx s t failures inFlight blocked; yield s
  sendToEach eligibleServers (\server ->
    sendBatchedAcksToServer (acksForServer pendingAcks server) server)

-- Retry sending acks that were evicted from ackedIds due to capacity limits.
-- On failure, re-insert into ackedIds or overflow buffer; overflow entries eventually
-- move to deliveredIds (terminal dedup state) if the buffer is also full.
retryEvictedAcks = \evictedEntries pendingAcks ->
  let evictedToRetry = retriableEvictedAcks evictedEntries pendingAcks
  in do
    let evictedOriginServers = collectPeerServers evictedToRetry (\a -> a.originServer)
    sendToEach evictedOriginServers (\server -> do
      fetchResult <- fetchFederationAck server (do a <- acksForServer evictedToRetry server; yield a.messageId)
      case fetchResult of
        Err e -> do
          logWarn ("federation: evicted ack to " ++ server ++ " failed: " ++ show e)
          overflow <- atomic do
            ackedIds <- readAllAcked
            let reinsert = do a <- acksForServer evictedToRetry server; yield {messageId: a.messageId, toKey: a.toKey, ackedAt: a.ackedAt, originServer: a.originServer, retries: a.retries + 1}
            let combined = union ackedIds reinsert
            let excess = count combined - maxAckedIds
            if excess <= 0
              then do writeAllAcked combined; yield []
              else do
                let eviction = evictSmallest combined (max 0 excess) (\a -> a.ackedAt)
                writeAllAcked eviction.kept
                yield eviction.evicted
          when (count overflow > 0) (do
            dropped <- atomic do
              ackOverflow <- *ackOverflow
              let updated = union ackOverflow overflow
              let overflowExcess = count updated - maxAckOverflow
              if overflowExcess <= 0
                then do set *ackOverflow = updated; yield 0
                else do
                  let overflowEviction = evictSmallest updated (max 0 overflowExcess) (\a -> a.ackedAt)
                  set *ackOverflow = overflowEviction.kept
                  deliveredIds <- readAllDelivered
                  let newDelivered = do a <- overflowEviction.evicted; yield {messageId: a.messageId, toKey: a.toKey, deliveredAt: a.ackedAt}
                  let combinedDelivered = union deliveredIds newDelivered
                  let deliveredExcess = count combinedDelivered - maxDeliveredIds
                  writeAllDelivered (if deliveredExcess <= 0 then combinedDelivered
                    else (evictSmallest combinedDelivered (max 0 deliveredExcess) (\d -> d.deliveredAt)).kept)
                  when (deliveredExcess > 0)
                    (logWarn ("ackMessages: deliveredIds at capacity (" ++ show maxDeliveredIds ++ "), " ++ show deliveredExcess ++ " oldest dedup entries permanently removed for " ++ server))
                  yield overflowExcess
            when (dropped > 0)
              (logWarn ("ackMessages: overflow at capacity (" ++ show maxAckOverflow ++ "), " ++ show dropped ++ " ack entries moved to delivered set for " ++ server)))
        Ok _ -> yield {})

-- Retry acks sitting in the overflow buffer (last chance before they become deliveredIds)
retryOverflowAcks = \overflow -> do
  let servers = collectPeerServers overflow (\a -> a.originServer)
  t <- now
  failures <- *forwardFailures
  if isFederationCircuitOpen failures t
    then logWarn ("federation: circuit breaker open, skipping overflow ack retries")
    else do
  inFlight <- *federationInFlight
  blocked <- *blockedPeers
  let eligibleServers = do s <- servers; where shouldRetryServerEx s t failures inFlight blocked; yield s
  sendToEach eligibleServers (\server ->
    forEachBatch (acksForServer overflow server) maxMessageIds (\batch -> do
      result <- fetchFederationAck server (do a <- batch; yield a.messageId)
      case result of
        Err e -> do
          logWarn ("federation: overflow ack to " ++ server ++ " failed: " ++ show e)
          recordFailure server
          -- Increment retry counters in overflow; drop entries exceeding maxAckRetries to deliveredIds
          dropped <- atomic do
            ackOverflow <- *ackOverflow
            let isTarget = \a -> a.originServer == server && hasMessage a.messageId a.toKey batch
            let toDrop = do a <- ackOverflow; where isTarget a && a.retries + 1 >= maxAckRetries; yield a
            let dropCount = count toDrop
            set *ackOverflow = do a <- ackOverflow
              where not (isTarget a && a.retries + 1 >= maxAckRetries)
              yield (if isTarget a then {messageId: a.messageId, toKey: a.toKey, ackedAt: a.ackedAt, originServer: a.originServer, retries: a.retries + 1} else a)
            when (dropCount > 0) (do
              deliveredIds <- readAllDelivered
              let newDelivered = do d <- toDrop; yield {messageId: d.messageId, toKey: d.toKey, deliveredAt: d.ackedAt}
              let combined = union deliveredIds newDelivered
              writeAllDelivered (if count combined > maxDeliveredIds then (evictSmallest combined (count combined - maxDeliveredIds) (\d -> d.deliveredAt)).kept else combined))
            yield dropCount
          when (dropped > 0)
            (logWarn ("federation: dropped " ++ show dropped ++ " overflow ack entries to " ++ server ++ " after " ++ show maxAckRetries ++ " retries"))
        Ok _ -> do
          clearFailure server
          atomic do
            ackOverflow <- *ackOverflow
            set *ackOverflow = do a <- ackOverflow; where not (a.originServer == server && hasMessage a.messageId a.toKey batch); yield a))

-- Queue a single failed cancel for retry during the next prune cycle.
queuePendingCancel = \messageId toKey server t -> atomic do
  pcs <- *pendingFederationCancels
  -- Dedup: don't queue if already pending for the same (messageId, toKey, server)
  let isDup = any pcs (\c -> c.messageId == messageId && c.toKey == toKey && c.toServer == server)
  when (not isDup) (do
    let updated = union pcs [{messageId: messageId, toKey: toKey, toServer: server, createdAt: t, retries: 0}]
    set *pendingFederationCancels = if count updated > maxPendingCancels
      then evictOneOldest updated (\c -> c.createdAt)
      else updated)

-- Queue multiple failed cancels for retry (batch cancel failure).
queuePendingCancels = \cancels server t ->
  case headOf cancels of
    Nothing {} -> yield {}
    Just {value: c} -> do
      let rest = do x <- cancels; where x.messageId != c.messageId || x.toKey != c.toKey; yield x
      queuePendingCancel c.messageId c.toKey server t
      queuePendingCancels rest server t

-- Retry pending federation cancels. Called during the prune cycle.
-- Groups cancels by server and sends batch cancels, respecting backoff.
retryPendingCancels : IO {network} {}
retryPendingCancels = do
  t <- now
  pending <- *pendingFederationCancels
  if count pending == 0 then yield {}
  else do
    failures <- *forwardFailures
    if isFederationCircuitOpen failures t
      then logWarn "federation: circuit breaker open, skipping cancel retries"
      else do
    inFlight <- *federationInFlight
    blocked <- *blockedPeers
    let servers = collectPeerServers pending (\c -> c.toServer)
    let eligibleServers = do s <- servers; where shouldRetryServerEx s t failures inFlight blocked; yield s
    sendToEach eligibleServers (\server -> do
      let serverCancels = do c <- pending; where c.toServer == server; yield c
      forEachBatch serverCancels maxBatchSize (\batch -> do
        cancelT <- now
        auth <- generateFederationAuth "cancel-batch" cancelT
        corrId <- genTokenN 1
        let payload = do c <- batch; yield {messageId: c.messageId, toKey: c.toKey}
        result <- fetchFederation server (FederationBatchCancel {
          cancels: payload, fromServer: serverHostN,
          requestTimestamp: cancelT, correlationId: corrId,
          authorization: auth, protocolVersion: federationProtocolVersion})
        case result of
          Err e -> do
            logWarn ("federation: cancel retry to " ++ server ++ " failed: " ++ show e)
            recordFailure server
            incrementCancelRetries batch server
          Ok r ->
            if r.ok then do
              clearFailure server
              removePendingCancels batch server
            else do
              logWarn ("federation: cancel retry to " ++ server ++ " rejected: " ++ r.error)
              incrementCancelRetries batch server))

-- Increment retry counters for failed cancel entries; drop entries exceeding maxCancelRetries.
incrementCancelRetries = \batch server -> atomic do
  pcs <- *pendingFederationCancels
  let isTarget = \c -> c.toServer == server && any batch (\b -> b.messageId == c.messageId && c.toKey == b.toKey)
  let toDrop = do c <- pcs; where isTarget c && c.retries + 1 >= maxCancelRetries; yield c
  when (count toDrop > 0)
    (logWarn ("federation: dropped " ++ show (count toDrop) ++ " cancel entries to " ++ server ++ " after " ++ show maxCancelRetries ++ " retries"))
  set *pendingFederationCancels = do c <- pcs
    where not (isTarget c && c.retries + 1 >= maxCancelRetries)
    yield (if isTarget c then {messageId: c.messageId, toKey: c.toKey, toServer: c.toServer, createdAt: c.createdAt, retries: c.retries + 1} else c)

-- Remove successfully delivered cancel entries.
removePendingCancels = \batch server -> atomic do
  pcs <- *pendingFederationCancels
  set *pendingFederationCancels = do c <- pcs; where not (c.toServer == server && any batch (\b -> b.messageId == c.messageId && c.toKey == b.toKey)); yield c

-- Wait for all in-flight federation requests to complete or timeout.
-- Uses STM retry instead of busy-wait: blocks until *federationInFlight changes
-- (when clearFederationInFlight writes) or *drainTimedOut is set by the timeout fork.
-- This avoids the 1-second polling loop and wakes immediately when work completes.
waitForInFlightDrain = \deadline -> do
  t <- now
  let remaining = deadline - t
  atomic do set *drainTimedOut = False {}
  -- Fork a timer that sets the timeout signal after the deadline
  fork (do
    when (remaining > 0) (sleep remaining)
    atomic do set *drainTimedOut = True {})
  -- Block until either all in-flight complete or timeout fires
  atomic do
    timedOut <- *drainTimedOut
    if timedOut then yield {}
    else do
      inFlight <- *federationInFlight
      let activeCount = fold (\acc r -> acc + r.count) 0 inFlight
      if activeCount <= 0 then yield {}
      else retry
  timedOut <- *drainTimedOut
  when timedOut (do
    logWarn "drain: timed out waiting for in-flight federation tasks"
    t2 <- now
    inFlight <- *federationInFlight
    let hungSlots = do r <- inFlight; where r.count > 0; yield r
    when (count hungSlots > 0) (logStaleInFlight hungSlots t2))

-- Full maintenance cycle: prune expired state, retry pending forwards and acks,
-- retry overflow acks, broadcast offline gossip, and refresh presence for local keys
-- nearing expiry. Called by both the background task and the /maintenance/prune endpoint.
pruneAndRetry = \t -> do
  atomic do
    set *lastPrunedAt = t
  pr <- pruneExpired t
  -- Warn if forward nonces are near capacity (non-expired eviction creates a replay window).
  -- Operators should increase maxForwardNonces or investigate high message volume.
  nonceCount <- countAllNonces 0
  when (nonceCount * 10 >= maxForwardNonces * 9)
    (logWarn ("forward nonces at " ++ show (nonceCount * 100 / maxForwardNonces) ++ "% capacity (" ++ show nonceCount ++ "/" ++ show maxForwardNonces ++ ") — non-expired eviction may create replay windows, consider increasing maxForwardNonces"))
  -- Capacity warnings at 75%: structured log events for monitoring pipelines.
  -- Fires before the 90% health check threshold, giving operators early warning.
  capacityCounts <- atomic do
    tmc <- *totalMessageCount
    sc <- *totalSessionCount
    pc <- *totalPresenceCount
    fc <- *totalForwardCount
    -- Update cached adaptive rate scale (avoids 3 reads per rate check on hot path)
    set *cachedAdaptiveScale = adaptiveRateScale tmc sc pc
    yield {messages: tmc, sessions: sc, presence: pc, forwards: fc}
  when (capacityCounts.messages * 4 >= maxMessages * 3)
    (logEvent "warn" "capacity_warning" ("messages at " ++ show (capacityCounts.messages * 100 / maxMessages) ++ "% (" ++ show capacityCounts.messages ++ "/" ++ show maxMessages ++ ")"))
  when (capacityCounts.sessions * 4 >= maxSessions * 3)
    (logEvent "warn" "capacity_warning" ("sessions at " ++ show (capacityCounts.sessions * 100 / maxSessions) ++ "% (" ++ show capacityCounts.sessions ++ "/" ++ show maxSessions ++ ")"))
  when (capacityCounts.presence * 4 >= maxPresenceEntries * 3)
    (logEvent "warn" "capacity_warning" ("presence at " ++ show (capacityCounts.presence * 100 / maxPresenceEntries) ++ "% (" ++ show capacityCounts.presence ++ "/" ++ show maxPresenceEntries ++ ")"))
  when (capacityCounts.forwards * 4 >= maxForwardsEntries * 3)
    (logEvent "warn" "capacity_warning" ("forwards at " ++ show (capacityCounts.forwards * 100 / maxForwardsEntries) ++ "% (" ++ show capacityCounts.forwards ++ "/" ++ show maxForwardsEntries ++ ")"))
  -- Counter reconciliation: presence/session/forward counters reconciled every Nth cycle
  -- (lightReconciliationInterval). Between cycles, cached counters are trusted — drift
  -- from concurrent operations is typically small and self-corrects.
  pc <- *pruneCount
  let isLightReconcCycle = pc > 0 && (pc - (pc / lightReconciliationInterval) * lightReconciliationInterval) == 0
  when isLightReconcCycle (do
    presDrift <- atomic do
      actual <- countAllPresence
      stored <- *totalPresenceCount
      set *totalPresenceCount = actual
      yield (actual - stored)
    sessDrift <- atomic do
      actual <- countAllSessions
      stored <- *totalSessionCount
      set *totalSessionCount = actual
      yield (actual - stored)
    fwdDrift <- atomic do
      actual <- countAllForwards 0
      stored <- *totalForwardCount
      set *totalForwardCount = actual
      yield (actual - stored)
    when (presDrift != 0 || sessDrift != 0 || fwdDrift != 0)
      (logInfo ("reconciliation: corrected drift — presence: " ++ show presDrift ++ ", sessions: " ++ show sessDrift ++ ", forwards: " ++ show fwdDrift)))
  -- Active request counter reconciliation: detect leaked counters from panicked handlers.
  -- Knot lacks try-finally, so if serveInner panics, the activeRequests decrement is skipped.
  -- If no request has completed in 3x pollTimeoutMs (the longest a request should take)
  -- but activeRequests > 0, the counter has leaked. Reset to 0 and log the recovery.
  arqLeak <- atomic do
    arq <- *activeRequests
    if arq > 0 then do
      lastCompleted <- *lastRequestCompletedAt
      if lastCompleted > 0 && t - lastCompleted > pollTimeoutMs * 3
        then do
          set *activeRequests = 0
          yield arq
        else yield 0
    else yield 0
  when (arqLeak > 0)
    (logWarn ("reconciliation: reset leaked activeRequests counter (was " ++ show arqLeak ++ ")"))
  -- Message reconciliation: cheap check first (sum rcBucket .count fields vs totalMessageCount).
  -- Full scan only when drift exceeds threshold or every Nth cycle.
  -- Small drifts from concurrent bucket pruning self-correct; only trigger the expensive
  -- full scan when drift is significant (> reconciliationDriftThreshold) or periodic.
  let isFullCycle = pc > 0 && (pc - (pc / reconciliationFullCycleInterval) * reconciliationFullCycleInterval) == 0
  cheapMsgDrift <- atomic do
    rcTotal <- sumRcBucketTotals 0
    stored <- *totalMessageCount
    yield (rcTotal - stored)
  let absDrift = if cheapMsgDrift < 0 then 0 - cheapMsgDrift else cheapMsgDrift
  if absDrift > reconciliationDriftThreshold || isFullCycle
    then do
      msgDrift <- reconcileMessageCountsDelta
      when (msgDrift != 0)
        (logInfo ("reconciliation: corrected message drift: " ++ show msgDrift))
    else when (cheapMsgDrift != 0) (atomic do
      -- Small drift: correct totalMessageCount directly from rcBucket totals
      -- without the full per-bucket rebuild (O(16 bucket scans) vs O(all messages))
      rcTotal <- sumRcBucketTotals 0
      set *totalMessageCount = rcTotal)
  ackState <- atomic do
    ackedIds2 <- readAllAcked
    let pendingAcks = do a <- ackedIds2; where not (isLocalServer a.originServer); yield a
    ackOverflow <- *ackOverflow
    let pendingOverflow = do a <- ackOverflow; where not (isLocalServer a.originServer); yield a
    yield {pendingAcks: pendingAcks, pendingOverflow: pendingOverflow}
  refreshResult <- atomic do
    lastRefresh <- *lastPresenceRefresh
    let shouldRefresh = federationEnabled && t - lastRefresh >= presenceRefreshInterval
    -- Early return: skip expensive reads on ~9/10 prune cycles
    if not shouldRefresh then yield {extendedActive: [], nearExpiryActive: [], refreshPeers: [], shouldRefresh: False {}}
    else do
      -- Round-robin: scan 4 of 16 presence buckets per refresh cycle.
      -- Spreads the gossip traffic across 4 refresh intervals instead of
      -- scanning all 16 buckets every cycle.
      group <- *presenceRefreshGroup
      let startBucket = (group * 4) - ((group * 4) / 16) * 16
      let endBucket = min 15 (startBucket + 3)
      set *presenceRefreshGroup = if group >= 3 then 0 else group + 1
      localNearExpiry <- findNearExpiryPresence startBucket endBucket t
      if count localNearExpiry == 0 then do
        knownPeers <- *knownPeerServers
        set *lastPresenceRefresh = t
        yield {extendedActive: [], nearExpiryActive: [], refreshPeers: knownPeers, shouldRefresh: True {}}
      else do
        -- Check per-key session existence (avoids materializing all 16 session buckets)
        let nearExpiryPubkeys = fold (\acc p -> if any acc (\a -> a == p.pubkey) then acc else union [p.pubkey] acc) [] localNearExpiry
        activeKeys <- filterActiveSessionKeys nearExpiryPubkeys t
        let toExtend = do p <- localNearExpiry; where any activeKeys (\k -> k == p.pubkey); yield p
        let notExtended = do p <- localNearExpiry; where none activeKeys (\k -> k == p.pubkey); yield p
        when (count toExtend > 0) (do
          -- Only write to the affected presence buckets (not all 16)
          let affectedBuckets = uniqueBucketsFor toExtend (\e -> e.pubkey)
          affectedPresence <- readSelectedPresenceBuckets affectedBuckets
          let updatedPresence = do pp <- affectedPresence; yield (if any toExtend (\e -> e.pubkey == pp.pubkey && isLocalServer pp.server) then {pubkey: pp.pubkey, server: pp.server, expiresAt: t + sessionExpiry, timestamp: t} else pp)
          writeSelectedPresenceBuckets affectedBuckets updatedPresence
          set *presenceVersion = t)
        knownPeers <- *knownPeerServers
        set *lastPresenceRefresh = t
        yield {extendedActive: toExtend, nearExpiryActive: notExtended, refreshPeers: knownPeers, shouldRefresh: True {}}
  -- Reset federation latency metrics periodically for windowed averages (prevents
  -- lifetime-cumulative average from masking current conditions)
  atomic do
    resetAt <- *federationLatencyResetAt
    when (t - resetAt >= federationLatencyWindowMs) (do
      set *federationLatencyTotal = 0
      set *federationLatencyCount = 0
      set *federationLatencyMax = 0
      set *federationLatencyBucket0 = 0
      set *federationLatencyBucket1 = 0
      set *federationLatencyBucket2 = 0
      set *federationLatencyBucket3 = 0
      set *slowVerifyCount = 0
      set *verifyFailCount = 0
      -- Reset rate-limit rejection counters (windowed with federation latency metrics)
      set *rateLimitedGlobal = 0
      set *rateLimitedIp = 0
      set *rateLimitedAuth = 0
      set *rateLimitedPerKey = 0
      set *rateLimitedFederation = 0
      -- Prune expired verify cache entries
      cache <- *verificationCache
      set *verificationCache = do c <- cache; where t - c.verifiedAt < verificationCacheMaxMs; yield c
      -- Reset per-peer latency tracking with global window
      set *peerLatencies = []
      -- Reset gossip send metrics (windowed with federation metrics)
      set *gossipSendSuccess = 0
      set *gossipSendFail = 0
      -- Reset client operation latency metrics (windowed with federation metrics)
      set *clientPollLatencyTotal = 0
      set *clientPollLatencyCount = 0
      set *clientPollLatencyMax = 0
      set *clientSendLatencyTotal = 0
      set *clientSendLatencyCount = 0
      set *clientSendLatencyMax = 0
      -- Reset client latency histogram buckets
      set *clientPollLatencyBucket0 = 0
      set *clientPollLatencyBucket1 = 0
      set *clientPollLatencyBucket2 = 0
      set *clientPollLatencyBucket3 = 0
      set *clientSendLatencyBucket0 = 0
      set *clientSendLatencyBucket1 = 0
      set *clientSendLatencyBucket2 = 0
      set *clientSendLatencyBucket3 = 0
      -- Reset auth latency metrics
      set *clientAuthLatencyTotal = 0
      set *clientAuthLatencyCount = 0
      set *clientAuthLatencyMax = 0
      -- Reset cancel metrics (windowed with other metrics)
      set *clientCancelCount = 0
      set *federationCancelCount = 0
      set *federationLatencyResetAt = t)
  -- Process deferred ack cleanups: reclaim origin messages whose grace period has elapsed.
  -- These were queued by handleFederationAck instead of fork+sleep.
  readyCleanups <- atomic do
    cleanups <- *pendingAckCleanups
    let ready = do c <- cleanups; where t >= c.cleanupAfter; yield c
    let remaining = do c <- cleanups; where t < c.cleanupAfter; yield c
    set *pendingAckCleanups = remaining
    yield ready
  when (count readyCleanups > 0) (ackCleanupForwards readyCleanups t)
  let result = {pendingAcks: ackState.pendingAcks, pendingOverflow: ackState.pendingOverflow, extendedActive: refreshResult.extendedActive, nearExpiryActive: refreshResult.nearExpiryActive, refreshPeers: refreshResult.refreshPeers, shouldRefresh: refreshResult.shouldRefresh}
  -- Fork federation I/O phases independently so a failure in one doesn't block others.
  -- Previously a single fork ran gossip -> forwards -> acks -> cancels sequentially,
  -- meaning a panic in forward retries would skip ack and cancel retries entirely.
  fork (broadcastOfflineGossip t pr.peerServers pr.expiredLocal)
  when federationEnabled (do
    fork retryPendingForwardsFromBuckets
    fork (do
      -- Coalesce regular and overflow acks: merge into a single send pass so acks to
      -- the same origin server share HTTP round-trips instead of two separate send cycles.
      let coalescedAcks = union result.pendingAcks result.pendingOverflow
      sendAcksAndClean coalescedAcks)
    fork retryPendingCancels)
  -- Only gossip extended sessions; keys nearing expiry without active sessions will naturally
  -- trigger offline gossip when they expire (avoids wasted federation traffic)
  when result.shouldRefresh (do
    let refreshEvents = do p <- result.extendedActive; yield {eventType: GossipOnline {}, pubkey: p.pubkey, server: serverHostN, timestamp: t, ttl: clampTtl (sessionExpiry / 1000), seenBy: [serverHostN]}
    when (count result.refreshPeers > 0 && count refreshEvents > 0)
      (fork (sendBatchedGossip result.refreshPeers refreshEvents gossipOriginHops)))
  -- Update cached health state so /health returns fresh data even when rate-limited.
  -- This runs every prune cycle (~30s), keeping the cache within one interval of reality.
  computeAndCacheHealth t
  yield {}

-- Map a single hex character to its integer value (0-15).
-- Handles both lowercase and uppercase hex to prevent hot-bucket skew from
-- federation peers or clients that send uppercase pubkeys.
-- Clamped to 0-15 by callers (pubkeyBucket, tokenBucket) as a safety net.
hexCharIndex : Text -> Int
hexCharIndex = \c ->
  if c == "0" then 0 else if c == "1" then 1 else if c == "2" then 2 else if c == "3" then 3
  else if c == "4" then 4 else if c == "5" then 5 else if c == "6" then 6 else if c == "7" then 7
  else if c == "8" then 8 else if c == "9" then 9
  else if c == "a" || c == "A" then 10 else if c == "b" || c == "B" then 11
  else if c == "c" || c == "C" then 12 else if c == "d" || c == "D" then 13
  else if c == "e" || c == "E" then 14 else 15

-- Map pubkey to one of 16 signal buckets based on first hex digit.
-- This partitions the signal space so storing a message for one pubkey
-- only wakes polls in the same bucket, not all active polls.
-- Defensive clamp ensures an invalid first char never indexes out of bounds
pubkeyBucket : PubkeyHex -> Int
pubkeyBucket = \pubkey -> clamp 0 15 (hexCharIndex (take 1 pubkey))

-- Update the signal timestamp for a pubkey's bucket, waking any blocked polls in that bucket
signalMessageForKey = \pubkey ts ->
  let b = pubkeyBucket pubkey in
  if b == 0 then set *messageSignal0 = ts
  else if b == 1 then set *messageSignal1 = ts
  else if b == 2 then set *messageSignal2 = ts
  else if b == 3 then set *messageSignal3 = ts
  else if b == 4 then set *messageSignal4 = ts
  else if b == 5 then set *messageSignal5 = ts
  else if b == 6 then set *messageSignal6 = ts
  else if b == 7 then set *messageSignal7 = ts
  else if b == 8 then set *messageSignal8 = ts
  else if b == 9 then set *messageSignal9 = ts
  else if b == 10 then set *messageSignal10 = ts
  else if b == 11 then set *messageSignal11 = ts
  else if b == 12 then set *messageSignal12 = ts
  else if b == 13 then set *messageSignal13 = ts
  else if b == 14 then set *messageSignal14 = ts
  else set *messageSignal15 = ts

readMessageSignal = \pubkey ->
  let b = pubkeyBucket pubkey in
  if b == 0 then do s <- *messageSignal0; yield s
  else if b == 1 then do s <- *messageSignal1; yield s
  else if b == 2 then do s <- *messageSignal2; yield s
  else if b == 3 then do s <- *messageSignal3; yield s
  else if b == 4 then do s <- *messageSignal4; yield s
  else if b == 5 then do s <- *messageSignal5; yield s
  else if b == 6 then do s <- *messageSignal6; yield s
  else if b == 7 then do s <- *messageSignal7; yield s
  else if b == 8 then do s <- *messageSignal8; yield s
  else if b == 9 then do s <- *messageSignal9; yield s
  else if b == 10 then do s <- *messageSignal10; yield s
  else if b == 11 then do s <- *messageSignal11; yield s
  else if b == 12 then do s <- *messageSignal12; yield s
  else if b == 13 then do s <- *messageSignal13; yield s
  else if b == 14 then do s <- *messageSignal14; yield s
  else do s <- *messageSignal15; yield s

-- Acknowledge messages up to the given cursor: remove from messages, cancel pending forwards,
-- and create ack entries for federated messages (to notify origin servers).
-- Returns pending acks and any evicted entries that exceeded ackedIds capacity.
ackPolledMessages = \pubkey cursor t -> do
  let b = pubkeyBucket pubkey
  bucket <- readMessageBucket b
  let toAck = do m <- bucket; where m.toKey == pubkey && m.receivedAt <= cursor; yield m
  let ackCount = count toAck
  if ackCount > 0
    then do
      writeMessageBucket b (diff bucket toAck)
      totalCount <- *totalMessageCount
      set *totalMessageCount = max 0 (totalCount - ackCount)
      recipientCounts <- readRcBucket b
      writeRcBucket b (adjustRecipientCount recipientCounts pubkey (0 - ackCount))
      let ackedMsgIds = do m <- toAck; yield m.messageId
      fwdBkt <- readFwdBucket b
      let keptFwds = do f <- fwdBkt; where none ackedMsgIds (\mid -> f.messageId == mid && f.toKey == pubkey); yield f
      let fwdRemoved = count fwdBkt - count keptFwds
      writeFwdBucket b keptFwds
      when (fwdRemoved > 0) (do
        tfc <- *totalForwardCount
        set *totalForwardCount = max 0 (tfc - fwdRemoved))
      let ackedFederated = federatedAckEntries toAck t
      ackedBkt <- readAckedBucket b
      let combinedAckedIds = union ackedBkt ackedFederated
      let excessCount = max 0 (count combinedAckedIds - maxAckedIds)
      let eviction = evictSmallest combinedAckedIds excessCount (\a -> a.ackedAt)
      writeAckedBucket b eviction.kept
      -- Queue delivery receipts for locally-originated messages (senderKey != "")
      -- so the sender learns their message was delivered on their next poll.
      let localDelivered = do m <- toAck; where m.senderKey != "" && m.originServer == ""; yield {senderKey: m.senderKey, messageId: m.messageId, toKey: m.toKey, deliveredAt: t}
      when (count localDelivered > 0) (do
        sd <- *senderDeliveries
        -- Dedup: skip receipts already recorded (e.g., cursor ack + explicit ack for same message)
        let deduped = do d <- localDelivered; where none sd (\e -> e.messageId == d.messageId && e.toKey == d.toKey); yield d
        let combined = union sd deduped
        let overCap = count combined > maxSenderDeliveries
        if overCap then do
          -- Batch eviction: evict 2% of capacity instead of 1 entry at a time.
          -- Amortizes the O(n) scan cost across multiple inserts, reducing overhead
          -- under sustained capacity pressure from O(n) per insert to O(n) per 2% fills.
          let evictCount = max 1 (count combined - maxSenderDeliveries + maxSenderDeliveries / 50)
          let eviction = evictSmallest combined evictCount (\d -> d.deliveredAt)
          set *senderDeliveries = eviction.kept
          -- Track per-sender drop counts for all evicted entries
          let dropCounts = fold (\acc e -> incrementDropCounter acc e.senderKey 1 t) [] eviction.evicted
          when (count dropCounts > 0) (do
            ddr <- *droppedDeliveryReceipts
            set *droppedDeliveryReceipts = fold (\acc dc -> incrementDropCounter acc dc.senderKey dc.count t) ddr dropCounts)
        else set *senderDeliveries = combined)
      yield {pendingAcks: ackedFederated, evictedEntries: eviction.evicted}
    else yield {pendingAcks: [], evictedEntries: []}

pollNewEvents = \pubkey clampedCursor t -> do
  bucket <- readMessageBucket (pubkeyBucket pubkey)
  let raw = pollableMessages bucket pubkey clampedCursor t
  -- Priority-aware delivery with starvation prevention: reserve a fraction of
  -- maxPollEvents for priority-0 messages so high-priority floods can't completely
  -- starve normal messages. Reservation only activates when both pools have messages.
  let priority0 = do m <- raw; where m.priority == 0; yield m
  let highPri = do m <- raw; where m.priority > 0; yield m
  let reservedSlots = if reservedPollFraction > 0 && count highPri > 0 && count priority0 > 0
    then max 1 (maxPollEvents / reservedPollFraction)
    else 0
  let highPriSlots = maxPollEvents - reservedSlots
  let sortedHigh = sortBy (\m -> (0 - m.priority) * 10000000000000 + m.receivedAt) highPri
  let sortedLow = sortBy (\m -> m.receivedAt) priority0
  let selectedHigh = takeRelation highPriSlots sortedHigh
  let selectedLow = takeRelation reservedSlots sortedLow
  -- Merge and re-sort to maintain correct cursor advancement (lastReceivedAt must
  -- reflect the actual latest receivedAt across both pools for cursor consistency).
  let limitedMsgs = sortBy (\m -> (0 - m.priority) * 10000000000000 + m.receivedAt) (union selectedHigh selectedLow)
  let evts = do
    m <- limitedMsgs
    yield {id: m.messageId, eventType: "message",
           payload: {toKey: m.toKey,
                      encryptedBlob: m.encryptedBlob,
                      timestamp: m.timestamp,
                      expiresAt: m.expiresAt}}
  let lastReceivedAt = fold (\acc m -> max acc m.receivedAt) clampedCursor limitedMsgs
  -- hasMore: tells clients there are additional messages beyond this batch,
  -- so they can immediately re-poll without waiting for the next heartbeat.
  let hasMore = count raw > count limitedMsgs
  yield {events: evts, cursor: lastReceivedAt, hasMore: hasMore}

-- Execute a single long-poll cycle:
-- 1. Authenticate and ack messages up to cursor (atomic)
-- 2. Acquire a poll slot (limit concurrent polls per key)
-- 3. Check for existing messages; if none, block on signal/heartbeat (retry-based wait)
-- 4. Re-authenticate after waking (session may have expired during wait)
-- 5. Return new events and release the poll slot
pollOnce = \token cursor clientIp -> do
  t <- now
  let bucket = tokenBucket token
  setup <- atomic do
    sessions <- readSessionBucket bucket
    case authenticateSession sessions token t of
      Unauthorized {} -> yield (Nothing {})
      Authorized {pubkey, ip} ->
        if not (matchIp clientIp ip)
          then yield (Nothing {})
          else do
        -- Sliding window: refresh session expiry when within half of sessionExpiry.
        -- Avoids rewriting the session bucket on every poll (reduces write contention
        -- on the hottest path). Uses pubkey pre-filter so safeCompare only runs on
        -- sessions matching the authenticated pubkey (~1-2 per bucket vs ~600).
        let needsRefresh = any sessions (\s -> s.pubkey == pubkey && s.expiresAt - t < sessionExpiry / 3)
        when needsRefresh
          (writeSessionBucket bucket (do s <- sessions; yield (if s.pubkey == pubkey && s.expiresAt - t < sessionExpiry / 3 && safeCompare s.token token then {token: s.token, pubkey: s.pubkey, expiresAt: t + sessionExpiry, ip: s.ip, createdAt: s.createdAt} else s)))
        seqCounter <- *seqCounter
        let clampedCursor = clamp 0 (max seqCounter t) cursor
        ackResult <- if clampedCursor > 0
          then ackPolledMessages pubkey clampedCursor t
          else yield {pendingAcks: [], evictedEntries: []}
        startWakeup <- *pollWakeup
        startSignal <- readMessageSignal pubkey
        yield (Just {value: {pubkey: pubkey, clampedCursor: clampedCursor, startWakeup: startWakeup, startSignal: startSignal, pendingAcks: ackResult.pendingAcks, evictedEntries: ackResult.evictedEntries}})
  case setup of
    Nothing {} -> yield {authorized: False {}, events: [], cursor: 0, pendingAcks: [], evictedEntries: [], pubkey: "", pollSlotFull: False {}, hasMore: False {}}
    Just {value: s} -> do
      -- Acquire poll slot (limit concurrent polls per key)
      acquired <- atomic do
        activePolls <- *activePolls
        let pollsForKey = count (do p <- activePolls; where p.pubkey == s.pubkey; yield p)
        if pollsForKey >= maxPollsPerKey
          then yield (False {})
          else do
            set *activePolls = if count activePolls >= maxActivePolls
              then union (evictOneOldest activePolls (\p -> p.startedAt)) [{pubkey: s.pubkey, startedAt: t}]
              else union activePolls [{pubkey: s.pubkey, startedAt: t}]
            yield (True {})
      if not acquired
        -- Poll slot exhausted: tell client to back off for one poll cycle instead of busy-retrying
        then yield {authorized: True {}, events: [], cursor: cursor, pendingAcks: s.pendingAcks, evictedEntries: s.evictedEntries, pubkey: s.pubkey, pollSlotFull: True {}, hasMore: False {}}
        else do
          pollResult <- do
            -- Phase 1: check for existing messages (atomic read)
            initialResult <- atomic do
              bucket <- readMessageBucket (pubkeyBucket s.pubkey)
              if count (pollableMessages bucket s.pubkey s.clampedCursor t) > 0
                then do
                  r <- pollNewEvents s.pubkey s.clampedCursor t
                  yield (Just {value: {events: r.events, cursor: r.cursor, hasMore: r.hasMore}})
                else yield (Nothing {})
            case initialResult of
              Just {value: result} ->
                yield {authorized: True {}, events: result.events, cursor: result.cursor, hasMore: result.hasMore}
              Nothing {} -> do
                -- Phase 2: wait for signal or heartbeat
                atomic do
                  wakeup <- *pollWakeup
                  signal <- readMessageSignal s.pubkey
                  if wakeup > s.startWakeup || signal > s.startSignal
                    then yield {}
                    else retry
                -- Phase 3: re-authenticate and read messages after waking.
                -- Check drain flag (server may have started draining during our wait).
                -- Uses reauthenticateSession (pre-filters by pubkey) instead of full
                -- authenticateSession to skip safeCompare on unrelated sessions.
                t2 <- now
                result <- atomic do
                  dp <- *drainPhase
                  if dp >= 2 then yield {authorized: True {}, events: [], cursor: s.clampedCursor, hasMore: False {}}
                  else do
                    sessions2 <- readSessionBucket bucket
                    if not (reauthenticateSession sessions2 token s.pubkey t2)
                      then yield {authorized: False {}, events: [], cursor: s.clampedCursor, hasMore: False {}}
                      else do
                        r <- pollNewEvents s.pubkey s.clampedCursor t2
                        yield {authorized: True {}, events: r.events, cursor: r.cursor, hasMore: r.hasMore}
                yield {authorized: result.authorized, events: result.events, cursor: result.cursor, hasMore: result.hasMore}
          -- Release poll slot. Safety: the code between acquire and release only contains
          -- atomic reads and STM retry (no IO that can throw), so this path is always reached.
          -- If it ever isn't (e.g., runtime panic), pruneExpired cleans stale entries
          -- after pollTimeoutMs * 3 as a safety net.
          atomic do
            activePolls <- *activePolls
            set *activePolls = removeOneForKey activePolls s.pubkey
          yield {authorized: pollResult.authorized, events: pollResult.events, cursor: pollResult.cursor, pendingAcks: s.pendingAcks, evictedEntries: s.evictedEntries, pubkey: s.pubkey, pollSlotFull: False {}, hasMore: pollResult.hasMore}

-- ============================================
-- Derived Relations
-- ============================================
-- Pure query functions over in-memory state. No side effects.

-- All non-expired presence entries for a given pubkey
presenceForKey = \presence pubkey t ->
  do p <- presence; where p.pubkey == pubkey && p.expiresAt > t; yield p

-- Pubkeys that are online on this server
localOnlineKeys = \presence t ->
  do p <- presence; where isLocalServer p.server && p.expiresAt > t; yield p.pubkey

-- Remove the local presence entry for a pubkey (used before re-inserting on auth)
presenceWithoutLocalKey = \presence pubkey ->
  do p <- presence; where p.pubkey != pubkey || not (isLocalServer p.server); yield p

-- Local presence entries that expired during this prune cycle (for offline gossip)
expiredLocalPresence = \before after t ->
  do p <- before; where p.expiresAt <= t && isLocalServer p.server && none after (\q -> q.pubkey == p.pubkey && isLocalServer q.server); yield p

-- Resolve the best server for a pubkey: prefer local, otherwise pick the remote with latest expiry
bestServerForKey = \entries ->
  if any entries (\p -> isLocalServer p.server) then serverHostN
  else case maxBy (do p <- entries; where not (isLocalServer p.server); yield p) (\p -> p.expiresAt) of
    Just {value: p} -> p.server
    Nothing {} -> ""

-- Messages for a pubkey newer than cursor and not expired (per-message expiresAt)
pollableMessages = \messages pubkey cursor t ->
  do m <- messages; where m.toKey == pubkey && m.expiresAt > t && m.receivedAt > cursor; yield m

-- Build ack entries for messages that came from a remote origin server (need federation ack)
federatedAckEntries = \ackedMessages t ->
  do m <- ackedMessages; where m.originServer != ""; yield {messageId: m.messageId, toKey: m.toKey, ackedAt: t, originServer: m.originServer, retries: 0}

-- Remove forwards for specific message IDs destined to a given server
forwardsExcluding = \forwards server messageIds ->
  do f <- forwards; where not (f.toServer == server && any messageIds (\mid -> f.messageId == mid)); yield f

-- Find messages that haven't been forwarded yet to each target's server.
-- Includes relay: messages received via federation (originServer != "") can be
-- re-forwarded when the recipient moves to a different server. Cascade is bounded
-- by dedup (same messageId won't be forwarded to the same server twice).
forwardCandidates = \targets messages forwards t ->
  fold (\acc target ->
    let serverFwdIds = do f <- forwards; where f.toServer == target.server; yield f.messageId in
    union acc (do
      m <- messages
      where m.toKey == target.pubkey
      where none serverFwdIds (\fid -> fid == m.messageId)
      let origin = if m.originServer == "" then serverHostN else m.originServer
      yield {messageId: m.messageId, toServer: target.server, createdAt: t,
             toKey: m.toKey, encryptedBlob: m.encryptedBlob, timestamp: m.timestamp,
             originServer: origin, retries: 0, expiresAt: m.expiresAt, priority: m.priority, senderKey: m.senderKey})) [] targets


-- Challenge-IP binding rules:
-- 1. Both sides have IPs: must match (standard proxy case)
-- 2. Challenge created without IP, verify without IP: accept (no-proxy case)
-- 3. Challenge created without IP, verify with IP: accept (proxy added mid-flow)
-- 4. Challenge created with IP, verify without IP: REJECT (proxy removed or bypassed)
-- Case 4 prevents an attacker who intercepts the challenge string from verifying
-- without going through the same reverse proxy that issued the challenge.
challengeMatch = \challenges pubkey challenge ip t ->
  any challenges (\c -> c.pubkey == pubkey && safeCompare c.challenge challenge && c.expiresAt > t && matchIp ip c.ip)

challengesExcluding = \challenges pubkey challenge ->
  do c <- challenges; where c.pubkey != pubkey || c.challenge != challenge; yield c

hasLocalPresence = \entries -> any entries (\p -> isLocalServer p.server)

ackedIdsExcludingBatch = \ackedIds server batch ->
  do a <- ackedIds; where not (a.originServer == server && hasMessage a.messageId a.toKey batch); yield a

retriableEvictedAcks = \evictedEntries pendingAcks ->
  do a <- evictedEntries; where not (hasMessage a.messageId a.toKey pendingAcks); yield a

acksForServer = \acks server -> do a <- acks; where a.originServer == server; yield a

forwardsForServer = \forwards server -> do f <- forwards; where f.toServer == server; yield f

-- Partition forwards by server and dispatch sequentially. Each iteration removes
-- processed entries from the working list, so subsequent scans are smaller.
-- Total work: ~n*k/2 vs n*k for the naive sendToEach + forwardsForServer pattern.
-- Per-server jitter (0-2s) prevents thundering herd when multiple servers restart
-- simultaneously and all retry pending forwards in the same prune window.
sendForwardsPartitioned = \pending servers maxRetries ->
  case headOf servers of
    Nothing {} -> yield {}
    Just {value: server} -> do
      let rest = do s <- servers; where s != server; yield s
      let serverForwards = do f <- pending; where f.toServer == server; yield f
      let remaining = do f <- pending; where f.toServer != server; yield f
      jitter <- randomInt 2000
      sleep jitter
      retryForwardsForServer serverForwards maxRetries
      sendForwardsPartitioned remaining rest maxRetries

-- Only trust offline events that claim to be from the sending server itself
trustedOfflineEvents = \events fromServer ->
  do e <- events; where e.server == fromServer; yield e

-- Peer servers to re-gossip to, excluding the server that sent us the gossip
gossipTargets = \peerServers fromServer ->
  do s <- peerServers; where s != fromServer; yield s

-- Remote keys that just came online (triggers forwarding of queued messages).
-- Pre-extracts unique pubkeys from appliedKeys for fast-path rejection (same optimization
-- as effectiveGossipEvents: skip full samePubkeyServer check when pubkey doesn't match).
newlyOnlineRemoteKeys = \events appliedKeys ->
  let appliedPubkeys = fold (\acc a -> if any acc (\p -> p == a.pubkey) then acc else union [a.pubkey] acc) [] appliedKeys
  in do e <- events; where any appliedPubkeys (\pk -> pk == e.pubkey); where any appliedKeys (\a -> samePubkeyServer a e); where not (isLocalServer e.server); yield {pubkey: e.pubkey, server: e.server}

-- Trust gossip entries if they're first-party (server == fromServer) or updating
-- an existing (pubkey, server) presence entry. Third-party gossip cannot create
-- new entries for keys we haven't seen — only the key's home server can do that.
-- Additional constraint: third-party updates must carry a strictly newer timestamp
-- than the existing entry — prevents stale relays from refreshing presence TTLs
-- beyond what the original server intended.
trustedGossipEntries = \deduped presence fromServer t ->
  do e <- deduped; where
    if e.server == fromServer then True {} -- first-party: always trusted
    else any presence (\p -> samePubkeyServer p e && p.expiresAt > t && e.timestamp > p.timestamp)
    -- third-party: only update existing entries with strictly newer timestamps
  ; yield {expiresAt: e.expiresAt, pubkey: e.pubkey, server: e.server, timestamp: e.timestamp}

-- Keys whose presence was actually updated (new or extended expiry)
appliedOnlineKeys = \entries presence ->
  do e <- entries; where none presence (\p -> samePubkeyServer p e && p.expiresAt >= e.expiresAt); yield (pubkeyServer e)

-- Gossip entries that update existing presence (vs. creating new entries)
existingPresenceUpdates = \entries presence ->
  do e <- entries; where any presence (\p -> samePubkeyServer p e); yield e

-- Gossip entries for keys not yet in the presence table
newPresenceEntries = \entries presence ->
  do e <- entries; where none presence (\p -> samePubkeyServer p e); yield e

-- Generate offline gossip events for locally-expired presence entries
offlineGossipEvents = \expiredLocal -> do
  p <- expiredLocal
  let ttl = clamp offlineGossipMinTtl maxPresenceTtl ((p.expiresAt - p.timestamp) / 1000)
  yield {eventType: GossipOffline {}, pubkey: p.pubkey, server: serverHostN, timestamp: p.expiresAt, ttl: ttl, seenBy: [serverHostN]}

-- Filter targets to only those not locally online (avoid forwarding to keys that can poll directly)
remoteOnlyTargets = \targets localOnline ->
  do target <- targets; where none localOnline (\pk -> pk == target.pubkey); yield target

-- ============================================
-- Request Handler
-- ============================================

-- POST /auth/challenge: Generate a random challenge for Ed25519 authentication.
-- Rate-limited per key; globally capped. Challenge expires in 1 minute.
handleChallenge = \pubkey clientIp respond -> do
  t <- now
  -- Reject challenges without ClientIp when requireClientIp is enabled.
  -- Prevents creating sessions with no IP binding (permanently accept from any IP).
  if requireClientIp && clientIp == ""
    then do
      logEvent "warn" "missing_client_ip" ("endpoint=challenge key=" ++ pubkey)
      yield (respond {challenge: "", ok: False {}, expiresAt: 0, retryAfterMs: 0, error: "client_ip_required"})
    else do
  preAuth <- checkPreAuth clientIp t
  if preAuth != ""
    then do
      when (preAuth == "ip_rate_limited") (logEvent "warn" "rate_limited_ip" ("endpoint=challenge ip=" ++ clientIp))
      yield (respond {challenge: "", ok: False {}, expiresAt: 0, retryAfterMs: 0, error: preAuth})
    else do
      authLimited <- checkAuthGlobalRate t
      if authLimited then yield (respond {challenge: "", ok: False {}, expiresAt: 0, retryAfterMs: 0, error: "auth_rate_limited"})
      else do
      challenge <- genToken
      result <- atomic do
        challenges <- *challenges
        let active = do c <- challenges; where c.expiresAt > t; yield c
        let activeForKey = count (do c <- active; where c.pubkey == pubkey; yield c)
        let cappedActive = if activeForKey >= maxChallengesPerKey
          then let forKey = do c <- active; where c.pubkey == pubkey; yield c in
               let others = do c <- active; where c.pubkey != pubkey; yield c in
               union others (evictOneOldest forKey (\c -> c.expiresAt))
          else active
        if count cappedActive >= maxChallenges
          then yield {accepted: False {}, rateLimited: False {}, retryAfterMs: 0, error: "capacity"}
          else do
            challengeRates <- *challengeRates
            chalRate <- effectiveChallengeRate
            let rateResult = checkPubkeyRate challengeRates pubkey chalRate challengeRateWindowMs maxChallengeRateEntries t
            if rateResult.limited
              then yield {accepted: False {}, rateLimited: True {}, retryAfterMs: rateResult.retryAfterMs, error: "rate_limited:" ++ show challengeRateWindowMs ++ "ms"}
              else do
                set *challengeRates = rateResult.entries
                set *challenges = union cappedActive [{pubkey: pubkey, challenge: challenge, expiresAt: t + challengeExpiry, ip: clientIp}]
                yield {accepted: True {}, rateLimited: False {}, retryAfterMs: 0, error: ""}
      when result.rateLimited (do
        effChal <- effectiveChallengeRate
        logEvent "warn" "rate_limited_per_key" ("endpoint=challenge key=" ++ pubkey ++ " limit=" ++ show effChal))
      when (not result.accepted && not result.rateLimited)
        (logWarn ("challenge: at capacity (" ++ show maxChallenges ++ "), rejecting for " ++ pubkey))
      yield (respond {challenge: if result.accepted then challenge else "", ok: result.accepted, expiresAt: if result.accepted then t + challengeExpiry else 0, retryAfterMs: result.retryAfterMs, error: result.error})

-- POST /auth/verify: Verify Ed25519 signature over challenge string.
-- On success: creates a session, registers local presence, and gossips online status.
-- Rate-limited globally and per-key (shares auth rate window with challenge requests).
handleVerifyAuth = \pubkey challenge signature revokeOthers clientIp respond -> do
  t <- now
  preAuth <- checkPreAuth clientIp t
  if preAuth != ""
    then do
      when (preAuth == "ip_rate_limited") (logEvent "warn" "rate_limited_ip" ("endpoint=verify ip=" ++ clientIp))
      yield (respond {token: "", expiresAt: 0, error: preAuth})
    else do
      authRateLimited <- atomic do
        challengeRates <- *challengeRates
        chalRate <- effectiveChallengeRate
        let rateResult = checkPubkeyRate challengeRates pubkey chalRate challengeRateWindowMs maxChallengeRateEntries t
        set *challengeRates = rateResult.entries
        yield rateResult.limited
      if authRateLimited then do
        effChal <- effectiveChallengeRate
        logEvent "warn" "rate_limited_per_key" ("endpoint=verify key=" ++ pubkey ++ " limit=" ++ show effChal)
        yield (respond {token: "", expiresAt: 0, error: "rate_limited:" ++ show challengeRateWindowMs ++ "ms"})
      else do
        authGlobalLimited <- checkAuthGlobalRate t
        if authGlobalLimited then yield (respond {token: "", expiresAt: 0, error: "auth_rate_limited"})
        else do
        -- Per-IP unique key abuse detection: reject IPs authenticating too many distinct pubkeys
        uniqueKeyLimited <- atomic do
          ukr <- *uniqueKeyIpRates
          let result = checkUniqueKeyIpRate ukr clientIp pubkey t
          set *uniqueKeyIpRates = if count result.entries > maxUniqueKeyIpEntries
            then do r <- result.entries; where t - r.windowStart < uniqueKeyIpWindowMs; yield r
            else result.entries
          yield result.limited
        if uniqueKeyLimited then do
          logEvent "warn" "rate_limited_unique_key_ip" ("ip=" ++ clientIp ++ " limit=" ++ show maxUniqueKeysPerIp)
          yield (respond {token: "", expiresAt: 0, error: "unique_key_limited"})
        else verifyAuthInner pubkey challenge signature revokeOthers clientIp respond t

verifyAuthInner = \pubkey challenge signature revokeOthers clientIp respond t -> do
  let expiry = t + sessionExpiry
  -- Generate token before atomic block (IO can't run inside STM).
  -- Token is discarded if challenge validation fails — no session is created.
  token <- genToken
  -- Single atomic block for challenge verification + session creation.
  -- Eliminates the TOCTOU gap where a challenge could be consumed without
  -- creating a session (e.g., drain phase changes between two atomic blocks).
  authResult <- atomic do
    challenges <- *challenges
    let hasMatch = challengeMatch challenges pubkey challenge clientIp t
    -- Only consume the challenge on full success (match AND valid signature).
    -- verify() is pure (no IO) so safe in STM.
    if not hasMatch
      then yield {valid: False {}, result: Nothing {}}
      else do
        let sigValid = verify (bytesFromHex pubkey) (textToBytes challenge) (bytesFromHex signature)
        if not sigValid
          then yield {valid: False {}, result: Nothing {}}
          else do
            set *challenges = challengesExcluding challenges pubkey challenge
            dp <- *drainPhase
            if dp >= 1 then yield {valid: True {}, result: Nothing {}}
            else do
              tpc <- *totalPresenceCount
              knownPeers <- *knownPeerServers
              sessionsForKey <- countSessionsForKey pubkey
              tsc <- *totalSessionCount
          let newSession = {token: token, pubkey: pubkey, expiresAt: expiry, ip: clientIp, createdAt: t}
          -- Update presence: replace local entry for this pubkey, evict oldest if over capacity
          let pb = pubkeyBucket pubkey
          presenceBkt <- readPresenceBucket pb
          let bucketWithout = do p <- presenceBkt; where p.pubkey != pubkey || not (isLocalServer p.server); yield p
          let hadLocalEntry = count presenceBkt > count bucketWithout
          let bucketEvicted = if not hadLocalEntry && tpc >= maxPresenceEntries then evictOneOldest bucketWithout (\p -> p.expiresAt) else bucketWithout
          let newPresenceEntry = {pubkey: pubkey, server: serverHostN, expiresAt: expiry, timestamp: t}
          writePresenceBucket pb (union bucketEvicted [newPresenceEntry])
          let presenceDelta = count (union bucketEvicted [newPresenceEntry]) - count presenceBkt
          set *totalPresenceCount = tpc + presenceDelta
          set *presenceVersion = t
          let peerServers = if federationEnabled then knownPeers else []
          -- Fast path: no revocation, under per-key and global limits — only write one bucket
          if not revokeOthers && sessionsForKey < maxSessionsPerKey && tsc < maxSessions
            then do
              let nb = tokenBucket token
              currentBucket <- readSessionBucket nb
              writeSessionBucket nb (union currentBucket [newSession])
              set *totalSessionCount = tsc + 1
              yield {valid: True {}, result: Just {value: {peerServers: peerServers, revokedCount: 0}}}
            else do
              -- Slow path: revocation or capacity pressure.
              -- Bucket-by-bucket approach: revoke sessions for this pubkey across all
              -- 16 buckets without materializing them into one list. Then add the new
              -- session to its bucket and handle global capacity if needed.
              let revokedCount = if revokeOthers then sessionsForKey else 0
              when revokeOthers
                (transformAllSessionBuckets (\bucket -> do s <- bucket; where s.pubkey != pubkey; yield s))
              -- Per-key cap: if still over maxSessionsPerKey (non-revoke case), evict oldest for this key
              let nb = tokenBucket token
              when (not revokeOthers && sessionsForKey >= maxSessionsPerKey)
                (transformAllSessionBuckets (\bucket ->
                  let forKey = do s <- bucket; where s.pubkey == pubkey; yield s in
                  let others = do s <- bucket; where s.pubkey != pubkey; yield s in
                  if count forKey > 0 then union others (evictOneOldest forKey (\s -> s.expiresAt))
                  else bucket))
              -- Global cap: if over maxSessions, evict oldest globally.
              -- Derive count from cached tsc: after revokeOthers, we removed revokedCount sessions;
              -- after per-key cap, we removed at most 1. Avoids a redundant 16-bucket scan.
              let perKeyEvicted = if not revokeOthers && sessionsForKey >= maxSessionsPerKey then 1 else 0
              let estimatedTotal = tsc - revokedCount - perKeyEvicted
              when (estimatedTotal >= maxSessions)
                (do -- Find the bucket containing the oldest session and evict from just that bucket.
                  -- Avoids materializing all 16 session buckets into a single list (O(n) union chain).
                  -- Instead, reads each bucket to find the global minimum, then writes only one bucket.
                  evictOldestSessionFromBuckets 0 Nothing {})
              currentBucket <- readSessionBucket nb
              writeSessionBucket nb (union currentBucket [newSession])
              -- Final count: estimatedTotal + 1 (new session) - globalEviction (0 or 1)
              let globalEvicted = if estimatedTotal >= maxSessions then 1 else 0
              set *totalSessionCount = estimatedTotal - globalEvicted + 1
              yield {valid: True {}, result: Just {value: {peerServers: peerServers, revokedCount: revokedCount}}}
  if not authResult.valid
    then yield (respond {token: "", expiresAt: 0, error: "invalid"})
    else case authResult.result of
      Nothing {} -> yield (respond {token: "", expiresAt: 0, error: "draining"})
      Just {value: result} -> do
          when (revokeOthers && result.revokedCount > 0)
            (logInfo ("verify: revokeOthers revoked " ++ show result.revokedCount ++ " sessions for " ++ pubkey))
          fork (when federationEnabled
            (sendBatchedGossip result.peerServers [{eventType: GossipOnline {}, pubkey: pubkey, server: serverHostN, timestamp: t, ttl: onlineGossipTtl, seenBy: [serverHostN]}] gossipOriginHops))
          yield (respond {token: token, expiresAt: expiry, error: ""})

-- POST /poll: Long-poll for new messages. Cursor-based: messages at or before cursor
-- are acked (removed from mailbox). Blocks until new messages arrive or heartbeat fires.
-- Acks for federated messages are sent to origin servers in the background.
handlePoll = \cursor generation watchKeys authorization clientIp respond -> do
  t <- now
  serverGen <- *serverGeneration
  let generationMismatch = generation != serverGen
  let effectiveCursor = if generationMismatch then 0 else cursor
  -- Cursor reset: generation changed (server restarted) and client had a non-zero cursor.
  -- Tells the client their cursor was invalidated so they can handle re-delivery.
  let cursorWasReset = generationMismatch && cursor > 0
  let cappedWatchKeys = takeRelation maxWatchKeys watchKeys
  dp <- *drainPhase
  -- Cursor staleness: cursor is older than message retention, so messages were missed.
  -- Different from cursorReset (server restart): staleness means client was offline too long.
  let cursorStale = effectiveCursor > 0 && t - effectiveCursor > unackedMessageMaxAge
  if dp >= 2 then yield (respond {events: [], cursor: 0, authorized: True {}, rateLimited: False {}, draining: True {}, generation: serverGen, presenceUpdates: [], heartbeat: False {}, retryAfterMs: 0, cursorReset: cursorWasReset, hasMore: False {}, cursorStale: False {}, messageExpirations: [], messageDeliveries: [], droppedDeliveryReceipts: 0, droppedExpirationNotifs: 0, loadPct: 0, messageCancellations: []})
  else do
  globalRateLimited <- checkGlobalRate t
  if globalRateLimited then yield (respond {events: [], cursor: 0, authorized: False {}, rateLimited: True {}, draining: False {}, generation: serverGen, presenceUpdates: [], heartbeat: False {}, retryAfterMs: globalRateWindowMs, cursorReset: cursorWasReset, hasMore: False {}, cursorStale: False {}, messageExpirations: [], messageDeliveries: [], droppedDeliveryReceipts: 0, droppedExpirationNotifs: 0, loadPct: 0, messageCancellations: []})
  else do
    -- Capture presenceVersion before long-poll wait to skip unchanged lookups
    startPresenceVersion <- *presenceVersion
    result <- case extractToken authorization of
      Nothing {} -> yield {authorized: False {}, events: [], cursor: 0, pendingAcks: [], evictedEntries: [], pubkey: "", pollSlotFull: False {}, hasMore: False {}}
      Just {value: token} -> pollOnce token effectiveCursor clientIp
    -- Check presence for watched keys (piggybacks on poll cycle; max latency = pollTimeoutMs).
    -- Skip the expensive bucket reads if presenceVersion hasn't changed since poll start.
    presenceUpdates <- if result.authorized && count cappedWatchKeys > 0 then do
      currentPresenceVersion <- *presenceVersion
      if currentPresenceVersion == startPresenceVersion then yield []
      else do
        t2 <- now
        atomic do
          let neededBuckets = uniqueBucketsFor cappedWatchKeys (\k -> k)
          relevantPresence <- readSelectedPresenceBuckets neededBuckets
          yield (do key <- cappedWatchKeys; yield {pubkey: key, online: count (presenceForKey relevantPresence key t2) > 0})
    else yield []
    -- Short-circuit: skip fork overhead when there are no pending acks or evicted entries.
    -- Every poll with cursor > 0 reaches this path, but most polls have zero acks.
    when (federationEnabled && (count result.pendingAcks > 0 || count result.evictedEntries > 0))
      (fork (do
        sendAcksAndClean result.pendingAcks
        retryEvictedAcks result.evictedEntries result.pendingAcks))
    let isHeartbeat = result.authorized && count result.events == 0
    -- Deliver message expiration notifications: atomically read and drain expirations
    -- for this sender's pubkey so each notification is delivered exactly once.
    -- Uses result.pubkey from pollOnce (already authenticated) instead of re-authenticating,
    -- avoiding a redundant safeCompare scan and preventing a race where a concurrent poll
    -- could double-drain or lose expirations between the two separate atomic blocks.
    expirations <- if not result.authorized || result.pubkey == "" then yield []
      else atomic do
        se <- *senderExpirations
        let forKey = do e <- se; where e.senderKey == result.pubkey; yield {messageId: e.messageId, toKey: e.toKey, expiredAt: e.expiredAt}
        let remaining = do e <- se; where e.senderKey != result.pubkey; yield e
        set *senderExpirations = remaining
        let capped = takeRelation maxSenderExpirationsPerKey forKey
        yield capped
    -- Deliver message delivery receipts: atomically read and drain delivery notifications
    -- for this sender's pubkey so each receipt is delivered exactly once.
    deliveries <- if not result.authorized || result.pubkey == "" then yield []
      else atomic do
        sd <- *senderDeliveries
        let forKey = do d <- sd; where d.senderKey == result.pubkey; yield {messageId: d.messageId, toKey: d.toKey, deliveredAt: d.deliveredAt}
        let remaining = do d <- sd; where d.senderKey != result.pubkey; yield d
        set *senderDeliveries = remaining
        let capped = takeRelation maxSenderDeliveriesPerKey forKey
        yield capped
    -- Poll slot exhaustion: signal clients to back off for one poll cycle
    effPollTimeout <- effectivePollTimeoutMs
    let pollRetryMs = if result.pollSlotFull then effPollTimeout else 0
    -- Read and drain per-sender drop counters so this sender knows if their receipts were lost.
    -- Each sender sees only their own drops (not a global counter conflating all senders).
    drops <- if not result.authorized || result.pubkey == "" then yield {dr: 0, de: 0}
      else atomic do
        ddr <- *droppedDeliveryReceipts
        let drResult = drainDropCounter ddr result.pubkey
        when (drResult.count > 0) (set *droppedDeliveryReceipts = drResult.remaining)
        den <- *droppedExpirationNotifs
        let deResult = drainDropCounter den result.pubkey
        when (deResult.count > 0) (set *droppedExpirationNotifs = deResult.remaining)
        yield {dr: drResult.count, de: deResult.count}
    -- Deliver cancel notifications: messages retracted by the sender, delivered to the
    -- recipient so clients can remove them from the UI. Keyed by toKey (recipient pubkey).
    cancellations <- if not result.authorized || result.pubkey == "" then yield []
      else atomic do
        cn <- *cancelNotifications
        let forKey = do c <- cn; where c.toKey == result.pubkey; yield {messageId: c.messageId, cancelledAt: c.cancelledAt}
        let remaining = do c <- cn; where c.toKey != result.pubkey; yield c
        set *cancelNotifications = remaining
        let capped = takeRelation maxCancelNotificationsPerKey forKey
        yield capped
    -- Expose server load to clients: 0 = healthy (<=80% capacity), up to 90 = near-full.
    -- Clients can voluntarily reduce poll frequency or batch sends when loadPct > 0.
    loadPct <- do scale <- *cachedAdaptiveScale; yield (if scale >= 100 then 0 else 100 - scale)
    yield (respond {events: result.events, cursor: result.cursor, authorized: result.authorized, rateLimited: result.pollSlotFull, draining: False {}, generation: serverGen, presenceUpdates: presenceUpdates, heartbeat: isHeartbeat, retryAfterMs: pollRetryMs, cursorReset: cursorWasReset, hasMore: result.hasMore, cursorStale: cursorStale, messageExpirations: expirations, messageDeliveries: deliveries, droppedDeliveryReceipts: drops.dr, droppedExpirationNotifs: drops.de, loadPct: loadPct, messageCancellations: cancellations})

-- Core send logic: dedup, rate limiting, store message, create forwards.
-- Called inside an atomic block by both handleSendMessage and sendBatchInner.
-- Caller handles auth, drain checks, and messageId generation.
sendMessageCore = \senderKey to encryptedBlob clampedTs effectiveMsgId expiresInMs msgPriority t ->
  if senderKey == to then yield {status: MsRejected {}, remoteServers: [], retryAfterMs: 0}
  else do
    let msgBucket = pubkeyBucket to
    bucket <- readMessageBucket msgBucket
    ackedBkt <- readAckedBucket msgBucket
    delivBkt <- readDelivBucket msgBucket
    -- Nonce check closes the dedup gap between message expiry (30 days) and nonce retention
    -- (60 days): without this, a client could replay a messageId after messages/ackedIds/deliveredIds
    -- expire but before the nonce expires.
    nonceBkt <- readNonceBucket msgBucket
    let isDup = checkMessageDup bucket effectiveMsgId to || hasMessage effectiveMsgId to ackedBkt || hasMessage effectiveMsgId to delivBkt || any nonceBkt (\n -> n.messageId == effectiveMsgId && n.toKey == to)
    if isDup then yield {status: MsDuplicate {}, remoteServers: [], retryAfterMs: 0}
    else do
      sendRates <- *sendRates
      sendRate <- effectiveSendRate
      let rateResult = checkPubkeyRate sendRates senderKey sendRate sendRateWindowMs maxSendRateEntries t
      if rateResult.limited then yield {status: MsRateLimited {}, remoteServers: [], retryAfterMs: rateResult.retryAfterMs}
      else do
        set *sendRates = rateResult.entries
        pairRates <- *pairRates
        pRate <- effectivePairRate
        let pairResult = checkPairRate pairRates senderKey to pRate pairRateWindowMs maxPairRateEntries t
        set *pairRates = pairResult.entries
        if pairResult.limited then yield {status: MsRateLimited {}, remoteServers: [], retryAfterMs: pairResult.retryAfterMs}
        else do
          recvRates <- *recvRates
          recvRate <- effectiveRecvRate
          let recvResult = checkPubkeyRate recvRates to recvRate recvRateWindowMs maxRecvRateEntries t
          if recvResult.limited then yield {status: MsRateLimited {}, remoteServers: [], retryAfterMs: recvResult.retryAfterMs}
          else do
            set *recvRates = recvResult.entries
            totalMsgCount <- *totalMessageCount
            if totalMsgCount >= maxMessages then yield {status: MsRejected {}, remoteServers: [], retryAfterMs: 0}
            else do
              recipientCounts <- readRcBucket msgBucket
              let recipientCount = getRecipientCount to recipientCounts
              -- Return MsQueued (not MsRejected) for per-recipient capacity: prevents
              -- an attacker from probing mailbox fullness for arbitrary pubkeys. Global
              -- capacity still returns MsRejected since it's not per-recipient.
              effMaxPerRecipient <- effectiveMaxMessagesPerRecipient
              if recipientCount >= effMaxPerRecipient then yield {status: MsQueued {}, remoteServers: [], retryAfterMs: 0}
              else do
                recipientPresence <- readPresenceBucket (pubkeyBucket to)
                seqCounter <- *seqCounter
                let seqTs = nextSeqTs t seqCounter
                set *seqCounter = seqTs
                let msgExpiresAt = seqTs + effectiveMessageTtl expiresInMs
                writeMessageBucket msgBucket (union bucket
                  [{messageId: effectiveMsgId, toKey: to,
                    encryptedBlob: encryptedBlob, timestamp: clampedTs, originServer: "", receivedAt: seqTs, expiresAt: msgExpiresAt, senderKey: senderKey, priority: msgPriority}])
                set *totalMessageCount = totalMsgCount + 1
                writeRcBucket msgBucket (adjustRecipientCount recipientCounts to 1)
                signalMessageForKey to seqTs
                -- Record forward nonce for locally-originated messages: prevents replay
                -- if the message expires from messages/ackedIds/deliveredIds and a federation
                -- peer forwards it back. Without this, the nonce check in handleForwardMessage
                -- would miss locally-originated messages entirely.
                recordForwardNonce effectiveMsgId to t
                let toPresence = presenceForKey recipientPresence to t
                let localOnline = hasLocalPresence toPresence
                let remoteServers = collectPeerServers toPresence (\p -> p.server)
                let forwardsEnqueued = if federationEnabled && count remoteServers > 0 then do
                  let fbi = pubkeyBucket to
                  fwdBkt <- readFwdBucket fbi
                  -- Per-server cap: prevents one unreachable peer from consuming the entire forward queue
                  let newFwds = do s <- remoteServers; where none fwdBkt (\f -> f.messageId == effectiveMsgId && f.toServer == s) && count (do f <- fwdBkt; where f.toServer == s; yield f) < maxForwardsPerServer; yield {messageId: effectiveMsgId, toServer: s, createdAt: t, toKey: to, encryptedBlob: encryptedBlob, timestamp: clampedTs, originServer: serverHostN, retries: 0, expiresAt: msgExpiresAt, priority: msgPriority, senderKey: senderKey}
                  totalFwdCount <- *totalForwardCount
                  let globalCap = maxForwardsEntries - totalFwdCount
                  -- Per-key cap: prevents one key from consuming disproportionate forward slots
                  let keyFwdCount = count (do f <- fwdBkt; where f.toKey == to; yield f)
                  let keyCap = maxForwardsPerKey - keyFwdCount
                  -- Per-sender-per-recipient cap: prevents a single sender from monopolizing
                  -- a recipient's forward queue, ensuring at least (maxForwardsPerKey /
                  -- maxForwardsPerSenderPerKey) distinct senders can queue forwards.
                  let senderKeyFwdCount = if senderKey != "" then count (do f <- fwdBkt; where f.senderKey == senderKey && f.toKey == to; yield f) else 0
                  let senderKeyCap = if senderKey != "" && senderKeyFwdCount >= maxForwardsPerSenderPerKey then 0 else min globalCap keyCap
                  let cappedFwds = takeRelation senderKeyCap newFwds
                  writeFwdBucket fbi (union fwdBkt cappedFwds)
                  set *totalForwardCount = totalFwdCount + count cappedFwds
                  -- Return whether any forwards were actually enqueued (vs dropped by capacity cap)
                  yield (count cappedFwds > 0)
                else yield (False {})
                let status = if localOnline then MsDelivered {}
                  else if federationEnabled && forwardsEnqueued then MsFederated {}
                  else MsQueued {}
                yield {status: status, remoteServers: remoteServers, retryAfterMs: 0}

-- Fork federation forwards for messages that need to be delivered to remote servers.
forkSendForwards = \effectiveMsgId to encryptedBlob clampedTs remoteServers ->
  when (count remoteServers > 0 && federationEnabled) (
    fork (sendToEach remoteServers (\server -> do
      fwdInfo <- atomic do
        fwdBkt <- readFwdBucket (pubkeyBucket to)
        case headOf (do f <- fwdBkt; where f.messageId == effectiveMsgId && f.toServer == server; yield f) of
          Nothing {} -> yield {pending: False {}, fwdExpiresAt: 0, fwdPriority: 0}
          Just {value: fe} -> yield {pending: True {}, fwdExpiresAt: fe.expiresAt, fwdPriority: fe.priority}
      when fwdInfo.pending (do
        fwdT <- now
        fwdAuth <- generateFederationAuth ("forward:" ++ effectiveMsgId) fwdT
        fwdCorrId <- genTokenN 1
        fwdResult <- fetchFederation server (ForwardMessage {
          toKey: to, encryptedBlob: encryptedBlob,
          timestamp: clampedTs, originServer: serverHostN, messageId: effectiveMsgId,
          fromServer: serverHostN, requestTimestamp: fwdT,
          authorization: fwdAuth, correlationId: fwdCorrId,
          expiresAt: fwdInfo.fwdExpiresAt, priority: fwdInfo.fwdPriority, protocolVersion: federationProtocolVersion})
        case fwdResult of
          Err e -> do
            logKV "warn" "federation_forward_failed" ["server=" ++ server, "messageId=" ++ effectiveMsgId, "error=" ++ show e]
            recordFailure server
          Ok response ->
            if response.ok then do
              removeForward effectiveMsgId server to
              clearFailure server
            else
              logKV "warn" "federation_forward_rejected" ["server=" ++ server, "messageId=" ++ effectiveMsgId, "error=" ++ response.error]))))

-- Send all batch forwards for one server using FederationBatchForward (1 HTTP round-trip).
-- Used by handleSendBatch; reduces both fork count (O(servers) not O(messages * servers))
-- and HTTP round-trips (1 per server not 1 per message).
-- Falls back to individual ForwardMessage if the peer rejects the batch (old peer without
-- batch support), same as retryForwardsForServer.
-- Pre-filters to still-pending forwards: concurrent poll/ack between message creation
-- and this forked send may have already removed the forward entry.
sendBatchForwardsSequential = \msgs server ->
  if count msgs == 0 then yield {}
  else do
    -- Filter to messages still pending in forward buckets
    pending <- filterPendingBatchForwards msgs server []
    if count pending == 0 then yield {}
    else do
      t <- now
      auth <- generateFederationAuth "forward-batch" t
      corrId <- genTokenN 1
      let batchPayload = do r <- pending; yield {toKey: r.toKey, encryptedBlob: r.blob, timestamp: r.ts, originServer: serverHostN, messageId: r.messageId, expiresAt: r.fwdExpiresAt, priority: r.fwdPriority}
      result <- fetchFederation server (FederationBatchForward {
        forwards: batchPayload, fromServer: serverHostN,
        requestTimestamp: t, authorization: auth, correlationId: corrId, protocolVersion: federationProtocolVersion})
      case result of
        Err e -> do
          logKV "warn" "federation_batch_forward_failed" ["server=" ++ server, "batchSize=" ++ show (count pending), "error=" ++ show e]
          recordFailure server
        Ok response ->
          if response.ok then do
            clearFailure server
            processBatchForwardResults pending response.results server
          else do
            logKV "warn" "federation_batch_forward_rejected" ["server=" ++ server, "error=" ++ response.error]
            -- Fall back to individual forwards (old peer without /federation/forward-batch)
            sendBatchForwardsFallback pending server

-- Filter batch messages to those still pending in forward buckets.
-- Concurrent poll/ack may have removed the forward entry between creation and send.
filterPendingBatchForwards = \msgs server acc ->
  case headOf msgs of
    Nothing {} -> yield acc
    Just {value: r} -> do
      let rest = do m <- msgs; where m.messageId != r.messageId; yield m
      stillPending <- atomic do
        fwdBkt <- readFwdBucket (pubkeyBucket r.toKey)
        yield (any fwdBkt (\f -> f.messageId == r.messageId && f.toServer == server))
      filterPendingBatchForwards rest server (if stillPending then union acc [r] else acc)

-- Process per-message results from a batch forward response (initial send path).
-- Removes succeeded forward entries; logs rejections (no retry increment on initial send —
-- the background prune cycle handles retries with proper backoff).
processBatchForwardResults = \pending results server ->
  case headOf pending of
    Nothing {} -> yield {}
    Just {value: r} -> do
      let rest = do m <- pending; where m.messageId != r.messageId; yield m
      let msgResult = headOf (do res <- results; where res.messageId == r.messageId; yield res)
      case msgResult of
        Just {value: res} ->
          when res.ok (removeForward r.messageId server r.toKey)
        Nothing {} -> yield {}
      processBatchForwardResults rest results server

-- Fallback: send forwards individually when batch forward is rejected (old peer).
-- Same logic as the original sequential path but only runs when batch fails.
sendBatchForwardsFallback = \msgs server ->
  case headOf msgs of
    Nothing {} -> yield {}
    Just {value: r} -> do
      let rest = do m <- msgs; where m.messageId != r.messageId; yield m
      fwdT <- now
      fwdAuth <- generateFederationAuth ("forward:" ++ r.messageId) fwdT
      fwdCorrId <- genTokenN 1
      fwdResult <- fetchFederation server (ForwardMessage {
        toKey: r.toKey, encryptedBlob: r.blob,
        timestamp: r.ts, originServer: serverHostN, messageId: r.messageId,
        fromServer: serverHostN, requestTimestamp: fwdT,
        authorization: fwdAuth, correlationId: fwdCorrId,
        expiresAt: r.fwdExpiresAt, priority: r.fwdPriority, protocolVersion: federationProtocolVersion})
      case fwdResult of
        Err e -> do
          logKV "warn" "federation_forward_failed" ["server=" ++ server, "messageId=" ++ r.messageId, "error=" ++ show e]
          recordFailure server
        Ok response ->
          if response.ok then do
            removeForward r.messageId server r.toKey
            clearFailure server
          else
            logKV "warn" "federation_forward_rejected" ["server=" ++ server, "messageId=" ++ r.messageId, "error=" ++ response.error]
      sendBatchForwardsFallback rest server

-- POST /messages: Send an encrypted message to a recipient.
-- Deduplicates by messageId across messages, ackedIds, and deliveredIds.
-- Rate-limited per sender key. If recipient is known on a remote server, forwards via federation.
handleSendMessage = \to encryptedBlob timestamp messageId expiresInMs priority authorization clientIp respond -> do
  let clampedPriority = clamp 0 maxMessagePriority priority
  t <- now
  dp <- *drainPhase
  if dp >= 2 then yield (respond {status: MsDraining {}, messageId: "", retryAfterMs: 0, error: "draining", loadPct: 0})
  else do
  globalRateLimited <- checkGlobalRate t
  if globalRateLimited then yield (respond {status: MsRateLimited {}, messageId: "", retryAfterMs: 0, error: "rate_limited:" ++ show globalRateWindowMs ++ "ms", loadPct: 0})
  else do
    effectiveMsgId <- if messageId != "" then yield messageId else genToken
    if t - timestamp > messageMaxAge
      then yield (respond {status: MsRejected {}, messageId: "", retryAfterMs: 0, error: "stale_timestamp", loadPct: 0})
      else do
    when (timestamp > t + clockSkewTolerance)
      (logWarn ("sendMessage: future timestamp detected (+" ++ show (timestamp - t) ++ "ms ahead), clamping to now"))
    when (timestamp < t - messageMaxAge / 2)
      (logWarn ("sendMessage: stale timestamp (" ++ show ((t - timestamp) / 86400000) ++ " days old) for " ++ effectiveMsgId))
    let clampedTs = clampTimestamp timestamp t
    result <- atomic do
      withSessionAuth authorization t clientIp
        (yield {status: MsUnauthorized {}, remoteServers: [], retryAfterMs: 0})
        (\senderKey -> sendMessageCore senderKey to encryptedBlob clampedTs effectiveMsgId expiresInMs clampedPriority t)
    case result.status of
      MsRateLimited {} -> logEvent "warn" "rate_limited_send" ("messageId=" ++ effectiveMsgId)
      MsRejected {} -> when (result.retryAfterMs == 0) (logWarn ("sendMessage: rejected for " ++ effectiveMsgId ++ " (global capacity full)"))
      _ -> yield {}
    forkSendForwards effectiveMsgId to encryptedBlob clampedTs result.remoteServers
    loadPct <- do scale <- *cachedAdaptiveScale; yield (if scale >= 100 then 0 else 100 - scale)
    yield (case result.status of
      MsDuplicate {} -> respond {status: MsDuplicate {}, messageId: effectiveMsgId, retryAfterMs: 0, error: "", loadPct: loadPct}
      MsDelivered {} -> respond {status: MsDelivered {}, messageId: effectiveMsgId, retryAfterMs: 0, error: "", loadPct: loadPct}
      MsFederated {} -> respond {status: MsFederated {}, messageId: effectiveMsgId, retryAfterMs: 0, error: "", loadPct: loadPct}
      MsQueued {} -> respond {status: MsQueued {}, messageId: effectiveMsgId, retryAfterMs: 0, error: "", loadPct: loadPct}
      _ -> respond {status: result.status, messageId: "", retryAfterMs: result.retryAfterMs, error: "rejected", loadPct: loadPct})

-- GET /lookup/:pubkey: Look up the best known server for a pubkey.
-- Returns local server if key is online locally, otherwise the remote with latest expiry.
handleLookupPresence = \pubkey authorization clientIp respond -> do
  t <- now
  globalRateLimited <- checkGlobalRate t
  if globalRateLimited then yield (respond {server: "", authorized: False {}, error: "rate_limited:" ++ show globalRateWindowMs ++ "ms"})
  else do
    result <- atomic do
      dp <- *drainPhase
      if dp >= 2 then yield {server: "", authorized: False {}, error: ""}
      else withSessionAuth authorization t clientIp
        (yield {server: "", authorized: False {}, error: ""})
        (\senderKey -> do
          lookupRates <- *lookupRates
          lkRate <- effectiveLookupRate
          let rateResult = checkPubkeyRate lookupRates senderKey lkRate lookupRateWindowMs maxLookupRateEntries t
          set *lookupRates = rateResult.entries
          if rateResult.limited
            then yield {server: "", authorized: True {}, error: "rate_limited:" ++ show lookupRateWindowMs ++ "ms"}
            else do
              -- Hot path: read only the target key's presence bucket
              lookupBkt <- readPresenceBucket (pubkeyBucket pubkey)
              let foundServer = bestServerForKey (presenceForKey lookupBkt pubkey t)
              -- Mask remote server names: clients only need to know local/remote/unknown,
              -- not which specific peer server a key is homed on (prevents metadata leakage)
              let maskedServer = if foundServer == "" then "" else if isLocalServer foundServer then foundServer else "remote"
              yield {server: maskedServer, authorized: True {}, error: ""})
    yield (respond {server: result.server, authorized: result.authorized, error: result.error})

-- POST /lookup/batch: Look up presence for multiple pubkeys in one request.
-- Reads only the needed presence buckets (not all 16), reducing round trips
-- vs sequential single-key lookups. Uses one rate limit check for the whole batch.
handleBatchLookupPresence = \pubkeys authorization clientIp respond -> do
  t <- now
  globalRateLimited <- checkGlobalRate t
  if globalRateLimited then yield (respond {results: [], authorized: False {}, error: "rate_limited:" ++ show globalRateWindowMs ++ "ms"})
  else do
    dp <- *drainPhase
    if dp >= 2 then yield (respond {results: [], authorized: False {}, error: ""})
    else
      withSessionAuth authorization t clientIp
        (yield (respond {results: [], authorized: False {}, error: ""}))
        (\senderKey -> do
          lookupRateLimited <- atomic do
            lookupRates <- *lookupRates
            lkRate <- effectiveLookupRate
            let rateResult = checkPubkeyRate lookupRates senderKey lkRate lookupRateWindowMs maxLookupRateEntries t
            set *lookupRates = rateResult.entries
            yield rateResult.limited
          if lookupRateLimited then yield (respond {results: [], authorized: True {}, error: "rate_limited:" ++ show lookupRateWindowMs ++ "ms"})
          else do
            -- Deduplicate input pubkeys to avoid redundant presence bucket reads
            -- (a client could send 50 copies of the same pubkey, each triggering a scan)
            let dedupedKeys = fold (\acc k -> if any acc (\a -> a == k) then acc else union acc [k]) [] pubkeys
            let cappedKeys = takeRelation maxBatchLookupKeys dedupedKeys
            result <- atomic do
              let neededBuckets = uniqueBucketsFor cappedKeys (\k -> k)
              relevantPresence <- readSelectedPresenceBuckets neededBuckets
              yield (do key <- cappedKeys; yield (
                let foundServer = bestServerForKey (presenceForKey relevantPresence key t)
                in let maskedServer = if foundServer == "" then "" else if isLocalServer foundServer then foundServer else "remote"
                in {pubkey: key, server: maskedServer}))
            yield (respond {results: result, authorized: True {}, error: ""}))

-- POST /messages/status: Check delivery status of a previously sent message.
-- Caller must provide both messageId and recipient pubkey (proves they know the recipient).
-- Returns: "pending" (in mailbox), "forwarding" (federation in progress),
-- "delivered" (acked by recipient), "unknown" (expired or never existed).
handleMessageStatus = \to messageId authorization clientIp respond -> do
  t <- now
  dp <- *drainPhase
  if dp >= 2 then yield (respond {status: "", authorized: False {}})
  else do
  globalRateLimited <- checkGlobalRate t
  if globalRateLimited then yield (respond {status: "", authorized: False {}})
  else
    withSessionAuth authorization t clientIp
      (yield (respond {status: "", authorized: False {}}))
      (\senderKey -> do
        -- Per-key rate limiting (reuses lookup rate limiter — both are info lookups)
        statusRateLimited <- atomic do
          lookupRates <- *lookupRates
          lkRate <- effectiveLookupRate
          let rateResult = checkPubkeyRate lookupRates senderKey lkRate lookupRateWindowMs maxLookupRateEntries t
          set *lookupRates = rateResult.entries
          yield rateResult.limited
        if statusRateLimited then yield (respond {status: "", authorized: True {}})
        else do
          result <- atomic do
            let msgBucket = pubkeyBucket to
            bucket <- readMessageBucket msgBucket
            -- Check if message is still in mailbox (pending delivery)
            let inMailbox = any bucket (\m -> m.messageId == messageId && m.toKey == to)
            if inMailbox then yield "pending"
            else do
              -- Check if being forwarded to a remote server (bucket read: O(n/16))
              fwdBkt <- readFwdBucket (pubkeyBucket to)
              let inForwards = any fwdBkt (\f -> f.messageId == messageId && f.toKey == to)
              if inForwards then yield "forwarding"
              else do
                -- Check if already delivered (acked or in terminal delivered set)
                ackedBkt <- readAckedBucket msgBucket
                delivBkt <- readDelivBucket msgBucket
                let inAcked = hasMessage messageId to ackedBkt
                let inDelivered = hasMessage messageId to delivBkt
                if inAcked || inDelivered then yield "delivered"
                else do
                  -- Extended check: forward nonces have 60-day retention (2x message lifetime)
                  -- and 100k capacity, providing delivery evidence after ackedIds/deliveredIds are pruned.
                  -- Sharded: reads only the bucket for this recipient's pubkey.
                  nonceBkt <- readNonceBucket (pubkeyBucket to)
                  let inNonces = any nonceBkt (\n -> n.messageId == messageId && n.toKey == to)
                  if inNonces then yield "delivered"
                  else yield "unknown"
          yield (respond {status: result, authorized: True {}}))

-- POST /auth/revoke: Revoke a specific session token.
-- Caller authenticates via Authorization header, then specifies the target token to remove.
-- Only removes the target if it belongs to the same pubkey as the caller (prevents cross-user revocation).
handleRevoke = \targetToken authorization clientIp respond -> do
  t <- now
  globalRateLimited <- checkGlobalRate t
  if globalRateLimited then yield (respond {ok: False {}, authorized: False {}})
  else
    withSessionAuth authorization t clientIp
      (yield (respond {ok: False {}, authorized: False {}}))
      (\callerPubkey -> do
        authLimited <- checkAuthGlobalRate t
        if authLimited then yield (respond {ok: False {}, authorized: True {}})
        else do
        revokeLimited <- atomic do
          rr <- *revokeRates
          let rateResult = checkPubkeyRate rr callerPubkey maxRevokeRatePerKey revokeRateWindowMs maxRevokeRateEntries t
          set *revokeRates = rateResult.entries
          yield rateResult.limited
        if revokeLimited then yield (respond {ok: False {}, authorized: True {}})
        else do
        let targetBucket = tokenBucket targetToken
        result <- atomic do
          sessions <- readSessionBucket targetBucket
          -- Single-pass find-and-remove: avoids calling safeCompare twice per session
          -- (once in `any` to check existence, again in `where` to filter).
          let filtered = fold (\acc s ->
            if not acc.found && s.pubkey == callerPubkey && safeCompare s.token targetToken
              then {kept: acc.kept, found: True {}}
              else {kept: union acc.kept [s], found: acc.found}) {kept: [], found: False {}} sessions
          if filtered.found
            then do
              writeSessionBucket targetBucket filtered.kept
              sc <- *totalSessionCount
              set *totalSessionCount = max 0 (sc - 1)
              cleanup <- checkLastSessionCleanup callerPubkey t
              yield (Just {value: cleanup})
            else yield (Nothing {})
        case result of
          Nothing {} -> yield (respond {ok: False {}, authorized: True {}})
          Just {value: r} -> do
            gossipOfflineIfLastSession r "revoke"
            when (not r.gossipOffline) (logInfo ("revoke: session revoked for " ++ r.pubkey))
            yield (respond {ok: True {}, authorized: True {}}))

-- POST /auth/logout: Voluntary disconnect. Removes the caller's session and, if it was
-- the last active session for this pubkey, clears local presence and gossips offline.
-- This gives faster offline detection than waiting for session expiry (1 hour).
handleLogout = \authorization clientIp respond -> do
  t <- now
  -- Logout is allowed during all drain phases (including full drain): it reduces load
  -- and the offline gossip is skipped during drain by gossipOfflineIfLastSession.
  globalRateLimited <- checkGlobalRate t
  if globalRateLimited then yield (respond {ok: False {}, authorized: False {}})
  else do
  authLimited <- checkAuthGlobalRate t
  if authLimited then yield (respond {ok: False {}, authorized: False {}})
  else
    case extractToken authorization of
      Nothing {} -> yield (respond {ok: False {}, authorized: False {}})
      Just {value: token} -> do
        let bucket = tokenBucket token
        result <- atomic do
          sessions <- readSessionBucket bucket
          case authenticateSession sessions token t of
            Unauthorized {} -> yield (Nothing {})
            Authorized {pubkey, ip} ->
              if not (matchIp clientIp ip)
                then yield (Nothing {})
                else do
                  -- Remove the caller's session
                  writeSessionBucket bucket (do s <- sessions; where not (safeCompare s.token token); yield s)
                  sc <- *totalSessionCount
                  set *totalSessionCount = max 0 (sc - 1)
                  cleanup <- checkLastSessionCleanup pubkey t
                  yield (Just {value: cleanup})
        case result of
          Nothing {} -> yield (respond {ok: False {}, authorized: False {}})
          Just {value: r} -> do
            gossipOfflineIfLastSession r "logout"
            yield (respond {ok: True {}, authorized: True {}})

-- POST /federation/verify: Confirm a token was issued by this server.
-- Called by the receiving server during federation callback verification.
-- Tokens are single-use and expire after verificationTokenExpiry.
handleVerifyToken = \token scope clientIp respond -> do
  -- Reject empty scope: prevents matching against any cached verification entry
  if scope == "" then yield (respond {ok: False {}})
  else do
  t <- now
  globalRateLimited <- checkGlobalRate t
  if globalRateLimited then yield (respond {ok: False {}})
  else do
  ipLimited <- checkClientIpRate clientIp t
  if ipLimited then yield (respond {ok: False {}})
  else do
  -- Dedicated verify rate limit (tighter than general IP rate to limit token probing)
  verifyLimited <- if clientIp == "" then yield (False {})
    else atomic do
      verifyIpRates <- *verifyIpRates
      let result = checkIpRate verifyIpRates clientIp maxVerifyRatePerIp verifyRateWindowMs maxVerifyRateEntries t
      set *verifyIpRates = result.entries
      yield result.limited
  if verifyLimited then do
    logEvent "warn" "rate_limited_verify_ip" ("ip=" ++ clientIp)
    yield (respond {ok: False {}})
  else do
  found <- atomic do
    pending <- *pendingVerifications
    -- Filter by scope and expiry only — no token prefix optimization.
    -- The previous first-char pre-filter leaked one hex digit via timing side-channel.
    -- safeCompare must run on all candidates to prevent information leakage.
    -- Bounded by maxPendingVerifications and further filtered by scope+expiry.
    let isCandidate = \p -> p.scope == scope && t - p.createdAt < verificationTokenExpiry
    let candidates = do p <- pending; where isCandidate p; yield p
    let match = any candidates (\p -> safeCompare p.token token)
    when match (set *pendingVerifications = union
      (do p <- pending; where not (isCandidate p); yield p)
      (do p <- candidates; where not (safeCompare p.token token); yield p))
    yield match
  -- Omit scope from log to prevent scope enumeration by attackers probing the endpoint
  when (not found) (do
    logWarn ("federation/verify: failed attempt from " ++ clientIp)
    logEvent "warn" "verify_failed" clientIp)
  yield (respond {ok: found})

-- POST /federation/gossip: Receive presence gossip from a peer server.
-- Validates events, merges into presence table (last-write-wins), and re-gossips
-- to other known peers with decremented hop count. Triggers message forwarding
-- when a remote key comes online.
handleRecvGossip = \events hopsRemaining fromServer requestTimestamp correlationId authorization respond -> do
  t <- now
  effMaxHops <- effectiveMaxGossipHops
  let cappedHops = clamp 0 effMaxHops hopsRemaining
  let corrId = sanitizeCorrelationId correlationId
  when (corrId != "") (logInfo ("[CORR] " ++ corrId ++ " gossip from " ++ fromServer))
  -- Cap inbound seenBy lists and filter to known peers to prevent gossip suppression attacks
  knownPeersForSeenBy <- *knownPeerServers
  let cappedEvents = do e <- events; yield {eventType: e.eventType, pubkey: e.pubkey, server: e.server, timestamp: e.timestamp, ttl: e.ttl, seenBy: filterSeenBy (takeRelation maxSeenByLen e.seenBy) knownPeersForSeenBy}
  withFederationAuth authorization t respond fromServer "gossip" requestTimestamp (cappedHops >= 1 && not (isLocalServer fromServer) && count cappedEvents <= maxGossipEvents) (True {}) (do
    -- Per-peer gossip event volume limiting: counts total events (not just requests) per server.
    -- A single gossip request carries up to maxGossipEvents entries; without this, a peer
    -- sending 50 req/s * 100 events = 5000 presence mutations/second.
    eventRateLimited <- atomic do
      ger <- *gossipEventRates
      let eventCount = count cappedEvents
      let entry = headOf (do r <- ger; where r.server == fromServer; yield r)
      let isNewWindow = case entry of Nothing {} -> True {}; Just {value: r} -> t - r.windowStart >= gossipEventRateWindowMs
      let currentCount = case entry of Nothing {} -> 0; Just {value: r} -> if isNewWindow then 0 else r.count
      -- Sliding window: interpolate previous window's count for smoother rate limiting
      let elapsed = case entry of Nothing {} -> 0; Just {value: r} -> t - r.windowStart
      let prevWeight = case entry of Nothing {} -> 0; Just {value: r} -> if isNewWindow then 0 else r.prevCount * (gossipEventRateWindowMs - elapsed) / gossipEventRateWindowMs
      if prevWeight + currentCount + eventCount > maxGossipEventsPerServer
        then yield (True {})
        else do
          let newEntries = if isNewWindow
            then let pc = case entry of Nothing {} -> 0; Just {value: r} -> r.count
              in union (do r <- ger; where r.server != fromServer; yield r) [{server: fromServer, windowStart: t, count: eventCount, prevCount: pc}]
            else do r <- ger; yield (if r.server == fromServer then {server: r.server, windowStart: r.windowStart, count: r.count + eventCount, prevCount: r.prevCount} else r)
          set *gossipEventRates = if count newEntries > maxGossipEventRateEntries then (do r <- newEntries; where t - r.windowStart < gossipEventRateWindowMs * 2; yield r) else newEntries
          yield (False {})
    if eventRateLimited then do
      logEvent "warn" "rate_limited_gossip_volume" ("peer=" ++ fromServer ++ " limit=" ++ show maxGossipEventsPerServer)
      yield (respond {ok: False {}, error: "event_rate_limited", retryAfterMs: gossipEventRateWindowMs})
    else do
    let validated = validGossipEvents cappedEvents t
    let onlineEntries = validated.online
    let trustedOffline = trustedOfflineEvents validated.offline fromServer
    -- Early return: skip the expensive presence merge when all events are invalid/expired
    if count onlineEntries == 0 && count trustedOffline == 0
      then yield (respond {ok: True {}, error: "", retryAfterMs: 0})
      else do
    -- Warn if a peer sends both online and offline for the same key in one batch (suspicious)
    let conflictingKeys = do on <- onlineEntries; off <- trustedOffline; where on.pubkey == off.pubkey && on.server == off.server; yield on.pubkey
    when (count conflictingKeys > 0)
      (logWarn ("gossip: " ++ fromServer ++ " sent conflicting online+offline for same key(s)"))
    let filteredOnline = resolveByTimestamp onlineEntries trustedOffline
    let filteredOffline = resolveByTimestamp trustedOffline onlineEntries
    let deduped = mergeByPubkeyServer [] filteredOnline
    -- Combined local-clash check + gossip merge in a single atomic block.
    -- Previously these were two separate atomic blocks reading the same presence buckets;
    -- merging them halves the bucket reads and avoids a TOCTOU gap between clash check and merge.
    -- All entries for a pubkey hash to the same bucket, so per-bucket merge is complete.
    let allGossipEntries = union deduped trustedOffline
    let affectedBuckets = uniqueBucketsFor allGossipEntries (\e -> e.pubkey)
    gossipResult <- atomic do
      selectedPresence <- readSelectedPresenceBuckets affectedBuckets
      tpc <- *totalPresenceCount
      -- Reject gossip entries that claim keys locally authenticated on this server.
      -- A peer announcing presence for a key we have a live session for could be a presence
      -- hijack attempt: the attacker's server would receive forwarded message copies.
      let localClashes = do e <- deduped; where any selectedPresence (\p -> p.pubkey == e.pubkey && isLocalServer p.server && p.expiresAt > t); yield e.pubkey
      let safeDeduped = if count localClashes > 0
        then do d <- deduped; where not (any localClashes (\pk -> pk == d.pubkey)); yield d
        else deduped
      let safeTrustedOffline = if count localClashes > 0
        then do d <- trustedOffline; where not (any localClashes (\pk -> pk == d.pubkey)); yield d
        else trustedOffline
      -- Pre-filter: when near capacity, reject gossip entries for pubkeys not already in presence.
      -- This prevents a malicious peer from spiking presence above maxPresenceEntries via large batches.
      let capacityDeduped = if tpc >= maxPresenceEntries
        then do d <- safeDeduped; where any selectedPresence (\p -> p.pubkey == d.pubkey); yield d
        else safeDeduped
      let gm = mergeGossipPresence selectedPresence capacityDeduped safeTrustedOffline fromServer t
      -- Write back only affected buckets (not writeAllPresence, which would zero unaffected buckets)
      writeSelectedPresenceBuckets affectedBuckets gm.finalPresence
      let delta = count gm.finalPresence - count selectedPresence
      set *totalPresenceCount = max 0 (tpc + delta)
      -- Merge new peer servers with existing known peers (selected buckets may not contain all peers)
      knownPeers <- *knownPeerServers
      let newPeers = gm.gossipPeerServers
      set *knownPeerServers = fold (\acc s -> if any acc (\a -> a == s) then acc else union [s] acc) knownPeers newPeers
      set *presenceVersion = t
      yield {gm: gm, preFiltered: count safeDeduped - count capacityDeduped, localClashCount: count localClashes}
    when (gossipResult.localClashCount > 0)
      (logWarn ("gossip: " ++ fromServer ++ " claims " ++ show gossipResult.localClashCount ++ " locally-authenticated key(s) — filtered from merge"))
    -- seenBy for re-broadcast: include fromServer (sender) and ourselves so downstream
    -- peers that share connections with either skip this event.
    let rebroadcastSeenBy = if any [fromServer] (\s -> s == serverHostN) then [serverHostN] else [fromServer, serverHostN]
    let effectiveEvents = union (effectiveGossipEvents filteredOnline gossipResult.gm.appliedKeys (GossipOnline {}) rebroadcastSeenBy) (effectiveGossipEvents filteredOffline gossipResult.gm.appliedKeys (GossipOffline {}) rebroadcastSeenBy)
    when (not gossipResult.gm.withinCapacity || gossipResult.preFiltered > 0)
      (logWarn ("gossip: presence at capacity (" ++ show maxPresenceEntries ++ "), limiting new entries from " ++ fromServer ++ " (pre-filtered: " ++ show gossipResult.preFiltered ++ ")"))
    -- Suppress re-broadcast of events we've already gossiped recently (prevents amplification)
    freshEvents <- atomic do
      recentGossip <- *recentGossip
      let active = do r <- recentGossip; where t - r.seenAt < gossipDedupWindow; yield r
      -- Pre-filter active entries to only those matching (pubkey, server) pairs in this batch.
      -- Reduces the inner dedup scan from O(n*m) to O(n*k) where k << m (k = matching pairs).
      let batchPairs = fold (\acc e -> if any acc (\a -> a.pubkey == e.pubkey && a.server == e.server) then acc else union [{pubkey: e.pubkey, server: e.server}] acc) [] effectiveEvents
      let relevantActive = do r <- active; where any batchPairs (\p -> p.pubkey == r.pubkey && p.server == r.server); yield r
      let fresh = do e <- effectiveEvents; where none relevantActive (\r -> r.pubkey == e.pubkey && r.server == e.server && r.timestamp == e.timestamp); yield e
      let newRecent = do e <- fresh; yield {pubkey: e.pubkey, server: e.server, timestamp: e.timestamp, seenAt: t}
      let updated = union active newRecent
      set *recentGossip = if count updated > maxRecentGossip then do r <- updated; where t - r.seenAt < gossipDedupWindow; yield r else updated
      yield fresh
    let newlyOnlineRemote = newlyOnlineRemoteKeys filteredOnline gossipResult.gm.appliedKeys
    fork (do
      when (cappedHops > 1 && federationEnabled && count freshEvents > 0) (do
        -- Gossip batch backoff: when a large batch of fresh events arrives (e.g., peer
        -- recovering from downtime), delay re-broadcast by a random interval to prevent
        -- amplification storms. Multiple peers recovering simultaneously would otherwise
        -- generate O(peers^2 * events) gossip traffic.
        when (count freshEvents > gossipBatchBackoffThreshold) (do
          backoff <- randomInt gossipBatchBackoffMs
          logEvent "info" "gossip_batch_backoff" ("events=" ++ show (count freshEvents) ++ " from=" ++ fromServer ++ " backoffMs=" ++ show backoff)
          sleep backoff)
        let targets = gossipTargets gossipResult.gm.gossipPeerServers fromServer
        -- Split first-party (from the sender) vs third-party (relayed) events.
        -- Third-party events get fewer hops to limit amplification from inflated hopsRemaining.
        let firstPartyEvents = do e <- freshEvents; where e.server == fromServer; yield e
        let thirdPartyEvents = do e <- freshEvents; where e.server != fromServer; yield e
        when (count firstPartyEvents > 0) (sendBatchedGossip targets firstPartyEvents (cappedHops - 1))
        let thirdPartyHops = min (cappedHops - 1) maxThirdPartyGossipHops
        when (thirdPartyHops > 1 && count thirdPartyEvents > 0) (sendBatchedGossip targets thirdPartyEvents thirdPartyHops))
      when (federationEnabled && count newlyOnlineRemote > 0)
        (forwardQueuedMessages newlyOnlineRemote t))
    yield (respond {ok: True {}, error: "", retryAfterMs: 0}))

-- POST /federation/forward: Receive a message forwarded from a peer server.
-- Accepts both direct forwards (fromServer == originServer) and relay forwards
-- (fromServer != originServer) where an intermediate server re-forwards because
-- the recipient moved. Cascade is bounded by dedup (same messageId won't be stored
-- twice) and forwardCandidates (won't re-forward to the same server).
handleForwardMessage = \toKey encryptedBlob timestamp originServer messageId fromServer requestTimestamp correlationId expiresAt priority authorization respond -> do
  t <- now
  let corrId = sanitizeCorrelationId correlationId
  when (corrId != "") (logInfo ("[CORR] " ++ corrId ++ " forward " ++ messageId ++ " from " ++ fromServer))
  withFederationAuth authorization t respond fromServer ("forward:" ++ messageId) requestTimestamp (not (isLocalServer originServer) && not (isLocalServer fromServer)) (True {}) (do
    when (fromServer != originServer)
      (logInfo ("forward: relay from " ++ fromServer ++ " (origin: " ++ originServer ++ ") for " ++ toKey))
    -- Relay origin verification: for relay forwards, verify:
    -- 1. originServer is a known peer (prevents ack routing to arbitrary servers)
    -- 2. originServer is not on the blocklist (blocked peers can't receive acks)
    -- 3. originServer passes the allowlist if one is configured
    -- This prevents metadata leakage: without these checks, a malicious peer B could
    -- send a relay forward with originServer=A, causing us to send an ack (containing
    -- messageId + recipient pubkey) to server A on B's behalf.
    originOk <- if fromServer == originServer then yield (True {})
      else do
        knownPeers <- *knownPeerServers
        blocked <- *blockedPeers
        allowed <- *allowedPeers
        yield (any knownPeers (\p -> p == originServer)
          && not (isBlockedPeer originServer blocked)
          && isAllowedByAllowlist originServer allowed)
    if not originOk
      then do
        logWarn ("forward: rejected relay with untrusted origin " ++ originServer ++ " from " ++ fromServer)
        yield (respond {ok: False {}, error: "unknown_origin", retryAfterMs: 0})
      else do
    -- Replay protection: reject forwards with timestamps older than messageMaxAge.
    -- Legitimate queued messages have timestamps within this window. Replayed captures
    -- become stale once dedup state (messages + ackedIds + deliveredIds) is pruned (~30 days).
    if t - timestamp > messageMaxAge
      then yield (respond {ok: False {}, error: "stale_timestamp", retryAfterMs: 0})
      else do
    -- Presence check + message storage in a single atomic block to prevent TOCTOU
    -- race where a key goes offline between presence check and store.
    let clampedTs = clampTimestamp timestamp t
    result <- atomic do
      -- Verify recipient has active presence on this server. Peers should only forward
      -- to us if gossip indicated the key is here. Accepting messages for completely
      -- unknown keys wastes mailbox slots that will never be drained by polling.
      -- All sharded collections (presence, messages, acked, delivered, nonces) use
      -- pubkeyBucket(toKey), so a single index serves all reads in this block.
      let bkt = pubkeyBucket toKey
      presenceBkt <- readPresenceBucket bkt
      let hasPresence = any presenceBkt (\p -> p.pubkey == toKey && p.expiresAt > t)
      if not hasPresence
        then yield {forward: ForwardRejected {}, globalCapReached: False {}, recvRateLimited: False {}, noPresence: True {}, nonceCutoffRejected: False {}}
        else do
      bucket <- readMessageBucket bkt
      ackedBkt <- readAckedBucket bkt
      delivBkt <- readDelivBucket bkt
      -- Sharded nonce check: reads only the bucket for this recipient's pubkey (O(n/16) vs O(n)).
      nonceBkt <- readNonceBucket bkt
      -- Nonce check ignores originServer: a (messageId, toKey) pair is globally unique,
      -- so replays from any origin should be rejected. This also catches locally-originated
      -- messages (originServer="") whose nonces were recorded by sendMessageCore.
      let isDup = checkMessageDup bucket messageId toKey || hasMessage messageId toKey ackedBkt || hasMessage messageId toKey delivBkt || any nonceBkt (\n -> n.messageId == messageId && n.toKey == toKey)
      if isDup
        then yield {forward: ForwardDuplicate {}, globalCapReached: False {}, recvRateLimited: False {}, noPresence: False {}, nonceCutoffRejected: False {}}
        else do
          -- Nonce eviction replay protection: if LRU eviction has occurred in this bucket,
          -- we cannot verify dedup for messages whose nonces may have been evicted. Reject
          -- forwards with timestamps older than this bucket's eviction cutoff.
          -- Per-bucket cutoff (not global) ensures eviction in one bucket doesn't reject
          -- valid forwards destined for a different bucket.
          nonceCutoff <- readNonceCutoff bkt
          if nonceCutoff > 0 && timestamp > 0 && timestamp < nonceCutoff
            then yield {forward: ForwardRejected {}, globalCapReached: False {}, recvRateLimited: False {}, noPresence: False {}, nonceCutoffRejected: True {}}
            else do
          totalMsgCount <- *totalMessageCount
          if totalMsgCount >= maxMessages
            then yield {forward: ForwardRejected {}, globalCapReached: True {}, recvRateLimited: False {}, noPresence: False {}, nonceCutoffRejected: False {}}
            else do
              recipientCounts <- readRcBucket bkt
              let recipientCount = getRecipientCount toKey recipientCounts
              effMaxPerRecipient <- effectiveMaxMessagesPerRecipient
              if recipientCount >= effMaxPerRecipient
                then yield {forward: ForwardRejected {}, globalCapReached: False {}, recvRateLimited: False {}, noPresence: False {}, nonceCutoffRejected: False {}}
                else do
                  recvRates <- *recvRates
                  recvRate <- effectiveRecvRate
                  let recvResult = checkPubkeyRate recvRates toKey recvRate recvRateWindowMs maxRecvRateEntries t
                  if recvResult.limited
                    then yield {forward: ForwardRejected {}, globalCapReached: False {}, recvRateLimited: True {}, noPresence: False {}, nonceCutoffRejected: False {}}
                    else do
                      set *recvRates = recvResult.entries
                      federationPairRates <- *federationPairRates
                      let fedPairResult = checkServerRecipientRate federationPairRates fromServer toKey maxFederationPairRatePerPair federationPairRateWindowMs maxFederationPairRateEntries t
                      if fedPairResult.limited
                        then yield {forward: ForwardRejected {}, globalCapReached: False {}, recvRateLimited: False {}, noPresence: False {}, nonceCutoffRejected: False {}}
                        else do
                      set *federationPairRates = fedPairResult.entries
                      seqCounter <- *seqCounter
                      let seqTs = nextSeqTs t seqCounter
                      set *seqCounter = seqTs
                      -- Use sender-specified TTL if provided and still in the future; clamp to local max.
                      -- expiresAt == 0 means pre-v10 peer or unset; fall back to server default.
                      let fwdExpiresAt = if expiresAt > 0 && expiresAt > t then min expiresAt (seqTs + unackedMessageMaxAge) else seqTs + unackedMessageMaxAge
                      let clampedPriority = clamp 0 maxMessagePriority priority
                      writeMessageBucket bkt (union bucket
                        [{messageId: messageId, toKey: toKey,
                          encryptedBlob: encryptedBlob, timestamp: clampedTs, originServer: originServer, receivedAt: seqTs, expiresAt: fwdExpiresAt, senderKey: "", priority: clampedPriority}])
                      set *totalMessageCount = totalMsgCount + 1
                      writeRcBucket bkt (adjustRecipientCount recipientCounts toKey 1)
                      signalMessageForKey toKey seqTs
                      -- Record forward nonce for replay protection beyond message/ack dedup lifetime.
                      recordForwardNonce messageId toKey t
                      yield {forward: ForwardStored {}, globalCapReached: False {}, recvRateLimited: False {}, noPresence: False {}, nonceCutoffRejected: False {}}
    if result.noPresence then do
      logWarn ("forward: rejected for " ++ toKey ++ " — no active presence on this server (from " ++ fromServer ++ ")")
      yield (respond {ok: False {}, error: "no_presence", retryAfterMs: 0})
    else do
    case result.forward of
      ForwardRejected {} ->
        if result.nonceCutoffRejected
          then logEvent "warn" "forward_nonce_cutoff" ("messageId=" ++ messageId ++ " key=" ++ toKey ++ " from=" ++ fromServer ++ " — timestamp older than nonce eviction cutoff, possible replay")
          else if result.globalCapReached
          then logWarn ("forward: global message cap reached (" ++ show maxMessages ++ "), rejecting for " ++ toKey)
          else if result.recvRateLimited
          then do effRecv <- effectiveRecvRate; logEvent "warn" "rate_limited_recv" ("key=" ++ toKey ++ " limit=" ++ show effRecv)
          else logWarn ("forward: rejected for " ++ toKey ++ " (mailbox full, max " ++ show maxMessagesPerRecipient ++ ")")
      _ -> yield {}
    yield (case result.forward of
      ForwardRejected {} -> respond {ok: False {}, error: if result.nonceCutoffRejected then "nonce_cutoff" else "mailbox_full", retryAfterMs: 0}
      _ -> respond {ok: True {}, error: "", retryAfterMs: 0}))

-- Generate sender delivery receipts for messages confirmed delivered via federation ack.
-- Uses senderKey from the ForwardEntry directly (stored since v12), so receipts are
-- generated even if the original message was already pruned from the mailbox.
-- Falls back to message lookup for pre-v12 forward entries where senderKey is "".
-- Per-bucket: only reads message buckets containing the acked recipients.
fedDeliveryReceipts : [Int] -> [ForwardEntry] -> Timestamp -> IO ()
fedDeliveryReceipts = \bucketIds forwards t -> case headOf bucketIds of
  Nothing {} -> yield {}
  Just {value: b} -> do
    let rest = do x <- bucketIds; where x != b; yield x
    let bucketFwds = do f <- forwards; where pubkeyBucket f.toKey == b; yield f
    -- Fast path: forward entries with senderKey (v12+) don't need message lookup
    let fromForwards = do f <- bucketFwds; where f.senderKey != ""; yield {senderKey: f.senderKey, messageId: f.messageId, toKey: f.toKey, deliveredAt: t}
    -- Fallback: pre-v12 entries without senderKey — look up the original message
    let needLookup = do f <- bucketFwds; where f.senderKey == ""; yield f
    msgDeliveries <- if count needLookup > 0
      then atomic do
        msgs <- readMessageBucket b
        yield (do f <- needLookup; m <- msgs; where m.messageId == f.messageId && m.toKey == f.toKey && m.senderKey != "" && m.originServer == ""; yield {senderKey: m.senderKey, messageId: m.messageId, toKey: m.toKey, deliveredAt: t})
      else yield []
    let deliveries = union fromForwards msgDeliveries
    when (count deliveries > 0) (atomic do
      sd <- *senderDeliveries
      -- Dedup: skip receipts already recorded (avoids duplicates from concurrent ack paths)
      let deduped = do d <- deliveries; where none sd (\e -> e.messageId == d.messageId && e.toKey == d.toKey); yield d
      let combined = union sd deduped
      let overCap = count combined > maxSenderDeliveries
      if overCap then do
        -- Batch eviction: evict 2% of capacity instead of 1 entry at a time.
        -- Amortizes the O(n) scan cost across multiple inserts, reducing overhead
        -- under sustained capacity pressure from O(n) per insert to O(n) per 2% fills.
        let evictCount = max 1 (count combined - maxSenderDeliveries + maxSenderDeliveries / 50)
        let eviction = evictSmallest combined evictCount (\d -> d.deliveredAt)
        set *senderDeliveries = eviction.kept
        -- Track per-sender drop counts for all evicted entries
        let dropCounts = fold (\acc e -> incrementDropCounter acc e.senderKey 1 t) [] eviction.evicted
        when (count dropCounts > 0) (do
          ddr <- *droppedDeliveryReceipts
          set *droppedDeliveryReceipts = fold (\acc dc -> incrementDropCounter acc dc.senderKey dc.count t) ddr dropCounts)
      else set *senderDeliveries = combined)
    fedDeliveryReceipts rest forwards t

-- POST /federation/ack: Peer server confirms delivery of messages we originated.
-- Removes corresponding forward entries. Also cleans up the original message if the
-- recipient has no local presence and no other pending forwards for that message.
handleFederationAck = \messageIds originServer fromServer requestTimestamp correlationId authorization respond -> do
  t <- now
  let corrId = sanitizeCorrelationId correlationId
  when (corrId != "") (logInfo ("[CORR] " ++ corrId ++ " ack from " ++ fromServer))
  -- Wrap respond to add ackedCount default for withFederationAuth error paths
  let ackRespond = \r -> respond {ok: r.ok, error: r.error, ackedCount: 0, results: [], retryAfterMs: r.retryAfterMs}
  -- clearOnAuth=False: defer clearFailure until we confirm the ack matched actual
  -- forward entries. Prevents a peer from resetting its failure/backoff counters by
  -- spamming acks for messageIds we never forwarded to it.
  withFederationAuth authorization t ackRespond fromServer "ack" requestTimestamp (isLocalServer originServer && not (isLocalServer fromServer)) (False {}) (do
    let dedupedIds = dedupMessageIds messageIds
    -- Clear forward entries for the acking server. Extract removed forwards' toKey
    -- so we can reclaim origin messages that are no longer needed.
    -- Optimized: scan all 16 forward buckets but only rewrite those that changed.
    -- Avoids the O(n) writeAllForwards repartitioning when only a few buckets are affected.
    removedForwards <- removeForwardsByServer fromServer dedupedIds 0 []
    let ackedCount = count removedForwards
    let unmatched = count dedupedIds - ackedCount
    -- Reject when ALL acked IDs are unmatched: the peer is acking messages we never
    -- forwarded to it. Partial matches are accepted (some forwards may have been pruned).
    if ackedCount == 0 && count dedupedIds > 0
      then do
        logWarn ("federation/ack: rejecting ack from " ++ fromServer ++ " — all " ++ show (count dedupedIds) ++ " messageIds unmatched (no forward entries)")
        logEvent "warn" "ack_all_unmatched" (fromServer ++ " " ++ show (count dedupedIds))
        yield (respond {ok: False {}, error: "no_matching_forwards", ackedCount: 0, results: do mid <- dedupedIds; yield {messageId: mid, found: False {}}, retryAfterMs: 0})
      else do
    when (unmatched > 0) (do
      logWarn ("federation/ack: " ++ fromServer ++ " acked " ++ show unmatched ++ " messageIds with no matching forward entries — skipping cleanup for those")
      logEvent "warn" "ack_partial_unmatched" (fromServer ++ " " ++ show unmatched ++ "/" ++ show (count dedupedIds)))
    -- Only clear failure record when ALL acked IDs matched forward entries.
    -- Prevents a malicious peer from resetting its backoff by padding ack requests
    -- with known messageIds that no longer have forward entries.
    when (ackedCount > 0 && unmatched == 0) (clearFailure fromServer)
    -- Generate delivery receipts for locally-originated messages confirmed delivered via federation.
    -- Looks up the original message (still on this server) to get senderKey.
    when (ackedCount > 0) (do
      let receiptBuckets = uniqueBucketsFor removedForwards (\f -> f.toKey)
      fedDeliveryReceipts receiptBuckets removedForwards t)
    -- Deferred origin message cleanup: only queue cleanup for messages that actually had
    -- matching forward entries. Messages acked without a forward entry are NOT cleaned up,
    -- preventing premature deletion when a peer acks messages it never actually received.
    when (ackedCount > 0) (do
      capWarning <- atomic do
        cleanups <- *pendingAckCleanups
        let newCleanups = do f <- removedForwards; yield {messageId: f.messageId, toKey: f.toKey, cleanupAfter: t + ackGracePeriod}
        -- Per-key cap: limit cleanups per recipient to prevent one noisy key from dominating the queue
        let perKeyCapped = fold (\acc c ->
          let existingForKey = count (do x <- acc; where x.toKey == c.toKey; yield x)
          in if existingForKey >= maxPendingAckCleanupsPerKey then acc else union acc [c])
          cleanups newCleanups
        let perKeyDropped = count newCleanups - (count perKeyCapped - count cleanups)
        let globalCapped = count perKeyCapped > maxPendingAckCleanups
        set *pendingAckCleanups = if globalCapped then takeRelation maxPendingAckCleanups perKeyCapped else perKeyCapped
        yield {perKeyDropped: perKeyDropped, globalCapped: globalCapped}
      when (capWarning.perKeyDropped > 0)
        (logWarn ("federation/ack: dropped " ++ show capWarning.perKeyDropped ++ " deferred cleanups (per-key cap " ++ show maxPendingAckCleanupsPerKey ++ " reached) — origin messages may not be reclaimed"))
      when capWarning.globalCapped
        (logWarn ("federation/ack: pendingAckCleanups at global capacity (" ++ show maxPendingAckCleanups ++ ") — oldest entries truncated, origin messages may not be reclaimed")))
    -- Per-message ack results: lets the origin server know which messageIds matched
    -- forward entries (found=True) vs which had no matching forward (found=False).
    -- Origin servers can drop entries with found=False from their retry queues instead
    -- of retrying indefinitely for messages that were already pruned or never forwarded.
    let perMessageResults = do mid <- dedupedIds; yield {messageId: mid, found: any removedForwards (\f -> f.messageId == mid)}
    yield (respond {ok: True {}, error: "", ackedCount: ackedCount, results: perMessageResults, retryAfterMs: 0}))

-- POST /federation/cancel: Cancel a previously forwarded message.
-- Called by the origin server when the sender retracts a message via /messages/cancel.
-- Deletes the message from the recipient's mailbox if it hasn't been polled yet.
-- If the message was already polled, returns cancelled=False (no-op).
-- NOTE: Only the origin server (fromServer == message's originServer) can cancel.
-- Relay cancels (where intermediate server B forwards A's cancel request) are not
-- supported in the current protocol. If server A originates a message, forwards it to B,
-- and B re-forwards to C, then A's /messages/cancel sends federation cancel to B and C
-- directly (via presence/forward targets). B cannot relay the cancel to C on A's behalf
-- because C would reject it (fromServer=B != originServer=A). This means cancel coverage
-- depends on the origin server knowing all forward destinations at cancel time.
handleFederationCancel = \messageId toKey fromServer requestTimestamp correlationId authorization respond -> do
  t <- now
  let corrId = sanitizeCorrelationId correlationId
  when (corrId != "") (logInfo ("[CORR] " ++ corrId ++ " cancel " ++ messageId ++ " from " ++ fromServer))
  let cancelRespond = \r -> respond {ok: r.ok, error: r.error, cancelled: False {}, retryAfterMs: r.retryAfterMs}
  withFederationAuth authorization t cancelRespond fromServer ("cancel:" ++ messageId) requestTimestamp (not (isLocalServer fromServer)) (False {}) (do
    result <- atomic do
      let b = pubkeyBucket toKey
      bucket <- readMessageBucket b
      -- Only cancel messages that originated from the requesting server
      let toCancel = headOf (do m <- bucket; where m.messageId == messageId && m.toKey == toKey && m.originServer == fromServer; yield m)
      case toCancel of
        Nothing {} -> yield {cancelled: False {}}
        Just {} -> do
          writeMessageBucket b (do m <- bucket; where not (m.messageId == messageId && m.toKey == toKey); yield m)
          tc <- *totalMessageCount
          set *totalMessageCount = max 0 (tc - 1)
          rc <- readRcBucket b
          writeRcBucket b (adjustRecipientCount rc toKey (0 - 1))
          -- Also cancel pending forwards for this message
          fwdBkt <- readFwdBucket b
          let keptFwds = do f <- fwdBkt; where not (f.messageId == messageId && f.toKey == toKey); yield f
          writeFwdBucket b keptFwds
          let fwdRemoved = count fwdBkt - count keptFwds
          when (fwdRemoved > 0) (do
            tfc <- *totalForwardCount
            set *totalForwardCount = max 0 (tfc - fwdRemoved))
          -- Record cancel nonce: prevents replayed federation forwards of the
          -- cancelled message from being accepted after dedup state expires.
          nonceBkt <- readNonceBucket b
          let updatedNonces = union nonceBkt [{messageId: messageId, toKey: toKey, seenAt: t}]
          writeNonceBucket b (if count updatedNonces > maxNoncesPerBucket
            then evictNonces updatedNonces maxNoncesPerBucket forwardNonceRetention t
            else updatedNonces)
          yield {cancelled: True {}}
    when result.cancelled (do
      logInfo ("federation/cancel: cancelled " ++ messageId ++ " for " ++ toKey ++ " (from " ++ fromServer ++ ")")
      queueCancelNotification toKey messageId t
      atomic do fcc <- *federationCancelCount; set *federationCancelCount = fcc + 1)
    yield (respond {ok: True {}, error: "", cancelled: result.cancelled, retryAfterMs: 0}))

-- POST /federation/cancel-batch: Batch cancel multiple previously forwarded messages.
-- Reuses the cancel logic from handleFederationCancel for each entry.
handleFederationBatchCancel = \cancels fromServer requestTimestamp correlationId authorization respond -> do
  t <- now
  let corrId = sanitizeCorrelationId correlationId
  when (corrId != "") (logInfo ("[CORR] " ++ corrId ++ " cancel-batch (" ++ show (count cancels) ++ " entries) from " ++ fromServer))
  let batchRespond = \r -> respond {ok: r.ok, error: r.error, results: [], retryAfterMs: r.retryAfterMs}
  withFederationAuth authorization t batchRespond fromServer "cancel-batch" requestTimestamp (not (isLocalServer fromServer) && count cancels <= maxBatchSize) (False {}) (do
    let capped = takeRelation maxBatchSize cancels
    results <- cancelBatchInner capped fromServer t []
    let cancelledCount = count (do r <- results; where r.cancelled; yield r)
    when (cancelledCount > 0) (do
      logInfo ("federation/cancel-batch: cancelled " ++ show cancelledCount ++ "/" ++ show (count capped) ++ " messages from " ++ fromServer)
      atomic do fcc <- *federationCancelCount; set *federationCancelCount = fcc + cancelledCount)
    yield (respond {ok: True {}, error: "", results: results, retryAfterMs: 0}))

-- Process cancel entries grouped by bucket: all entries sharing a pubkeyBucket are
-- processed in a single atomic block, reducing bucket reads from O(entries) to O(buckets).
cancelBatchInner = \entries fromServer t acc ->
  case headOf entries of
    Nothing {} -> yield acc
    Just {value: first} -> do
      let b = pubkeyBucket first.toKey
      -- Collect all entries targeting the same bucket
      let sameBucket = do e <- entries; where pubkeyBucket e.toKey == b; yield e
      let otherBuckets = do e <- entries; where pubkeyBucket e.toKey != b; yield e
      -- Process the entire bucket group in one atomic block.
      -- Read buckets once upfront and thread state through the recursion.
      results <- atomic do
        bucket <- readMessageBucket b
        fwdBkt <- readFwdBucket b
        nonceBkt <- readNonceBucket b
        rc <- readRcBucket b
        r <- cancelBucketGroupInner sameBucket fromServer b t [] bucket fwdBkt nonceBkt rc 0 0
        -- Write back all modified buckets once after processing all entries
        writeMessageBucket b r.bucket
        writeFwdBucket b r.fwdBkt
        writeNonceBucket b r.nonceBkt
        writeRcBucket b r.rc
        -- Batch-adjust shared counters once (not per-entry)
        when (r.msgRemoved > 0) (do
          tc <- *totalMessageCount
          set *totalMessageCount = max 0 (tc - r.msgRemoved))
        when (r.fwdRemoved > 0) (do
          tfc <- *totalForwardCount
          set *totalForwardCount = max 0 (tfc - r.fwdRemoved))
        yield r.acc
      -- Queue cancel notifications for successfully cancelled messages in this bucket group
      let cancelled = do r <- results; where r.cancelled; yield r
      let cancelledEntries = do c <- cancelled; e <- sameBucket; where e.messageId == c.messageId; yield e
      case headOf cancelledEntries of
        Nothing {} -> yield {}
        Just {} -> do
          queueCancelNotificationBatch cancelledEntries t
      cancelBatchInner otherBuckets fromServer t (union acc results)

-- Process all cancel entries for a single bucket within one atomic block.
-- Threads bucket state through recursion to avoid redundant per-entry reads.
-- Accumulates removal counts for batch counter adjustment after the loop.
cancelBucketGroupInner = \entries fromServer b t acc bucket fwdBkt nonceBkt rc msgRemoved fwdRemoved ->
  case headOf entries of
    Nothing {} -> yield {acc: acc, bucket: bucket, fwdBkt: fwdBkt, nonceBkt: nonceBkt, rc: rc, msgRemoved: msgRemoved, fwdRemoved: fwdRemoved}
    Just {value: entry} -> do
      let rest = do e <- entries; where e.messageId != entry.messageId || e.toKey != entry.toKey; yield e
      let toCancel = headOf (do m <- bucket; where m.messageId == entry.messageId && m.toKey == entry.toKey && m.originServer == fromServer; yield m)
      case toCancel of
        Nothing {} ->
          cancelBucketGroupInner rest fromServer b t (union acc [{messageId: entry.messageId, cancelled: False {}}]) bucket fwdBkt nonceBkt rc msgRemoved fwdRemoved
        Just {} -> do
          let newBucket = do m <- bucket; where not (m.messageId == entry.messageId && m.toKey == entry.toKey); yield m
          let newRc = adjustRecipientCount rc entry.toKey (0 - 1)
          let newFwdBkt = do f <- fwdBkt; where not (f.messageId == entry.messageId && f.toKey == entry.toKey); yield f
          let entryFwdRemoved = count fwdBkt - count newFwdBkt
          -- Record cancel nonce for replay protection
          let updatedNonces = union nonceBkt [{messageId: entry.messageId, toKey: entry.toKey, seenAt: t}]
          let newNonceBkt = if count updatedNonces > maxNoncesPerBucket
            then evictNonces updatedNonces maxNoncesPerBucket forwardNonceRetention t
            else updatedNonces
          cancelBucketGroupInner rest fromServer b t (union acc [{messageId: entry.messageId, cancelled: True {}}]) newBucket newFwdBkt newNonceBkt newRc (msgRemoved + 1) (fwdRemoved + entryFwdRemoved)

-- POST /federation/forward-batch: Receive multiple forwarded messages in one request.
-- Each message is processed independently (same logic as handleForwardMessage).
-- Partial success is possible; per-message results are returned.
handleFederationBatchForward = \forwards fromServer requestTimestamp correlationId authorization respond -> do
  t <- now
  let corrId = sanitizeCorrelationId correlationId
  when (corrId != "") (logInfo ("[CORR] " ++ corrId ++ " forward-batch (" ++ show (count forwards) ++ " entries) from " ++ fromServer))
  let batchRespond = \r -> respond {ok: r.ok, error: r.error, results: [], retryAfterMs: r.retryAfterMs}
  withFederationAuth authorization t batchRespond fromServer "forward-batch" requestTimestamp (not (isLocalServer fromServer) && count forwards <= maxBatchSize) (True {}) (do
    let capped = takeRelation maxBatchSize forwards
    -- Pre-deduplicate (messageId, toKey) pairs: a malicious peer could send 100 entries
    -- for the same pair, each triggering a full atomic block (presence check, 5 bucket reads).
    -- Dedup keeps the first occurrence; subsequent duplicates are silently dropped.
    let deduped = fold (\acc f -> if any acc (\a -> a.messageId == f.messageId && a.toKey == f.toKey) then acc else union acc [f]) [] capped
    results <- forwardBatchInner deduped fromServer t []
    let storedCount = count (do r <- results; where r.ok; yield r)
    when (storedCount > 0)
      (logInfo ("federation/forward-batch: stored " ++ show storedCount ++ "/" ++ show (count capped) ++ " messages from " ++ fromServer))
    yield (respond {ok: True {}, error: "", results: results, retryAfterMs: 0}))

-- Process forward entries grouped by bucket: all entries sharing a pubkeyBucket(toKey) are
-- processed in a single atomic block, reducing bucket reads from O(entries) to O(buckets).
-- Pre-validation (timestamp, origin) runs outside the atomic block since it reads global state.
forwardBatchInner = \entries fromServer t acc ->
  case headOf entries of
    Nothing {} -> yield acc
    Just {value: first} -> do
      -- Pre-validate all entries: reject stale timestamps and untrusted relay origins.
      -- Read global state once before the loop (not per-entry) to avoid redundant IO.
      knownPeers <- *knownPeerServers
      blocked <- *blockedPeers
      allowed <- *allowedPeers
      let validated = prevalidateForwardBatch entries fromServer t knownPeers blocked allowed [] []
      -- Group validated entries by bucket
      forwardBatchByBucket validated.valid fromServer t (union acc validated.rejected)

-- Pre-validate forward entries: reject stale timestamps and untrusted relay origins.
-- Returns {valid: entries to store, rejected: per-message results for failed entries}.
-- Pure function: global state (knownPeers, blocked, allowed) is passed in by caller.
prevalidateForwardBatch = \entries fromServer t knownPeers blocked allowed validAcc rejectedAcc ->
  case headOf entries of
    Nothing {} -> {valid: validAcc, rejected: rejectedAcc}
    Just {value: entry} ->
      let rest = do e <- entries; where e.messageId != entry.messageId || e.toKey != entry.toKey; yield e in
      if isLocalServer entry.originServer || t - entry.timestamp > messageMaxAge
        then prevalidateForwardBatch rest fromServer t knownPeers blocked allowed validAcc (union rejectedAcc [{messageId: entry.messageId, ok: False {}}])
        else
      -- Relay origin verification (same as handleForwardMessage)
      let originOk = if fromServer == entry.originServer then True {}
        else any knownPeers (\p -> p == entry.originServer)
          && not (isBlockedPeer entry.originServer blocked)
          && isAllowedByAllowlist entry.originServer allowed
      in if not originOk
        then prevalidateForwardBatch rest fromServer t knownPeers blocked allowed validAcc (union rejectedAcc [{messageId: entry.messageId, ok: False {}}])
        else prevalidateForwardBatch rest fromServer t knownPeers blocked allowed (union validAcc [entry]) rejectedAcc

-- Group validated entries by pubkeyBucket and process each group in one atomic block.
forwardBatchByBucket = \entries fromServer t acc ->
  case headOf entries of
    Nothing {} -> yield acc
    Just {value: first} -> do
      let b = pubkeyBucket first.toKey
      let sameBucket = do e <- entries; where pubkeyBucket e.toKey == b; yield e
      let otherBuckets = do e <- entries; where pubkeyBucket e.toKey != b; yield e
      -- Process the entire bucket group in one atomic block.
      -- Read bucket-local state once upfront and thread through the recursion.
      results <- atomic do
        presenceBkt <- readPresenceBucket b
        bucket <- readMessageBucket b
        ackedBkt <- readAckedBucket b
        delivBkt <- readDelivBucket b
        nonceBkt <- readNonceBucket b
        rc <- readRcBucket b
        rr <- *recvRates
        fpr <- *federationPairRates
        r <- forwardBucketGroupInner sameBucket fromServer b t [] presenceBkt bucket ackedBkt delivBkt nonceBkt rc 0 rr fpr
        -- Write back modified bucket-local state once after processing all entries
        writeMessageBucket b r.bucket
        writeNonceBucket b r.nonceBkt
        writeRcBucket b r.rc
        set *recvRates = r.recvRates
        set *federationPairRates = r.fedPairRates
        -- Batch-adjust totalMessageCount once (not per-entry)
        when (r.msgStored > 0) (do
          tc <- *totalMessageCount
          set *totalMessageCount = tc + r.msgStored)
        yield r.acc
      forwardBatchByBucket otherBuckets fromServer t (union acc results)

-- Process all forward entries for a single bucket within one atomic block.
-- Threads bucket-local state through recursion to avoid redundant per-entry reads.
-- recvRates and federationPairRates are threaded through to avoid re-reading shared
-- refs per entry (was O(entries) reads, now O(1) read + O(1) write per bucket group).
-- seqCounter is still read per-entry since it must monotonically increase.
forwardBucketGroupInner = \entries fromServer b t acc presenceBkt bucket ackedBkt delivBkt nonceBkt rc msgStored rr fpr ->
  case headOf entries of
    Nothing {} -> yield {acc: acc, bucket: bucket, nonceBkt: nonceBkt, rc: rc, msgStored: msgStored, recvRates: rr, fedPairRates: fpr}
    Just {value: entry} -> do
      let rest = do e <- entries; where e.messageId != entry.messageId || e.toKey != entry.toKey; yield e
      let clampedTs = clampTimestamp entry.timestamp t
      let hasPresence = any presenceBkt (\p -> p.pubkey == entry.toKey && p.expiresAt > t)
      if not hasPresence
        then forwardBucketGroupInner rest fromServer b t (union acc [{messageId: entry.messageId, ok: False {}}]) presenceBkt bucket ackedBkt delivBkt nonceBkt rc msgStored rr fpr
        else do
          let isDup = checkMessageDup bucket entry.messageId entry.toKey || hasMessage entry.messageId entry.toKey ackedBkt || hasMessage entry.messageId entry.toKey delivBkt || any nonceBkt (\n -> n.messageId == entry.messageId && n.toKey == entry.toKey)
          if isDup
            then forwardBucketGroupInner rest fromServer b t (union acc [{messageId: entry.messageId, ok: True {}}]) presenceBkt bucket ackedBkt delivBkt nonceBkt rc msgStored rr fpr
            else do
              -- Nonce eviction replay protection (per-bucket cutoff, matches handleForwardMessage)
              nonceCutoff <- readNonceCutoff b
              if nonceCutoff > 0 && entry.timestamp > 0 && entry.timestamp < nonceCutoff
                then forwardBucketGroupInner rest fromServer b t (union acc [{messageId: entry.messageId, ok: False {}}]) presenceBkt bucket ackedBkt delivBkt nonceBkt rc msgStored rr fpr
                else do
              totalMsgCount <- *totalMessageCount
              let recipientCount = getRecipientCount entry.toKey rc
              effMaxPerRecipient <- effectiveMaxMessagesPerRecipient
              if totalMsgCount + msgStored >= maxMessages || recipientCount >= effMaxPerRecipient
                then forwardBucketGroupInner rest fromServer b t (union acc [{messageId: entry.messageId, ok: False {}}]) presenceBkt bucket ackedBkt delivBkt nonceBkt rc msgStored rr fpr
                else do
                  -- Per-recipient receive rate limiting (matches handleForwardMessage)
                  let recvResult = checkPubkeyRate rr entry.toKey maxRecvRatePerKey recvRateWindowMs maxRecvRateEntries t
                  if recvResult.limited
                    then forwardBucketGroupInner rest fromServer b t (union acc [{messageId: entry.messageId, ok: False {}}]) presenceBkt bucket ackedBkt delivBkt nonceBkt rc msgStored rr fpr
                    else do
                      -- Per-server-per-recipient rate limiting (matches handleForwardMessage)
                      let fedPairResult = checkServerRecipientRate fpr fromServer entry.toKey maxFederationPairRatePerPair federationPairRateWindowMs maxFederationPairRateEntries t
                      if fedPairResult.limited
                        then forwardBucketGroupInner rest fromServer b t (union acc [{messageId: entry.messageId, ok: False {}}]) presenceBkt bucket ackedBkt delivBkt nonceBkt rc msgStored recvResult.entries fpr
                        else do
                          seqCounter <- *seqCounter
                          let seqTs = nextSeqTs t seqCounter
                          set *seqCounter = seqTs
                          let fwdExpiresAt = if entry.expiresAt > 0 && entry.expiresAt > t then min entry.expiresAt (seqTs + unackedMessageMaxAge) else seqTs + unackedMessageMaxAge
                          let batchClampedPriority = clamp 0 maxMessagePriority entry.priority
                          let newBucket = union bucket
                            [{messageId: entry.messageId, toKey: entry.toKey,
                              encryptedBlob: entry.encryptedBlob, timestamp: clampedTs, originServer: entry.originServer, receivedAt: seqTs, expiresAt: fwdExpiresAt, senderKey: "", priority: batchClampedPriority}]
                          let newRc = adjustRecipientCount rc entry.toKey 1
                          signalMessageForKey entry.toKey seqTs
                          let updatedNonces = union nonceBkt [{messageId: entry.messageId, toKey: entry.toKey, seenAt: t}]
                          let newNonceBkt = if count updatedNonces > maxNoncesPerBucket
                            then evictNonces updatedNonces maxNoncesPerBucket forwardNonceRetention t
                            else updatedNonces
                          forwardBucketGroupInner rest fromServer b t (union acc [{messageId: entry.messageId, ok: True {}}]) presenceBkt newBucket ackedBkt delivBkt newNonceBkt newRc (msgStored + 1) recvResult.entries fedPairResult.entries

-- POST /federation/delivery-receipt: Destination server notifies origin that federated
-- messages were polled/acked by the recipient. The origin server records delivery receipts
-- so the sender can see "delivered" status via their next poll response.
-- Best-effort: uses federation rate limiting but failures are not retried. The federation
-- ack path already confirms protocol-level delivery; receipts are a UX enhancement.
handleFederationDeliveryReceipt = \messageIds toKeys fromServer requestTimestamp correlationId authorization respond -> do
  t <- now
  let corrId = sanitizeCorrelationId correlationId
  when (corrId != "") (logInfo ("[CORR] " ++ corrId ++ " delivery-receipt from " ++ fromServer))
  let receiptRespond = \r -> respond {ok: r.ok, error: r.error, receivedCount: 0, retryAfterMs: r.retryAfterMs}
  withFederationAuth authorization t receiptRespond fromServer "delivery-receipt" requestTimestamp (not (isLocalServer fromServer) && count messageIds <= maxMessageIds) (False {}) (do
    -- Pair messageIds with toKeys (parallel arrays). Reject if lengths differ.
    if count messageIds != count toKeys
      then yield (respond {ok: False {}, error: "mismatched_lengths", receivedCount: 0, retryAfterMs: 0})
      else do
    -- Zip parallel arrays into pairs upfront (O(n) once), then consume head-first.
    -- Previous code used fold-to-index-N per element, making receiptsByBucket O(n^2).
    let capped = takeRelation maxMessageIds messageIds
    let pairs = zipParallelArrays capped toKeys
    -- Look up senderKey per-bucket and record delivery receipts
    receiptsByBucket pairs t
    yield (respond {ok: True {}, error: "", receivedCount: count pairs, retryAfterMs: 0}))

-- Zip two parallel arrays into a list of {messageId, toKey} pairs.
-- Consumes both lists head-first in O(n), replacing the O(n^2) fold-to-index pattern.
-- Uses skipRelation 1 instead of filter-not-equal to correctly handle duplicate values:
-- filter (where m != mid) removes ALL occurrences of mid, corrupting the pairing when
-- the same messageId appears multiple times (e.g., same message sent to different recipients).
-- skipRelation 1 removes only the first element regardless of duplicates.
zipParallelArrays : [MessageIdHex] -> [PubkeyHex] -> [{messageId: MessageIdHex, toKey: PubkeyHex}]
zipParallelArrays = \mids keys ->
  case headOf mids of
    Nothing {} -> []
    Just {value: mid} ->
      case headOf keys of
        Nothing {} -> []
        Just {value: key} ->
          union [{messageId: mid, toKey: key}] (zipParallelArrays (skipRelation 1 mids) (skipRelation 1 keys))

-- Look up senderKey from messages and record delivery receipts.
-- Groups pairs by pubkeyBucket so each message bucket is read once per group instead
-- of once per receipt. With 10 receipts targeting the same bucket, this reduces bucket
-- reads from 10 to 1 (and senderDeliveries reads/writes from 10 to 1).
receiptsByBucket : [{messageId: MessageIdHex, toKey: PubkeyHex}] -> Timestamp -> IO ()
receiptsByBucket = \pairs t ->
  case headOf pairs of
    Nothing {} -> yield {}
    Just {value: first} -> do
      let b = pubkeyBucket first.toKey
      let sameBucket = do p <- pairs; where pubkeyBucket p.toKey == b; yield p
      let otherBuckets = do p <- pairs; where pubkeyBucket p.toKey != b; yield p
      -- Process all pairs for this bucket in a single atomic block
      atomic do
        bucket <- readMessageBucket b
        sd <- *senderDeliveries
        let updatedSd = receiptsBucketInner sameBucket bucket sd t
        set *senderDeliveries = updatedSd
      receiptsByBucket otherBuckets t

-- Process all receipt pairs for one bucket within a single atomic read.
-- Threads senderDeliveries through so each new receipt sees previous ones (dedup).
receiptsBucketInner : [{messageId: MessageIdHex, toKey: PubkeyHex}] -> [Message] -> [SenderDelivery] -> Timestamp -> [SenderDelivery]
receiptsBucketInner = \pairs bucket sd t ->
  case headOf pairs of
    Nothing {} -> sd
    Just {value: pair} ->
      let rest = do p <- pairs; where p.messageId != pair.messageId || p.toKey != pair.toKey; yield p in
      let msg = headOf (do m <- bucket; where m.messageId == pair.messageId && m.toKey == pair.toKey && m.senderKey != "" && m.originServer == ""; yield m) in
      case msg of
        Nothing {} -> receiptsBucketInner rest bucket sd t
        Just {value: m} ->
          let isDup = any sd (\d -> d.messageId == pair.messageId && d.toKey == pair.toKey) in
          if isDup then receiptsBucketInner rest bucket sd t
          else let combined = union sd [{senderKey: m.senderKey, messageId: pair.messageId, toKey: pair.toKey, deliveredAt: t}] in
            let updatedSd = if count combined > maxSenderDeliveries
              then evictOneOldest combined (\d -> d.deliveredAt)
              else combined
            in receiptsBucketInner rest bucket updatedSd t

-- POST /messages/cancel-batch: Cancel multiple sent messages in one request.
-- Auth checked once; each cancel processed independently. Partial success possible.
handleCancelBatch = \cancels authorization clientIp respond -> do
  t <- now
  dp <- *drainPhase
  if dp >= 2 then yield (respond {results: [], authorized: False {}, error: ""})
  else do
  globalRateLimited <- checkGlobalRate t
  if globalRateLimited then yield (respond {results: [], authorized: False {}, error: "rate_limited:" ++ show globalRateWindowMs ++ "ms"})
  else
    withSessionAuth authorization t clientIp
      (yield (respond {results: [], authorized: False {}, error: "unauthorized"}))
      (\senderKey -> do
        cancelRateLimited <- atomic do
          cwr <- *clientWriteRates
          cwRate <- effectiveClientWriteRate
          let rateResult = checkPubkeyRate cwr senderKey cwRate clientWriteRateWindowMs maxClientWriteRateEntries t
          set *clientWriteRates = rateResult.entries
          yield rateResult.limited
        if cancelRateLimited then yield (respond {results: [], authorized: True {}, error: "rate_limited:" ++ show clientWriteRateWindowMs ++ "ms"})
        else do
          let capped = takeRelation maxBatchSize cancels
          -- Process each cancel, collecting results and per-server cancel targets
          results <- clientCancelBatchInner senderKey capped t [] []
          -- Send federation batch cancels grouped by server.
          -- Failed cancels are queued for retry during the next prune cycle.
          fork (when (federationEnabled && count results.cancelServers > 0)
            (sendToEach results.cancelServers (\server -> do
              let serverCancels = do c <- results.fedCancels; where any c.servers (\s -> s == server); yield {messageId: c.messageId, toKey: c.toKey}
              when (count serverCancels > 0) (do
                cancelT <- now
                cancelAuth <- generateFederationAuth "cancel-batch" cancelT
                cancelCorrId <- genTokenN 1
                cancelResult <- fetchFederation server (FederationBatchCancel {
                  cancels: serverCancels, fromServer: serverHostN,
                  requestTimestamp: cancelT, correlationId: cancelCorrId,
                  authorization: cancelAuth, protocolVersion: federationProtocolVersion})
                case cancelResult of
                  Err e -> do
                    logWarn ("federation: batch cancel to " ++ server ++ " failed: " ++ show e)
                    queuePendingCancels serverCancels server cancelT
                  Ok r -> when (not r.ok) (do
                    logWarn ("federation: batch cancel to " ++ server ++ " rejected: " ++ r.error)
                    queuePendingCancels serverCancels server cancelT)))))
          yield (respond {results: results.results, authorized: True {}, error: ""}))

-- Process each client cancel entry, returning results and federation cancel targets.
clientCancelBatchInner = \senderKey entries t resultAcc fedAcc ->
  case headOf entries of
    Nothing {} -> do
      let allServers = fold (\acc c -> fold (\a s -> if any a (\x -> x == s) then a else union [s] a) acc c.servers) [] fedAcc
      yield {results: resultAcc, fedCancels: fedAcc, cancelServers: allServers}
    Just {value: entry} -> do
      let rest = do e <- entries; where e.messageId != entry.messageId || e.to != entry.to; yield e
      cancelResult <- atomic do
        let b = pubkeyBucket entry.to
        bucket <- readMessageBucket b
        let toCancel = headOf (do m <- bucket; where m.messageId == entry.messageId && m.toKey == entry.to; yield m)
        case toCancel of
          Nothing {} -> yield {cancelled: False {}, cancelServers: []}
          Just {value: msg} ->
            if msg.originServer != "" then yield {cancelled: False {}, cancelServers: []}
            else if msg.senderKey == "" || msg.senderKey != senderKey then yield {cancelled: False {}, cancelServers: []}
            else do
            writeMessageBucket b (do m <- bucket; where not (m.messageId == entry.messageId && m.toKey == entry.to); yield m)
            tc <- *totalMessageCount
            set *totalMessageCount = max 0 (tc - 1)
            rc <- readRcBucket b
            writeRcBucket b (adjustRecipientCount rc entry.to (0 - 1))
            fwdBkt <- readFwdBucket b
            let cancelledFwds = do f <- fwdBkt; where f.messageId == entry.messageId && f.toKey == entry.to; yield f
            let forwardTargetServers = collectPeerServers cancelledFwds (\f -> f.toServer)
            let fwdRemoved = count cancelledFwds
            writeFwdBucket b (do f <- fwdBkt; where not (f.messageId == entry.messageId && f.toKey == entry.to); yield f)
            when (fwdRemoved > 0) (do
              tfc <- *totalForwardCount
              set *totalForwardCount = max 0 (tfc - fwdRemoved))
            presenceBkt <- readPresenceBucket b
            let remotePresence = collectPeerServers (presenceForKey presenceBkt entry.to t) (\p -> p.server)
            let allCancelServers = fold (\acc s -> if any acc (\a -> a == s) then acc else union [s] acc) remotePresence forwardTargetServers
            -- Record cancel nonce: prevents replayed federation forwards of the
            -- cancelled message from being accepted after dedup state expires.
            nonceBkt <- readNonceBucket b
            let updatedNonces = union nonceBkt [{messageId: entry.messageId, toKey: entry.to, seenAt: t}]
            writeNonceBucket b (if count updatedNonces > maxNoncesPerBucket
              then evictNonces updatedNonces maxNoncesPerBucket forwardNonceRetention t
              else updatedNonces)
            yield {cancelled: True {}, cancelServers: allCancelServers}
      when cancelResult.cancelled (do
        queueCancelNotification entry.to entry.messageId t
        atomic do cc <- *clientCancelCount; set *clientCancelCount = cc + 1)
      let newFedAcc = if cancelResult.cancelled && count cancelResult.cancelServers > 0
        then union fedAcc [{messageId: entry.messageId, toKey: entry.to, servers: cancelResult.cancelServers}]
        else fedAcc
      clientCancelBatchInner senderKey rest t (union resultAcc [{messageId: entry.messageId, cancelled: cancelResult.cancelled}]) newFedAcc

-- POST /maintenance/drain: Broadcast offline gossip for all local keys (graceful shutdown).
-- Call before stopping the server so peers learn keys went offline immediately.
-- Gossip is sent via fork; allow a few seconds after response before process exit.
-- phase: 0 or 2 = full drain (backward compat default), 1 = soft drain (block new auth only)
handleDrain = \phase authorization respond -> do
  t <- now
  authorized <- verifyMaintenanceAuth authorization
  if not authorized then yield (respond {ok: False {}, drained: 0, phase: 0})
  else do
    logEvent "audit" "drain" ("phase=" ++ show phase)
    -- Effective phase: 0 or >=2 means full drain (backward compat for clients sending empty body)
    let effectivePhase = if phase == 1 then 1 else 2
    -- Idempotency: if already at or above requested phase, return success.
    currentPhase <- *drainPhase
    if currentPhase >= effectivePhase then do
      logInfo ("drain: already at phase " ++ show currentPhase ++ ", skipping")
      yield (respond {ok: True {}, drained: 0, phase: currentPhase})
    -- Soft drain (phase 1): block new auth but keep serving existing sessions.
    -- No gossip or flush needed since sessions are still active.
    else if effectivePhase == 1 then do
      atomic do set *drainPhase = 1
      logInfo "drain: soft drain active (new auth blocked, existing sessions served)"
      yield (respond {ok: True {}, drained: 0, phase: 1})
    else do
    drainResult <- atomic do
      set *drainPhase = 2
      allPresence <- readAllPresence
      let localEntries = do p <- allPresence; where isLocalServer p.server && p.expiresAt > t; yield p
      let remainingPresence = do p <- allPresence; where not (isLocalServer p.server) || p.expiresAt <= t; yield p
      writeAllPresence remainingPresence
      set *totalPresenceCount = count remainingPresence
      set *presenceVersion = t
      set *pollWakeup = t
      -- Use cached knownPeerServers instead of recomputing from allPresence
      -- (knownPeerServers is updated every prune cycle, equivalent for gossip targets)
      peerServers <- *knownPeerServers
      yield {localEntries: localEntries, peerServers: peerServers}
    let drainedCount = count drainResult.localEntries
    -- Read pending federation state atomically (fix: was read outside atomic)
    flushState <- atomic do
      f <- readAllForwards
      a <- readAllAcked
      let pa = do x <- a; where not (isLocalServer x.originServer); yield x
      yield {forwards: f, pendingAcks: pa}
    let pendingForwardCount = count flushState.forwards
    let pendingAckCount = count flushState.pendingAcks
    -- Fork best-effort flush of pending federation ops, then gossip, then wait for in-flight.
    -- Operator polls /stats for drainCompletedAt > 0 to know when safe to stop.
    -- Drain generation: capture the current generation before forking. Flush forks check
    -- this before writing drainCompletedAt to prevent stale drain operations (started before
    -- an undrain+redrain cycle) from interfering with the current drain's state.
    thisGeneration <- atomic do
      dg <- *drainGeneration
      let newDg = dg + 1
      set *drainGeneration = newDg
      set *drainCompletedAt = 0
      yield newDg
    -- Fork a deadline timer: force-complete drain if flush ops hang on slow/dead peers.
    -- Without this, operators waiting on drainCompletedAt > 0 could wait forever.
    fork (do
      sleep drainTimeoutMs
      tTimeout <- now
      atomic do
        dg <- *drainGeneration
        dc <- *drainCompletedAt
        when (dg == thisGeneration && dc == 0) (do
          set *drainCompletedAt = tTimeout)
      when (True {}) (logWarn ("drain: timeout after " ++ show drainTimeoutMs ++ "ms, force-completing")))
    fork (do
      -- Best-effort flush of pending forwards and acks before stopping
      when (federationEnabled && pendingForwardCount > 0) (do
        logInfo ("drain: flushing " ++ show pendingForwardCount ++ " pending forwards")
        retryPendingForwardsFromBuckets)
      when (federationEnabled && pendingAckCount > 0) (do
        logInfo ("drain: flushing " ++ show pendingAckCount ++ " pending acks")
        sendAcksAndClean flushState.pendingAcks)
      when (federationEnabled && drainedCount > 0 && count drainResult.peerServers > 0) (do
        let gossipEvents = do p <- drainResult.localEntries; yield {eventType: GossipOffline {}, pubkey: p.pubkey, server: serverHostN, timestamp: t, ttl: offlineGossipMinTtl, seenBy: [serverHostN]}
        sendBatchedGossip drainResult.peerServers gossipEvents gossipOriginHops)
      -- Wait for in-flight federation requests to complete (timeout: 2x fetch timeout)
      when federationEnabled (waitForInFlightDrain (t + federationFetchTimeoutMs * 2))
      t2 <- now
      -- Only set if deadline timer hasn't already force-completed and drain generation matches
      atomic do
        dg <- *drainGeneration
        dc <- *drainCompletedAt
        when (dg == thisGeneration && dc == 0) (set *drainCompletedAt = t2))
    logInfo ("drain: broadcast offline for " ++ show drainedCount ++ " local keys")
    when (pendingForwardCount > 0)
      (logInfo ("drain: flushing " ++ show pendingForwardCount ++ " pending forwards"))
    when (pendingAckCount > 0)
      (logInfo ("drain: flushing " ++ show pendingAckCount ++ " pending acks"))
    yield (respond {ok: True {}, drained: drainedCount, phase: 2})

-- POST /maintenance/undrain: Resume accepting requests after a drain.
-- Background loops (prune, heartbeat) automatically resume on next iteration.
handleUndrain = \authorization respond -> do
  authorized <- verifyMaintenanceAuth authorization
  if not authorized then yield (respond {ok: False {}})
  else do
    logEvent "audit" "undrain" ""
    wasDraining <- atomic do
      d <- *drainPhase
      set *drainPhase = 0
      set *drainCompletedAt = 0
      set *shutdownRequested = False {}
      -- Clear stale verification cache: entries cached during drain may reference
      -- peers whose trust state changed during the drain/undrain cycle.
      set *verificationCache = []
      set *peerPublicKeys = []
      yield (d > 0)
    when wasDraining (logInfo "undrain: server resumed, accepting new requests")
    when (not wasDraining) (logInfo "undrain: server was not draining")
    yield (respond {ok: True {}})

-- POST /maintenance/shutdown: Trigger full drain + set shutdown flag.
-- Background loops will exit after drain flush completes, allowing the process to stop.
-- Unlike drain, shutdown is not undoable (requires process restart).
handleShutdown = \authorization respond -> do
  t <- now
  authorized <- verifyMaintenanceAuth authorization
  if not authorized then yield (respond {ok: False {}, drained: 0})
  else do
    logEvent "audit" "shutdown" ""
    dp <- *drainPhase
    if dp >= 2 then do
      -- Already draining, just set the shutdown flag
      atomic do set *shutdownRequested = True {}
      logInfo "shutdown: flag set (drain already active)"
      yield (respond {ok: True {}, drained: 0})
    else do
      atomic do set *shutdownRequested = True {}
      -- Delegate to handleDrain with phase=2 (full drain)
      handleDrain 2 authorization (\drainResult -> respond {ok: drainResult.ok, drained: drainResult.drained})

-- POST /maintenance/prune: Trigger a full maintenance cycle (prune + retry all pending ops).
-- Accepts either federation or maintenance secret.
handlePrune = \authorization respond -> do
  t <- now
  dp <- *drainPhase
  authOk <- verifyMaintenanceAuth authorization
  let authorized = authOk && dp < 2
  when authorized (fork (pruneAndRetry t))
  yield (respond {ok: authorized})

-- POST /maintenance/reconcile: Force counter reconciliation without a full prune cycle.
-- Returns drift values for messages, presence, and sessions. Non-zero drift means
-- counters were corrected. Use when /stats shows suspicious counter values.
handleReconcile = \authorization respond -> do
  authorized <- verifyMaintenanceAuth authorization
  if not authorized then yield (respond {ok: False {}, messageDrift: 0, presenceDrift: 0, sessionDrift: 0})
  else do
    logEvent "audit" "reconcile" ""
    presDrift <- atomic do
      actual <- countAllPresence
      stored <- *totalPresenceCount
      set *totalPresenceCount = actual
      yield (actual - stored)
    sessDrift <- atomic do
      actual <- countAllSessions
      stored <- *totalSessionCount
      set *totalSessionCount = actual
      yield (actual - stored)
    fwdDrift <- atomic do
      actual <- countAllForwards 0
      stored <- *totalForwardCount
      set *totalForwardCount = actual
      yield (actual - stored)
    msgDrift <- reconcileMessageCountsDelta
    when (presDrift != 0 || sessDrift != 0 || fwdDrift != 0 || msgDrift != 0)
      (logInfo ("reconcile: corrected drift — messages: " ++ show msgDrift ++ ", presence: " ++ show presDrift ++ ", sessions: " ++ show sessDrift ++ ", forwards: " ++ show fwdDrift))
    yield (respond {ok: True {}, messageDrift: msgDrift, presenceDrift: presDrift, sessionDrift: sessDrift})

-- Compute health state and update the cached health values.
-- Called from both handleHealth (request-driven) and pruneAndRetry (background-driven)
-- so the cache stays fresh even when /health is rate-limited under sustained monitoring load.
computeAndCacheHealth = \t -> do
  result <- atomic do
    lastPrune <- *lastPrunedAt
    lastHb <- *lastHeartbeatAt
    lastWd <- *lastWatchdogAt
    sa <- *startedAt
    presenceCount <- *totalPresenceCount
    forwardCount <- countAllForwards 0
    sessionCount <- *totalSessionCount
    activePolls <- *activePolls
    tmc <- *totalMessageCount
    lastFedSuccess <- *lastFederationSuccessAt
    forwardFailures <- *forwardFailures
    pendingCancels <- *pendingFederationCancels
    pruneRun <- *pruneRunning
    dp <- *drainPhase
    let warmup = t - sa < healthPruneMaxAge
    lastDur <- *lastPruneDuration
    let pruneStuckThreshold = if lastDur > 0 then clamp (backgroundPruneInterval * 3) (backgroundPruneInterval * 10) (lastDur * 3) else backgroundPruneInterval * 5
    let pruneStuck = pruneRun > 0 && t - pruneRun > pruneStuckThreshold
    let cancelCount = count pendingCancels
    let capacityOk = tmc * 10 <= maxMessages * 9
      && presenceCount * 10 <= maxPresenceEntries * 9
      && forwardCount * 10 <= maxForwardsEntries * 9
      && sessionCount * 10 <= maxSessions * 9
      && count activePolls * 10 <= maxActivePolls * 9
      && cancelCount * 10 <= maxPendingCancels * 9
    -- 75% capacity early warning (fires before the 90% health check failure)
    let capacityWarn = tmc * 4 >= maxMessages * 3
      || presenceCount * 4 >= maxPresenceEntries * 3
      || forwardCount * 4 >= maxForwardsEntries * 3
      || sessionCount * 4 >= maxSessions * 3
      || cancelCount * 4 >= maxPendingCancels * 3
    let fedOk = not federationEnabled || warmup
      || count forwardFailures == 0
      || (lastFedSuccess > 0 && t - lastFedSuccess < backgroundPruneInterval * 5)
    let wdOk = warmup || t - sa < healthWatchdogMaxAge || (lastWd > 0 && t - lastWd < healthWatchdogMaxAge)
    nonceCount <- countAllNonces 0
    let nonceOk = nonceCount * 10 <= maxForwardNonces * 9
    -- Count peers with active failure records (degraded federation connectivity)
    let degradedPeerCount = count (do f <- forwardFailures; where t - f.firstFailedAt < maxServerDowntime; yield f)
    -- Forward queue age health: use cached stale count from the last prune cycle
    -- (updated every ~30s) instead of scanning all 16 forward buckets per health check.
    -- Staleness of up to 30 seconds is acceptable for health monitoring; stale forwards
    -- take >24 minutes (healthForwardQueueMaxAge) to appear, so they're always caught.
    fwdStaleCount <- *cachedForwardStaleCount
    let fwdQueueOk = fwdStaleCount < healthForwardQueueMinStaleServers
    -- Request pressure: healthy when active requests < 90% of max (or backpressure disabled)
    arq <- *activeRequests
    let requestPressureOk = maxActiveRequests <= 0 || arq * 10 < maxActiveRequests * 9
    yield {pruneOk: warmup || (t - lastPrune < healthPruneMaxAge && not pruneStuck),
           heartbeatOk: warmup || t - lastHb < healthHeartbeatMaxAge,
           capacityOk: capacityOk,
           capacityWarning: capacityWarn,
           federationOk: fedOk,
           watchdogOk: wdOk,
           nonceOk: nonceOk,
           forwardQueueOk: fwdQueueOk,
           requestPressureOk: requestPressureOk,
           isDraining: dp > 0,
           degradedPeers: degradedPeerCount}
  let allOk = not result.isDraining && result.pruneOk && result.heartbeatOk && result.capacityOk && result.federationOk && result.watchdogOk && result.nonceOk && result.forwardQueueOk && result.requestPressureOk
  atomic do
    set *cachedHealthOk = allOk
    set *cachedHealthPrune = result.pruneOk
    set *cachedHealthHeartbeat = result.heartbeatOk
    set *cachedHealthCapacity = result.capacityOk
    set *cachedHealthCapacityWarning = result.capacityWarning
    set *cachedHealthFederation = result.federationOk
    set *cachedHealthWatchdog = result.watchdogOk
    set *cachedHealthNonce = result.nonceOk
    set *cachedHealthForwardQueue = result.forwardQueueOk
    set *cachedHealthRequestPressure = result.requestPressureOk
    set *cachedHealthDegradedPeers = result.degradedPeers
  yield result

-- Return cached health state. Used for unauthenticated callers and rate-limited requests.
-- Provides constant-time responses regardless of server state complexity.
readCachedHealth = \respond -> do
  cached <- atomic do
    cOk <- *cachedHealthOk
    cP <- *cachedHealthPrune
    cH <- *cachedHealthHeartbeat
    cC <- *cachedHealthCapacity
    cF <- *cachedHealthFederation
    cW <- *cachedHealthWatchdog
    cN <- *cachedHealthNonce
    cFQ <- *cachedHealthForwardQueue
    cRP <- *cachedHealthRequestPressure
    cCW <- *cachedHealthCapacityWarning
    cDP <- *cachedHealthDegradedPeers
    dp <- *drainPhase
    yield {ok: cOk && dp == 0, version: serverBuildVersion, pruneHealthy: cP, heartbeatHealthy: cH, capacityHealthy: cC, capacityWarning: cCW, federationHealthy: cF, watchdogHealthy: cW, nonceHealthy: cN, forwardQueueHealthy: cFQ, requestPressureHealthy: cRP, draining: dp > 0, degradedPeers: cDP}
  yield (respond cached)

handleHealth = \authorization respond -> do
  t <- now
  -- Health checks exempt from global rate limiting (monitoring traffic shouldn't starve real requests)
  -- but have their own dedicated rate limiter to prevent DDoS on /health from saturating reads.
  healthLimited <- checkHealthRate t
  if healthLimited then readCachedHealth respond
  else do
  isAuthed <- verifyMaintenanceAuth authorization
  -- Unauthenticated callers get cached results (constant-time, no live computation).
  -- This prevents timing side-channels: an attacker cannot infer server load by measuring
  -- response time differences between cached (fast) and computed (slow) health checks.
  -- Cache is kept fresh by computeAndCacheHealth called from background prune (~30s).
  -- Only authenticated callers trigger live computation + cache refresh.
  -- Subsystem booleans are returned from cache so load balancers and k8s probes can
  -- detect degradation without requiring authentication. The cached reads are all
  -- constant-time (single STM reads) so no timing information is leaked.
  if not isAuthed
    then readCachedHealth respond
    else do
  result <- computeAndCacheHealth t
  let allOk = not result.isDraining && result.pruneOk && result.heartbeatOk && result.capacityOk && result.federationOk && result.watchdogOk && result.nonceOk && result.forwardQueueOk && result.requestPressureOk
  yield (respond {ok: allOk, version: serverBuildVersion, pruneHealthy: result.pruneOk,
                  heartbeatHealthy: result.heartbeatOk,
                  capacityHealthy: result.capacityOk,
                  capacityWarning: result.capacityWarning,
                  federationHealthy: result.federationOk,
                  watchdogHealthy: result.watchdogOk,
                  nonceHealthy: result.nonceOk,
                  forwardQueueHealthy: result.forwardQueueOk,
                  requestPressureHealthy: result.requestPressureOk,
                  draining: result.isDraining,
                  degradedPeers: result.degradedPeers})

zeroStats = {ok: False {}, version: serverBuildVersion, capacity: {sessions: 0, sessionsMax: 0, sessionsPct: 0, messages: 0, messagesMax: 0, messagesPct: 0, totalMessageCount: 0, presence: 0, presenceMax: 0, presencePct: 0, forwards: 0, forwardsMax: 0, forwardsPct: 0, challenges: 0, challengesMax: 0, ackedIds: 0, ackedIdsMax: 0, ackOverflow: 0, ackOverflowMax: 0, deliveredIds: 0, deliveredIdsMax: 0, forwardNonces: 0, forwardNoncesMax: 0, activePolls: 0, activePollsMax: 0, recipientCounts: 0, messageBucketMax: 0, messageBucketMin: 0}, federation: {enabled: False {}, inFlight: 0, hungSlots: 0, avgLatencyMs: 0, maxLatencyMs: 0, callCount: 0, slowVerifies: 0, verifyFailures: 0, forwardFailures: 0, oldestForwardAge: 0, oldestAckAge: 0, recentGossip: 0, blockedPeers: 0, drainCompletedAt: 0, forwardServers: 0, maxForwardQueueDepth: 0, topFailingPeers: [], pendingCancels: 0, gossipSuccess: 0, gossipFail: 0, latencyBuckets: {lt100: 0, lt500: 0, lt2000: 0, gte2000: 0}}, rates: {send: 0, challenge: 0, federation: 0, federationPair: 0, global: 0, ip: 0, lookup: 0, recv: 0, pair: 0, gossipEvent: 0, verifyIp: 0, uniqueKeyIp: 0, pendingAckCleanups: 0, senderExpirations: 0, senderDeliveries: 0, rejectedGlobal: 0, rejectedIp: 0, rejectedAuth: 0, rejectedPerKey: 0, rejectedFederation: 0, clientCancels: 0, federationCancels: 0}, timing: {pruneCount: 0, pruneRunning: 0, heartbeatCount: 0, uptime: 0, lastPruneAt: 0, lastHeartbeatAt: 0, draining: False {}, drainPhase: 0, totalEntries: 0, activeRequests: 0, peakActiveRequests: 0, pollAvgMs: 0, pollMaxMs: 0, pollCount: 0, pollLatencyBuckets: {lt50: 0, lt200: 0, lt1000: 0, gte1000: 0}, sendAvgMs: 0, sendMaxMs: 0, sendCount: 0, sendLatencyBuckets: {lt50: 0, lt200: 0, lt1000: 0, gte1000: 0}, authAvgMs: 0, authMaxMs: 0, authCount: 0}}

handleStats = \authorization respond -> do
  t <- now
  globalRateLimited <- checkGlobalRate t
  if globalRateLimited then yield (respond zeroStats)
  else do
  authorized <- verifyMaintenanceAuth authorization
  if authorized
    then do
      -- Split into two atomic reads: core capacity state (consistent) and counters/timing
      -- (slight inconsistency acceptable for monitoring). This narrows the lock window.
      -- Forward stats computed per-bucket to avoid materializing all 16 buckets into one list.
      -- Each bucket is read independently; counts and per-server stats are aggregated.
      fwdStats <- computeForwardStats 0 t
      bucketStats <- messageBucketMinMax
      core <- atomic do
        sc <- *totalSessionCount
        pc <- *totalPresenceCount
        c <- *challenges
        -- Count-only: avoids materializing all 16 acked/delivered buckets into one list
        -- since only the count is needed for stats (not the entries themselves).
        aCount <- countAllAcked 0
        ao <- *ackOverflow
        dCount <- countAllDelivered 0
        ff <- *forwardFailures
        ap <- *activePolls
        tmc <- *totalMessageCount
        rc <- countAllRcEntries 0
        fi <- *federationInFlight
        rg <- *recentGossip
        fnCount <- countAllNonces 0
        pac <- *pendingAckCleanups
        bp <- *blockedPeers
        ger <- *gossipEventRates
        vir <- *verifyIpRates
        ukir <- *uniqueKeyIpRates
        se <- *senderExpirations
        sdl <- *senderDeliveries
        pfc <- *pendingFederationCancels
        yield {sc: sc, pc: pc, c: c, aCount: aCount, ao: ao, dCount: dCount, ff: ff, ap: ap, tmc: tmc, rc: rc, fi: fi, rg: rg, fnCount: fnCount, pac: pac, bp: bp, ger: ger, vir: vir, ukir: ukir, se: se, sdl: sdl, pfc: pfc}
      counters <- atomic do
        sr <- *sendRates
        cr <- *challengeRates
        fr <- *federationRates
        fpr <- *federationPairRates
        grc <- *globalRateCount
        ir <- *ipRates
        lr <- *lookupRates
        rr <- *recvRates
        prr <- *pairRates
        pc <- *pruneCount
        pr <- *pruneRunning
        hc <- *heartbeatCount
        sa <- *startedAt
        lp <- *lastPrunedAt
        lh <- *lastHeartbeatAt
        dr <- *drainPhase
        flt <- *federationLatencyTotal
        flc <- *federationLatencyCount
        flm <- *federationLatencyMax
        flb0 <- *federationLatencyBucket0
        flb1 <- *federationLatencyBucket1
        flb2 <- *federationLatencyBucket2
        flb3 <- *federationLatencyBucket3
        svc <- *slowVerifyCount
        vfc <- *verifyFailCount
        dca <- *drainCompletedAt
        rlg <- *rateLimitedGlobal
        rli <- *rateLimitedIp
        rla <- *rateLimitedAuth
        rlk <- *rateLimitedPerKey
        rlf <- *rateLimitedFederation
        arq <- *activeRequests
        parq <- *peakActiveRequests
        cplt <- *clientPollLatencyTotal
        cplc <- *clientPollLatencyCount
        cplm <- *clientPollLatencyMax
        cslt <- *clientSendLatencyTotal
        cslc <- *clientSendLatencyCount
        cslm <- *clientSendLatencyMax
        gss <- *gossipSendSuccess
        gsf <- *gossipSendFail
        cplb0 <- *clientPollLatencyBucket0
        cplb1 <- *clientPollLatencyBucket1
        cplb2 <- *clientPollLatencyBucket2
        cplb3 <- *clientPollLatencyBucket3
        cslb0 <- *clientSendLatencyBucket0
        cslb1 <- *clientSendLatencyBucket1
        cslb2 <- *clientSendLatencyBucket2
        cslb3 <- *clientSendLatencyBucket3
        calt <- *clientAuthLatencyTotal
        calc <- *clientAuthLatencyCount
        calm <- *clientAuthLatencyMax
        ccc <- *clientCancelCount
        fccn <- *federationCancelCount
        yield {sr: sr, cr: cr, fr: fr, fpr: fpr, grc: grc, ir: ir, lr: lr, rr: rr, prr: prr, pc: pc, pr: pr, hc: hc, sa: sa, lp: lp, lh: lh, dr: dr, flt: flt, flc: flc, flm: flm, flb0: flb0, flb1: flb1, flb2: flb2, flb3: flb3, svc: svc, vfc: vfc, dca: dca, rlg: rlg, rli: rli, rla: rla, rlk: rlk, rlf: rlf, arq: arq, parq: parq, cplt: cplt, cplc: cplc, cplm: cplm, cslt: cslt, cslc: cslc, cslm: cslm, gss: gss, gsf: gsf, cplb0: cplb0, cplb1: cplb1, cplb2: cplb2, cplb3: cplb3, cslb0: cslb0, cslb1: cslb1, cslb2: cslb2, cslb3: cslb3, calt: calt, calc: calc, calm: calm, ccc: ccc, fccn: fccn}
      -- Compute derived metrics
      let sessions = core.sc
      let messages = core.tmc
      let presence = core.pc
      let fwds = fwdStats.totalCount
      let msgPct = if maxMessages > 0 then messages * 100 / maxMessages else 0
      let presPct = if maxPresenceEntries > 0 then presence * 100 / maxPresenceEntries else 0
      let fwdPct = if maxForwardsEntries > 0 then fwds * 100 / maxForwardsEntries else 0
      let sessPct = if maxSessions > 0 then sessions * 100 / maxSessions else 0
      let fedAvg = if counters.flc > 0 then counters.flt / counters.flc else 0
      let hungFedSlots = count (do r <- core.fi; where r.count > 0 && r.firstStartedAt > 0 && t - r.firstStartedAt >= federationFetchTimeoutMs; yield r)
      let oldestFwdAge = fwdStats.oldestAge
      -- Oldest ack age computed per-bucket without materializing all 16 buckets.
      -- Scans one bucket at a time to find the global minimum ackedAt.
      oldestAckTs <- computeOldestAckedAt 0
      let oldestAckAge = if oldestAckTs == 0 then 0 else t - oldestAckTs
      let fwdServerCount = fwdStats.serverCount
      let maxFwdDepth = fwdStats.maxDepth
      -- Top-3 failing peers by failure count (inline in /stats to reduce monitoring queries)
      let topFailing = takeRelation 3 (sortBy (\f -> 0 - f.failures) core.ff)
      let topFailingPeers = do f <- topFailing; yield {server: f.server, failures: f.failures}
      let pollAvg = if counters.cplc > 0 then counters.cplt / counters.cplc else 0
      let sendAvg = if counters.cslc > 0 then counters.cslt / counters.cslc else 0
      yield (respond {ok: True {}, version: serverBuildVersion,
        capacity: {sessions: sessions, sessionsMax: maxSessions, sessionsPct: sessPct, messages: messages, messagesMax: maxMessages, messagesPct: msgPct, totalMessageCount: messages, presence: presence, presenceMax: maxPresenceEntries, presencePct: presPct, forwards: fwds, forwardsMax: maxForwardsEntries, forwardsPct: fwdPct, challenges: count core.c, challengesMax: maxChallenges, ackedIds: core.aCount, ackedIdsMax: maxAckedIds, ackOverflow: count core.ao, ackOverflowMax: maxAckOverflow, deliveredIds: core.dCount, deliveredIdsMax: maxDeliveredIds, forwardNonces: core.fnCount, forwardNoncesMax: maxForwardNonces, activePolls: count core.ap, activePollsMax: maxActivePolls, recipientCounts: count core.rc, messageBucketMax: bucketStats.bucketMax, messageBucketMin: bucketStats.bucketMin},
        federation: {enabled: federationEnabled, inFlight: count core.fi, hungSlots: hungFedSlots, avgLatencyMs: fedAvg, maxLatencyMs: counters.flm, callCount: counters.flc, slowVerifies: counters.svc, verifyFailures: counters.vfc, forwardFailures: count core.ff, oldestForwardAge: oldestFwdAge, oldestAckAge: oldestAckAge, recentGossip: count core.rg, blockedPeers: count core.bp, drainCompletedAt: counters.dca, forwardServers: fwdServerCount, maxForwardQueueDepth: maxFwdDepth, topFailingPeers: topFailingPeers, pendingCancels: count core.pfc, gossipSuccess: counters.gss, gossipFail: counters.gsf, latencyBuckets: {lt100: counters.flb0, lt500: counters.flb1, lt2000: counters.flb2, gte2000: counters.flb3}},
        rates: {send: count counters.sr, challenge: count counters.cr, federation: count counters.fr, federationPair: count counters.fpr, global: counters.grc, ip: count counters.ir, lookup: count counters.lr, recv: count counters.rr, pair: count counters.prr, gossipEvent: count core.ger, verifyIp: count core.vir, uniqueKeyIp: count core.ukir, pendingAckCleanups: count core.pac, senderExpirations: count core.se, senderDeliveries: count core.sdl, rejectedGlobal: counters.rlg, rejectedIp: counters.rli, rejectedAuth: counters.rla, rejectedPerKey: counters.rlk, rejectedFederation: counters.rlf, clientCancels: counters.ccc, federationCancels: counters.fccn},
        timing: {pruneCount: counters.pc, pruneRunning: counters.pr, heartbeatCount: counters.hc, uptime: t - counters.sa, lastPruneAt: counters.lp, lastHeartbeatAt: counters.lh, draining: counters.dr > 0, drainPhase: counters.dr, totalEntries: sessions + messages + presence + fwds + count core.c + core.aCount + count core.ao + core.dCount + core.fnCount + count core.ap + count core.fi, activeRequests: counters.arq, peakActiveRequests: counters.parq, pollAvgMs: pollAvg, pollMaxMs: counters.cplm, pollCount: counters.cplc, pollLatencyBuckets: {lt50: counters.cplb0, lt200: counters.cplb1, lt1000: counters.cplb2, gte1000: counters.cplb3}, sendAvgMs: sendAvg, sendMaxMs: counters.cslm, sendCount: counters.cslc, sendLatencyBuckets: {lt50: counters.cslb0, lt200: counters.cslb1, lt1000: counters.cslb2, gte1000: counters.cslb3}, authAvgMs: if counters.calc > 0 then counters.calt / counters.calc else 0, authMaxMs: counters.calm, authCount: counters.calc}})
    else yield (respond zeroStats)

handleStatsPeers = \authorization respond -> do
  t <- now
  globalRateLimited <- checkGlobalRate t
  if globalRateLimited then yield (respond {peers: [], ok: False {}})
  else do
  authorized <- verifyMaintenanceAuth authorization
  if authorized
    then do
      failures <- *forwardFailures
      peerLats <- *peerLatencies
      gossipRates <- *gossipEventRates
      -- Per-bucket aggregation: compute forward counts without materializing all 16 buckets.
      -- Reuses computeForwardStats which reads one bucket at a time.
      fwdStats <- computeForwardStats 0 t
      let fwdCounts = fwdStats.serverCounts
      let fwdCountFor = \server -> fold (\acc c -> if c.server == server then c.count else acc) 0 fwdCounts
      let peerLatFor = \server -> case headOf (do p <- peerLats; where p.server == server; yield p) of
            Nothing {} -> {avg: 0, mx: 0, samples: 0}
            Just {value: p} -> {avg: if p.count > 0 then p.totalMs / p.count else 0, mx: p.maxMs, samples: p.count}
      -- Per-peer gossip event volume: events per minute from gossipEventRates (1-minute sliding window)
      let gossipFor = \server -> fold (\acc r -> if r.server == server then r.count + r.prevCount else acc) 0 gossipRates
      let peers = do f <- failures; let lat = peerLatFor f.server in yield {server: f.server, failures: f.failures, lastFailedAt: f.failedAt, firstFailedAt: f.firstFailedAt, backoffMs: retryBackoffFor f.failures f.server, retriable: shouldRetryServer f.server t failures, pendingForwards: fwdCountFor f.server, avgLatencyMs: lat.avg, maxLatencyMs: lat.mx, latencySamples: lat.samples, gossipEventsPerMin: gossipFor f.server}
      -- Include servers with pending forwards but no failure records
      let fwdOnlyPeers = do c <- fwdCounts; where none failures (\f -> f.server == c.server); let lat = peerLatFor c.server in yield {server: c.server, failures: 0, lastFailedAt: 0, firstFailedAt: 0, backoffMs: 0, retriable: True {}, pendingForwards: c.count, avgLatencyMs: lat.avg, maxLatencyMs: lat.mx, latencySamples: lat.samples, gossipEventsPerMin: gossipFor c.server}
      yield (respond {peers: union peers fwdOnlyPeers, ok: True {}})
    else yield (respond {peers: [], ok: False {}})

handleStatsKey = \pubkey authorization respond -> do
  t <- now
  globalRateLimited <- checkGlobalRate t
  if globalRateLimited then yield (respond {messages: 0, presence: [], sessions: 0, forwards: 0, activePolls: 0, ok: False {}})
  else do
  authorized <- verifyMaintenanceAuth authorization
  if authorized
    then do
      result <- atomic do
        keyBucket <- readMessageBucket (pubkeyBucket pubkey)
        -- Single bucket read: all entries for this pubkey are in the same presence bucket
        keyPresenceBkt <- readPresenceBucket (pubkeyBucket pubkey)
        -- Count sessions without materializing all 16 buckets (O(n/16) best case)
        keySessions <- countSessionsForKey pubkey
        forwards <- readFwdBucket (pubkeyBucket pubkey)
        activePolls <- *activePolls
        let keyMessages = count (do m <- keyBucket; where m.toKey == pubkey; yield m)
        let keyPresence = do p <- keyPresenceBkt; where p.pubkey == pubkey && p.expiresAt > t; yield {server: p.server, expiresAt: p.expiresAt}
        let keyForwardEntries = do f <- forwards; where f.toKey == pubkey; yield f
        let keyForwards = count keyForwardEntries
        let keyForwardDetails = do f <- keyForwardEntries; yield {server: f.toServer, retries: f.retries, createdAt: f.createdAt}
        let keyPolls = count (do p <- activePolls; where p.pubkey == pubkey; yield p)
        yield {messages: keyMessages, presence: keyPresence, sessions: keySessions, forwards: keyForwards, forwardDetails: keyForwardDetails, activePolls: keyPolls}
      yield (respond {messages: result.messages, presence: result.presence, sessions: result.sessions, forwards: result.forwards, forwardDetails: result.forwardDetails, activePolls: result.activePolls, ok: True {}})
    else yield (respond {messages: 0, presence: [], sessions: 0, forwards: 0, forwardDetails: [], activePolls: 0, ok: False {}})

-- GET /stats/top-recipients: Return recipients sorted by pending message count (descending).
-- Uses rcBucket data (per-recipient counts) — O(total_unique_recipients) with no message scan.
-- Helps operators identify inbox-bombing targets without knowing the recipient key in advance.
handleTopRecipients = \limit authorization respond -> do
  t <- now
  globalRateLimited <- checkGlobalRate t
  if globalRateLimited then yield (respond {recipients: [], ok: False {}, total: 0})
  else do
  authorized <- verifyMaintenanceAuth authorization
  if authorized
    then do
      let effectiveLimit = if limit <= 0 then 20 else clamp 1 100 limit
      -- Per-bucket top-N merge: scans one rcBucket at a time, maintaining a running
      -- top-N list. Avoids materializing all 16 buckets into a single list.
      top <- topRecipientsByBucket 0 effectiveLimit []
      totalRc <- countAllRcEntries 0
      yield (respond {recipients: top, ok: True {}, total: totalRc})
    else yield (respond {recipients: [], ok: False {}, total: 0})

-- GET /stats/forwards: Per-server forward queue breakdown.
-- Shows pending forwards grouped by destination server with oldest age and total retries.
-- Use to identify which peers have queue buildup (unreachable or slow peers).
handleStatsForwards = \authorization respond -> do
  t <- now
  globalRateLimited <- checkGlobalRate t
  if globalRateLimited then yield (respond {servers: [], ok: False {}, total: 0})
  else do
  authorized <- verifyMaintenanceAuth authorization
  if authorized
    then do
      fwdStats <- computeForwardStats 0 t
      -- Enrich per-server counts with oldest age and total retries
      let enriched = do sc <- fwdStats.serverCounts; yield {server: sc.server, count: sc.count, oldestAge: 0, totalRetries: 0}
      enrichedStats <- enrichForwardServerStats enriched 0 t
      yield (respond {servers: enrichedStats, ok: True {}, total: fwdStats.totalCount})
    else yield (respond {servers: [], ok: False {}, total: 0})

-- Enrich per-server forward stats with oldest age and total retries.
-- Scans one forward bucket at a time, accumulating per-server metrics.
enrichForwardServerStats = \servers b t ->
  if b > 15 then yield servers
  else do
    bucket <- readFwdBucket b
    let updated = do s <- servers; yield (
      let serverFwds = do f <- bucket; where f.toServer == s.server; yield f in
      let bucketOldest = case minBy serverFwds (\x -> x.createdAt) of Nothing {} -> 0; Just {value: x} -> t - x.createdAt in
      let bucketRetries = fold (\acc f -> acc + f.retries) 0 serverFwds in
      {server: s.server, count: s.count, oldestAge: max s.oldestAge bucketOldest, totalRetries: s.totalRetries + bucketRetries})
    enrichForwardServerStats updated (b + 1) t

-- GET /stats/rates: Show effective rate limits after adaptive scaling.
-- Returns the current scale factor (0-100%) and each rate limit as actually applied.
handleStatsRates = \authorization respond -> do
  t <- now
  globalRateLimited <- checkGlobalRate t
  if globalRateLimited then yield (respond {ok: False {}, scalePct: 0, globalRequest: 0, ipRate: 0, sendRate: 0, federationRate: 0, authGlobal: 0, recvRate: 0, challengeRate: 0, pairRate: 0, lookupRate: 0, clientWriteRate: 0})
  else do
  authorized <- verifyMaintenanceAuth authorization
  if authorized
    then do
      scale <- atomic do
        tmc <- *totalMessageCount
        sc <- *totalSessionCount
        pc <- *totalPresenceCount
        yield (adaptiveRateScale tmc sc pc)
      effGlobal <- effectiveGlobalRequestRate
      effIp <- effectiveIpRate
      effSend <- effectiveSendRate
      effFed <- effectiveFederationRate
      effAuth <- effectiveAuthGlobalRate
      effRecv <- effectiveRecvRate
      effChal <- effectiveChallengeRate
      effPair <- effectivePairRate
      effLookup <- effectiveLookupRate
      effCw <- effectiveClientWriteRate
      yield (respond {ok: True {}, scalePct: scale, globalRequest: effGlobal, ipRate: effIp, sendRate: effSend, federationRate: effFed, authGlobal: effAuth, recvRate: effRecv, challengeRate: effChal, pairRate: effPair, lookupRate: effLookup, clientWriteRate: effCw})
    else yield (respond {ok: False {}, scalePct: 0, globalRequest: 0, ipRate: 0, sendRate: 0, federationRate: 0, authGlobal: 0, recvRate: 0, challengeRate: 0, pairRate: 0, lookupRate: 0, clientWriteRate: 0})

-- GET /ready: Readiness probe — returns true once the server has completed startup.
-- Unlike /health, this is unauthenticated and doesn't check subsystem liveness.
-- Returns false until the first prune cycle completes (server fully initialized).
handleReady = \respond -> do
  t <- now
  -- Rate-limit /ready to prevent DoS (shares health rate limiter since both are
  -- unauthenticated probes). Without this, /ready can be hit unlimited times
  -- for cheap reconnaissance (detecting restarts) or resource exhaustion.
  healthLimited <- checkHealthRate t
  if healthLimited then yield (respond {ready: True {}})
  else do
    sa <- *startedAt
    lastPrune <- *lastPrunedAt
    -- Ready once the first prune cycle has run (indicates all background loops are alive)
    let isReady = lastPrune > 0 && lastPrune >= sa
    yield (respond {ready: isReady})

-- GET /metrics: Prometheus-format metrics in a JSON wrapper.
-- Authenticated callers get full metrics; unauthenticated get basic capacity only.
handleMetrics = \authorization respond -> do
  t <- now
  healthLimited <- checkHealthRate t
  if healthLimited then yield (respond {metrics: "", ok: False {}})
  else do
  isAuthed <- verifyMaintenanceAuth authorization
  result <- atomic do
    tmc <- *totalMessageCount
    sc <- *totalSessionCount
    pc <- *totalPresenceCount
    fc <- *totalForwardCount
    ap <- *activePolls
    arq <- *activeRequests
    parq <- *peakActiveRequests
    sa <- *startedAt
    dp <- *drainPhase
    yield {tmc: tmc, sc: sc, pc: pc, fc: fc, ap: ap, arq: arq, parq: parq, sa: sa, dp: dp}
  -- Basic capacity metrics (always available)
  let base = "# HELP skrepka_messages_total Current message count\n# TYPE skrepka_messages_total gauge\nskrepka_messages_total " ++ show result.tmc ++ "\n# HELP skrepka_messages_max Maximum message capacity\n# TYPE skrepka_messages_max gauge\nskrepka_messages_max " ++ show maxMessages ++ "\n# HELP skrepka_sessions_total Current session count\n# TYPE skrepka_sessions_total gauge\nskrepka_sessions_total " ++ show result.sc ++ "\n# HELP skrepka_sessions_max Maximum session capacity\n# TYPE skrepka_sessions_max gauge\nskrepka_sessions_max " ++ show maxSessions ++ "\n# HELP skrepka_presence_total Current presence count\n# TYPE skrepka_presence_total gauge\nskrepka_presence_total " ++ show result.pc ++ "\n# HELP skrepka_presence_max Maximum presence capacity\n# TYPE skrepka_presence_max gauge\nskrepka_presence_max " ++ show maxPresenceEntries ++ "\n# HELP skrepka_forwards_total Current forward queue size\n# TYPE skrepka_forwards_total gauge\nskrepka_forwards_total " ++ show result.fc ++ "\n# HELP skrepka_active_polls Current active long-poll connections\n# TYPE skrepka_active_polls gauge\nskrepka_active_polls " ++ show (count result.ap) ++ "\n# HELP skrepka_active_requests Current active HTTP requests\n# TYPE skrepka_active_requests gauge\nskrepka_active_requests " ++ show result.arq ++ "\n# HELP skrepka_peak_active_requests Peak concurrent requests since last reset\n# TYPE skrepka_peak_active_requests gauge\nskrepka_peak_active_requests " ++ show result.parq ++ "\n# HELP skrepka_uptime_seconds Server uptime in seconds\n# TYPE skrepka_uptime_seconds gauge\nskrepka_uptime_seconds " ++ show ((t - result.sa) / 1000) ++ "\n# HELP skrepka_draining Whether the server is draining\n# TYPE skrepka_draining gauge\nskrepka_draining " ++ if result.dp > 0 then "1" else "0" ++ "\n"
  if not isAuthed then yield (respond {metrics: base, ok: True {}})
  else do
    -- Extended metrics for authenticated callers
    ext <- atomic do
      flc <- *federationLatencyCount
      flt <- *federationLatencyTotal
      flm <- *federationLatencyMax
      cplc <- *clientPollLatencyCount
      cplt <- *clientPollLatencyTotal
      cslc <- *clientSendLatencyCount
      cslt <- *clientSendLatencyTotal
      rlg <- *rateLimitedGlobal
      rli <- *rateLimitedIp
      rla <- *rateLimitedAuth
      rlk <- *rateLimitedPerKey
      rlf <- *rateLimitedFederation
      gss <- *gossipSendSuccess
      gsf <- *gossipSendFail
      ccc <- *clientCancelCount
      fccn <- *federationCancelCount
      yield {flc: flc, flt: flt, flm: flm, cplc: cplc, cplt: cplt, cslc: cslc, cslt: cslt, rlg: rlg, rli: rli, rla: rla, rlk: rlk, rlf: rlf, gss: gss, gsf: gsf, ccc: ccc, fccn: fccn}
    let fedAvg = if ext.flc > 0 then ext.flt / ext.flc else 0
    let pollAvg = if ext.cplc > 0 then ext.cplt / ext.cplc else 0
    let sendAvg = if ext.cslc > 0 then ext.cslt / ext.cslc else 0
    let extended = "# HELP skrepka_federation_latency_avg_ms Average federation call latency\n# TYPE skrepka_federation_latency_avg_ms gauge\nskrepka_federation_latency_avg_ms " ++ show fedAvg ++ "\n# HELP skrepka_federation_latency_max_ms Max federation call latency\n# TYPE skrepka_federation_latency_max_ms gauge\nskrepka_federation_latency_max_ms " ++ show ext.flm ++ "\n# HELP skrepka_federation_calls_total Federation calls in current window\n# TYPE skrepka_federation_calls_total gauge\nskrepka_federation_calls_total " ++ show ext.flc ++ "\n# HELP skrepka_poll_latency_avg_ms Average poll latency\n# TYPE skrepka_poll_latency_avg_ms gauge\nskrepka_poll_latency_avg_ms " ++ show pollAvg ++ "\n# HELP skrepka_send_latency_avg_ms Average send latency\n# TYPE skrepka_send_latency_avg_ms gauge\nskrepka_send_latency_avg_ms " ++ show sendAvg ++ "\n# HELP skrepka_rate_limited_total Rate-limited requests by type\n# TYPE skrepka_rate_limited_total gauge\nskrepka_rate_limited_total{type=\"global\"} " ++ show ext.rlg ++ "\nskrepka_rate_limited_total{type=\"ip\"} " ++ show ext.rli ++ "\nskrepka_rate_limited_total{type=\"auth\"} " ++ show ext.rla ++ "\nskrepka_rate_limited_total{type=\"per_key\"} " ++ show ext.rlk ++ "\nskrepka_rate_limited_total{type=\"federation\"} " ++ show ext.rlf ++ "\n# HELP skrepka_gossip_total Gossip send results\n# TYPE skrepka_gossip_total gauge\nskrepka_gossip_total{result=\"success\"} " ++ show ext.gss ++ "\nskrepka_gossip_total{result=\"fail\"} " ++ show ext.gsf ++ "\n# HELP skrepka_cancels_total Message cancellations by source\n# TYPE skrepka_cancels_total gauge\nskrepka_cancels_total{source=\"client\"} " ++ show ext.ccc ++ "\nskrepka_cancels_total{source=\"federation\"} " ++ show ext.fccn ++ "\n"
    yield (respond {metrics: base ++ extended, ok: True {}})

-- POST /messages/ack: Explicitly acknowledge received messages by ID.
-- Alternative to the implicit cursor-based ack in poll. Benefits:
-- 1. Reduces the window for duplicate delivery (ack immediately without waiting for next poll)
-- 2. Selective ack: acknowledge specific messages without acking all messages up to a cursor
-- Rate-limited via global rate limiter; requires session auth.
handleAckMessages = \messageIds authorization clientIp respond -> do
  t <- now
  dp <- *drainPhase
  if dp >= 2 then yield (respond {ok: False {}, authorized: False {}, ackedCount: 0, error: "draining"})
  else do
  globalRateLimited <- checkGlobalRate t
  if globalRateLimited then yield (respond {ok: False {}, authorized: False {}, ackedCount: 0, error: "rate_limited:" ++ show globalRateWindowMs ++ "ms"})
  else
    withSessionAuth authorization t clientIp
      (yield (respond {ok: False {}, authorized: False {}, ackedCount: 0, error: "unauthorized"}))
      (\pubkey -> do
        -- Uses clientWriteRates (separate from lookupRates) so ack bursts don't starve lookups
        ackRateLimited <- atomic do
          cwr <- *clientWriteRates
          cwRate <- effectiveClientWriteRate
          let rateResult = checkPubkeyRate cwr pubkey cwRate clientWriteRateWindowMs maxClientWriteRateEntries t
          set *clientWriteRates = rateResult.entries
          yield rateResult.limited
        if ackRateLimited then yield (respond {ok: False {}, authorized: True {}, ackedCount: 0, error: "rate_limited:" ++ show clientWriteRateWindowMs ++ "ms"})
        else do
        -- Cap input size to prevent expensive scans from unbounded messageIds lists
        let dedupedIds = dedupMessageIds (takeRelation maxMessageIds messageIds)
        result <- atomic do
          let b = pubkeyBucket pubkey
          bucket <- readMessageBucket b
          let toAck = do m <- bucket; where m.toKey == pubkey && any dedupedIds (\mid -> m.messageId == mid); yield m
          let ackCount = count toAck
          if ackCount > 0 then do
            writeMessageBucket b (diff bucket toAck)
            totalCount <- *totalMessageCount
            set *totalMessageCount = max 0 (totalCount - ackCount)
            recipientCounts <- readRcBucket b
            writeRcBucket b (adjustRecipientCount recipientCounts pubkey (0 - ackCount))
            let ackedMsgIds = do m <- toAck; yield m.messageId
            let fb2 = pubkeyBucket pubkey
            fwdBkt2 <- readFwdBucket fb2
            writeFwdBucket fb2 (do f <- fwdBkt2; where none ackedMsgIds (\mid -> f.messageId == mid && f.toKey == pubkey); yield f)
            let ackedFederated = federatedAckEntries toAck t
            ackedBkt <- readAckedBucket b
            let combinedAckedIds = union ackedBkt ackedFederated
            let excessCount = max 0 (count combinedAckedIds - maxAckedIds)
            let eviction = evictSmallest combinedAckedIds excessCount (\a -> a.ackedAt)
            writeAckedBucket b eviction.kept
            -- Queue delivery receipts for locally-originated messages
            let localDelivered = do m <- toAck; where m.senderKey != "" && m.originServer == ""; yield {senderKey: m.senderKey, messageId: m.messageId, toKey: m.toKey, deliveredAt: t}
            when (count localDelivered > 0) (do
              sd <- *senderDeliveries
              -- Dedup: skip receipts already recorded (e.g., cursor ack + explicit ack for same message)
              let deduped = do d <- localDelivered; where none sd (\e -> e.messageId == d.messageId && e.toKey == d.toKey); yield d
              let combined = union sd deduped
              let overCap = count combined > maxSenderDeliveries
              if overCap then do
                let evicted = extractOldest combined (\d -> d.deliveredAt)
                set *senderDeliveries = evicted.items
                case evicted.candidate of
                  Nothing {} -> yield {}
                  Just {value: ev} -> do
                    ddr <- *droppedDeliveryReceipts
                    set *droppedDeliveryReceipts = incrementDropCounter ddr ev.senderKey 1 t
              else set *senderDeliveries = combined)
            yield {ackedCount: ackCount, pendingAcks: ackedFederated, evictedEntries: eviction.evicted}
          else yield {ackedCount: 0, pendingAcks: [], evictedEntries: []}
        fork (when federationEnabled (do
          sendAcksAndClean result.pendingAcks
          retryEvictedAcks result.evictedEntries result.pendingAcks))
        yield (respond {ok: True {}, authorized: True {}, ackedCount: result.ackedCount, error: ""}))

-- GET /messages/list: List pending messages without acking.
-- Useful after cursor loss (app reinstall, new device) to see what's pending.
-- Rate-limited via lookup rate limiter (read-only info lookup).
handleListMessages = \offset authorization clientIp respond -> do
  t <- now
  dp <- *drainPhase
  if dp >= 2 then yield (respond {messages: [], authorized: False {}, count: 0, error: ""})
  else do
  globalRateLimited <- checkGlobalRate t
  if globalRateLimited then yield (respond {messages: [], authorized: False {}, count: 0, error: "rate_limited:" ++ show globalRateWindowMs ++ "ms"})
  else
    withSessionAuth authorization t clientIp
      (yield (respond {messages: [], authorized: False {}, count: 0, error: ""}))
      (\pubkey -> do
        listRateLimited <- atomic do
          lookupRates <- *lookupRates
          lkRate <- effectiveLookupRate
          let rateResult = checkPubkeyRate lookupRates pubkey lkRate lookupRateWindowMs maxLookupRateEntries t
          set *lookupRates = rateResult.entries
          yield rateResult.limited
        if listRateLimited then yield (respond {messages: [], authorized: True {}, count: 0, error: "rate_limited:" ++ show lookupRateWindowMs ++ "ms"})
        else do
          result <- atomic do
            bucket <- readMessageBucket (pubkeyBucket pubkey)
            let myMsgs = sortBy (\m -> m.receivedAt) (do m <- bucket; where m.toKey == pubkey && m.expiresAt > t; yield m)
            let total = count myMsgs
            -- Pagination: skip first `offset` messages, then take up to maxPollEvents.
            -- skipRelation uses fold to drop the first N items from a list.
            let effectiveOffset = clamp 0 total offset
            let afterOffset = skipRelation effectiveOffset myMsgs
            let capped = takeRelation maxPollEvents afterOffset
            yield {msgs: do m <- capped; yield {messageId: m.messageId, timestamp: m.timestamp, receivedAt: m.receivedAt}, total: total}
          yield (respond {messages: result.msgs, authorized: True {}, count: result.total, error: ""}))

-- POST /messages/delete: Delete pending messages by ID (recipient-only).
-- The recipient knows their pubkey (toKey) and can be authenticated via session.
-- Deletes matching messages, adjusts counters, cancels pending forwards, and
-- sends federation acks for federated messages so origin servers can reclaim
-- their forward entries instead of retrying until prune.
handleDeleteMessages = \messageIds authorization clientIp respond -> do
  t <- now
  dp <- *drainPhase
  if dp >= 2 then yield (respond {ok: False {}, authorized: False {}, deletedCount: 0, error: ""})
  else do
  globalRateLimited <- checkGlobalRate t
  if globalRateLimited then yield (respond {ok: False {}, authorized: False {}, deletedCount: 0, error: "rate_limited:" ++ show globalRateWindowMs ++ "ms"})
  else
    withSessionAuth authorization t clientIp
      (yield (respond {ok: False {}, authorized: False {}, deletedCount: 0, error: "unauthorized"}))
      (\pubkey -> do
        -- Uses clientWriteRates (separate from lookupRates) so delete bursts don't starve lookups
        deleteRateLimited <- atomic do
          cwr <- *clientWriteRates
          cwRate <- effectiveClientWriteRate
          let rateResult = checkPubkeyRate cwr pubkey cwRate clientWriteRateWindowMs maxClientWriteRateEntries t
          set *clientWriteRates = rateResult.entries
          yield rateResult.limited
        if deleteRateLimited then yield (respond {ok: False {}, authorized: True {}, deletedCount: 0, error: "rate_limited:" ++ show clientWriteRateWindowMs ++ "ms"})
        else do
          -- Cap input size to prevent expensive scans from unbounded messageIds lists
          let dedupedIds = dedupMessageIds (takeRelation maxMessageIds messageIds)
          deleteResult <- atomic do
            let b = pubkeyBucket pubkey
            bucket <- readMessageBucket b
            let toDelete = do m <- bucket; where m.toKey == pubkey && any dedupedIds (\mid -> mid == m.messageId); yield m
            let removed = count toDelete
            if removed > 0 then do
              writeMessageBucket b (diff bucket toDelete)
              tc <- *totalMessageCount
              set *totalMessageCount = max 0 (tc - removed)
              rc <- readRcBucket b
              writeRcBucket b (adjustRecipientCount rc pubkey (0 - removed))
              -- Cancel pending forwards for deleted messages (bucket read: O(n/16))
              let deletedMsgIds = do m <- toDelete; yield m.messageId
              let dfb = pubkeyBucket pubkey
              fwdBkt <- readFwdBucket dfb
              let keptDeleteFwds = do f <- fwdBkt; where none deletedMsgIds (\mid -> f.messageId == mid && f.toKey == pubkey); yield f
              let fwdDeleteRemoved = count fwdBkt - count keptDeleteFwds
              writeFwdBucket dfb keptDeleteFwds
              when (fwdDeleteRemoved > 0) (do
                tfc <- *totalForwardCount
                set *totalForwardCount = max 0 (tfc - fwdDeleteRemoved))
              -- Create ack entries for federated messages so origin servers learn about the delete
              let federatedDeleted = do m <- toDelete; where m.originServer != ""; yield m
              let ackedFederated = federatedAckEntries federatedDeleted t
              -- Queue delivery receipts for locally-originated deleted messages
              let localDeleted = do m <- toDelete; where m.senderKey != "" && m.originServer == ""; yield {senderKey: m.senderKey, messageId: m.messageId, toKey: m.toKey, deliveredAt: t}
              when (count localDeleted > 0) (do
                sd <- *senderDeliveries
                -- Dedup: skip receipts already recorded (avoids duplicates from concurrent ack paths)
                let dedupedDel = do d <- localDeleted; where none sd (\e -> e.messageId == d.messageId && e.toKey == d.toKey); yield d
                let combinedDel = union sd dedupedDel
                let overCapDel = count combinedDel > maxSenderDeliveries
                if overCapDel then do
                  let evicted = extractOldest combinedDel (\d -> d.deliveredAt)
                  set *senderDeliveries = evicted.items
                  case evicted.candidate of
                    Nothing {} -> yield {}
                    Just {value: ev} -> do
                      ddr <- *droppedDeliveryReceipts
                      set *droppedDeliveryReceipts = incrementDropCounter ddr ev.senderKey 1 t
                else set *senderDeliveries = combinedDel)
              if count ackedFederated > 0 then do
                ackedBkt <- readAckedBucket b
                let combinedAcked = union ackedBkt ackedFederated
                let excessCount = max 0 (count combinedAcked - maxAckedIds)
                let eviction = evictSmallest combinedAcked excessCount (\a -> a.ackedAt)
                writeAckedBucket b eviction.kept
                yield {deletedCount: removed, pendingAcks: ackedFederated, evictedEntries: eviction.evicted}
              else yield {deletedCount: removed, pendingAcks: [], evictedEntries: []}
            else yield {deletedCount: 0, pendingAcks: [], evictedEntries: []}
          fork (when federationEnabled (do
            sendAcksAndClean deleteResult.pendingAcks
            retryEvictedAcks deleteResult.evictedEntries deleteResult.pendingAcks))
          yield (respond {ok: True {}, authorized: True {}, deletedCount: deleteResult.deletedCount, error: ""}))

-- POST /messages/cancel: Retract a previously sent message before the recipient reads it.
-- Only works for locally-originated messages where the caller's pubkey matches the
-- stored senderKey. Federation forwards cannot be cancelled via this endpoint.
-- Removes from recipient mailbox and cancels pending forwards.
-- NOTE: Race condition between cancel and re-send: after this endpoint deletes the
-- local message and sends federation cancel, there's a window where:
-- 1. The federation cancel hasn't arrived at the remote server yet
-- 2. The sender immediately re-sends (with a new messageId)
-- 3. The recipient receives the new message before the cancel is processed
-- This can cause a UX inconsistency where the recipient sees the "retracted" message
-- briefly before the cancel arrives. Not fixable at the relay layer — requires
-- higher-level protocol support (e.g., cancel tokens in the encrypted payload).
handleCancelMessage = \messageId to authorization clientIp respond -> do
  t <- now
  dp <- *drainPhase
  if dp >= 2 then yield (respond {ok: False {}, authorized: False {}, cancelled: False {}, error: ""})
  else do
  globalRateLimited <- checkGlobalRate t
  if globalRateLimited then yield (respond {ok: False {}, authorized: False {}, cancelled: False {}, error: "rate_limited:" ++ show globalRateWindowMs ++ "ms"})
  else
    withSessionAuth authorization t clientIp
      (yield (respond {ok: False {}, authorized: False {}, cancelled: False {}, error: "unauthorized"}))
      (\senderKey -> do
        -- Uses clientWriteRates (like ack/delete) so cancel bursts don't starve lookups
        cancelRateLimited <- atomic do
          cwr <- *clientWriteRates
          cwRate <- effectiveClientWriteRate
          let rateResult = checkPubkeyRate cwr senderKey cwRate clientWriteRateWindowMs maxClientWriteRateEntries t
          set *clientWriteRates = rateResult.entries
          yield rateResult.limited
        if cancelRateLimited then yield (respond {ok: False {}, authorized: True {}, cancelled: False {}, error: "rate_limited:" ++ show clientWriteRateWindowMs ++ "ms"})
        else do
          cancelResult <- atomic do
            let b = pubkeyBucket to
            bucket <- readMessageBucket b
            let toCancel = headOf (do m <- bucket; where m.messageId == messageId && m.toKey == to; yield m)
            case toCancel of
              Nothing {} -> yield {cancelled: False {}, cancelServers: [], nonceLruEvicted: 0, nonceOldestAge: 0}
              Just {value: msg} ->
                -- Only allow cancelling locally-originated messages (originServer == "")
                -- where the caller's pubkey matches the stored senderKey. Federation
                -- forwards have no senderKey and cannot be cancelled via this endpoint.
                -- Strict check: senderKey must be non-empty and match. MessageId knowledge
                -- alone is insufficient — prevents cancel if messageId leaks via logs,
                -- federation peers, or recipient sharing.
                if msg.originServer != "" then yield {cancelled: False {}, cancelServers: [], nonceLruEvicted: 0, nonceOldestAge: 0}
                else if msg.senderKey == "" || msg.senderKey != senderKey then yield {cancelled: False {}, cancelServers: [], nonceLruEvicted: 0, nonceOldestAge: 0}
                else do
                writeMessageBucket b (do m <- bucket; where not (m.messageId == messageId && m.toKey == to); yield m)
                tc <- *totalMessageCount
                set *totalMessageCount = max 0 (tc - 1)
                rc <- readRcBucket b
                writeRcBucket b (adjustRecipientCount rc to (0 - 1))
                -- Cancel pending forwards and collect their target servers before deleting
                fwdBkt <- readFwdBucket b
                let cancelledFwds = do f <- fwdBkt; where f.messageId == messageId && f.toKey == to; yield f
                let forwardTargetServers = collectPeerServers cancelledFwds (\f -> f.toServer)
                let fwdCancelRemoved = count cancelledFwds
                writeFwdBucket b (do f <- fwdBkt; where not (f.messageId == messageId && f.toKey == to); yield f)
                when (fwdCancelRemoved > 0) (do
                  tfc <- *totalForwardCount
                  set *totalForwardCount = max 0 (tfc - fwdCancelRemoved))
                -- Collect servers from recipient's presence that may have received the forward
                -- (completed forwards are no longer in fwdBucket, so check presence too)
                presenceBkt <- readPresenceBucket b
                let remotePresence = collectPeerServers (presenceForKey presenceBkt to t) (\p -> p.server)
                -- Union forward targets (servers that haven't received it yet or already have it)
                -- with presence servers (servers that already received and stored the message).
                -- This ensures cancel reaches both pending and completed forward destinations.
                let allCancelServers = fold (\acc s -> if any acc (\a -> a == s) then acc else union [s] acc) remotePresence forwardTargetServers
                -- Record cancel nonce: prevents replayed federation forwards of the
                -- cancelled message from being accepted after the message is removed
                -- from all dedup sets (messages, ackedIds, deliveredIds).
                nonceResult <- updateForwardNonce b messageId to t
                yield {cancelled: True {}, cancelServers: allCancelServers, nonceLruEvicted: nonceResult.lruEvicted, nonceOldestAge: nonceResult.oldestRetainedAge}
          -- Log nonce eviction outside atomic block (println can't run inside STM)
          logNonceEviction (pubkeyBucket to) cancelResult.nonceLruEvicted cancelResult.nonceOldestAge
          -- Notify recipient that this message was retracted (delivered via next poll)
          when cancelResult.cancelled (do
            queueCancelNotification to messageId t
            atomic do cc <- *clientCancelCount; set *clientCancelCount = cc + 1)
          -- Send federation batch cancel to remote servers that may have the message.
          -- Uses FederationBatchCancel (single-entry batch) instead of FederationCancel
          -- for code path consistency with handleCancelBatch.
          -- Failed cancels are queued for retry during the next prune cycle.
          fork (when (federationEnabled && cancelResult.cancelled && count cancelResult.cancelServers > 0)
            (sendToEach cancelResult.cancelServers (\server -> do
              cancelT <- now
              cancelAuth <- generateFederationAuth "cancel-batch" cancelT
              cancelCorrId <- genTokenN 1
              cancelFedResult <- fetchFederation server (FederationBatchCancel {
                cancels: [{messageId: messageId, toKey: to}], fromServer: serverHostN,
                requestTimestamp: cancelT, correlationId: cancelCorrId,
                authorization: cancelAuth, protocolVersion: federationProtocolVersion})
              case cancelFedResult of
                Err e -> do
                  logWarn ("federation: cancel to " ++ server ++ " failed for " ++ messageId ++ ": " ++ show e)
                  queuePendingCancel messageId to server cancelT
                Ok r -> when (not r.ok) (do
                  logWarn ("federation: cancel to " ++ server ++ " rejected for " ++ messageId ++ ": " ++ r.error)
                  queuePendingCancel messageId to server cancelT))))
          yield (respond {ok: True {}, authorized: True {}, cancelled: cancelResult.cancelled, error: ""}))

-- POST /messages/batch: Send multiple messages in one request.
-- Auth checked once; each message processed independently with its own rate limiting.
-- Partial success is possible — check per-message status in results.
handleSendBatch = \messages authorization clientIp respond -> do
  t <- now
  dp <- *drainPhase
  if dp >= 2 then yield (respond {results: [], authorized: False {}, retryAfterMs: 0})
  else do
  globalRateLimited <- checkGlobalRate t
  if globalRateLimited then yield (respond {results: [], authorized: False {}, retryAfterMs: 0})
  else
    withSessionAuth authorization t clientIp
      (yield (respond {results: [], authorized: False {}, retryAfterMs: 0}))
      (\senderKey -> do
        let sized = takeRelation maxBatchSize messages
        -- Pre-deduplicate by explicit messageId to prevent within-batch duplicates.
        -- Each message in a batch gets its own atomic block via sendMessageCore, so
        -- dedup between messages in the same batch is not caught by STM.
        -- Messages with empty messageId (auto-generated) are always kept.
        let capped = fold (\acc m -> if m.messageId != "" && any acc (\a -> a.messageId == m.messageId) then acc else union acc [m]) [] sized
        -- Sort by pubkeyBucket(to) so sequential atomic blocks in sendBatchInner benefit
        -- from STM cache locality when multiple messages target the same recipient bucket.
        let sorted = sortBy (\m -> pubkeyBucket m.to) capped
        results <- sendBatchInner senderKey sorted t []
        -- Fork federation forwarding: one forked task per target server (not per message).
        -- Within each task, forwards are sent sequentially to avoid per-message fork overhead.
        let forwardTargets = do r <- results; where count r.remoteServers > 0; yield r
        -- Flatten all remote servers from all results (previous code used headOf, missing 2nd+ servers per message)
        let allServers = fold (\acc r ->
          fold (\innerAcc s ->
            if isLocalServer s then innerAcc
            else if any innerAcc (\a -> a == s) then innerAcc
            else union innerAcc [s]) acc r.remoteServers) [] forwardTargets
        fork (when (federationEnabled && count forwardTargets > 0)
          (sendToEach allServers (\server -> do
            let serverMsgs = do r <- forwardTargets; where any r.remoteServers (\s -> s == server); yield r
            sendBatchForwardsSequential serverMsgs server)))
        let batchRetryMs = fold (\acc r -> max acc r.retryAfterMs) 0 results
        yield (respond {results: do r <- results; yield {messageId: r.messageId, status: r.status}, authorized: True {}, retryAfterMs: batchRetryMs}))

-- Batch messages are sorted by pubkeyBucket(to) by the caller, so consecutive messages
-- sharing a bucket are grouped into a single atomic block. This reduces bucket reads
-- from O(batchSize) to O(uniqueBuckets) and avoids per-message transaction overhead.
-- Messages requiring genToken (empty messageId) are pre-processed outside the atomic block.
sendBatchInner = \senderKey messages t acc ->
  case headOf messages of
    Nothing {} -> yield acc
    Just {value: first} -> do
      let bucket = pubkeyBucket first.to
      -- Collect consecutive messages targeting the same bucket
      let sameR = fold (\a m -> if pubkeyBucket m.to == bucket then {same: union a.same [m], rest: a.rest} else {same: a.same, rest: union a.rest [m]}) {same: [], rest: []} messages
      -- Pre-generate message IDs and validate timestamps (IO, outside atomic block)
      prepared <- prepareBatchMessages sameR.same t []
      -- Process the entire bucket group in a single atomic block
      results <- atomic do
        dp <- *drainPhase
        sendBatchBucketGroup senderKey prepared t dp []
      -- Log warnings for rate-limited/rejected messages outside the atomic block
      logBatchResults results
      sendBatchInner senderKey sameR.rest t (union acc results)

-- Pre-generate message IDs and validate timestamps for a group of messages.
-- IO actions (genToken, logWarn) can't run inside atomic, so this runs outside.
prepareBatchMessages = \messages t acc ->
  case headOf messages of
    Nothing {} -> yield acc
    Just {value: msg} -> do
      let rest = do m <- messages; where m != msg; yield m
      effectiveMsgId <- if msg.messageId != "" then yield msg.messageId else genToken
      when (msg.timestamp > t + clockSkewTolerance)
        (logWarn ("sendBatch: future timestamp detected (+" ++ show (msg.timestamp - t) ++ "ms ahead) for " ++ effectiveMsgId))
      when (msg.timestamp < t - messageMaxAge / 2 && t - msg.timestamp <= messageMaxAge)
        (logWarn ("sendBatch: stale timestamp (" ++ show ((t - msg.timestamp) / 86400000) ++ " days old) for " ++ effectiveMsgId))
      let entry = if t - msg.timestamp > messageMaxAge
        then {msg: msg, effectiveMsgId: effectiveMsgId, stale: True {}}
        else {msg: msg, effectiveMsgId: effectiveMsgId, stale: False {}}
      prepareBatchMessages rest t (union acc [entry])

-- Process all prepared messages for one bucket in a single atomic block.
-- Each call to sendMessageCore sees the previous call's writes (updated counters,
-- new messages), avoiding redundant bucket reads.
sendBatchBucketGroup = \senderKey prepared t dp acc ->
  case headOf prepared of
    Nothing {} -> yield acc
    Just {value: entry} -> do
      let rest = do p <- prepared; where p != entry; yield p
      let clampedPri = clamp 0 maxMessagePriority entry.msg.priority
      result <- if entry.stale
        then yield {messageId: entry.effectiveMsgId, status: MsRejected {}, remoteServers: [], toKey: "", blob: "", ts: 0, retryAfterMs: 0, fwdExpiresAt: 0, fwdPriority: 0}
        else do
          let clampedTs = clampTimestamp entry.msg.timestamp t
          if dp >= 2 then yield {messageId: entry.effectiveMsgId, status: MsDraining {}, remoteServers: [], toKey: entry.msg.to, blob: entry.msg.encryptedBlob, ts: clampedTs, retryAfterMs: 0, fwdExpiresAt: 0, fwdPriority: 0}
          else do
            sendResult <- sendMessageCore senderKey entry.msg.to entry.msg.encryptedBlob clampedTs entry.effectiveMsgId entry.msg.expiresInMs clampedPri t
            yield {messageId: entry.effectiveMsgId, status: sendResult.status, remoteServers: sendResult.remoteServers, toKey: entry.msg.to, blob: entry.msg.encryptedBlob, ts: clampedTs, retryAfterMs: sendResult.retryAfterMs, fwdExpiresAt: t + effectiveMessageTtl entry.msg.expiresInMs, fwdPriority: clampedPri}
      sendBatchBucketGroup senderKey rest t dp (union acc [result])

-- Log warnings for batch results outside the atomic block
logBatchResults = \results ->
  case headOf results of
    Nothing {} -> yield {}
    Just {value: r} -> do
      let rest = do x <- results; where x != r; yield x
      case r.status of
        MsRateLimited {} -> logEvent "warn" "rate_limited_send" ("messageId=" ++ r.messageId ++ " batch=true")
        MsRejected {} -> logWarn ("sendBatch: rejected for " ++ r.messageId ++ " (capacity or mailbox full)")
        _ -> yield {}
      logBatchResults rest

-- POST /maintenance/block: Add a server to the federation blocklist.
-- Blocked peers are rejected from all inbound and outbound federation operations.
handleBlockPeer = \server authorization respond -> do
  authorized <- verifyMaintenanceAuth authorization
  if not authorized then yield (respond {ok: False {}, blocked: 0})
  else do
    logEvent "audit" "block_peer" server
    result <- atomic do
      blocked <- *blockedPeers
      if isBlockedPeer server blocked then yield {alreadyBlocked: True {}, total: count blocked}
      else do
        -- FIFO eviction: remove the oldest entry (head of list) since union appends
        let updated = if count blocked >= maxBlockedPeers
          then case headOf blocked of
            Nothing {} -> [server]
            Just {value: oldest} -> union (do b <- blocked; where b != oldest; yield b) [server]
          else union blocked [server]
        set *blockedPeers = updated
        yield {alreadyBlocked: False {}, total: count updated}
    when (not result.alreadyBlocked) (logInfo ("block: added " ++ server ++ " to blocklist (" ++ show result.total ++ " total)"))
    yield (respond {ok: True {}, blocked: result.total})

-- POST /maintenance/unblock: Remove a server from the federation blocklist.
handleUnblockPeer = \server authorization respond -> do
  authorized <- verifyMaintenanceAuth authorization
  if not authorized then yield (respond {ok: False {}, unblocked: False {}})
  else do
    logEvent "audit" "unblock_peer" server
    removed <- atomic do
      blocked <- *blockedPeers
      let had = isBlockedPeer server blocked
      set *blockedPeers = do b <- blocked; where b != server; yield b
      yield had
    when removed (logInfo ("unblock: removed " ++ server ++ " from blocklist"))
    yield (respond {ok: True {}, unblocked: removed})

-- GET /maintenance/blocked: List currently blocked federation peers.
handleListBlocked = \authorization respond -> do
  authorized <- verifyMaintenanceAuth authorization
  if not authorized then yield (respond {peers: [], ok: False {}})
  else do
    blocked <- *blockedPeers
    yield (respond {peers: blocked, ok: True {}})

-- POST /maintenance/allow: Add a server to the federation allowlist.
-- When the allowlist is non-empty, only servers on the list can federate with us.
-- Adding the first server transitions from open federation to allowlist-only mode.
handleAllowPeer = \server authorization respond -> do
  authorized <- verifyMaintenanceAuth authorization
  if not authorized then yield (respond {ok: False {}, allowed: 0})
  else do
    logEvent "audit" "allow_peer" server
    result <- atomic do
      allowed <- *allowedPeers
      if any allowed (\a -> a == server) then yield {alreadyAllowed: True {}, total: count allowed}
      else do
        let updated = if count allowed >= maxAllowedPeers
          then case headOf allowed of
            Nothing {} -> [server]
            Just {value: oldest} -> union (do a <- allowed; where a != oldest; yield a) [server]
          else union allowed [server]
        set *allowedPeers = updated
        yield {alreadyAllowed: False {}, total: count updated}
    when (not result.alreadyAllowed) (logInfo ("allow: added " ++ server ++ " to allowlist (" ++ show result.total ++ " total)"))
    yield (respond {ok: True {}, allowed: result.total})

-- POST /maintenance/unallow: Remove a server from the federation allowlist.
-- Removing the last server transitions back to open federation mode.
handleUnallowPeer = \server authorization respond -> do
  authorized <- verifyMaintenanceAuth authorization
  if not authorized then yield (respond {ok: False {}, removed: False {}})
  else do
    logEvent "audit" "unallow_peer" server
    removed <- atomic do
      allowed <- *allowedPeers
      let had = any allowed (\a -> a == server)
      set *allowedPeers = do a <- allowed; where a != server; yield a
      yield had
    when removed (logInfo ("unallow: removed " ++ server ++ " from allowlist"))
    yield (respond {ok: True {}, removed: removed})

-- GET /maintenance/allowed: List currently allowed federation peers.
-- Empty list = open federation (all peers allowed).
handleListAllowed = \authorization respond -> do
  authorized <- verifyMaintenanceAuth authorization
  if not authorized then yield (respond {peers: [], ok: False {}})
  else do
    allowed <- *allowedPeers
    yield (respond {peers: allowed, ok: True {}})

-- POST /maintenance/ping: Test federation connectivity to a specific peer.
-- Sends an empty gossip (0 events, hopsRemaining=1) to the peer via the full
-- federation auth path. The peer calls back to our /federation/verify to authenticate,
-- then processes the empty gossip (no mutations, no re-broadcast since hops=1).
-- This exercises the real bidirectional connectivity and auth flow.
handlePingPeer = \server authorization respond -> do
  authorized <- verifyMaintenanceAuth authorization
  if not authorized then yield (respond {ok: False {}, latencyMs: 0, error: "unauthorized"})
  else do
    startTime <- now
    auth <- generateFederationAuth "gossip" startTime
    pingCorrId <- genTokenN 1
    result <- fetchFederation server (RecvGossip {
      authorization: auth,
      events: [], hopsRemaining: 1, fromServer: serverHostN,
      requestTimestamp: startTime, correlationId: pingCorrId, protocolVersion: federationProtocolVersion})
    endTime <- now
    let latency = endTime - startTime
    case result of
      Err e -> do
        logWarn ("ping: " ++ server ++ " failed: " ++ show e)
        yield (respond {ok: False {}, latencyMs: latency, error: show e})
      Ok r -> yield (respond {ok: r.ok, latencyMs: latency, error: r.error})

-- GET /maintenance/sessions/{pubkey}: List sessions for a specific pubkey.
-- Uses per-bucket scan (collectSessionsForKey) instead of readAllSessions to avoid
-- materializing all 16 session buckets into one list just to filter by pubkey.
handleAdminListSessions = \pubkey authorization respond -> do
  authorized <- verifyMaintenanceAuth authorization
  if not authorized then yield (respond {sessions: [], count: 0, ok: False {}})
  else do
    keySessions <- collectSessionsForKey pubkey 0
    -- Return only metadata (IP, timestamps) — no token fragments. Even a 4-char prefix
    -- (16 bits) narrows brute-force search space and can be correlated with token bucket
    -- indices. Sessions are identifiable by (ip, createdAt) pair without token exposure.
    let masked = do s <- keySessions; yield {token: "***", expiresAt: s.expiresAt, ip: s.ip, createdAt: s.createdAt}
    yield (respond {sessions: masked, count: count masked, ok: True {}})

-- POST /maintenance/sessions/revoke-all: Revoke all sessions for a pubkey (abuse response).
-- Also clears local presence and gossips offline if federation is enabled.
handleAdminRevokeSessions = \pubkey authorization respond -> do
  authorized <- verifyMaintenanceAuth authorization
  if not authorized then yield (respond {ok: False {}, revokedCount: 0})
  else do
    logEvent "audit" "revoke_all_sessions" pubkey
    t <- now
    result <- atomic do
      -- Filter each session bucket in-place (avoids readAllSessions + writeAllSessions repartition)
      revokedCount <- revokeSessionsForKey pubkey 0
      sc <- *totalSessionCount
      set *totalSessionCount = max 0 (sc - revokedCount)
      -- Clear local presence
      let pb = pubkeyBucket pubkey
      presenceBkt <- readPresenceBucket pb
      let presenceRemoved = count presenceBkt - count (do p <- presenceBkt; where p.pubkey != pubkey || not (isLocalServer p.server); yield p)
      writePresenceBucket pb (do p <- presenceBkt; where p.pubkey != pubkey || not (isLocalServer p.server); yield p)
      tpc <- *totalPresenceCount
      set *totalPresenceCount = max 0 (tpc - presenceRemoved)
      when (presenceRemoved > 0) (set *presenceVersion = t)
      peerServers <- *knownPeerServers
      yield {revokedCount: revokedCount, peerServers: peerServers, hadPresence: presenceRemoved > 0}
    when (result.revokedCount > 0)
      (logInfo ("admin: revoked " ++ show result.revokedCount ++ " sessions for " ++ pubkey))
    when (result.hadPresence && federationEnabled && count result.peerServers > 0)
      (fork (sendBatchedGossip result.peerServers [{eventType: GossipOffline {}, pubkey: pubkey, server: serverHostN, timestamp: t, ttl: offlineGossipMinTtl, seenBy: [serverHostN]}] gossipOriginHops))
    yield (respond {ok: True {}, revokedCount: result.revokedCount})

-- POST /maintenance/messages/purge: Purge all pending messages for a specific pubkey.
-- Use for inbox-bombing abuse response: clears the recipient's mailbox without
-- requiring their session token. Also cancels pending forwards for purged messages.
-- Federated messages (originServer != "") generate ack entries so origin servers
-- can reclaim their forward entries instead of retrying until prune.
handleAdminPurgeMessages = \pubkey authorization respond -> do
  authorized <- verifyMaintenanceAuth authorization
  if not authorized then yield (respond {ok: False {}, purgedCount: 0})
  else do
    logEvent "audit" "purge_messages" pubkey
    t <- now
    purgeResult <- atomic do
      let b = pubkeyBucket pubkey
      bucket <- readMessageBucket b
      let toDelete = do m <- bucket; where m.toKey == pubkey; yield m
      let removed = count toDelete
      if removed > 0 then do
        writeMessageBucket b (do m <- bucket; where m.toKey != pubkey; yield m)
        tc <- *totalMessageCount
        set *totalMessageCount = max 0 (tc - removed)
        rc <- readRcBucket b
        writeRcBucket b (adjustRecipientCount rc pubkey (0 - removed))
        -- Cancel pending forwards for purged messages (bucket read: O(n/16))
        let deletedMsgIds = do m <- toDelete; yield m.messageId
        let pfb = pubkeyBucket pubkey
        fwdBkt <- readFwdBucket pfb
        let keptPurgeFwds = do f <- fwdBkt; where none deletedMsgIds (\mid -> f.messageId == mid && f.toKey == pubkey); yield f
        let fwdPurgeRemoved = count fwdBkt - count keptPurgeFwds
        writeFwdBucket pfb keptPurgeFwds
        when (fwdPurgeRemoved > 0) (do
          tfc <- *totalForwardCount
          set *totalForwardCount = max 0 (tfc - fwdPurgeRemoved))
        -- Create ack entries for federated messages so origin servers learn about the purge
        let federatedPurged = do m <- toDelete; where m.originServer != ""; yield m
        let ackedFederated = federatedAckEntries federatedPurged t
        if count ackedFederated > 0 then do
          ackedBkt <- readAckedBucket b
          let combinedAcked = union ackedBkt ackedFederated
          let excessCount = max 0 (count combinedAcked - maxAckedIds)
          let eviction = evictSmallest combinedAcked excessCount (\a -> a.ackedAt)
          writeAckedBucket b eviction.kept
          yield {purgedCount: removed, pendingAcks: ackedFederated, evictedEntries: eviction.evicted}
        else yield {purgedCount: removed, pendingAcks: [], evictedEntries: []}
      else yield {purgedCount: 0, pendingAcks: [], evictedEntries: []}
    when (purgeResult.purgedCount > 0)
      (logInfo ("admin: purged " ++ show purgeResult.purgedCount ++ " messages for " ++ pubkey))
    when (count purgeResult.pendingAcks > 0)
      (logInfo ("admin: sending federation acks for " ++ show (count purgeResult.pendingAcks) ++ " purged federated messages"))
    -- Send federation acks in the background (same pattern as handleAckMessages)
    fork (when federationEnabled (do
      sendAcksAndClean purgeResult.pendingAcks
      retryEvictedAcks purgeResult.evictedEntries purgeResult.pendingAcks))
    yield (respond {ok: True {}, purgedCount: purgeResult.purgedCount})

-- POST /maintenance/sessions/revoke-ip: Revoke all sessions from a specific IP address.
-- Useful for abuse response when key-rotation abuse is detected from a single IP
-- (one IP authenticating many distinct pubkeys to bypass per-key rate limits).
-- Scans all 16 session buckets, removes matching sessions, and gossips offline
-- for any pubkey that lost its last session.
handleAdminRevokeIp = \ip authorization respond -> do
  authorized <- verifyMaintenanceAuth authorization
  if not authorized then yield (respond {ok: False {}, revokedCount: 0, affectedKeys: 0})
  else do
    logEvent "audit" "revoke_ip" ip
    if ip == "" then yield (respond {ok: False {}, revokedCount: 0, affectedKeys: 0})
    else do
    t <- now
    result <- revokeSessionsByIp ip 0 t {revokedCount: 0, affectedKeys: [], cleanups: []}
    -- Gossip offline for pubkeys that lost their last session
    fork (do
      offlines <- do c <- result.cleanups; where c.gossipOffline; yield c
      when (count offlines > 0 && federationEnabled) (do
        peerServers <- *knownPeerServers
        when (count peerServers > 0) (do
          let gossipEvents = do c <- offlines; yield {eventType: GossipOffline {}, pubkey: c.pubkey, server: serverHostN, timestamp: t, ttl: offlineGossipMinTtl, seenBy: [serverHostN]}
          sendBatchedGossip peerServers gossipEvents gossipOriginHops)))
    when (result.revokedCount > 0)
      (logInfo ("admin: revoked " ++ show result.revokedCount ++ " sessions from IP " ++ ip ++ " (" ++ show (count result.affectedKeys) ++ " keys affected)"))
    yield (respond {ok: True {}, revokedCount: result.revokedCount, affectedKeys: count result.affectedKeys})

-- Per-bucket IP session revocation: scans one session bucket at a time, collecting
-- affected pubkeys and checking for last-session cleanup needs.
revokeSessionsByIp = \ip b t acc ->
  if b > 15 then yield acc
  else do
    bucketResult <- atomic do
      bucket <- readSessionBucket b
      let matching = do s <- bucket; where s.ip == ip; yield s
      let matchCount = count matching
      if matchCount == 0 then yield {removed: 0, pubkeys: []}
      else do
        writeSessionBucket b (do s <- bucket; where s.ip != ip; yield s)
        sc <- *totalSessionCount
        set *totalSessionCount = max 0 (sc - matchCount)
        -- Collect unique affected pubkeys from this bucket
        let pks = fold (\a s -> if any a (\x -> x == s.pubkey) then a else union [s.pubkey] a) [] matching
        yield {removed: matchCount, pubkeys: pks}
    -- For each newly seen pubkey, check if it was their last session
    let newKeys = do k <- bucketResult.pubkeys; where none acc.affectedKeys (\a -> a == k); yield k
    cleanups <- checkCleanupForKeys newKeys t []
    let newAcc = {revokedCount: acc.revokedCount + bucketResult.removed,
                  affectedKeys: fold (\a k -> if any a (\x -> x == k) then a else union [k] a) acc.affectedKeys bucketResult.pubkeys,
                  cleanups: union acc.cleanups cleanups}
    revokeSessionsByIp ip (b + 1) t newAcc

-- Check last-session cleanup for a list of pubkeys (used by revokeSessionsByIp)
checkCleanupForKeys = \keys t acc ->
  case headOf keys of
    Nothing {} -> yield acc
    Just {value: k} -> do
      let rest = do x <- keys; where x != k; yield x
      cleanup <- checkLastSessionCleanup k t
      checkCleanupForKeys rest t (union acc [cleanup])

-- POST /maintenance/sessions/list: List all active pubkeys with session counts and IPs.
-- Useful for detecting suspicious multi-key activity (e.g., one IP authenticating many keys)
-- without needing to know the pubkey in advance. Groups sessions by pubkey.
handleAdminListAllSessions = \limit authorization respond -> do
  authorized <- verifyMaintenanceAuth authorization
  if not authorized then yield (respond {sessions: [], ok: False {}, total: 0})
  else do
    let effectiveLimit = if limit <= 0 then 100 else clamp 1 500 limit
    t <- now
    -- Per-bucket scan: reads one session bucket at a time instead of materializing
    -- all 16 into one list (avoids O(n) union across all sessions).
    grouped <- groupSessionsByBucket 0 t []
    -- Sort by count descending (most sessions first) for abuse investigation
    let sorted = sortBy (\g -> 0 - g.count) grouped
    let capped = takeRelation effectiveLimit sorted
    yield (respond {sessions: capped, ok: True {}, total: count grouped})

-- Per-bucket session grouping: reads one bucket at a time, merging active sessions
-- into the running grouped accumulator. Avoids readAllSessions O(n) materialization.
groupSessionsByBucket = \b t acc ->
  if b > 15 then yield acc
  else do
    bucket <- readSessionBucket b
    let active = do s <- bucket; where s.expiresAt > t && t - s.createdAt < maxSessionLifetime; yield s
    let merged = fold (\grouped s ->
      if any grouped (\a -> a.pubkey == s.pubkey)
        then do a <- grouped; yield (if a.pubkey == s.pubkey then {pubkey: a.pubkey, count: a.count + 1, ips: if any a.ips (\i -> i == s.ip) || s.ip == "" then a.ips else union a.ips [s.ip], latestExpiry: max a.latestExpiry s.expiresAt} else a)
        else union grouped [{pubkey: s.pubkey, count: 1, ips: if s.ip == "" then [] else [s.ip], latestExpiry: s.expiresAt}])
      acc active
    groupSessionsByBucket (b + 1) t merged

-- POST /maintenance/nonces/flush: Clear all forward nonces (recovery from corruption).
-- Nonces provide extended replay protection beyond message/ack dedup lifetime.
-- Flushing temporarily reopens a replay window for messages older than 30 days but
-- younger than 60 days. Use only for recovery, not routine maintenance.
handleFlushNonces = \authorization respond -> do
  authorized <- verifyMaintenanceAuth authorization
  if not authorized then yield (respond {ok: False {}, flushedCount: 0})
  else do
    logEvent "audit" "flush_nonces" ""
    flushedCount <- atomic do
      total <- countAllNonces 0
      writeAllNonces []
      -- Reset all per-bucket eviction cutoffs (no nonces remain, accept all timestamps)
      resetAllNonceCutoffs 0
      yield total
    logInfo ("nonces/flush: flushed " ++ show flushedCount ++ " forward nonces")
    yield (respond {ok: True {}, flushedCount: flushedCount})

-- POST /maintenance/rotate-secret: Rotate the maintenance secret at runtime.
-- Authenticated with the current secret. The new secret takes effect immediately
-- for all subsequent requests. Pass empty newSecret to revert to the compile-time default.
handleRotateSecret = \newSecret authorization respond -> do
  authorized <- verifyMaintenanceAuth authorization
  if not authorized then yield (respond {ok: False {}, error: "unauthorized"})
  else do
    logEvent "audit" "rotate_secret" (if newSecret == "" then "revert_to_default" else "new_secret")
    if newSecret != "" && federationEnabled && not (tooLong newSecret 15) then do
      logError "rotate-secret: rejected — secret must be at least 16 characters when federation is enabled"
      yield (respond {ok: False {}, error: "secret_too_short"})
    else if newSecret != "" && not (tooLong newSecret 31) then do
      logWarn "rotate-secret: new secret is shorter than 32 characters — 32+ recommended for production"
      atomic do set *runtimeMaintenanceSecret = newSecret
      logInfo "rotate-secret: maintenance secret rotated (warning: short secret)"
      yield (respond {ok: True {}, error: ""})
    else do
      atomic do set *runtimeMaintenanceSecret = newSecret
      if newSecret == ""
        then logInfo "rotate-secret: reverted to compile-time maintenance secret"
        else logInfo "rotate-secret: maintenance secret rotated"
      yield (respond {ok: True {}, error: ""})

-- GET /maintenance/rate-limits: Return current effective rate limits.
handleGetRateLimits = \authorization respond -> do
  authorized <- verifyMaintenanceAuth authorization
  if not authorized then yield (respond {ok: False {}, globalRequest: 0, ipRate: 0, sendRate: 0, federationRate: 0, authGlobal: 0, recvRate: 0, challengeRate: 0, pairRate: 0, lookupRate: 0, clientWriteRate: 0})
  else do
    result <- atomic do
      gr <- effectiveGlobalRequestRate
      ir <- effectiveIpRate
      sr <- effectiveSendRate
      fr <- effectiveFederationRate
      ar <- effectiveAuthGlobalRate
      rr <- effectiveRecvRate
      cr <- effectiveChallengeRate
      pr <- effectivePairRate
      lr <- effectiveLookupRate
      cwr <- effectiveClientWriteRate
      yield {globalRequest: gr, ipRate: ir, sendRate: sr, federationRate: fr, authGlobal: ar, recvRate: rr, challengeRate: cr, pairRate: pr, lookupRate: lr, clientWriteRate: cwr}
    yield (respond {ok: True {}, globalRequest: result.globalRequest, ipRate: result.ipRate, sendRate: result.sendRate, federationRate: result.federationRate, authGlobal: result.authGlobal, recvRate: result.recvRate, challengeRate: result.challengeRate, pairRate: result.pairRate, lookupRate: result.lookupRate, clientWriteRate: result.clientWriteRate})

-- POST /maintenance/rate-limits: Update rate limits at runtime. 0 = reset to compile-time default.
-- Negative values are clamped to 0. Changes take effect on the next rate check cycle.
handleSetRateLimits = \globalRequest ipRate sendRate federationRate authGlobal recvRate challengeRate pairRate lookupRate clientWriteRate authorization respond -> do
  authorized <- verifyMaintenanceAuth authorization
  if not authorized then yield (respond {ok: False {}})
  else do
    logEvent "audit" "set_rate_limits" ("global=" ++ show globalRequest ++ " ip=" ++ show ipRate ++ " send=" ++ show sendRate)
    atomic do
      set *rateOverrideGlobalRequest = max 0 globalRequest
      set *rateOverrideIpRate = max 0 ipRate
      set *rateOverrideSendRate = max 0 sendRate
      set *rateOverrideFederationRate = max 0 federationRate
      set *rateOverrideAuthGlobal = max 0 authGlobal
      set *rateOverrideRecvRate = max 0 recvRate
      set *rateOverrideChallengeRate = max 0 challengeRate
      set *rateOverridePairRate = max 0 pairRate
      set *rateOverrideLookupRate = max 0 lookupRate
      set *rateOverrideClientWriteRate = max 0 clientWriteRate
    logInfo ("rate-limits: updated — global=" ++ show globalRequest ++ " ip=" ++ show ipRate ++ " send=" ++ show sendRate ++ " federation=" ++ show federationRate ++ " auth=" ++ show authGlobal ++ " recv=" ++ show recvRate ++ " challenge=" ++ show challengeRate ++ " pair=" ++ show pairRate ++ " lookup=" ++ show lookupRate ++ " clientWrite=" ++ show clientWriteRate ++ " (0 = default)")
    yield (respond {ok: True {}})

-- GET /maintenance/config: Return current effective operational parameters.
handleGetConfig = \authorization respond -> do
  authorized <- verifyMaintenanceAuth authorization
  if not authorized then yield (respond {ok: False {}, maxMessagesPerRecipient: 0, maxGossipHops: 0, pollTimeoutMs: 0})
  else do
    result <- atomic do
      mpr <- effectiveMaxMessagesPerRecipient
      mgh <- effectiveMaxGossipHops
      ptm <- effectivePollTimeoutMs
      yield {maxMessagesPerRecipient: mpr, maxGossipHops: mgh, pollTimeoutMs: ptm}
    yield (respond {ok: True {}, maxMessagesPerRecipient: result.maxMessagesPerRecipient, maxGossipHops: result.maxGossipHops, pollTimeoutMs: result.pollTimeoutMs})

-- POST /maintenance/config: Update operational parameters at runtime. 0 = reset to compile-time default.
-- Changes take effect immediately for new requests. Existing long-polls continue with old values.
handleSetConfig = \newMaxMessagesPerRecipient newMaxGossipHops newPollTimeoutMs authorization respond -> do
  authorized <- verifyMaintenanceAuth authorization
  if not authorized then yield (respond {ok: False {}})
  else do
    logEvent "audit" "set_config" ("maxMessagesPerRecipient=" ++ show newMaxMessagesPerRecipient ++ " maxGossipHops=" ++ show newMaxGossipHops ++ " pollTimeoutMs=" ++ show newPollTimeoutMs)
    atomic do
      set *configOverrideMaxMessagesPerRecipient = max 0 newMaxMessagesPerRecipient
      set *configOverrideMaxGossipHops = max 0 newMaxGossipHops
      set *configOverridePollTimeoutMs = max 0 newPollTimeoutMs
    logInfo ("config: updated — maxMessagesPerRecipient=" ++ show newMaxMessagesPerRecipient ++ " maxGossipHops=" ++ show newMaxGossipHops ++ " pollTimeoutMs=" ++ show newPollTimeoutMs ++ " (0 = default)")
    yield (respond {ok: True {}})

-- Extract request path for access logging (excludes poll to reduce log volume)
requestPath = \req -> case req of
  ReqChallenge {} -> "POST /auth/challenge"
  VerifyAuth {} -> "POST /auth/verify"
  RevokeSession {} -> "POST /auth/revoke"
  Logout {} -> "POST /auth/logout"
  Poll {} -> ""  -- suppress: high volume, logged on slow path only
  SendMessage {} -> "POST /messages"
  MessageStatus {} -> "POST /messages/status"
  AckMessages {} -> "POST /messages/ack"
  SendBatch {} -> "POST /messages/batch"
  ListMessages {} -> "POST /messages/list"
  DeleteMessages {} -> "POST /messages/delete"
  CancelMessage {} -> "POST /messages/cancel"
  CancelBatch {} -> "POST /messages/cancel-batch"
  LookupPresence {} -> "GET /lookup"
  BatchLookupPresence {} -> "POST /lookup/batch"
  RecvGossip {} -> "POST /federation/gossip"
  ForwardMessage {} -> "POST /federation/forward"
  FederationAck {} -> "POST /federation/ack"
  FederationCancel {} -> "POST /federation/cancel"
  FederationBatchCancel {} -> "POST /federation/cancel-batch"
  FederationBatchForward {} -> "POST /federation/forward-batch"
  FederationDeliveryReceipt {} -> "POST /federation/delivery-receipt"
  VerifyToken {} -> "POST /federation/verify"
  FederationPubkey {} -> "GET /federation/pubkey"
  Prune {} -> "POST /maintenance/prune"
  Drain {} -> "POST /maintenance/drain"
  Shutdown {} -> "POST /maintenance/shutdown"
  Undrain {} -> "POST /maintenance/undrain"
  BlockPeer {} -> "POST /maintenance/block"
  UnblockPeer {} -> "POST /maintenance/unblock"
  ListBlocked {} -> "GET /maintenance/blocked"
  PingPeer {} -> "POST /maintenance/ping"
  AdminListSessions {} -> "GET /maintenance/sessions"
  AdminRevokeSessions {} -> "POST /maintenance/sessions/revoke-all"
  AdminListAllSessions {} -> "POST /maintenance/sessions/list"
  AdminPurgeMessages {} -> "POST /maintenance/messages/purge"
  AdminRevokeIp {} -> "POST /maintenance/sessions/revoke-ip"
  GetRateLimits {} -> "GET /maintenance/rate-limits"
  SetRateLimits {} -> "POST /maintenance/rate-limits"
  FlushNonces {} -> "POST /maintenance/nonces/flush"
  AllowPeer {} -> "POST /maintenance/allow"
  UnallowPeer {} -> "POST /maintenance/unallow"
  ListAllowed {} -> "GET /maintenance/allowed"
  Reconcile {} -> "POST /maintenance/reconcile"
  RotateSecret {} -> "POST /maintenance/rotate-secret"
  GetConfig {} -> "GET /maintenance/config"
  SetConfig {} -> "POST /maintenance/config"
  Health {} -> "GET /health"
  Stats {} -> "GET /stats"
  StatsPeers {} -> "GET /stats/peers"
  StatsKey {} -> "GET /stats/key"
  TopRecipients {} -> "POST /stats/top-recipients"
  StatsForwards {} -> "GET /stats/forwards"
  StatsRates {} -> "GET /stats/rates"
  Metrics {} -> "GET /metrics"
  Ready {} -> "GET /ready"

-- Extract client IP for access logging (empty for federation/maintenance/stats routes).
-- Client-facing routes extract clientIp; all others use catch-all to avoid enumerating
-- every federation/maintenance/stats route (reduces maintenance burden on new routes).
requestClientIp = \req -> case req of
  ReqChallenge {clientIp} -> clientIp
  VerifyAuth {clientIp} -> clientIp
  RevokeSession {clientIp} -> clientIp
  Logout {clientIp} -> clientIp
  Poll {clientIp} -> clientIp
  SendMessage {clientIp} -> clientIp
  MessageStatus {clientIp} -> clientIp
  AckMessages {clientIp} -> clientIp
  SendBatch {clientIp} -> clientIp
  ListMessages {clientIp} -> clientIp
  DeleteMessages {clientIp} -> clientIp
  CancelMessage {clientIp} -> clientIp
  CancelBatch {clientIp} -> clientIp
  LookupPresence {clientIp} -> clientIp
  BatchLookupPresence {clientIp} -> clientIp
  VerifyToken {clientIp} -> clientIp
  _ -> ""

-- Slow request threshold for access logging (ms)
slowRequestThreshold : Int<Ms>
slowRequestThreshold = 1000

serveInner = \req -> case req of
  ReqChallenge {pubkey, clientIp, respond} -> handleChallenge pubkey clientIp respond
  VerifyAuth {pubkey, challenge, signature, revokeOthers, clientIp, respond} -> handleVerifyAuth pubkey challenge signature revokeOthers clientIp respond
  RevokeSession {targetToken, authorization, clientIp, respond} -> handleRevoke targetToken authorization clientIp respond
  Logout {authorization, clientIp, respond} -> handleLogout authorization clientIp respond
  Poll {cursor, generation, watchKeys, authorization, clientIp, respond} -> handlePoll cursor generation watchKeys authorization clientIp respond
  SendMessage {to, encryptedBlob, timestamp, messageId, expiresInMs, priority, authorization, clientIp, respond} -> handleSendMessage to encryptedBlob timestamp messageId expiresInMs priority authorization clientIp respond
  MessageStatus {to, messageId, authorization, clientIp, respond} -> handleMessageStatus to messageId authorization clientIp respond
  AckMessages {messageIds, authorization, clientIp, respond} -> handleAckMessages messageIds authorization clientIp respond
  SendBatch {messages, authorization, clientIp, respond} -> handleSendBatch messages authorization clientIp respond
  ListMessages {offset, authorization, clientIp, respond} -> handleListMessages offset authorization clientIp respond
  DeleteMessages {messageIds, authorization, clientIp, respond} -> handleDeleteMessages messageIds authorization clientIp respond
  CancelMessage {messageId, to, authorization, clientIp, respond} -> handleCancelMessage messageId to authorization clientIp respond
  CancelBatch {cancels, authorization, clientIp, respond} -> handleCancelBatch cancels authorization clientIp respond
  LookupPresence {pubkey, authorization, clientIp, respond} -> handleLookupPresence pubkey authorization clientIp respond
  BatchLookupPresence {pubkeys, authorization, clientIp, respond} -> handleBatchLookupPresence pubkeys authorization clientIp respond
  RecvGossip {events, hopsRemaining, fromServer, requestTimestamp, correlationId, protocolVersion, authorization, respond} -> do
    warnOldProtocol fromServer protocolVersion; handleRecvGossip events hopsRemaining fromServer requestTimestamp correlationId authorization respond
  ForwardMessage {toKey, encryptedBlob, timestamp, originServer, messageId, fromServer, requestTimestamp, correlationId, expiresAt, priority, protocolVersion, authorization, respond} -> do
    warnOldProtocol fromServer protocolVersion; handleForwardMessage toKey encryptedBlob timestamp originServer messageId fromServer requestTimestamp correlationId expiresAt priority authorization respond
  FederationAck {messageIds, originServer, fromServer, requestTimestamp, correlationId, protocolVersion, authorization, respond} -> do
    warnOldProtocol fromServer protocolVersion; handleFederationAck messageIds originServer fromServer requestTimestamp correlationId authorization respond
  FederationCancel {messageId, toKey, fromServer, requestTimestamp, correlationId, protocolVersion, authorization, respond} -> do
    warnOldProtocol fromServer protocolVersion; handleFederationCancel messageId toKey fromServer requestTimestamp correlationId authorization respond
  FederationBatchCancel {cancels, fromServer, requestTimestamp, correlationId, protocolVersion, authorization, respond} -> do
    warnOldProtocol fromServer protocolVersion; handleFederationBatchCancel cancels fromServer requestTimestamp correlationId authorization respond
  FederationBatchForward {forwards, fromServer, requestTimestamp, correlationId, protocolVersion, authorization, respond} -> do
    warnOldProtocol fromServer protocolVersion; handleFederationBatchForward forwards fromServer requestTimestamp correlationId authorization respond
  FederationDeliveryReceipt {messageIds, toKeys, fromServer, requestTimestamp, correlationId, protocolVersion, authorization, respond} -> do
    warnOldProtocol fromServer protocolVersion; handleFederationDeliveryReceipt messageIds toKeys fromServer requestTimestamp correlationId authorization respond
  VerifyToken {token, scope, clientIp, respond} -> handleVerifyToken token scope clientIp respond
  FederationPubkey {respond} -> handleFederationPubkey respond
  Prune {authorization, respond} -> handlePrune authorization respond
  Drain {phase, authorization, respond} -> handleDrain phase authorization respond
  Shutdown {authorization, respond} -> handleShutdown authorization respond
  Undrain {authorization, respond} -> handleUndrain authorization respond
  BlockPeer {server, authorization, respond} -> handleBlockPeer server authorization respond
  UnblockPeer {server, authorization, respond} -> handleUnblockPeer server authorization respond
  ListBlocked {authorization, respond} -> handleListBlocked authorization respond
  PingPeer {server, authorization, respond} -> handlePingPeer server authorization respond
  AdminListSessions {pubkey, authorization, respond} -> handleAdminListSessions pubkey authorization respond
  AdminRevokeSessions {pubkey, authorization, respond} -> handleAdminRevokeSessions pubkey authorization respond
  AdminListAllSessions {limit, authorization, respond} -> handleAdminListAllSessions limit authorization respond
  AdminPurgeMessages {pubkey, authorization, respond} -> handleAdminPurgeMessages pubkey authorization respond
  AdminRevokeIp {ip, authorization, respond} -> handleAdminRevokeIp ip authorization respond
  GetRateLimits {authorization, respond} -> handleGetRateLimits authorization respond
  SetRateLimits {globalRequest, ipRate, sendRate, federationRate, authGlobal, recvRate, challengeRate, pairRate, lookupRate, clientWriteRate, authorization, respond} -> handleSetRateLimits globalRequest ipRate sendRate federationRate authGlobal recvRate challengeRate pairRate lookupRate clientWriteRate authorization respond
  FlushNonces {authorization, respond} -> handleFlushNonces authorization respond
  AllowPeer {server, authorization, respond} -> handleAllowPeer server authorization respond
  UnallowPeer {server, authorization, respond} -> handleUnallowPeer server authorization respond
  ListAllowed {authorization, respond} -> handleListAllowed authorization respond
  Reconcile {authorization, respond} -> handleReconcile authorization respond
  RotateSecret {newSecret, authorization, respond} -> handleRotateSecret newSecret authorization respond
  GetConfig {authorization, respond} -> handleGetConfig authorization respond
  SetConfig {maxMessagesPerRecipient, maxGossipHops, pollTimeoutMs, authorization, respond} -> handleSetConfig maxMessagesPerRecipient maxGossipHops pollTimeoutMs authorization respond
  Health {authorization, respond} -> handleHealth authorization respond
  Stats {authorization, respond} -> handleStats authorization respond
  StatsPeers {authorization, respond} -> handleStatsPeers authorization respond
  StatsKey {pubkey, authorization, respond} -> handleStatsKey pubkey authorization respond
  TopRecipients {limit, authorization, respond} -> handleTopRecipients limit authorization respond
  StatsForwards {authorization, respond} -> handleStatsForwards authorization respond
  StatsRates {authorization, respond} -> handleStatsRates authorization respond
  Metrics {authorization, respond} -> handleMetrics authorization respond
  Ready {respond} -> handleReady respond

-- Backpressure: check if the server is overloaded (too many concurrent requests).
-- Health, Ready, and Maintenance endpoints are exempt so operators can always monitor
-- and control the server even under extreme load.
isOverloadExempt = \req -> case req of
  Health {} -> True {}
  Ready {} -> True {}
  Prune {} -> True {}
  Drain {} -> True {}
  Shutdown {} -> True {}
  Undrain {} -> True {}
  Reconcile {} -> True {}
  Stats {} -> True {}
  StatsPeers {} -> True {}
  StatsKey {} -> True {}
  StatsRates {} -> True {}
  Metrics {} -> True {}
  _ -> False {}

-- Reject overloaded requests with appropriate empty/error responses per route type.
-- Each response matches the handler's return shape with zeroed/empty fields.
-- NOTE: This exhaustive case match is required by Knot's type system — each route has a
-- different response shape. If Knot adds a default response constructor or row-polymorphic
-- error responses, this can be collapsed to a single default branch.
serveOverloaded = \req -> case req of
  -- Auth routes
  ReqChallenge {respond} -> respond {challenge: "", ok: False {}, expiresAt: 0, retryAfterMs: 1000, error: "overloaded"}
  VerifyAuth {respond} -> respond {token: "", expiresAt: 0, error: "overloaded"}
  RevokeSession {respond} -> respond {ok: False {}, authorized: False {}}
  Logout {respond} -> respond {ok: False {}, authorized: False {}}
  -- Client routes
  Poll {respond} -> respond {events: [], cursor: 0, authorized: False {}, rateLimited: True {}, draining: False {}, generation: 0, presenceUpdates: [], heartbeat: False {}, retryAfterMs: 1000, cursorReset: False {}, hasMore: False {}, cursorStale: False {}, messageExpirations: [], messageDeliveries: [], droppedDeliveryReceipts: 0, droppedExpirationNotifs: 0, loadPct: 0, messageCancellations: []}
  SendMessage {respond} -> respond {status: MsRejected {}, messageId: "", retryAfterMs: 1000, error: "overloaded", loadPct: 0}
  MessageStatus {respond} -> respond {status: "", authorized: False {}}
  AckMessages {respond} -> respond {ok: False {}, authorized: False {}, ackedCount: 0, error: "overloaded"}
  SendBatch {respond} -> respond {results: [], authorized: False {}, retryAfterMs: 1000}
  ListMessages {respond} -> respond {messages: [], authorized: False {}, count: 0, error: "overloaded"}
  DeleteMessages {respond} -> respond {ok: False {}, authorized: False {}, deletedCount: 0, error: "overloaded"}
  CancelMessage {respond} -> respond {ok: False {}, authorized: False {}, cancelled: False {}, error: "overloaded"}
  CancelBatch {respond} -> respond {results: [], authorized: False {}, error: "overloaded"}
  LookupPresence {respond} -> respond {server: "", authorized: False {}, error: "overloaded"}
  BatchLookupPresence {respond} -> respond {results: [], authorized: False {}, error: "overloaded"}
  -- Federation routes
  RecvGossip {respond} -> respond {ok: False {}, error: "overloaded", retryAfterMs: 1000}
  ForwardMessage {respond} -> respond {ok: False {}, error: "overloaded", retryAfterMs: 1000}
  FederationAck {respond} -> respond {ok: False {}, error: "overloaded", ackedCount: 0, results: [], retryAfterMs: 1000}
  FederationCancel {respond} -> respond {ok: False {}, error: "overloaded", cancelled: False {}, retryAfterMs: 1000}
  FederationBatchCancel {respond} -> respond {ok: False {}, error: "overloaded", results: [], retryAfterMs: 1000}
  FederationBatchForward {respond} -> respond {ok: False {}, error: "overloaded", results: [], retryAfterMs: 1000}
  FederationDeliveryReceipt {respond} -> respond {ok: False {}, error: "overloaded", receivedCount: 0, retryAfterMs: 1000}
  VerifyToken {respond} -> respond {ok: False {}}
  FederationPubkey {respond} -> respond {pubkey: "", ok: False {}}
  -- Stats/admin routes (exempt routes handled by isOverloadExempt; these are fallbacks)
  TopRecipients {respond} -> respond {recipients: [], ok: False {}, total: 0}
  StatsForwards {respond} -> respond {servers: [], ok: False {}, total: 0}
  StatsRates {respond} -> respond {ok: False {}, scalePct: 0, globalRequest: 0, ipRate: 0, sendRate: 0, federationRate: 0, authGlobal: 0, recvRate: 0, challengeRate: 0, pairRate: 0, lookupRate: 0, clientWriteRate: 0}
  BlockPeer {respond} -> respond {ok: False {}, blocked: 0}
  UnblockPeer {respond} -> respond {ok: False {}, unblocked: False {}}
  ListBlocked {respond} -> respond {peers: [], ok: False {}}
  PingPeer {respond} -> respond {ok: False {}, latencyMs: 0, error: "overloaded"}
  AdminListSessions {respond} -> respond {sessions: [], count: 0, ok: False {}}
  AdminRevokeSessions {respond} -> respond {ok: False {}, revokedCount: 0}
  AdminPurgeMessages {respond} -> respond {ok: False {}, purgedCount: 0}
  AdminRevokeIp {respond} -> respond {ok: False {}, revokedCount: 0, affectedKeys: 0}
  AdminListAllSessions {respond} -> respond {sessions: [], ok: False {}, total: 0}
  GetRateLimits {respond} -> respond {ok: False {}, globalRequest: 0, ipRate: 0, sendRate: 0, federationRate: 0, authGlobal: 0, recvRate: 0, challengeRate: 0, pairRate: 0, lookupRate: 0, clientWriteRate: 0}
  SetRateLimits {respond} -> respond {ok: False {}}
  FlushNonces {respond} -> respond {ok: False {}, flushedCount: 0}
  AllowPeer {respond} -> respond {ok: False {}, allowed: 0}
  UnallowPeer {respond} -> respond {ok: False {}, removed: False {}}
  ListAllowed {respond} -> respond {peers: [], ok: False {}}
  RotateSecret {respond} -> respond {ok: False {}, error: "overloaded"}
  GetConfig {respond} -> respond {ok: False {}, maxMessagesPerRecipient: 0, maxGossipHops: 0, pollTimeoutMs: 0}
  SetConfig {respond} -> respond {ok: False {}}
  Metrics {respond} -> respond {metrics: "", ok: False {}}
  -- Exempt routes handled by isOverloadExempt; this branch is unreachable
  _ -> yield {}

-- Access-logged request handler: wraps serveInner with timing and correlation ID.
-- Logs all non-poll requests with a 6-hex-char request ID for log correlation.
-- Polls are only logged when slow (> slowRequestThreshold) to avoid overwhelming
-- logs with high-frequency long-poll traffic.
-- Backpressure: rejects non-exempt requests when activeRequests >= maxActiveRequests.
serve = \req -> do
  startTime <- now
  reqId <- genTokenN 1
  -- Backpressure check: reject early if overloaded (exempt: health, ready, maintenance)
  overloaded <- if maxActiveRequests <= 0 || isOverloadExempt req then yield (False {})
    else do
      ar <- *activeRequests
      yield (ar >= maxActiveRequests)
  if overloaded then do
    logEvent "warn" "overloaded" (requestPath req)
    serveOverloaded req
  else do
  atomic do
    ar <- *activeRequests
    let newAr = ar + 1
    set *activeRequests = newAr
    peak <- *peakActiveRequests
    when (newAr > peak) (set *peakActiveRequests = newAr)
  serveInner req
  endTime <- now
  atomic do
    ar <- *activeRequests
    set *activeRequests = max 0 (ar - 1)
    set *lastRequestCompletedAt = endTime
  let latency = endTime - startTime
  -- Record client operation latency for /stats monitoring (windowed avg/max).
  -- Only tracks poll and send — the two highest-volume client operations.
  case req of
    Poll {} -> atomic do
      total <- *clientPollLatencyTotal
      cnt <- *clientPollLatencyCount
      mx <- *clientPollLatencyMax
      set *clientPollLatencyTotal = total + latency
      set *clientPollLatencyCount = cnt + 1
      set *clientPollLatencyMax = if latency > mx then latency else mx
      -- Histogram bucket increment
      if latency < clientLatencyT1 then do b <- *clientPollLatencyBucket0; set *clientPollLatencyBucket0 = b + 1
      else if latency < clientLatencyT2 then do b <- *clientPollLatencyBucket1; set *clientPollLatencyBucket1 = b + 1
      else if latency < clientLatencyT3 then do b <- *clientPollLatencyBucket2; set *clientPollLatencyBucket2 = b + 1
      else do b <- *clientPollLatencyBucket3; set *clientPollLatencyBucket3 = b + 1
    SendMessage {} -> atomic do
      total <- *clientSendLatencyTotal
      cnt <- *clientSendLatencyCount
      mx <- *clientSendLatencyMax
      set *clientSendLatencyTotal = total + latency
      set *clientSendLatencyCount = cnt + 1
      set *clientSendLatencyMax = if latency > mx then latency else mx
      if latency < clientLatencyT1 then do b <- *clientSendLatencyBucket0; set *clientSendLatencyBucket0 = b + 1
      else if latency < clientLatencyT2 then do b <- *clientSendLatencyBucket1; set *clientSendLatencyBucket1 = b + 1
      else if latency < clientLatencyT3 then do b <- *clientSendLatencyBucket2; set *clientSendLatencyBucket2 = b + 1
      else do b <- *clientSendLatencyBucket3; set *clientSendLatencyBucket3 = b + 1
    SendBatch {} -> atomic do
      total <- *clientSendLatencyTotal
      cnt <- *clientSendLatencyCount
      mx <- *clientSendLatencyMax
      set *clientSendLatencyTotal = total + latency
      set *clientSendLatencyCount = cnt + 1
      set *clientSendLatencyMax = if latency > mx then latency else mx
      if latency < clientLatencyT1 then do b <- *clientSendLatencyBucket0; set *clientSendLatencyBucket0 = b + 1
      else if latency < clientLatencyT2 then do b <- *clientSendLatencyBucket1; set *clientSendLatencyBucket1 = b + 1
      else if latency < clientLatencyT3 then do b <- *clientSendLatencyBucket2; set *clientSendLatencyBucket2 = b + 1
      else do b <- *clientSendLatencyBucket3; set *clientSendLatencyBucket3 = b + 1
    ReqChallenge {} -> atomic do
      total <- *clientAuthLatencyTotal
      cnt <- *clientAuthLatencyCount
      mx <- *clientAuthLatencyMax
      set *clientAuthLatencyTotal = total + latency
      set *clientAuthLatencyCount = cnt + 1
      set *clientAuthLatencyMax = if latency > mx then latency else mx
    VerifyAuth {} -> atomic do
      total <- *clientAuthLatencyTotal
      cnt <- *clientAuthLatencyCount
      mx <- *clientAuthLatencyMax
      set *clientAuthLatencyTotal = total + latency
      set *clientAuthLatencyCount = cnt + 1
      set *clientAuthLatencyMax = if latency > mx then latency else mx
    RevokeSession {} -> atomic do
      total <- *clientAuthLatencyTotal
      cnt <- *clientAuthLatencyCount
      mx <- *clientAuthLatencyMax
      set *clientAuthLatencyTotal = total + latency
      set *clientAuthLatencyCount = cnt + 1
      set *clientAuthLatencyMax = if latency > mx then latency else mx
    Logout {} -> atomic do
      total <- *clientAuthLatencyTotal
      cnt <- *clientAuthLatencyCount
      mx <- *clientAuthLatencyMax
      set *clientAuthLatencyTotal = total + latency
      set *clientAuthLatencyCount = cnt + 1
      set *clientAuthLatencyMax = if latency > mx then latency else mx
    _ -> yield {}
  let path = requestPath req
  let ip = requestClientIp req
  -- Structured access log: machine-parseable JSON for monitoring pipelines.
  -- Polls only logged when slow (> slowRequestThreshold) to avoid log volume from long-poll traffic.
  if path != ""
    then do
      println ("{\"level\":\"info\",\"event\":\"access\",\"req\":\"" ++ escapeJsonString reqId ++ "\",\"path\":\"" ++ escapeJsonString path ++ "\",\"ms\":" ++ show latency ++ (if ip != "" then ",\"ip\":\"" ++ escapeJsonString ip ++ "\"" else "") ++ "}")
      when (latency > slowRequestThreshold)
        (logEvent "warn" "slow_request" (path ++ " " ++ show latency ++ "ms"))
    else when (latency > slowRequestThreshold) (do
      println ("{\"level\":\"warn\",\"event\":\"access\",\"req\":\"" ++ escapeJsonString reqId ++ "\",\"path\":\"poll\",\"ms\":" ++ show latency ++ (if ip != "" then ",\"ip\":\"" ++ escapeJsonString ip ++ "\"" else "") ++ ",\"slow\":true}")
      logEvent "warn" "slow_request" ("poll " ++ show latency ++ "ms"))

-- ============================================
-- Entry Point
-- ============================================

-- Background loop: periodically prunes expired state and retries pending federation ops.
-- Jitter prevents thundering herd when multiple servers restart simultaneously.
-- NOTE: This function (and all background loops below) recurse via tail calls.
-- Knot compiles tail calls to loops, so stack growth is bounded. If Knot's tail-call
-- optimization is ever disabled, these loops will overflow the stack over time.
-- The backgroundWatchdog can restart backgroundPrune and pollHeartbeat if they die,
-- but cannot restart itself. A TCO failure in any loop would
-- eventually surface as a health check failure (pruneHealthy/heartbeatHealthy/watchdogHealthy).
-- TODO: If Knot adds an iterative construct (e.g., loop/while), migrate background loops
-- to avoid the TCO dependency entirely.
backgroundPrune = do
  jitter <- randomInt 5000
  sleep (backgroundPruneInterval + jitter)
  dp <- *drainPhase
  -- Check shutdown: if drain completed and shutdown requested, exit the loop
  shutdownReq <- *shutdownRequested
  dca <- *drainCompletedAt
  if shutdownReq && dca > 0 then logInfo "backgroundPrune: shutdown complete, exiting loop"
  else if dp >= 2 then do
    sleep backgroundPruneInterval
    backgroundPrune
  else do
  t <- now
  -- Detect clock jumps in both directions:
  -- Backward: seqCounter ahead of now (clock corrected back after forward jump)
  -- Forward: now jumped far ahead of last prune (VM suspend, NTP step)
  -- Forward jumps cause inflated receivedAt timestamps; clients with those cursors
  -- miss new messages until real time catches up. Log a warning so operators can
  -- advise affected clients to reset their cursor (generation change handles this).
  atomic do
    sc <- *seqCounter
    lp <- *lastPrunedAt
    when (sc > t + clockSkewTolerance) (do
      logWarn ("clock jump detected — seqCounter " ++ show (sc - t) ++ "ms ahead of now, resetting")
      set *seqCounter = t
      -- Bump server generation so clients reset their cursors (avoids stuck polls
      -- from messages with inflated receivedAt timestamps during the forward jump)
      set *serverGeneration = t)
    -- Forward jump detection: now is far ahead of last prune (more than 10x interval).
    -- Bump server generation so clients reset their cursors: messages stored during the
    -- jump window have inflated receivedAt timestamps that would appear as "already seen"
    -- to clients with pre-jump cursors. Without a generation bump, these messages are
    -- silently skipped until real time catches up to the inflated timestamps.
    when (lp > 0 && t - lp > backgroundPruneInterval * 10) (do
      logWarn ("clock forward jump detected — " ++ show (t - lp) ++ "ms since last prune (expected ~" ++ show backgroundPruneInterval ++ "ms), bumping server generation and resetting seqCounter")
      set *serverGeneration = t
      -- Also reset seqCounter: messages stored during the forward jump window have
      -- inflated receivedAt timestamps from nextSeqTs using the jumped seqCounter.
      -- Without this reset, new messages would continue getting inflated timestamps
      -- until seqCounter is organically surpassed by real time.
      set *seqCounter = t)
  -- Heartbeat watchdog: bump pollWakeup if heartbeat loop appears dead
  sa <- *startedAt
  lastHb <- *lastHeartbeatAt
  when (t - sa > healthHeartbeatMaxAge && t - lastHb > healthHeartbeatMaxAge) (do
    logWarn "backgroundPrune: heartbeat appears dead, bumping pollWakeup"
    atomic do
      set *pollWakeup = t
      set *lastHeartbeatAt = t)
  status <- atomic do
    running <- *pruneRunning
    -- Dynamic stuck threshold: 3x the last known cycle duration, with a floor of 3x prune interval
    -- and ceiling of 10x prune interval. Adapts to heavy cycles (reconciliation, large nonce pruning)
    -- without the fixed 5x being too tight for fast cycles or too loose for slow ones.
    lastDuration <- *lastPruneDuration
    let dynamicThreshold = if lastDuration > 0 then clamp (backgroundPruneInterval * 3) (backgroundPruneInterval * 10) (lastDuration * 3) else backgroundPruneInterval * 5
    if running > 0 && t - running < dynamicThreshold
      then yield {canRun: False {}, recovered: False {}, gen: 0, stuckSince: 0}
      else do
        set *pruneRunning = t
        gen <- *pruneGeneration
        let newGen = gen + 1
        set *pruneGeneration = newGen
        pc <- *pruneCount
        set *pruneCount = pc + 1
        yield {canRun: True {}, recovered: running > 0, gen: newGen, stuckSince: running}
  when status.recovered (do
    logWarn ("backgroundPrune: previous cycle stuck for " ++ show (t - status.stuckSince) ++ "ms, forcing recovery")
    -- Reset fork counter: the stuck fork leaked its slot, so reclaim it to prevent permanent lockout
    atomic do set *activePruneForks = 0)
  if status.canRun
    then do
      -- Guard against unbounded concurrent prune forks from repeated stuck recovery
      forks <- *activePruneForks
      if forks >= 2
        then logWarn "backgroundPrune: skipping (max concurrent prune forks reached)"
        else do
          atomic do
            af <- *activePruneForks
            set *activePruneForks = af + 1
          fork (do
            -- Pre-flight generation check: if a newer prune cycle was scheduled between
            -- our fork and when the runtime schedules this task, skip to avoid overlapping
            -- prune cycles that could double-count counter decrements.
            preFlightGen <- *pruneGeneration
            if preFlightGen != status.gen
              then do
                logWarn "backgroundPrune: stale fork detected (generation changed), skipping"
                atomic do
                  af <- *activePruneForks
                  set *activePruneForks = max 0 (af - 1)
              else do
                pruneAndRetry t
                -- Only clear running flag if this is still the latest generation
                -- (prevents a stuck old fork from clearing the flag after a recovery cycle started)
                endT <- now
                atomic do
                  currentGen <- *pruneGeneration
                  when (currentGen == status.gen) (do
                    set *pruneRunning = 0
                    set *lastPruneDuration = endT - t)
                  af <- *activePruneForks
                  set *activePruneForks = max 0 (af - 1))
    else logWarn "backgroundPrune: skipping (previous cycle still running)"
  backgroundPrune

-- Background loop: periodically bumps pollWakeup to unblock long-polls that have been
-- waiting too long (heartbeat). Ensures polls return within pollTimeoutMs even if no messages arrive.
-- Adaptive: under high load (>80% capacity), the heartbeat fires more frequently
-- (down to 5s at peak) to release poll slots faster and reduce connection hold time.
-- Normal load uses the full pollTimeoutMs (~25s).
pollHeartbeat = do
  -- Adaptive poll timeout: scale heartbeat interval based on server load.
  -- adaptiveRateScale returns 10-100 (percentage). At 100% (normal): full pollTimeoutMs.
  -- At 10% (peak load): max(5000, pollTimeoutMs * 10 / 100) = 5000ms.
  basePollTimeout <- effectivePollTimeoutMs
  scale <- atomic do
    tmc <- *totalMessageCount
    sc <- *totalSessionCount
    pc <- *totalPresenceCount
    yield (adaptiveRateScale tmc sc pc)
  let effectiveTimeout = max 5000 (basePollTimeout * scale / 100)
  jitter <- randomInt 2000
  sleep (effectiveTimeout + jitter)
  dp <- *drainPhase
  shutdownReq <- *shutdownRequested
  dca <- *drainCompletedAt
  if shutdownReq && dca > 0 then logInfo "pollHeartbeat: shutdown complete, exiting loop"
  else if dp >= 2 then do
    t <- now
    atomic do set *pollWakeup = t
    -- Don't exit; sleep and retry so undrain can resume the loop
    sleep pollTimeoutMs
    pollHeartbeat
  else do
    t <- now
    atomic do
      set *pollWakeup = t
      set *lastHeartbeatAt = t
      hc <- *heartbeatCount
      set *heartbeatCount = hc + 1
    pollHeartbeat

-- Background watchdog: monitors prune and heartbeat loops, restarts if they appear dead.
-- Knot lacks try/catch, so panicked loops can't self-recover. This watchdog detects
-- liveness by checking counter freshness and forks a new loop instance as needed.
backgroundWatchdog = do
  sleep (backgroundPruneInterval * 5)
  t <- now
  atomic do set *lastWatchdogAt = t
  sa <- *startedAt
  let warmup = t - sa < backgroundPruneInterval * 10
  if warmup then backgroundWatchdog
  else do
    -- Check prune loop health
    lastPrune <- *lastPrunedAt
    when (t - lastPrune > healthPruneMaxAge * 3) (do
      logError "watchdog: prune loop appears dead, restarting"
      atomic do set *pruneRunning = 0
      fork backgroundPrune)
    -- Check heartbeat loop health
    lastHb <- *lastHeartbeatAt
    when (t - lastHb > healthHeartbeatMaxAge * 3) (do
      logError "watchdog: heartbeat loop appears dead, restarting"
      fork pollHeartbeat)
    -- Recover leaked federation slots: if prune is alive but in-flight counters
    -- are stuck, force-reconcile. This catches edge cases where panicked fetches
    -- leaked slots but prune's stale threshold hasn't reclaimed them yet.
    fedActive <- *federationActiveConnections
    when (fedActive > maxGlobalFederationConcurrency) (do
      logWarn ("watchdog: federation connection counter (" ++ show fedActive ++ ") exceeds max (" ++ show maxGlobalFederationConcurrency ++ "), reconciling")
      atomic do
        inFlight <- *federationInFlight
        set *federationActiveConnections = fold (\acc r -> acc + r.count) 0 inFlight)
    -- Log hung federation connections even below the max threshold (early warning)
    inFlight <- *federationInFlight
    let hungSlots = do r <- inFlight; where r.count > 0 && r.firstStartedAt > 0 && t - r.firstStartedAt >= federationFetchTimeoutMs; yield r
    when (count hungSlots > 0) (do
      logEvent "warn" "watchdog_hung_federation" (show (count hungSlots) ++ " servers with hung connections")
      logStaleInFlight hungSlots t)
    backgroundWatchdog

-- Meta-watchdog: monitors the watchdog itself. The backgroundWatchdog can restart prune
-- and heartbeat loops, but if the watchdog itself panics (e.g., a bug in hung-slot detection),
-- no loop monitors it. This ultra-simple loop just checks lastWatchdogAt freshness and
-- restarts backgroundWatchdog if stale. Runs infrequently (10x watchdog interval) to minimize cost.
-- Cannot restart itself — a panic here surfaces as healthWatchdogMaxAge failure in /health.
backgroundMetaWatchdog = do
  sleep (backgroundPruneInterval * 50)
  t <- now
  sa <- *startedAt
  let warmup = t - sa < backgroundPruneInterval * 60
  if warmup then backgroundMetaWatchdog
  else do
    lastWd <- *lastWatchdogAt
    when (lastWd > 0 && t - lastWd > healthWatchdogMaxAge * 3) (do
      logError "meta-watchdog: watchdog loop appears dead, restarting"
      fork backgroundWatchdog)
    backgroundMetaWatchdog

-- Startup connectivity probe: two-phase check for each peer.
-- Phase 1: unauthenticated probe tests TCP/TLS/HTTP connectivity.
-- Phase 2: authenticated probe tests the verify callback round-trip — the critical
-- federation auth path. Catches misconfigured reverse proxies that pass HTTP but block
-- the /federation/verify callback, which would cause all federation requests to fail.
-- Probes up to 10 peers sequentially (not forked) to avoid overwhelming the network.
startupProbePeers = do
  atomic do set *startupProbeActive = True {}
  knownPeers <- *knownPeerServers
  startupProbeNext knownPeers 0
  atomic do set *startupProbeActive = False {}

startupProbeNext = \peers probed ->
  if probed >= 10 then logInfo ("startup: probed " ++ show probed ++ " peers")
  else case headOf peers of
    Nothing {} -> logInfo ("startup: probed " ++ show probed ++ " peers")
    Just {value: server} -> do
      let rest = do p <- peers; where p != server; yield p
      startTime <- now
      -- Phase 1: unauthenticated probe (TCP/TLS/HTTP connectivity)
      result <- fetchFederation server (RecvGossip {
        authorization: "",
        events: [], hopsRemaining: 1, fromServer: serverHostN,
        requestTimestamp: startTime, correlationId: "", protocolVersion: federationProtocolVersion})
      endTime <- now
      let latency = endTime - startTime
      case result of
        Err e -> logWarn ("startup: peer " ++ server ++ " unreachable (" ++ show e ++ ") — check DNS/firewall/TLS")
        Ok r -> do
          logInfo ("startup: peer " ++ server ++ " reachable (" ++ show latency ++ "ms)")
          -- Phase 2: authenticated probe (verify callback round-trip).
          -- Sends an empty gossip with a real auth token. The peer will call back to
          -- /federation/verify on this server to confirm the token, testing the full
          -- federation auth path in both directions.
          authStart <- now
          auth <- generateFederationAuth "gossip" authStart
          authResult <- fetchFederation server (RecvGossip {
            authorization: auth,
            events: [], hopsRemaining: 1, fromServer: serverHostN,
            requestTimestamp: authStart, correlationId: "", protocolVersion: federationProtocolVersion})
          authEnd <- now
          let authLatency = authEnd - authStart
          case authResult of
            Err e -> logWarn ("startup: peer " ++ server ++ " verify callback failed (" ++ show e ++ ") — check reverse proxy allows /federation/verify")
            Ok ar -> if ar.ok
              then logInfo ("startup: peer " ++ server ++ " verify callback OK (" ++ show authLatency ++ "ms)")
              else logWarn ("startup: peer " ++ server ++ " verify callback rejected: " ++ ar.error ++ " — check /federation/verify is reachable from peer")
      startupProbeNext rest (probed + 1)

main = do
  let configOk = listenPort > 0 && maxMessages > 0 && maxMessagesPerRecipient > 0 && maxPresenceEntries > 0
        && maxSessions > 0 && maxChallenges > 0 && backgroundPruneInterval > 0
        && pollTimeoutMs > 0 && challengeExpiry > 0 && sessionExpiry > 0
        && maxSessionLifetime > 0
        && maxPresenceTtl > 0 && maxForwardsEntries > 0 && maxAckedIds > 0
        && maxForwardRetries > 0 && maxGossipHops > 0 && maxPollsPerKey > 0
        && gossipOriginHops > 0 && maxThirdPartyGossipHops > 0
        && verificationTokenExpiry > 0
        && maxAckRetries > 0 && maxPairRatePerPair > 0 && pairRateWindowMs > 0
        && maxFederationPairRatePerPair > 0 && federationPairRateWindowMs > 0
        && maxForwardNonces > 0
        && maxGossipEventsPerServer > 0 && gossipEventRateWindowMs > 0
        && maxGlobalFederationConcurrency > 0
  -- Relationship invariants: these misconfigurations cause subtle bugs
  -- (e.g., messages pruned before their stated max age, backoff that never increases)
  let configRelationsOk = unackedMessageMaxAge <= messageMaxAge
        && challengeExpiry < sessionExpiry
        && sessionExpiry <= maxSessionLifetime
        && retryBackoffBase <= retryBackoffMax
        && backgroundPruneInterval < healthPruneMaxAge
        && ackGracePeriod < unackedMessageMaxAge
        && minMessageTtl > 0 && minMessageTtl <= unackedMessageMaxAge
        && clockSkewTolerance < challengeExpiry
        && maxMessagesPerRecipient <= maxMessages
        && maxForwardsPerKey <= maxForwardsEntries
        && maxForwardsPerSenderPerKey <= maxForwardsPerKey
        && maxForwardsPerServer <= maxForwardsEntries
        && maxSessionsPerKey <= maxSessions
        && maxChallengesPerKey <= maxChallenges
        && maxPollsPerKey <= maxActivePolls
        && pollTimeoutMs < sessionExpiry
        && gossipDedupWindow < presenceRefreshInterval
        && federationFetchTimeoutMs <= backgroundPruneInterval
        && maxAckOverflow <= maxAckedIds
        && gossipOriginHops <= maxGossipHops
        && maxThirdPartyGossipHops <= maxGossipHops
        && verificationTokenExpiry <= federationFetchTimeoutMs
        && forwardNonceRetention >= messageMaxAge
        && maxGlobalFederationConcurrency >= maxFederationConcurrency
        && maxGossipEventsPerServer > maxGossipEvents
        && onlineGossipTtl * 1000 > sessionExpiry
  if not configOk
    then logError "FATAL: invalid configuration — capacity limits and intervals must be > 0, server not started"
    else if not configRelationsOk
    then logError "FATAL: invalid configuration — relationship invariants violated (check: unackedMessageMaxAge <= messageMaxAge, challengeExpiry < sessionExpiry, sessionExpiry <= maxSessionLifetime, retryBackoffBase <= retryBackoffMax, backgroundPruneInterval < healthPruneMaxAge, pollTimeoutMs < sessionExpiry, gossipDedupWindow < presenceRefreshInterval, federationFetchTimeoutMs <= backgroundPruneInterval, maxAckOverflow <= maxAckedIds, gossipOriginHops <= maxGossipHops, maxThirdPartyGossipHops <= maxGossipHops, verificationTokenExpiry <= federationFetchTimeoutMs, forwardNonceRetention >= messageMaxAge, maxGlobalFederationConcurrency >= maxFederationConcurrency, maxGossipEventsPerServer > maxGossipEvents, onlineGossipTtl*1000 > sessionExpiry, maxForwardsPerSenderPerKey <= maxForwardsPerKey, per-key/per-server limits <= global limits), server not started"
    else do
      t <- now
      -- Mix random bits into generation to prevent sub-millisecond restart collisions.
      -- Clients use generation to detect server restarts; same generation = stale cursor.
      genJitter <- randomInt 1000000
      atomic do
        set *startedAt = t
        set *serverGeneration = t * 1000 + genJitter
      -- Empty maintenanceSecret is the recommended deployment path: use /maintenance/rotate-secret
      -- at startup via deployment scripts for zero-knowledge secret management. Log at INFO level
      -- since operators following the recommended path shouldn't see warnings on every startup.
      when (maintenanceSecret == "")
        (logInfo "maintenanceSecret is empty — use /maintenance/rotate-secret at startup to enable /maintenance/* and /stats endpoints")
      when (maintenanceSecret != "" && not (tooLong maintenanceSecret 15))
        (logWarn "maintenanceSecret is shorter than 16 characters — use a longer secret for production deployments")
      when (maintenanceSecret != "" && not (tooLong maintenanceSecret 31))
        (logWarn "maintenanceSecret is shorter than 32 characters — 32+ character secrets recommended for production (128+ bits of entropy)")
      when (maintenanceSecret != "" && federationEnabled && not (tooLong maintenanceSecret 15))
        (logError "SECURITY: maintenanceSecret is weak and federation is enabled — maintenance endpoints control drain and peer blocking. Use a secret of at least 32 characters.")
      when (maintenanceSecret != "")
        (logWarn "SECURITY: maintenanceSecret is set as a compile-time constant. Avoid committing secrets to source control. Prefer setting maintenanceSecret to empty and using /maintenance/rotate-secret at startup via deployment scripts for zero-knowledge secret management.")
      when (matchesHostnameOrSubdomain serverHostN "localhost")
        (logWarn ("serverHost is " ++ serverHost ++ " — peers cannot reach this server for federation"))
      when (federationEnabled && isBadServerName serverHostN)
        (logError ("serverHost '" ++ serverHost ++ "' would be rejected by isBadServerName — federation peers cannot forward messages here. Set serverHost to a public DNS name."))
      if requireClientIp
        then logInfo "IP binding: required — challenge requests without ClientIp header are rejected"
        else logInfo "IP binding: optional — sessions created with a ClientIp header will reject requests without one"
      logWarn "SECURITY: Knot has no HTTP-layer request body size limit. Deploy behind a reverse proxy with a body limit (e.g., Caddy: request_body { max_size 256KB }) to prevent large-payload DoS."
      when federationEnabled
        (logWarn "SECURITY: DNS rebinding risk — federation URLs resolve DNS at fetch time, not at validation time. A peer hostname passing isBadServerName could rebind to a private IP between validation and fetch. Mitigate by blocking outbound connections to RFC1918/link-local/CGNAT ranges at the firewall level.")
      logInfo ("Skrepka relay server starting on port " ++ show listenPort ++ "...")
      logInfo ("  federation: " ++ if federationEnabled then "enabled (protocol v" ++ show federationProtocolVersion ++ ")" else "disabled")
      when (serverFederationPrivateKeyHex != "" && serverFederationPublicKeyHex != "")
        (logInfo "  federation auth: Ed25519 signing enabled")
      when (serverFederationPrivateKeyHex == "" && federationEnabled)
        (logInfo "  federation auth: verify callback (no signing key configured)")
      when (serverFederationPrivateKeyHex != "" && serverFederationPublicKeyHex == "")
        (logError "FATAL: serverFederationPrivateKeyHex is set but serverFederationPublicKeyHex is empty — both must be configured together")
      when (serverFederationPrivateKeyHex == "" && serverFederationPublicKeyHex != "")
        (logError "FATAL: serverFederationPublicKeyHex is set but serverFederationPrivateKeyHex is empty — both must be configured together")
      logInfo ("  prune interval: " ++ show backgroundPruneInterval ++ "ms")
      logInfo ("  poll timeout: " ++ show pollTimeoutMs ++ "ms")
      logInfo ("  max messages: " ++ show maxMessages ++ " (per recipient: " ++ show maxMessagesPerRecipient ++ ")")
      logInfo ("  max sessions: " ++ show maxSessions ++ " (per key: " ++ show maxSessionsPerKey ++ ")")
      logInfo ("  max presence: " ++ show maxPresenceEntries)
      logInfo ("  max forwards: " ++ show maxForwardsEntries ++ " (per key: " ++ show maxForwardsPerKey ++ ", per sender-key: " ++ show maxForwardsPerSenderPerKey ++ ", per server: " ++ show maxForwardsPerServer ++ ")")
      logInfo ("  session expiry: " ++ show sessionExpiry ++ "ms (max lifetime: " ++ show maxSessionLifetime ++ "ms)")
      logInfo ("  message max age: " ++ show messageMaxAge ++ "ms")
      logInfo ("  max active requests: " ++ if maxActiveRequests > 0 then show maxActiveRequests else "unlimited")
      logInfo ("  global rate limit: " ++ show maxGlobalRequestRate ++ "/" ++ show globalRateWindowMs ++ "ms")
      logInfo ("  auth rate limit: " ++ show maxAuthGlobalRate ++ "/" ++ show authGlobalRateWindowMs ++ "ms")
      logInfo ("  pair rate limit: " ++ show maxPairRatePerPair ++ "/" ++ show pairRateWindowMs ++ "ms per sender-recipient")
      logInfo ("  federation pair rate limit: " ++ show maxFederationPairRatePerPair ++ "/" ++ show federationPairRateWindowMs ++ "ms per server-recipient")
      logInfo ("  gossip event rate limit: " ++ show maxGossipEventsPerServer ++ " events/" ++ show gossipEventRateWindowMs ++ "ms per server")
      logInfo ("  global federation concurrency: " ++ show maxGlobalFederationConcurrency)
      logInfo ("  ack retry limit: " ++ show maxAckRetries ++ " per entry")
      when (federationCircuitBreakerThreshold > 0)
        (logInfo ("  circuit breaker: " ++ show federationCircuitBreakerThreshold ++ " failing peers"))
      logInfo ("  federation allowlist: " ++ show maxAllowedPeers ++ " max (empty = open federation)")
      fork backgroundPrune
      fork pollHeartbeat
      fork backgroundWatchdog
      fork backgroundMetaWatchdog
      -- Startup peer connectivity check: probe known peers after a short delay
      -- to surface federation misconfigurations immediately (DNS, firewall, TLS).
      -- Runs as a forked task so it doesn't delay server startup.
      when federationEnabled (fork (do
        sleep 5000  -- wait for listener to be ready
        logInfo "startup: probing federation peers..."
        startupProbePeers))
      listen listenPort serve
