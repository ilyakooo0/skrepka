route Api = AuthApi | ClientApi | FederationApi | FederationVerifyApi | FederationPubkeyApi | MaintenanceApi | HealthApi | StatsApi | MetricsApi | ReadyApi

-- ============================================
-- Generic helpers
-- ============================================

any : [a] -> (a -> Bool) -> Bool
any = \xs pred -> fold (\acc x -> if acc then acc else pred x) (False {}) xs
none : [a] -> (a -> Bool) -> Bool
none = \xs pred -> not (any xs pred)
when = \cond action -> if cond then action else yield {}
clamp = \lo hi x -> if x < lo then lo else if x > hi then hi else x
min = \a b -> if a < b then a else b
max = \a b -> if a > b then a else b

headOf = \items -> fold (\acc x -> case acc of
  Nothing {} -> Just {value: x}
  _ -> acc) Nothing {} items

minBy = \items getKey -> fold (\acc x -> case acc of
  Nothing {} -> Just {value: x}
  Just {value: v} -> if getKey x < getKey v then Just {value: x} else acc) Nothing {} items

maxBy = \items getKey -> fold (\acc x -> case acc of
  Nothing {} -> Just {value: x}
  Just {value: v} -> if getKey x > getKey v then Just {value: x} else acc) Nothing {} items

-- Drop entries with the oldest key (LRU-style eviction; ties drop together)
evictOldest = \items getKey ->
  case minBy items getKey of
    Nothing {} -> items
    Just {value: oldest} -> do x <- items; where getKey x != getKey oldest; yield x

capList = \items maxN getKey ->
  if count items > maxN then evictOldest items getKey else items

-- Sequence an IO action over each unique item (dedup by getKey).
forEach = \items getKey action -> case headOf items of
  Nothing {} -> yield {}
  Just {value: x} -> do
    action x
    forEach (do y <- items; where getKey y != getKey x; yield y) getKey action

-- Like forEach, but collects each action's result into a list.
mapEach = \items getKey action -> case headOf items of
  Nothing {} -> yield []
  Just {value: x} -> do
    r <- action x
    rest <- mapEach (do y <- items; where getKey y != getKey x; yield y) getKey action
    yield (union [r] rest)

-- Hex tokens
hexDigit : Int -> Text
hexDigit = \n -> take 1 (drop (clamp 0 15 n) "0123456789abcdef")

byteToHex : Int -> Text
byteToHex = \n -> hexDigit (n / 16) ++ hexDigit (n - (n / 16) * 16)

intTo3Hex : Int -> Text
intTo3Hex = \n ->
  let b0 = n / 65536 in
  let r0 = n - b0 * 65536 in
  let b1 = r0 / 256 in
  let b2 = r0 - b1 * 256 in
  byteToHex b0 ++ byteToHex b1 ++ byteToHex b2

genTokenN = \n -> if n <= 0 then yield "" else do
  chunk <- randomInt 16777216
  rest <- genTokenN (n - 1)
  yield (intTo3Hex chunk ++ rest)

genToken = genTokenN 8

tooLong : Text -> Int -> Bool
tooLong = \s maxLen -> drop maxLen s != ""

isValidHex : Text -> Bool
isValidHex = \s ->
  s != "" && drop 1 s != ""
  && contains (take 1 s) "0123456789abcdef"
  && contains (take 1 (drop 1 s)) "0123456789abcdef"
  && (drop 2 s == "" || isValidHex (drop 2 s))

normalizeHex : Text -> Text
normalizeHex = \s -> bytesToHex (bytesFromHex s)

-- Strip all trailing dots by recursing left-to-right; once the tail is all dots, it's dropped.
stripTrailingDot : Text -> Text
stripTrailingDot = \s ->
  if s == "" then ""
  else if take 1 s != "." then take 1 s ++ stripTrailingDot (drop 1 s)
  else let rest = stripTrailingDot (drop 1 s) in
    if rest == "" then "" else "." ++ rest

normalizeServerName : Text -> Text
normalizeServerName = \s -> toLower (stripTrailingDot s)

serverHostN : Text
serverHostN = normalizeServerName serverHost
isLocalServer : Text -> Bool
isLocalServer = \s -> s == serverHostN

containsSuffix : Text -> Text -> Bool
containsSuffix = \suffix s ->
  let suffixLen = count (chars suffix) in
  let sLen = count (chars s) in
  sLen >= suffixLen && drop (sLen - suffixLen) s == suffix

-- Block private/reserved/internal hostnames (SSRF defense). Simplified vs original:
-- still rejects the high-value cases (loopback, RFC1918, link-local, metadata services)
-- but skips obscure encoding tricks (octal, hex, percent-encoding).
isBadServerName : Text -> Bool
isBadServerName = \sn ->
  let fc = take 1 sn in
  fc == "" || fc == "." || fc == ":" || fc == "["
  || any (chars sn) (\c -> not (contains c "0123456789abcdefghijklmnopqrstuvwxyz-.:"))
  || sn == "localhost"
  || containsSuffix ".localhost" sn
  || containsSuffix ".local" sn
  || containsSuffix ".internal" sn
  || containsSuffix ".arpa" sn
  || containsSuffix ".onion" sn
  || take 4 sn == "127."
  || take 3 sn == "10."
  || take 8 sn == "192.168."
  || take 8 sn == "169.254."
  || take 2 sn == "0."
  || take 2 sn == "::"

-- ============================================
-- Auth helpers
-- ============================================

-- Plain ip match (sessions with empty ip skip the check).
matchIp = \clientIp sessionIp -> sessionIp == "" || clientIp == sessionIp

extractToken = \authHeader ->
  let token = drop 7 authHeader in
  if take 7 authHeader == "Bearer " && token != "" && not (tooLong token maxTokenLen)
    then Just {value: token}
    else Nothing {}

verifyMaintenanceAuth : Text -> IO Bool
verifyMaintenanceAuth = \authorization -> do
  secret <- *runtimeMaintenanceSecret
  case extractToken authorization of
    Just {value: token} -> yield (secret != "" && token == secret)
    _ -> yield False

authenticateSession : [Session] -> Text -> Timestamp -> AuthResult
authenticateSession = \sessions token t ->
  case headOf (do s <- sessions; where s.expiresAt > t && s.token == token; yield s) of
    Nothing {} -> Unauthorized {}
    Just {value: s} -> Authorized {pubkey: s.pubkey, ip: s.ip}

withSessionAuth = \authorization t clientIp onUnauth onAuth -> do
  case extractToken authorization of
    Nothing {} -> onUnauth
    Just {value: token} -> do
      sessions <- *sessions
      case authenticateSession sessions token t of
        Authorized {pubkey, ip} ->
          if matchIp clientIp ip then onAuth pubkey else onUnauth
        _ -> onUnauth

isBlockedPeer : Text -> [Text] -> Bool
isBlockedPeer = \server blocked -> any blocked (\b -> b == server)

isAllowedByAllowlist : Text -> [Text] -> Bool
isAllowedByAllowlist = \server allowed -> count allowed == 0 || any allowed (\a -> a == server)

splitOnColon : Text -> {before: Text, after: Text}
splitOnColon = \s ->
  if s == "" then {before: "", after: ""}
  else if take 1 s == ":" then {before: "", after: drop 1 s}
  else
    let r = splitOnColon (drop 1 s) in
    {before: take 1 s ++ r.before, after: r.after}

generateFederationAuth : Text -> Timestamp -> IO {network} Text
generateFederationAuth = \scope requestTimestamp ->
  if serverFederationPrivateKeyHex != ""
    then do
      nonce <- genTokenN 8
      let message = textToBytes (scope ++ "|" ++ show requestTimestamp ++ "|" ++ serverHostN ++ "|" ++ nonce)
      let sig = sign (bytesFromHex serverFederationPrivateKeyHex) message
      yield ("Signed " ++ bytesToHex sig ++ ":" ++ nonce)
    else do
      token <- genToken
      t <- now
      atomic do
        pending <- *pendingVerifications
        let updated = union pending [{token: token, createdAt: t, scope: scope}]
        set *pendingVerifications = capList updated maxPendingVerifications (\p -> p.createdAt)
      yield ("Bearer " ++ token)

-- Verify a federation request: signed (Ed25519 over scope|ts|fromServer|nonce) or callback Bearer token.
verifyFederationAuth = \authorization fromServer scope requestTimestamp -> do
  if take 7 authorization == "Signed " then do
    let payload = drop 7 authorization
    if payload == "" || tooLong payload (maxSignatureLen + 25) then yield False
    else do
      let parts = splitOnColon payload
      result <- fetch (federationUrl fromServer) (FederationPubkey {})
      case result of
        Ok r ->
          if not r.ok || r.pubkey == "" then yield False
          else
            let msg = scope ++ "|" ++ show requestTimestamp ++ "|" ++ fromServer ++ (if parts.after == "" then "" else "|" ++ parts.after) in
            yield (verify (bytesFromHex r.pubkey) (textToBytes msg) (bytesFromHex parts.before))
        _ -> yield False
  else case extractToken authorization of
    Just {value: token} -> do
      result <- fetch (federationUrl fromServer) (VerifyToken {token: token, scope: scope})
      case result of Ok r -> yield r.ok; _ -> yield False
    _ -> yield False

withFederationAuth = \authorization t respond fromServer scope requestTimestamp precondition action -> do
  blocked <- *blockedPeers
  allowed <- *allowedPeers
  let denyReason =
    if isBlockedPeer fromServer blocked then "blocked"
    else if not (isAllowedByAllowlist fromServer allowed) then "not_allowed"
    else ""
  if denyReason != "" then yield (respond {ok: False {}, error: denyReason, retryAfterMs: 0})
  else do
    verified <- verifyFederationAuth authorization fromServer scope requestTimestamp
    if not verified then yield (respond {ok: False {}, error: "unauthorized", retryAfterMs: 0})
    else if requestTimestamp > 0 && (requestTimestamp > t + clockSkewTolerance || requestTimestamp < t - clockSkewTolerance)
    then yield (respond {ok: False {}, error: "clock_skew", retryAfterMs: 0})
    else if not precondition then yield (respond {ok: False {}, error: "invalid_request", retryAfterMs: 0})
    else do
      limited <- checkServerRateGate fromServer t
      if limited then yield (respond {ok: False {}, error: "rate_limited", retryAfterMs: federationRateWindowMs})
      else action

-- ============================================
-- Rate limiting (plain count-per-window, no sliding interpolation)
-- ============================================

-- Returns {limited, entries}. Increments count when the key fits within the window.
-- Simplified: drop any stale/matching entry, then either reject or insert a fresh entry.
checkRate = \entries key maxRate windowMs maxEntries t ->
  let cur = headOf (do r <- entries; where r.key == key && t - r.windowStart < windowMs; yield r) in
  let nextCount = case cur of Just {value: r} -> r.count + 1; _ -> 1 in
  if nextCount > maxRate
    then {limited: True {}, entries: entries}
    else
      let others = do x <- entries; where x.key != key; yield x in
      let windowStart = case cur of Just {value: r} -> r.windowStart; _ -> t in
      {limited: False {}, entries: capList (union others [{key: key, windowStart: windowStart, count: nextCount}]) maxEntries (\r -> r.windowStart)}

checkGlobalRate = \t -> atomic do
  ws <- *globalRateWindowStart
  c <- *globalRateCount
  if t - ws >= globalRateWindowMs then do
    set *globalRateWindowStart = t
    set *globalRateCount = 1
    yield False
  else if c >= maxGlobalRequestRate then yield True
  else do
    set *globalRateCount = c + 1
    yield False

checkAuthGlobalRate = \t -> atomic do
  ws <- *authGlobalRateWindowStart
  c <- *authGlobalRateCount
  if t - ws >= authGlobalRateWindowMs then do
    set *authGlobalRateWindowStart = t
    set *authGlobalRateCount = 1
    yield False
  else if c >= maxAuthGlobalRate then yield True
  else do
    set *authGlobalRateCount = c + 1
    yield False

checkIpRateGate = \ip t ->
  if ip == "" then yield False
  else checkPubkeyRateGate ipRates ip maxIpRatePerIp ipRateWindowMs t

checkPubkeyRateGate = \rateRef pubkey maxRate windowMs t -> atomic do
  rates <- *rateRef
  let r = checkRate rates pubkey maxRate windowMs 5000 t
  set *rateRef = r.entries
  yield r.limited

checkServerRateGate = \server t ->
  checkPubkeyRateGate federationRates server maxFederationRatePerServer federationRateWindowMs t

checkPreAuth = \clientIp t -> do
  dp <- *drainPhase
  if dp >= 1 then yield "draining"
  else do
    g <- checkGlobalRate t
    if g then yield "global_rate_limited"
    else do
      i <- checkIpRateGate clientIp t
      yield (if i then "ip_rate_limited" else "")

-- ============================================
-- Federation failure tracking (simple, no circuit breaker)
-- ============================================

retryBackoff : Int -> Int<Ms>
retryBackoff = \failures -> min retryBackoffMax (retryBackoffBase * max 1 failures)

shouldRetryServer : Text -> Timestamp -> [ForwardFailure] -> Bool
shouldRetryServer = \server t failures ->
  case headOf (do f <- failures; where f.server == server; yield f) of
    Nothing {} -> True {}
    Just {value: f} -> t - f.failedAt >= retryBackoff f.failures

recordFailure = \server -> do
  t <- now
  atomic do
    failures <- *forwardFailures
    let others = do f <- failures; where f.server != server; yield f
    let prior = headOf (do f <- failures; where f.server == server; yield f)
    let firstAt = case prior of Just {value: f} -> f.firstFailedAt; _ -> t
    let nextN = case prior of Just {value: f} -> min (f.failures + 1) 10; _ -> 1
    set *forwardFailures = union others [{server: server, failedAt: t, failures: nextN, firstFailedAt: firstAt}]

clearFailure = \server -> atomic do
  failures <- *forwardFailures
  set *forwardFailures = do f <- failures; where f.server != server; yield f

-- ============================================
-- Common utility queries
-- ============================================

clampTtl : Int<S> -> Int<S>
clampTtl = clamp 1 maxPresenceTtl

clampTimestamp : Timestamp -> Timestamp -> Timestamp
clampTimestamp = \timestamp t -> clamp (t - messageMaxAge) t timestamp

effectiveMessageTtl : Int<Ms> -> Int<Ms>
effectiveMessageTtl = \expiresInMs ->
  if expiresInMs <= 0 then unackedMessageMaxAge
  else clamp minMessageTtl unackedMessageMaxAge expiresInMs

nextSeqTs : Timestamp -> Timestamp -> Timestamp
nextSeqTs = \t seqCounter -> if t > seqCounter then t else seqCounter + 1

dedupMessageIds : [MessageIdHex] -> [MessageIdHex]
dedupMessageIds = \ids ->
  let capped = takeRelation maxMessageIds ids in
  fold (\acc mid -> if any acc (\a -> a == mid) then acc else union acc [mid]) [] capped

presenceForKey = \presence pubkey t ->
  do p <- presence; where p.pubkey == pubkey && p.expiresAt > t; yield p

-- Pick local if present, else the remote with the latest expiresAt; "" when none.
bestServerForKey = \entries ->
  if any entries (\p -> isLocalServer p.server) then serverHostN
  else case maxBy entries (\p -> p.expiresAt) of
    Just {value: p} -> p.server
    Nothing {} -> ""

hasMessage : MessageIdHex -> PubkeyHex -> [{messageId: MessageIdHex, toKey: PubkeyHex | a}] -> Bool
hasMessage = \mid toKey items -> any items (\x -> x.messageId == mid && x.toKey == toKey)

collectPeers : [a] -> (a -> Text) -> [Text]
collectPeers = \items getServer ->
  fold (\acc item ->
    let s = getServer item in
    if isLocalServer s || any acc (\a -> a == s) then acc
    else union acc [s]) [] items

knownPeerServersFromPresence : [PresenceEntry] -> [Text]
knownPeerServersFromPresence = \presence -> collectPeers presence (\p -> p.server)

-- Last-write-wins merge by (pubkey, server), keeping the entry with the larger expiresAt.
mergePresence = \existing incoming ->
  fold (\acc e ->
    if any acc (\a -> a.pubkey == e.pubkey && a.server == e.server && a.expiresAt >= e.expiresAt) then acc
    else union (do x <- acc; where x.pubkey != e.pubkey || x.server != e.server; yield x) [e]) existing incoming

-- ============================================
-- Pruning
-- ============================================

pruneExpired = \t -> do
  expiredLocalKeys <- atomic do
    -- challenges
    ch <- *challenges
    set *challenges = do x <- ch; where x.expiresAt > t; yield x
    -- sessions
    ses <- *sessions
    set *sessions = do x <- ses; where x.expiresAt > t; yield x
    -- messages
    msgs <- *messages
    set *messages = do m <- msgs; where m.expiresAt > t; yield m
    -- forwards
    fwds <- *forwards
    set *forwards = do f <- fwds; where f.expiresAt > t; yield f
    -- ackedIds, deliveredIds
    aids <- *ackedIds
    set *ackedIds = do a <- aids; where t - a.ackedAt < messageMaxAge; yield a
    dids <- *deliveredIds
    set *deliveredIds = do d <- dids; where t - d.deliveredAt < messageMaxAge; yield d
    -- presence: remember locally-expired keys for offline gossip
    pres <- *presence
    let keptPres = do p <- pres; where p.expiresAt > t; yield p
    let expiredLocal = do p <- pres; where p.expiresAt <= t && isLocalServer p.server && none keptPres (\k -> k.pubkey == p.pubkey && isLocalServer k.server); yield p
    set *presence = keptPres
    -- forwardFailures
    ff <- *forwardFailures
    set *forwardFailures = do f <- ff; where t - f.failedAt < 86400000; yield f
    -- activePolls (clean up stale entries beyond 3x poll timeout)
    aps <- *activePolls
    set *activePolls = do p <- aps; where t - p.startedAt < pollTimeoutMs * 3; yield p
    -- pendingVerifications
    pv <- *pendingVerifications
    set *pendingVerifications = do p <- pv; where t - p.createdAt < verificationTokenExpiry; yield p
    -- sender notifications
    se <- *senderExpirations
    set *senderExpirations = do x <- se; where t - x.expiredAt < unackedMessageMaxAge; yield x
    sd <- *senderDeliveries
    set *senderDeliveries = do x <- sd; where t - x.deliveredAt < unackedMessageMaxAge; yield x
    cn <- *cancelNotifications
    set *cancelNotifications = do x <- cn; where t - x.cancelledAt < unackedMessageMaxAge; yield x
    pfc <- *pendingFederationCancels
    set *pendingFederationCancels = do x <- pfc; where t - x.createdAt < messageMaxAge; yield x
    yield expiredLocal
  yield expiredLocalKeys

-- ============================================
-- Federation gossip
-- ============================================

sendBatchedGossip = \peers events hops -> forEach peers (\s -> s) (\server -> do
  t <- now
  failures <- *forwardFailures
  when (shouldRetryServer server t failures) (do
    auth <- generateFederationAuth "gossip" t
    result <- fetch (federationUrl server) (RecvGossip {
      authorization: auth,
      events: events, hopsRemaining: hops, fromServer: serverHostN,
      requestTimestamp: t, correlationId: "", protocolVersion: federationProtocolVersion})
    case result of
      Err _ -> recordFailure server
      Ok _ -> clearFailure server))

broadcastOfflineGossip = \t expiredLocal -> do
  presence <- *presence
  let peers = knownPeerServersFromPresence presence
  when (federationEnabled && count peers > 0 && count expiredLocal > 0) (do
    let events = do p <- expiredLocal; yield {eventType: GossipOffline {}, pubkey: p.pubkey, server: serverHostN, timestamp: t, ttl: offlineGossipMinTtl, seenBy: [serverHostN]}
    sendBatchedGossip peers events gossipOriginHops)

-- ============================================
-- Forward retries and acks
-- ============================================

retryPendingForwards = do
  t <- now
  fwds <- *forwards
  failures <- *forwardFailures
  blocked <- *blockedPeers
  let servers = do s <- collectPeers fwds (\f -> f.toServer); where shouldRetryServer s t failures && not (isBlockedPeer s blocked); yield s
  forEach servers (\s -> s) (\server -> do
    let serverFwds = takeRelation maxBatchSize (do f <- fwds; where f.toServer == server; yield f)
    forEach serverFwds (\f -> f.messageId) (\f -> do
      t2 <- now
      auth <- generateFederationAuth ("forward:" ++ f.messageId) t2
      result <- fetch (federationUrl server) (ForwardMessage {
        toKey: f.toKey, encryptedBlob: f.encryptedBlob,
        timestamp: f.timestamp, originServer: f.originServer, messageId: f.messageId,
        fromServer: serverHostN, requestTimestamp: t2,
        authorization: auth, correlationId: "",
        expiresAt: f.expiresAt, priority: f.priority, protocolVersion: federationProtocolVersion})
      let success = case result of Ok r -> r.ok; _ -> False {}
      case result of Err _ -> recordFailure server; Ok _ -> when success (clearFailure server)
      atomic do
        cur <- *forwards
        set *forwards = do
          x <- cur
          where x.messageId != f.messageId || x.toServer != server || (not success && x.retries + 1 < maxForwardRetries)
          yield (if success || x.messageId != f.messageId || x.toServer != server then x
                 else {messageId: x.messageId, toServer: x.toServer, createdAt: x.createdAt, toKey: x.toKey, encryptedBlob: x.encryptedBlob, timestamp: x.timestamp, originServer: x.originServer, retries: x.retries + 1, expiresAt: x.expiresAt, priority: x.priority, senderKey: x.senderKey})))

sendAcksAndClean = \pendingAcks ->
  forEach (collectPeers pendingAcks (\a -> a.originServer)) (\s -> s) (\server -> do
    let mids = do a <- pendingAcks; where a.originServer == server; yield a.messageId
    t <- now
    auth <- generateFederationAuth "ack" t
    result <- fetch (federationUrl server) (FederationAck {
      authorization: auth,
      messageIds: mids, originServer: server, fromServer: serverHostN,
      requestTimestamp: t, correlationId: "", protocolVersion: federationProtocolVersion})
    case result of
      Err _ -> recordFailure server
      Ok _ -> do
        clearFailure server
        atomic do
          cur <- *ackedIds
          set *ackedIds = do a <- cur; where not (a.originServer == server && any mids (\m -> m == a.messageId)); yield a)

-- Forward queued messages to a server when a remote key comes online.
forwardQueuedToServer = \pubkey server t -> atomic do
  msgs <- *messages
  fwds <- *forwards
  let candidates = do
    m <- msgs
    where m.toKey == pubkey
    where none fwds (\f -> f.messageId == m.messageId && f.toServer == server)
    let origin = if m.originServer == "" then serverHostN else m.originServer
    yield {messageId: m.messageId, toServer: server, createdAt: t, toKey: m.toKey, encryptedBlob: m.encryptedBlob, timestamp: m.timestamp, originServer: origin, retries: 0, expiresAt: m.expiresAt, priority: m.priority, senderKey: m.senderKey}
  let capped = takeRelation maxForwardsPerServer candidates
  set *forwards = capList (union fwds capped) maxForwardsEntries (\f -> f.createdAt)

-- ============================================
-- Background loops
-- ============================================

pruneAndRetry = \t -> do
  atomic do set *lastPrunedAt = t
  expiredLocal <- pruneExpired t
  fork (broadcastOfflineGossip t expiredLocal)
  when federationEnabled (fork retryPendingForwards)
  when federationEnabled (do
    aids <- *ackedIds
    let pendingAcks = do a <- aids; where not (isLocalServer a.originServer); yield a
    fork (sendAcksAndClean pendingAcks))
  -- Refresh local presence for active sessions every ~5 minutes
  lastRefresh <- *lastPresenceRefresh
  when (federationEnabled && t - lastRefresh >= presenceRefreshInterval) (do
    atomic do set *lastPresenceRefresh = t
    refreshLocalPresence t)
  yield {}

refreshLocalPresence = \t -> do
  refreshState <- atomic do
    sessions <- *sessions
    presence <- *presence
    let activeKeys = fold (\acc s -> if any acc (\a -> a == s.pubkey) then acc else union acc [s.pubkey]) [] sessions
    let updated = do
      p <- presence
      yield (if isLocalServer p.server && any activeKeys (\k -> k == p.pubkey) && p.expiresAt - t < sessionExpiry / 2
               then {pubkey: p.pubkey, server: p.server, expiresAt: t + sessionExpiry, timestamp: t}
               else p)
    set *presence = updated
    let refreshed = do p <- updated; where isLocalServer p.server && p.expiresAt == t + sessionExpiry; yield p
    let peers = knownPeerServersFromPresence updated
    yield {refreshed: refreshed, peers: peers}
  when (count refreshState.refreshed > 0 && count refreshState.peers > 0) (do
    let events = do p <- refreshState.refreshed; yield {eventType: GossipOnline {}, pubkey: p.pubkey, server: serverHostN, timestamp: t, ttl: clampTtl (sessionExpiry / 1000), seenBy: [serverHostN]}
    fork (sendBatchedGossip refreshState.peers events gossipOriginHops))

-- ============================================
-- Handler: challenge / verify / revoke / logout
-- ============================================

handleChallenge = \pubkey clientIp respond -> do
  t <- now
  if requireClientIp && clientIp == ""
    then yield (respond {challenge: "", ok: False {}, expiresAt: 0, retryAfterMs: 0, error: "client_ip_required"})
    else do
  preAuth <- checkPreAuth clientIp t
  if preAuth != "" then yield (respond {challenge: "", ok: False {}, expiresAt: 0, retryAfterMs: 0, error: preAuth})
  else do
    authLimited <- checkAuthGlobalRate t
    if authLimited then yield (respond {challenge: "", ok: False {}, expiresAt: 0, retryAfterMs: 0, error: "auth_rate_limited"})
    else do
      challenge <- genToken
      result <- atomic do
        ch <- *challenges
        let active = do c <- ch; where c.expiresAt > t; yield c
        let activeForKey = count (do c <- active; where c.pubkey == pubkey; yield c)
        let cappedActive = if activeForKey >= maxChallengesPerKey
              then evictOldest active (\c -> if c.pubkey == pubkey then c.expiresAt else 999999999999)
              else active
        if count cappedActive >= maxChallenges then yield {ok: False {}, error: "capacity"}
        else do
          rates <- *challengeRates
          let r = checkRate rates pubkey maxChallengeRatePerKey challengeRateWindowMs 5000 t
          if r.limited then yield {ok: False {}, error: "rate_limited"}
          else do
            set *challengeRates = r.entries
            set *challenges = union cappedActive [{pubkey: pubkey, challenge: challenge, expiresAt: t + challengeExpiry, ip: clientIp}]
            yield {ok: True {}, error: ""}
      yield (respond {challenge: if result.ok then challenge else "", ok: result.ok, expiresAt: if result.ok then t + challengeExpiry else 0, retryAfterMs: 0, error: result.error})

handleVerifyAuth = \pubkey challenge signature revokeOthers clientIp respond -> do
  t <- now
  preAuth <- checkPreAuth clientIp t
  if preAuth != "" then yield (respond {token: "", expiresAt: 0, error: preAuth})
  else do
    authLimited <- checkAuthGlobalRate t
    if authLimited then yield (respond {token: "", expiresAt: 0, error: "auth_rate_limited"})
    else do
      let expiry = t + sessionExpiry
      token <- genToken
      result <- atomic do
        ch <- *challenges
        let hasMatch = any ch (\c -> c.pubkey == pubkey && c.challenge == challenge && c.expiresAt > t && matchIp clientIp c.ip)
        if not hasMatch then yield {valid: False {}, peers: []}
        else
          if not (verify (bytesFromHex pubkey) (textToBytes challenge) (bytesFromHex signature))
            then yield {valid: False {}, peers: []}
            else do
              set *challenges = do c <- ch; where c.pubkey != pubkey || c.challenge != challenge; yield c
              dp <- *drainPhase
              if dp >= 1 then yield {valid: False {}, peers: []}
              else do
                ses <- *sessions
                let kept = if revokeOthers then (do s <- ses; where s.pubkey != pubkey; yield s) else ses
                let perKeyOver = count (do s <- kept; where s.pubkey == pubkey; yield s) >= maxSessionsPerKey
                let afterPerKey = if perKeyOver
                      then let forKey = do s <- kept; where s.pubkey == pubkey; yield s in
                           let others = do s <- kept; where s.pubkey != pubkey; yield s in
                           union others (evictOldest forKey (\s -> s.expiresAt))
                      else kept
                let newSession = {token: token, pubkey: pubkey, expiresAt: expiry, ip: clientIp, createdAt: t}
                set *sessions = capList (union afterPerKey [newSession]) maxSessions (\s -> s.expiresAt)
                pres <- *presence
                let withoutLocal = do p <- pres; where p.pubkey != pubkey || not (isLocalServer p.server); yield p
                let newPres = capList (union withoutLocal [{pubkey: pubkey, server: serverHostN, expiresAt: expiry, timestamp: t}]) maxPresenceEntries (\p -> p.expiresAt)
                set *presence = newPres
                let peers = knownPeerServersFromPresence newPres
                yield {valid: True {}, peers: peers}
      if not result.valid then yield (respond {token: "", expiresAt: 0, error: "invalid"})
      else do
        when federationEnabled
          (fork (sendBatchedGossip result.peers [{eventType: GossipOnline {}, pubkey: pubkey, server: serverHostN, timestamp: t, ttl: onlineGossipTtl, seenBy: [serverHostN]}] gossipOriginHops))
        yield (respond {token: token, expiresAt: expiry, error: ""})

handleRevoke = \targetToken authorization clientIp respond -> do
  t <- now
  g <- checkGlobalRate t
  if g then yield (respond {ok: False {}, authorized: False {}})
  else withSessionAuth authorization t clientIp
    (yield (respond {ok: False {}, authorized: False {}}))
    (\caller -> do
      result <- atomic do
        ses <- *sessions
        let found = any ses (\s -> s.pubkey == caller && s.token == targetToken)
        if not found then yield False
        else do
          set *sessions = do s <- ses; where s.pubkey != caller || s.token != targetToken; yield s
          yield True
      yield (respond {ok: result, authorized: True {}}))

handleLogout = \authorization clientIp respond -> do
  t <- now
  case extractToken authorization of
    Nothing {} -> yield (respond {ok: False {}, authorized: False {}})
    Just {value: token} -> do
      removed <- atomic do
        ses <- *sessions
        case authenticateSession ses token t of
          Unauthorized {} -> yield {ok: False {}, pubkey: "", peers: []}
          Authorized {pubkey, ip} ->
            if not (matchIp clientIp ip) then yield {ok: False {}, pubkey: "", peers: []}
            else do
              set *sessions = do s <- ses; where s.token != token; yield s
              -- If no remaining sessions for this key, drop local presence
              after <- *sessions
              let stillHas = any after (\s -> s.pubkey == pubkey)
              peers <- if stillHas then yield []
                else do
                  pres <- *presence
                  set *presence = do p <- pres; where p.pubkey != pubkey || not (isLocalServer p.server); yield p
                  yield (knownPeerServersFromPresence pres)
              yield {ok: True {}, pubkey: pubkey, peers: peers}
      when (removed.ok && removed.pubkey != "" && count removed.peers > 0 && federationEnabled)
        (fork (sendBatchedGossip removed.peers [{eventType: GossipOffline {}, pubkey: removed.pubkey, server: serverHostN, timestamp: t, ttl: offlineGossipMinTtl, seenBy: [serverHostN]}] gossipOriginHops))
      yield (respond {ok: removed.ok, authorized: removed.ok})

-- ============================================
-- Handler: poll
-- ============================================

handlePoll = \cursor generation watchKeys authorization clientIp respond -> do
  t <- now
  serverGen <- *serverGeneration
  let generationMismatch = generation != serverGen
  let effectiveCursor = if generationMismatch then 0 else cursor
  let cursorWasReset = generationMismatch && cursor > 0
  let cappedWatchKeys = takeRelation maxWatchKeys watchKeys
  dp <- *drainPhase
  if dp >= 2 then yield (respond {events: [], cursor: 0, authorized: True {}, rateLimited: False {}, draining: True {}, generation: serverGen, presenceUpdates: [], heartbeat: False {}, retryAfterMs: 0, cursorReset: cursorWasReset, hasMore: False {}, cursorStale: False {}, messageExpirations: [], messageDeliveries: [], droppedDeliveryReceipts: 0, droppedExpirationNotifs: 0, loadPct: 0, messageCancellations: []})
  else do
    g <- checkGlobalRate t
    if g then yield (respond {events: [], cursor: 0, authorized: False {}, rateLimited: True {}, draining: False {}, generation: serverGen, presenceUpdates: [], heartbeat: False {}, retryAfterMs: globalRateWindowMs, cursorReset: cursorWasReset, hasMore: False {}, cursorStale: False {}, messageExpirations: [], messageDeliveries: [], droppedDeliveryReceipts: 0, droppedExpirationNotifs: 0, loadPct: 0, messageCancellations: []})
    else case extractToken authorization of
      Nothing {} -> yield (respond {events: [], cursor: 0, authorized: False {}, rateLimited: False {}, draining: False {}, generation: serverGen, presenceUpdates: [], heartbeat: False {}, retryAfterMs: 0, cursorReset: cursorWasReset, hasMore: False {}, cursorStale: False {}, messageExpirations: [], messageDeliveries: [], droppedDeliveryReceipts: 0, droppedExpirationNotifs: 0, loadPct: 0, messageCancellations: []})
      Just {value: token} -> pollOnce token effectiveCursor cursorWasReset cappedWatchKeys clientIp serverGen respond t

pollOnce = \token cursor cursorWasReset watchKeys clientIp serverGen respond t -> do
  setup <- atomic do
    ses <- *sessions
    case authenticateSession ses token t of
      Unauthorized {} -> yield Nothing {}
      Authorized {pubkey, ip} ->
        if not (matchIp clientIp ip) then yield Nothing {}
        else do
          let clampedCursor = clamp 0 t cursor
          ackResult <- if clampedCursor > 0 then ackPolledMessages pubkey clampedCursor t else yield {pendingAcks: []}
          startWakeup <- *pollWakeup
          yield (Just {value: {pubkey: pubkey, clampedCursor: clampedCursor, startWakeup: startWakeup, pendingAcks: ackResult.pendingAcks}})
  case setup of
    Nothing {} -> yield (respond {events: [], cursor: 0, authorized: False {}, rateLimited: False {}, draining: False {}, generation: serverGen, presenceUpdates: [], heartbeat: False {}, retryAfterMs: 0, cursorReset: cursorWasReset, hasMore: False {}, cursorStale: False {}, messageExpirations: [], messageDeliveries: [], droppedDeliveryReceipts: 0, droppedExpirationNotifs: 0, loadPct: 0, messageCancellations: []})
    Just {value: s} -> do
      acquired <- atomic do
        aps <- *activePolls
        let perKey = count (do p <- aps; where p.pubkey == s.pubkey; yield p)
        if perKey >= maxPollsPerKey then yield False
        else do
          set *activePolls = capList (union aps [{pubkey: s.pubkey, startedAt: t}]) maxActivePolls (\p -> p.startedAt)
          yield True
      if not acquired
        then yield (respond {events: [], cursor: cursor, authorized: True {}, rateLimited: True {}, draining: False {}, generation: serverGen, presenceUpdates: [], heartbeat: False {}, retryAfterMs: pollTimeoutMs, cursorReset: cursorWasReset, hasMore: False {}, cursorStale: False {}, messageExpirations: [], messageDeliveries: [], droppedDeliveryReceipts: 0, droppedExpirationNotifs: 0, loadPct: 0, messageCancellations: []})
        else do
          pollResult <- doPoll s t
          atomic do
            aps <- *activePolls
            set *activePolls = do p <- aps; where p.pubkey != s.pubkey; yield p
          when (federationEnabled && count s.pendingAcks > 0)
            (fork (sendAcksAndClean s.pendingAcks))
          presenceUpdates <- if count watchKeys > 0 && pollResult.authorized
            then atomic do
              t2 <- now
              pres <- *presence
              yield (do k <- watchKeys; yield {pubkey: k, online: count (presenceForKey pres k t2) > 0})
            else yield []
          drains <- atomic do
            se <- *senderExpirations
            let myExp = do x <- se; where x.senderKey == s.pubkey; yield {messageId: x.messageId, toKey: x.toKey, expiredAt: x.expiredAt}
            set *senderExpirations = do x <- se; where x.senderKey != s.pubkey; yield x
            sd <- *senderDeliveries
            let myDel = do x <- sd; where x.senderKey == s.pubkey; yield {messageId: x.messageId, toKey: x.toKey, deliveredAt: x.deliveredAt}
            set *senderDeliveries = do x <- sd; where x.senderKey != s.pubkey; yield x
            cn <- *cancelNotifications
            let myCancels = do x <- cn; where x.toKey == s.pubkey; yield {messageId: x.messageId, cancelledAt: x.cancelledAt}
            set *cancelNotifications = do x <- cn; where x.toKey != s.pubkey; yield x
            yield {expirations: myExp, deliveries: myDel, cancellations: myCancels}
          let isHeartbeat = pollResult.authorized && count pollResult.events == 0
          yield (respond {events: pollResult.events, cursor: pollResult.cursor, authorized: pollResult.authorized, rateLimited: False {}, draining: False {}, generation: serverGen, presenceUpdates: presenceUpdates, heartbeat: isHeartbeat, retryAfterMs: 0, cursorReset: cursorWasReset, hasMore: pollResult.hasMore, cursorStale: False {}, messageExpirations: drains.expirations, messageDeliveries: drains.deliveries, droppedDeliveryReceipts: 0, droppedExpirationNotifs: 0, loadPct: 0, messageCancellations: drains.cancellations})

doPoll = \s t -> do
  initial <- atomic do
    msgs <- *messages
    yield (collectPollEvents msgs s.pubkey s.clampedCursor t)
  if count initial.events > 0 then yield {authorized: True {}, events: initial.events, cursor: initial.cursor, hasMore: initial.hasMore}
  else do
    -- Wait for signal or heartbeat
    atomic do
      wakeup <- *pollWakeup
      if wakeup > s.startWakeup then yield {}
      else retry
    t2 <- now
    msgs2 <- *messages
    let r = collectPollEvents msgs2 s.pubkey s.clampedCursor t2
    yield {authorized: True {}, events: r.events, cursor: r.cursor, hasMore: r.hasMore}

collectPollEvents = \messages pubkey cursor t ->
  let myMsgs = do m <- messages; where m.toKey == pubkey && m.expiresAt > t && m.receivedAt > cursor; yield m in
  let sorted = sortBy (\m -> m.receivedAt) myMsgs in
  let limited = takeRelation maxPollEvents sorted in
  let evts = do m <- limited; yield {id: m.messageId, eventType: "message", payload: {toKey: m.toKey, encryptedBlob: m.encryptedBlob, timestamp: m.timestamp, expiresAt: m.expiresAt}} in
  let lastReceivedAt = fold (\acc m -> max acc m.receivedAt) cursor limited in
  {events: evts, cursor: lastReceivedAt, hasMore: count myMsgs > count limited}

ackPolledMessages = \pubkey cursor t -> do
  msgs <- *messages
  let toAck = do m <- msgs; where m.toKey == pubkey && m.receivedAt <= cursor; yield m
  if count toAck == 0 then yield {pendingAcks: []}
  else do
    set *messages = do m <- msgs; where not (m.toKey == pubkey && m.receivedAt <= cursor); yield m
    fwds <- *forwards
    let mids = do m <- toAck; yield m.messageId
    set *forwards = do f <- fwds; where not (f.toKey == pubkey && any mids (\mid -> mid == f.messageId)); yield f
    let ackedFederated = do m <- toAck; where m.originServer != ""; yield {messageId: m.messageId, toKey: m.toKey, ackedAt: t, originServer: m.originServer, retries: 0}
    aids <- *ackedIds
    set *ackedIds = capList (union aids ackedFederated) maxAckedIds (\a -> a.ackedAt)
    -- Sender delivery receipts for locally-originated messages
    let localDelivered = do m <- toAck; where m.senderKey != "" && m.originServer == ""; yield {senderKey: m.senderKey, messageId: m.messageId, toKey: m.toKey, deliveredAt: t}
    sd <- *senderDeliveries
    set *senderDeliveries = capList (union sd localDelivered) 10000 (\d -> d.deliveredAt)
    yield {pendingAcks: ackedFederated}

-- ============================================
-- Handler: send
-- ============================================

handleSendMessage = \to encryptedBlob timestamp messageId expiresInMs priority authorization clientIp respond -> do
  let clampedPriority = clamp 0 maxMessagePriority priority
  t <- now
  dp <- *drainPhase
  if dp >= 2 then yield (respond {status: MsDraining {}, messageId: "", retryAfterMs: 0, error: "draining", loadPct: 0})
  else do
    g <- checkGlobalRate t
    if g then yield (respond {status: MsRateLimited {}, messageId: "", retryAfterMs: 0, error: "rate_limited", loadPct: 0})
    else do
      effMsgId <- if messageId != "" then yield messageId else genToken
      if t - timestamp > messageMaxAge
        then yield (respond {status: MsRejected {}, messageId: "", retryAfterMs: 0, error: "stale_timestamp", loadPct: 0})
        else do
          let clampedTs = clampTimestamp timestamp t
          result <- atomic do
            withSessionAuth authorization t clientIp
              (yield {status: MsUnauthorized {}, remoteServers: []})
              (\senderKey -> sendMessageCore senderKey to encryptedBlob clampedTs effMsgId expiresInMs clampedPriority t)
          when (federationEnabled && count result.remoteServers > 0)
            (fork (forkForwardsTo effMsgId to encryptedBlob clampedTs result.remoteServers))
          let ok = case result.status of
                MsDelivered {} -> True {}; MsFederated {} -> True {}
                MsQueued {} -> True {}; MsDuplicate {} -> True {}; _ -> False {}
          yield (respond {status: result.status, messageId: if ok then effMsgId else "", retryAfterMs: 0, error: if ok then "" else "rejected", loadPct: 0})

sendMessageCore = \senderKey to encryptedBlob clampedTs effMsgId expiresInMs msgPriority t ->
  if senderKey == to then yield {status: MsRejected {}, remoteServers: []}
  else do
    msgs <- *messages
    aids <- *ackedIds
    dids <- *deliveredIds
    let isDup = (effMsgId != "" && any msgs (\m -> m.messageId == effMsgId && m.toKey == to))
              || hasMessage effMsgId to aids
              || hasMessage effMsgId to dids
    if isDup then yield {status: MsDuplicate {}, remoteServers: []}
    else do
      sendRates <- *sendRates
      let sr = checkRate sendRates senderKey maxSendRatePerKey sendRateWindowMs 5000 t
      if sr.limited then yield {status: MsRateLimited {}, remoteServers: []}
      else do
        set *sendRates = sr.entries
        pairRates <- *pairRates
        let pr = checkRate pairRates (senderKey ++ "|" ++ to) maxPairRatePerPair pairRateWindowMs 5000 t
        set *pairRates = pr.entries
        if pr.limited then yield {status: MsRateLimited {}, remoteServers: []}
        else do
          recvRates <- *recvRates
          let rr = checkRate recvRates to maxRecvRatePerKey recvRateWindowMs 5000 t
          if rr.limited then yield {status: MsRateLimited {}, remoteServers: []}
          else do
            set *recvRates = rr.entries
            if count msgs >= maxMessages then yield {status: MsRejected {}, remoteServers: []}
            else
              let recipientCount = count (do m <- msgs; where m.toKey == to; yield m) in
              if recipientCount >= maxMessagesPerRecipient then yield {status: MsQueued {}, remoteServers: []}
              else do
                pres <- *presence
                seq <- *seqCounter
                let seqTs = nextSeqTs t seq
                set *seqCounter = seqTs
                let expiresAt = seqTs + effectiveMessageTtl expiresInMs
                set *messages = union msgs [{messageId: effMsgId, toKey: to, encryptedBlob: encryptedBlob, timestamp: clampedTs, originServer: "", receivedAt: seqTs, expiresAt: expiresAt, senderKey: senderKey, priority: msgPriority}]
                set *pollWakeup = seqTs
                let toPresence = presenceForKey pres to t
                let localOnline = any toPresence (\p -> isLocalServer p.server)
                let remoteServers = collectPeers toPresence (\p -> p.server)
                forwardsEnqueued <- if federationEnabled && count remoteServers > 0
                  then do
                    fwds <- *forwards
                    let newFwds = do s <- remoteServers; where none fwds (\f -> f.messageId == effMsgId && f.toServer == s); yield {messageId: effMsgId, toServer: s, createdAt: t, toKey: to, encryptedBlob: encryptedBlob, timestamp: clampedTs, originServer: serverHostN, retries: 0, expiresAt: expiresAt, priority: msgPriority, senderKey: senderKey}
                    set *forwards = capList (union fwds newFwds) maxForwardsEntries (\f -> f.createdAt)
                    yield (count newFwds > 0)
                  else yield False
                let status = if localOnline then MsDelivered {}
                  else if forwardsEnqueued then MsFederated {}
                  else MsQueued {}
                yield {status: status, remoteServers: remoteServers}

forkForwardsTo = \effMsgId to encryptedBlob clampedTs servers ->
  forEach servers (\s -> s) (\server -> do
    info <- atomic do
      fwds <- *forwards
      case headOf (do f <- fwds; where f.messageId == effMsgId && f.toServer == server; yield f) of
        Nothing {} -> yield Nothing {}
        Just {value: f} -> yield (Just {value: {expiresAt: f.expiresAt, priority: f.priority}})
    case info of
      Nothing {} -> yield {}
      Just {value: i} -> do
        t <- now
        auth <- generateFederationAuth ("forward:" ++ effMsgId) t
        result <- fetch (federationUrl server) (ForwardMessage {
          toKey: to, encryptedBlob: encryptedBlob,
          timestamp: clampedTs, originServer: serverHostN, messageId: effMsgId,
          fromServer: serverHostN, requestTimestamp: t,
          authorization: auth, correlationId: "",
          expiresAt: i.expiresAt, priority: i.priority, protocolVersion: federationProtocolVersion})
        case result of
          Err _ -> recordFailure server
          Ok r ->
            if r.ok then do
              clearFailure server
              atomic do
                fwds <- *forwards
                set *forwards = do f <- fwds; where not (f.messageId == effMsgId && f.toServer == server); yield f
            else yield {})

-- ============================================
-- Handler: lookup
-- ============================================

handleLookupPresence = \pubkey authorization clientIp respond -> do
  t <- now
  g <- checkGlobalRate t
  if g then yield (respond {server: "", authorized: False {}, error: "rate_limited"})
  else withSessionAuth authorization t clientIp
    (yield (respond {server: "", authorized: False {}, error: ""}))
    (\senderKey -> do
      lim <- checkPubkeyRateGate lookupRates senderKey maxLookupRatePerKey lookupRateWindowMs t
      if lim then yield (respond {server: "", authorized: True {}, error: "rate_limited"})
      else do
        pres <- *presence
        let found = bestServerForKey (presenceForKey pres pubkey t)
        let masked = if found == "" then "" else if isLocalServer found then found else "remote"
        yield (respond {server: masked, authorized: True {}, error: ""}))

handleBatchLookupPresence = \pubkeys authorization clientIp respond -> do
  t <- now
  g <- checkGlobalRate t
  if g then yield (respond {results: [], authorized: False {}, error: "rate_limited"})
  else withSessionAuth authorization t clientIp
    (yield (respond {results: [], authorized: False {}, error: ""}))
    (\senderKey -> do
      lim <- checkPubkeyRateGate lookupRates senderKey maxLookupRatePerKey lookupRateWindowMs t
      if lim then yield (respond {results: [], authorized: True {}, error: "rate_limited"})
      else do
        let capped = takeRelation 50 pubkeys
        pres <- *presence
        let results = do
          k <- capped
          let found = bestServerForKey (presenceForKey pres k t)
          let masked = if found == "" then "" else if isLocalServer found then found else "remote"
          yield {pubkey: k, server: masked}
        yield (respond {results: results, authorized: True {}, error: ""}))

handleMessageStatus = \to messageId authorization clientIp respond -> do
  t <- now
  g <- checkGlobalRate t
  if g then yield (respond {status: "", authorized: False {}})
  else withSessionAuth authorization t clientIp
    (yield (respond {status: "", authorized: False {}}))
    (\_ -> do
      msgs <- *messages
      fwds <- *forwards
      aids <- *ackedIds
      dids <- *deliveredIds
      let s = if any msgs (\m -> m.messageId == messageId && m.toKey == to) then "pending"
            else if any fwds (\f -> f.messageId == messageId && f.toKey == to) then "forwarding"
            else if hasMessage messageId to aids || hasMessage messageId to dids then "delivered"
            else "unknown"
      yield (respond {status: s, authorized: True {}}))

-- ============================================
-- Handler: ack / list / delete / cancel
-- ============================================

handleAckMessages = \messageIds authorization clientIp respond -> do
  t <- now
  dp <- *drainPhase
  if dp >= 2 then yield (respond {ok: False {}, authorized: False {}, ackedCount: 0, error: "draining"})
  else do
    g <- checkGlobalRate t
    if g then yield (respond {ok: False {}, authorized: False {}, ackedCount: 0, error: "rate_limited"})
    else withSessionAuth authorization t clientIp
      (yield (respond {ok: False {}, authorized: False {}, ackedCount: 0, error: "unauthorized"}))
      (\pubkey -> do
        lim <- checkPubkeyRateGate clientWriteRates pubkey maxClientWriteRatePerKey clientWriteRateWindowMs t
        if lim then yield (respond {ok: False {}, authorized: True {}, ackedCount: 0, error: "rate_limited"})
        else do
          let dedupedIds = dedupMessageIds messageIds
          result <- atomic do
            msgs <- *messages
            let toAck = do m <- msgs; where m.toKey == pubkey && any dedupedIds (\mid -> m.messageId == mid); yield m
            if count toAck == 0 then yield {ackedCount: 0, pendingAcks: []}
            else do
              set *messages = do m <- msgs; where not (m.toKey == pubkey && any dedupedIds (\mid -> m.messageId == mid)); yield m
              fwds <- *forwards
              set *forwards = do f <- fwds; where not (f.toKey == pubkey && any dedupedIds (\mid -> f.messageId == mid)); yield f
              let ackedFed = do m <- toAck; where m.originServer != ""; yield {messageId: m.messageId, toKey: m.toKey, ackedAt: t, originServer: m.originServer, retries: 0}
              aids <- *ackedIds
              set *ackedIds = capList (union aids ackedFed) maxAckedIds (\a -> a.ackedAt)
              let localDelivered = do m <- toAck; where m.senderKey != "" && m.originServer == ""; yield {senderKey: m.senderKey, messageId: m.messageId, toKey: m.toKey, deliveredAt: t}
              sd <- *senderDeliveries
              set *senderDeliveries = capList (union sd localDelivered) 10000 (\d -> d.deliveredAt)
              yield {ackedCount: count toAck, pendingAcks: ackedFed}
          fork (when federationEnabled (sendAcksAndClean result.pendingAcks))
          yield (respond {ok: True {}, authorized: True {}, ackedCount: result.ackedCount, error: ""}))

handleListMessages = \offset authorization clientIp respond -> do
  t <- now
  dp <- *drainPhase
  if dp >= 2 then yield (respond {messages: [], authorized: False {}, count: 0, error: ""})
  else do
    g <- checkGlobalRate t
    if g then yield (respond {messages: [], authorized: False {}, count: 0, error: "rate_limited"})
    else withSessionAuth authorization t clientIp
      (yield (respond {messages: [], authorized: False {}, count: 0, error: ""}))
      (\pubkey -> do
        lim <- checkPubkeyRateGate lookupRates pubkey maxLookupRatePerKey lookupRateWindowMs t
        if lim then yield (respond {messages: [], authorized: True {}, count: 0, error: "rate_limited"})
        else do
          msgs <- *messages
          let myMsgs = sortBy (\m -> m.receivedAt) (do m <- msgs; where m.toKey == pubkey && m.expiresAt > t; yield m)
          let total = count myMsgs
          let effectiveOffset = clamp 0 total offset
          -- Index using a fold so we can drop items by position; simple O(n).
          let after = (fold (\acc m -> if acc.i < effectiveOffset then {i: acc.i + 1, out: acc.out} else {i: acc.i, out: union acc.out [m]}) {i: 0, out: []} myMsgs).out
          let capped = takeRelation maxPollEvents after
          let result = do m <- capped; yield {messageId: m.messageId, timestamp: m.timestamp, receivedAt: m.receivedAt}
          yield (respond {messages: result, authorized: True {}, count: total, error: ""}))

handleDeleteMessages = \messageIds authorization clientIp respond -> do
  t <- now
  dp <- *drainPhase
  if dp >= 2 then yield (respond {ok: False {}, authorized: False {}, deletedCount: 0, error: ""})
  else do
    g <- checkGlobalRate t
    if g then yield (respond {ok: False {}, authorized: False {}, deletedCount: 0, error: "rate_limited"})
    else withSessionAuth authorization t clientIp
      (yield (respond {ok: False {}, authorized: False {}, deletedCount: 0, error: "unauthorized"}))
      (\pubkey -> do
        lim <- checkPubkeyRateGate clientWriteRates pubkey maxClientWriteRatePerKey clientWriteRateWindowMs t
        if lim then yield (respond {ok: False {}, authorized: True {}, deletedCount: 0, error: "rate_limited"})
        else do
          let dedupedIds = dedupMessageIds messageIds
          result <- atomic do
            msgs <- *messages
            let toDel = do m <- msgs; where m.toKey == pubkey && any dedupedIds (\mid -> mid == m.messageId); yield m
            if count toDel == 0 then yield {deletedCount: 0, pendingAcks: []}
            else do
              set *messages = do m <- msgs; where not (m.toKey == pubkey && any dedupedIds (\mid -> mid == m.messageId)); yield m
              fwds <- *forwards
              set *forwards = do f <- fwds; where not (f.toKey == pubkey && any dedupedIds (\mid -> mid == f.messageId)); yield f
              let federatedDeleted = do m <- toDel; where m.originServer != ""; yield m
              let ackedFed = do m <- federatedDeleted; yield {messageId: m.messageId, toKey: m.toKey, ackedAt: t, originServer: m.originServer, retries: 0}
              aids <- *ackedIds
              set *ackedIds = capList (union aids ackedFed) maxAckedIds (\a -> a.ackedAt)
              yield {deletedCount: count toDel, pendingAcks: ackedFed}
          fork (when federationEnabled (sendAcksAndClean result.pendingAcks))
          yield (respond {ok: True {}, authorized: True {}, deletedCount: result.deletedCount, error: ""}))

handleCancelMessage = \messageId to authorization clientIp respond -> do
  t <- now
  dp <- *drainPhase
  if dp >= 2 then yield (respond {ok: False {}, authorized: False {}, cancelled: False {}, error: ""})
  else do
    g <- checkGlobalRate t
    if g then yield (respond {ok: False {}, authorized: False {}, cancelled: False {}, error: "rate_limited"})
    else withSessionAuth authorization t clientIp
      (yield (respond {ok: False {}, authorized: False {}, cancelled: False {}, error: "unauthorized"}))
      (\senderKey -> do
        lim <- checkPubkeyRateGate clientWriteRates senderKey maxClientWriteRatePerKey clientWriteRateWindowMs t
        if lim then yield (respond {ok: False {}, authorized: True {}, cancelled: False {}, error: "rate_limited"})
        else do
          result <- atomic do
            msgs <- *messages
            let target = headOf (do m <- msgs; where m.messageId == messageId && m.toKey == to; yield m)
            case target of
              Nothing {} -> yield {cancelled: False {}, cancelServers: []}
              Just {value: msg} ->
                if msg.originServer != "" || msg.senderKey == "" || msg.senderKey != senderKey
                  then yield {cancelled: False {}, cancelServers: []}
                  else do
                    set *messages = do m <- msgs; where not (m.messageId == messageId && m.toKey == to); yield m
                    fwds <- *forwards
                    let cancelledFwds = do f <- fwds; where f.messageId == messageId && f.toKey == to; yield f
                    let fwdServers = collectPeers cancelledFwds (\f -> f.toServer)
                    set *forwards = do f <- fwds; where not (f.messageId == messageId && f.toKey == to); yield f
                    pres <- *presence
                    let presServers = collectPeers (presenceForKey pres to t) (\p -> p.server)
                    let allServers = fold (\acc s -> if any acc (\a -> a == s) then acc else union acc [s]) presServers fwdServers
                    cn <- *cancelNotifications
                    set *cancelNotifications = capList (union cn [{toKey: to, messageId: messageId, cancelledAt: t}]) 10000 (\c -> c.cancelledAt)
                    yield {cancelled: True {}, cancelServers: allServers}
          when (result.cancelled && count result.cancelServers > 0 && federationEnabled)
            (fork (sendCancelToEach messageId to result.cancelServers))
          yield (respond {ok: True {}, authorized: True {}, cancelled: result.cancelled, error: ""}))

sendCancelToEach = \messageId to servers ->
  forEach servers (\s -> s) (\server -> do
    t <- now
    auth <- generateFederationAuth ("cancel:" ++ messageId) t
    result <- fetch (federationUrl server) (FederationCancel {
      messageId: messageId, toKey: to, fromServer: serverHostN,
      requestTimestamp: t, correlationId: "", authorization: auth,
      protocolVersion: federationProtocolVersion})
    let failed = case result of Err _ -> True {}; Ok r -> not r.ok
    when failed (atomic do
      pfc <- *pendingFederationCancels
      set *pendingFederationCancels = capList (union pfc [{messageId: messageId, toKey: to, toServer: server, createdAt: t, retries: 0}]) 10000 (\c -> c.createdAt)))

handleCancelBatch = \cancels authorization clientIp respond -> do
  t <- now
  dp <- *drainPhase
  if dp >= 2 then yield (respond {results: [], authorized: False {}, error: ""})
  else do
    g <- checkGlobalRate t
    if g then yield (respond {results: [], authorized: False {}, error: "rate_limited"})
    else withSessionAuth authorization t clientIp
      (yield (respond {results: [], authorized: False {}, error: "unauthorized"}))
      (\senderKey -> do
        lim <- checkPubkeyRateGate clientWriteRates senderKey maxClientWriteRatePerKey clientWriteRateWindowMs t
        if lim then yield (respond {results: [], authorized: True {}, error: "rate_limited"})
        else do
          results <- mapEach (takeRelation maxBatchSize cancels) (\e -> e.messageId) (\e -> do
            r <- atomic do
              msgs <- *messages
              let target = headOf (do m <- msgs; where m.messageId == e.messageId && m.toKey == e.to; yield m)
              case target of
                Nothing {} -> yield False
                Just {value: msg} ->
                  if msg.originServer != "" || msg.senderKey == "" || msg.senderKey != senderKey
                    then yield False
                    else do
                      set *messages = do m <- msgs; where not (m.messageId == e.messageId && m.toKey == e.to); yield m
                      fwds <- *forwards
                      set *forwards = do f <- fwds; where not (f.messageId == e.messageId && f.toKey == e.to); yield f
                      cn <- *cancelNotifications
                      set *cancelNotifications = capList (union cn [{toKey: e.to, messageId: e.messageId, cancelledAt: t}]) 10000 (\c -> c.cancelledAt)
                      yield True
            yield {messageId: e.messageId, cancelled: r})
          yield (respond {results: results, authorized: True {}, error: ""}))

handleSendBatch = \messages authorization clientIp respond -> do
  t <- now
  dp <- *drainPhase
  if dp >= 2 then yield (respond {results: [], authorized: False {}, retryAfterMs: 0})
  else do
    g <- checkGlobalRate t
    if g then yield (respond {results: [], authorized: False {}, retryAfterMs: 0})
    else withSessionAuth authorization t clientIp
      (yield (respond {results: [], authorized: False {}, retryAfterMs: 0}))
      (\senderKey -> do
        results <- mapEach (takeRelation maxBatchSize messages) (\m -> m) (\m -> do
          effMsgId <- if m.messageId != "" then yield m.messageId else genToken
          let clampedTs = clampTimestamp m.timestamp t
          let clampedPri = clamp 0 maxMessagePriority m.priority
          r <- if t - m.timestamp > messageMaxAge
            then yield {status: MsRejected {}, remoteServers: []}
            else atomic do sendMessageCore senderKey m.to m.encryptedBlob clampedTs effMsgId m.expiresInMs clampedPri t
          when (federationEnabled && count r.remoteServers > 0)
            (fork (forkForwardsTo effMsgId m.to m.encryptedBlob clampedTs r.remoteServers))
          yield {messageId: effMsgId, status: r.status})
        yield (respond {results: results, authorized: True {}, retryAfterMs: 0}))

-- ============================================
-- Handler: federation receive
-- ============================================

handleVerifyToken = \token scope clientIp respond -> do
  if scope == "" then yield (respond {ok: False {}})
  else do
    t <- now
    g <- checkGlobalRate t
    if g then yield (respond {ok: False {}})
    else do
      ipLim <- checkIpRateGate clientIp t
      if ipLim then yield (respond {ok: False {}})
      else do
        found <- atomic do
          pending <- *pendingVerifications
          let candidates = do p <- pending; where p.scope == scope && t - p.createdAt < verificationTokenExpiry; yield p
          let match = any candidates (\p -> p.token == token)
          when match (set *pendingVerifications = do p <- pending; where p.scope != scope || p.token != token; yield p)
          yield match
        yield (respond {ok: found})

handleFederationPubkey = \respond -> do
  yield (respond {pubkey: serverFederationPublicKeyHex, ok: serverFederationPublicKeyHex != ""})

handleRecvGossip = \events hopsRemaining fromServer requestTimestamp correlationId authorization respond -> do
  t <- now
  let cappedHops = clamp 0 maxGossipHops hopsRemaining
  withFederationAuth authorization t respond fromServer "gossip" requestTimestamp (cappedHops >= 1 && not (isLocalServer fromServer) && count events <= maxGossipEvents) (do
    valid <- atomic do
      pres <- *presence
      let validEvents = do
        e <- events
        where not (isLocalServer e.server) && e.timestamp <= t + clockSkewTolerance
        let expiresAt = min e.timestamp t + clampTtl e.ttl * 1000
        where expiresAt > t
        yield {pubkey: e.pubkey, server: e.server, expiresAt: expiresAt, timestamp: e.timestamp, eventType: e.eventType}
      let online = do v <- validEvents; where (case v.eventType of GossipOnline {} -> True {}; _ -> False {}); yield {pubkey: v.pubkey, server: v.server, expiresAt: v.expiresAt, timestamp: v.timestamp}
      let offline = do v <- validEvents; where (case v.eventType of GossipOffline {} -> True {}; _ -> False {}); yield {pubkey: v.pubkey, server: v.server, timestamp: v.timestamp}
      let withoutOffline = do
        p <- pres
        where none offline (\o -> o.pubkey == p.pubkey && o.server == p.server && o.timestamp > p.timestamp)
        yield p
      let merged = mergePresence withoutOffline online
      set *presence = capList merged maxPresenceEntries (\p -> p.expiresAt)
      let newlyOnline = do
        e <- online
        where not (isLocalServer e.server)
        where none pres (\p -> p.pubkey == e.pubkey && p.server == e.server && p.expiresAt >= e.expiresAt)
        yield {pubkey: e.pubkey, server: e.server}
      yield {newlyOnline: newlyOnline}
    when (count valid.newlyOnline > 0)
      (fork (forwardForNewlyOnline valid.newlyOnline t))
    yield (respond {ok: True {}, error: "", retryAfterMs: 0}))

forwardForNewlyOnline = \targets t ->
  forEach targets (\tgt -> tgt.pubkey ++ "|" ++ tgt.server) (\tgt -> forwardQueuedToServer tgt.pubkey tgt.server t)

handleForwardMessage = \toKey encryptedBlob timestamp originServer messageId fromServer requestTimestamp correlationId expiresAt priority authorization respond -> do
  t <- now
  withFederationAuth authorization t respond fromServer ("forward:" ++ messageId) requestTimestamp (not (isLocalServer originServer) && not (isLocalServer fromServer)) (do
    if t - timestamp > messageMaxAge
      then yield (respond {ok: False {}, error: "stale_timestamp", retryAfterMs: 0})
      else do
        let clampedTs = clampTimestamp timestamp t
        result <- atomic do
          pres <- *presence
          let hasPresence = any pres (\p -> p.pubkey == toKey && p.expiresAt > t)
          if not hasPresence then yield "no_presence"
          else do
            msgs <- *messages
            aids <- *ackedIds
            dids <- *deliveredIds
            let isDup = any msgs (\m -> m.messageId == messageId && m.toKey == toKey)
                      || hasMessage messageId toKey aids
                      || hasMessage messageId toKey dids
            if isDup then yield "duplicate"
            else if count msgs >= maxMessages then yield "global_full"
            else
              let rcCount = count (do m <- msgs; where m.toKey == toKey; yield m) in
              if rcCount >= maxMessagesPerRecipient then yield "mailbox_full"
              else do
                rr <- *recvRates
                let r = checkRate rr toKey maxRecvRatePerKey recvRateWindowMs 5000 t
                if r.limited then yield "rate_limited"
                else do
                  set *recvRates = r.entries
                  seq <- *seqCounter
                  let seqTs = nextSeqTs t seq
                  set *seqCounter = seqTs
                  let fwdExpiresAt = if expiresAt > t then min expiresAt (seqTs + unackedMessageMaxAge) else seqTs + unackedMessageMaxAge
                  let clampedPri = clamp 0 maxMessagePriority priority
                  set *messages = union msgs [{messageId: messageId, toKey: toKey, encryptedBlob: encryptedBlob, timestamp: clampedTs, originServer: originServer, receivedAt: seqTs, expiresAt: fwdExpiresAt, senderKey: "", priority: clampedPri}]
                  set *pollWakeup = seqTs
                  yield "stored"
        if result == "stored" || result == "duplicate"
          then yield (respond {ok: True {}, error: "", retryAfterMs: 0})
          else yield (respond {ok: False {}, error: result, retryAfterMs: 0}))

handleFederationAck = \messageIds originServer fromServer requestTimestamp correlationId authorization respond -> do
  t <- now
  let ackRespond = \r -> respond {ok: r.ok, error: r.error, ackedCount: 0, results: [], retryAfterMs: r.retryAfterMs}
  withFederationAuth authorization t ackRespond fromServer "ack" requestTimestamp (isLocalServer originServer && not (isLocalServer fromServer)) (do
    let dedupedIds = dedupMessageIds messageIds
    result <- atomic do
      fwds <- *forwards
      let removed = do f <- fwds; where f.toServer == fromServer && any dedupedIds (\m -> m == f.messageId); yield f
      set *forwards = do f <- fwds; where not (f.toServer == fromServer && any dedupedIds (\m -> m == f.messageId)); yield f
      -- Reclaim origin messages with no remaining forwards
      msgs <- *messages
      let removedIds = do f <- removed; yield f.messageId
      pres <- *presence
      remainingFwds <- *forwards
      let toReap = do
        m <- msgs
        where any removedIds (\mid -> mid == m.messageId)
        where t - m.receivedAt >= ackGracePeriod
        where none pres (\p -> p.pubkey == m.toKey && isLocalServer p.server && p.expiresAt > t)
        where none remainingFwds (\f -> f.messageId == m.messageId && f.toKey == m.toKey)
        yield m
      set *messages = do m <- msgs; where none toReap (\r -> r.messageId == m.messageId && r.toKey == m.toKey); yield m
      let perResult = do mid <- dedupedIds; yield {messageId: mid, found: any removed (\f -> f.messageId == mid)}
      yield {ackedCount: count removed, results: perResult}
    yield (respond {ok: True {}, error: "", ackedCount: result.ackedCount, results: result.results, retryAfterMs: 0}))

handleFederationCancel = \messageId toKey fromServer requestTimestamp correlationId authorization respond -> do
  t <- now
  let cancelRespond = \r -> respond {ok: r.ok, error: r.error, cancelled: False {}, retryAfterMs: r.retryAfterMs}
  withFederationAuth authorization t cancelRespond fromServer ("cancel:" ++ messageId) requestTimestamp (not (isLocalServer fromServer)) (do
    cancelled <- atomic do
      msgs <- *messages
      let target = headOf (do m <- msgs; where m.messageId == messageId && m.toKey == toKey && m.originServer == fromServer; yield m)
      case target of
        Nothing {} -> yield False
        Just {} -> do
          set *messages = do m <- msgs; where not (m.messageId == messageId && m.toKey == toKey); yield m
          fwds <- *forwards
          set *forwards = do f <- fwds; where not (f.messageId == messageId && f.toKey == toKey); yield f
          cn <- *cancelNotifications
          set *cancelNotifications = capList (union cn [{toKey: toKey, messageId: messageId, cancelledAt: t}]) 10000 (\c -> c.cancelledAt)
          yield True
    yield (respond {ok: True {}, error: "", cancelled: cancelled, retryAfterMs: 0}))

handleFederationBatchCancel = \cancels fromServer requestTimestamp correlationId authorization respond -> do
  t <- now
  let batchRespond = \r -> respond {ok: r.ok, error: r.error, results: [], retryAfterMs: r.retryAfterMs}
  withFederationAuth authorization t batchRespond fromServer "cancel-batch" requestTimestamp (not (isLocalServer fromServer) && count cancels <= maxBatchSize) (do
    results <- mapEach (takeRelation maxBatchSize cancels) (\e -> e.messageId) (\e -> do
      cancelled <- atomic do
        msgs <- *messages
        let target = headOf (do m <- msgs; where m.messageId == e.messageId && m.toKey == e.toKey && m.originServer == fromServer; yield m)
        case target of
          Nothing {} -> yield False
          Just {} -> do
            set *messages = do m <- msgs; where not (m.messageId == e.messageId && m.toKey == e.toKey); yield m
            fwds <- *forwards
            set *forwards = do f <- fwds; where not (f.messageId == e.messageId && f.toKey == e.toKey); yield f
            yield True
      yield {messageId: e.messageId, cancelled: cancelled})
    yield (respond {ok: True {}, error: "", results: results, retryAfterMs: 0}))

handleFederationBatchForward = \forwards fromServer requestTimestamp correlationId authorization respond -> do
  t <- now
  let batchRespond = \r -> respond {ok: r.ok, error: r.error, results: [], retryAfterMs: r.retryAfterMs}
  withFederationAuth authorization t batchRespond fromServer "forward-batch" requestTimestamp (not (isLocalServer fromServer) && count forwards <= maxBatchSize) (do
    results <- mapEach (takeRelation maxBatchSize forwards) (\e -> e.messageId) (\e -> do
      ok <- if isLocalServer e.originServer || t - e.timestamp > messageMaxAge then yield False
        else atomic do
          pres <- *presence
          let hasPresence = any pres (\p -> p.pubkey == e.toKey && p.expiresAt > t)
          if not hasPresence then yield False
          else do
            msgs <- *messages
            aids <- *ackedIds
            dids <- *deliveredIds
            let isDup = any msgs (\m -> m.messageId == e.messageId && m.toKey == e.toKey)
                      || hasMessage e.messageId e.toKey aids
                      || hasMessage e.messageId e.toKey dids
            if isDup then yield True
            else if count msgs >= maxMessages then yield False
            else
              let rcCount = count (do m <- msgs; where m.toKey == e.toKey; yield m) in
              if rcCount >= maxMessagesPerRecipient then yield False
              else do
                seq <- *seqCounter
                let seqTs = nextSeqTs t seq
                set *seqCounter = seqTs
                let clampedTs = clampTimestamp e.timestamp t
                let fwdExpiresAt = if e.expiresAt > t then min e.expiresAt (seqTs + unackedMessageMaxAge) else seqTs + unackedMessageMaxAge
                let clampedPri = clamp 0 maxMessagePriority e.priority
                set *messages = union msgs [{messageId: e.messageId, toKey: e.toKey, encryptedBlob: e.encryptedBlob, timestamp: clampedTs, originServer: e.originServer, receivedAt: seqTs, expiresAt: fwdExpiresAt, senderKey: "", priority: clampedPri}]
                set *pollWakeup = seqTs
                yield True
      yield {messageId: e.messageId, ok: ok})
    yield (respond {ok: True {}, error: "", results: results, retryAfterMs: 0}))

handleFederationDeliveryReceipt = \messageIds toKeys fromServer requestTimestamp correlationId authorization respond -> do
  t <- now
  let receiptRespond = \r -> respond {ok: r.ok, error: r.error, receivedCount: 0, retryAfterMs: r.retryAfterMs}
  withFederationAuth authorization t receiptRespond fromServer "delivery-receipt" requestTimestamp (not (isLocalServer fromServer) && count messageIds <= maxMessageIds) (do
    if count messageIds != count toKeys
      then yield (respond {ok: False {}, error: "mismatched_lengths", receivedCount: 0, retryAfterMs: 0})
      else do
        let pairs = zipPairs messageIds toKeys
        atomic do
          msgs <- *messages
          sd <- *senderDeliveries
          let receipts = do
            p <- pairs
            m <- msgs
            where m.messageId == p.messageId && m.toKey == p.toKey && m.senderKey != "" && m.originServer == ""
            yield {senderKey: m.senderKey, messageId: p.messageId, toKey: p.toKey, deliveredAt: t}
          set *senderDeliveries = capList (union sd receipts) 10000 (\d -> d.deliveredAt)
        yield (respond {ok: True {}, error: "", receivedCount: count pairs, retryAfterMs: 0}))

-- Pair up parallel lists by index. Builds index arrays and joins on i (O(n*m) but trivial code).
withIndex = \xs -> (fold (\acc x -> {i: acc.i + 1, out: union acc.out [{i: acc.i, v: x}]}) {i: 0, out: []} xs).out
zipPairs = \mids keys ->
  do mp <- withIndex mids; kp <- withIndex keys; where mp.i == kp.i; yield {messageId: mp.v, toKey: kp.v}

-- ============================================
-- Maintenance handlers
-- ============================================

handleDrain = \phase authorization respond -> do
  authorized <- verifyMaintenanceAuth authorization
  if not authorized then yield (respond {ok: False {}, drained: 0, phase: 0})
  else do
    let effectivePhase = if phase == 1 then 1 else 2
    t <- now
    drainResult <- atomic do
      set *drainPhase = effectivePhase
      set *drainCompletedAt = t
      if effectivePhase == 1 then yield {drainedCount: 0, peers: [], localKeys: []}
      else do
        pres <- *presence
        let localEntries = do p <- pres; where isLocalServer p.server && p.expiresAt > t; yield p
        set *presence = do p <- pres; where not (isLocalServer p.server) || p.expiresAt <= t; yield p
        set *pollWakeup = t
        let peers = knownPeerServersFromPresence pres
        yield {drainedCount: count localEntries, peers: peers, localKeys: localEntries}
    when (effectivePhase == 2 && count drainResult.localKeys > 0 && count drainResult.peers > 0 && federationEnabled)
      (fork (sendBatchedGossip drainResult.peers (do p <- drainResult.localKeys; yield {eventType: GossipOffline {}, pubkey: p.pubkey, server: serverHostN, timestamp: t, ttl: offlineGossipMinTtl, seenBy: [serverHostN]}) gossipOriginHops))
    yield (respond {ok: True {}, drained: drainResult.drainedCount, phase: effectivePhase})

handleUndrain = \authorization respond -> do
  authorized <- verifyMaintenanceAuth authorization
  if not authorized then yield (respond {ok: False {}})
  else do
    atomic do
      set *drainPhase = 0
      set *drainCompletedAt = 0
    yield (respond {ok: True {}})

handleShutdown = \authorization respond -> do
  authorized <- verifyMaintenanceAuth authorization
  if not authorized then yield (respond {ok: False {}, drained: 0})
  else handleDrain 2 authorization (\r -> respond {ok: r.ok, drained: r.drained})

handlePrune = \authorization respond -> do
  t <- now
  authorized <- verifyMaintenanceAuth authorization
  when authorized (fork (pruneAndRetry t))
  yield (respond {ok: authorized})

handleReconcile = \authorization respond -> do
  authorized <- verifyMaintenanceAuth authorization
  if not authorized then yield (respond {ok: False {}, messageDrift: 0, presenceDrift: 0, sessionDrift: 0})
  else yield (respond {ok: True {}, messageDrift: 0, presenceDrift: 0, sessionDrift: 0})

handleHealth = \authorization respond -> do
  t <- now
  lastPrune <- *lastPrunedAt
  lastHb <- *lastHeartbeatAt
  sa <- *startedAt
  dp <- *drainPhase
  let warmup = t - sa < backgroundPruneInterval * 3
  let pruneOk = warmup || t - lastPrune < backgroundPruneInterval * 3
  let heartbeatOk = warmup || t - lastHb < pollTimeoutMs * 3
  let allOk = dp == 0 && pruneOk && heartbeatOk
  yield (respond {ok: allOk, version: serverBuildVersion, pruneHealthy: pruneOk, heartbeatHealthy: heartbeatOk, capacityHealthy: True {}, capacityWarning: False {}, federationHealthy: True {}, watchdogHealthy: True {}, nonceHealthy: True {}, forwardQueueHealthy: True {}, requestPressureHealthy: True {}, draining: dp > 0, degradedPeers: 0})

handleReady = \respond -> do
  sa <- *startedAt
  lastPrune <- *lastPrunedAt
  yield (respond {ready: lastPrune > 0 && lastPrune >= sa})

handleBlockPeer = \server authorization respond -> do
  authorized <- verifyMaintenanceAuth authorization
  if not authorized then yield (respond {ok: False {}, blocked: 0})
  else do
    n <- atomic do
      blocked <- *blockedPeers
      if any blocked (\b -> b == server) then yield (count blocked)
      else do
        let updated = union blocked [server]
        set *blockedPeers = updated
        yield (count updated)
    yield (respond {ok: True {}, blocked: n})

handleUnblockPeer = \server authorization respond -> do
  authorized <- verifyMaintenanceAuth authorization
  if not authorized then yield (respond {ok: False {}, unblocked: False {}})
  else do
    removed <- atomic do
      blocked <- *blockedPeers
      let had = any blocked (\b -> b == server)
      set *blockedPeers = do b <- blocked; where b != server; yield b
      yield had
    yield (respond {ok: True {}, unblocked: removed})

handleListBlocked = \authorization respond -> do
  authorized <- verifyMaintenanceAuth authorization
  if not authorized then yield (respond {peers: [], ok: False {}})
  else do
    blocked <- *blockedPeers
    yield (respond {peers: blocked, ok: True {}})

handleAllowPeer = \server authorization respond -> do
  authorized <- verifyMaintenanceAuth authorization
  if not authorized then yield (respond {ok: False {}, allowed: 0})
  else do
    n <- atomic do
      allowed <- *allowedPeers
      if any allowed (\a -> a == server) then yield (count allowed)
      else do
        let updated = union allowed [server]
        set *allowedPeers = updated
        yield (count updated)
    yield (respond {ok: True {}, allowed: n})

handleUnallowPeer = \server authorization respond -> do
  authorized <- verifyMaintenanceAuth authorization
  if not authorized then yield (respond {ok: False {}, removed: False {}})
  else do
    removed <- atomic do
      allowed <- *allowedPeers
      let had = any allowed (\a -> a == server)
      set *allowedPeers = do a <- allowed; where a != server; yield a
      yield had
    yield (respond {ok: True {}, removed: removed})

handleListAllowed = \authorization respond -> do
  authorized <- verifyMaintenanceAuth authorization
  if not authorized then yield (respond {peers: [], ok: False {}})
  else do
    allowed <- *allowedPeers
    yield (respond {peers: allowed, ok: True {}})

handlePingPeer = \server authorization respond -> do
  authorized <- verifyMaintenanceAuth authorization
  if not authorized then yield (respond {ok: False {}, latencyMs: 0, error: "unauthorized"})
  else do
    startTime <- now
    auth <- generateFederationAuth "gossip" startTime
    result <- fetch (federationUrl server) (RecvGossip {
      authorization: auth,
      events: [], hopsRemaining: 1, fromServer: serverHostN,
      requestTimestamp: startTime, correlationId: "", protocolVersion: federationProtocolVersion})
    endTime <- now
    case result of
      Err e -> yield (respond {ok: False {}, latencyMs: endTime - startTime, error: show e})
      Ok r -> yield (respond {ok: r.ok, latencyMs: endTime - startTime, error: r.error})

handleAdminListSessions = \pubkey authorization respond -> do
  authorized <- verifyMaintenanceAuth authorization
  if not authorized then yield (respond {sessions: [], count: 0, ok: False {}})
  else do
    ses <- *sessions
    let mine = do s <- ses; where s.pubkey == pubkey; yield {token: "***", expiresAt: s.expiresAt, ip: s.ip, createdAt: s.createdAt}
    yield (respond {sessions: mine, count: count mine, ok: True {}})

handleAdminRevokeSessions = \pubkey authorization respond -> do
  authorized <- verifyMaintenanceAuth authorization
  if not authorized then yield (respond {ok: False {}, revokedCount: 0})
  else do
    t <- now
    revoked <- atomic do
      ses <- *sessions
      let mine = do s <- ses; where s.pubkey == pubkey; yield s
      set *sessions = do s <- ses; where s.pubkey != pubkey; yield s
      pres <- *presence
      set *presence = do p <- pres; where p.pubkey != pubkey || not (isLocalServer p.server); yield p
      yield (count mine)
    yield (respond {ok: True {}, revokedCount: revoked})

handleAdminPurgeMessages = \pubkey authorization respond -> do
  authorized <- verifyMaintenanceAuth authorization
  if not authorized then yield (respond {ok: False {}, purgedCount: 0})
  else do
    t <- now
    purged <- atomic do
      msgs <- *messages
      let mine = do m <- msgs; where m.toKey == pubkey; yield m
      set *messages = do m <- msgs; where m.toKey != pubkey; yield m
      fwds <- *forwards
      set *forwards = do f <- fwds; where f.toKey != pubkey; yield f
      let federated = do m <- mine; where m.originServer != ""; yield {messageId: m.messageId, toKey: m.toKey, ackedAt: t, originServer: m.originServer, retries: 0}
      aids <- *ackedIds
      set *ackedIds = capList (union aids federated) maxAckedIds (\a -> a.ackedAt)
      yield (count mine)
    yield (respond {ok: True {}, purgedCount: purged})

handleAdminRevokeIp = \ip authorization respond -> do
  authorized <- verifyMaintenanceAuth authorization
  if not authorized then yield (respond {ok: False {}, revokedCount: 0, affectedKeys: 0})
  else if ip == "" then yield (respond {ok: False {}, revokedCount: 0, affectedKeys: 0})
  else do
    result <- atomic do
      ses <- *sessions
      let mine = do s <- ses; where s.ip == ip; yield s
      set *sessions = do s <- ses; where s.ip != ip; yield s
      let keys = fold (\acc s -> if any acc (\a -> a == s.pubkey) then acc else union acc [s.pubkey]) [] mine
      yield {revoked: count mine, keys: count keys}
    yield (respond {ok: True {}, revokedCount: result.revoked, affectedKeys: result.keys})

handleAdminListAllSessions = \limit authorization respond -> do
  authorized <- verifyMaintenanceAuth authorization
  if not authorized then yield (respond {sessions: [], ok: False {}, total: 0})
  else do
    t <- now
    ses <- *sessions
    let active = do s <- ses; where s.expiresAt > t; yield s
    let grouped = fold (\acc s ->
      if any acc (\a -> a.pubkey == s.pubkey)
        then do a <- acc; yield (if a.pubkey == s.pubkey then {pubkey: a.pubkey, count: a.count + 1, ips: if any a.ips (\i -> i == s.ip) || s.ip == "" then a.ips else union a.ips [s.ip], latestExpiry: max a.latestExpiry s.expiresAt} else a)
        else union acc [{pubkey: s.pubkey, count: 1, ips: if s.ip == "" then [] else [s.ip], latestExpiry: s.expiresAt}]) [] active
    let sorted = sortBy (\g -> 0 - g.count) grouped
    let effLimit = if limit <= 0 then 100 else clamp 1 500 limit
    yield (respond {sessions: takeRelation effLimit sorted, ok: True {}, total: count grouped})

handleGetRateLimits = \authorization respond -> do
  authorized <- verifyMaintenanceAuth authorization
  if not authorized then yield (respond {ok: False {}, globalRequest: 0, ipRate: 0, sendRate: 0, federationRate: 0, authGlobal: 0, recvRate: 0, challengeRate: 0, pairRate: 0, lookupRate: 0, clientWriteRate: 0})
  else yield (respond {ok: True {}, globalRequest: maxGlobalRequestRate, ipRate: maxIpRatePerIp, sendRate: maxSendRatePerKey, federationRate: maxFederationRatePerServer, authGlobal: maxAuthGlobalRate, recvRate: maxRecvRatePerKey, challengeRate: maxChallengeRatePerKey, pairRate: maxPairRatePerPair, lookupRate: maxLookupRatePerKey, clientWriteRate: maxClientWriteRatePerKey})

handleSetRateLimits = \globalRequest ipRate sendRate federationRate authGlobal recvRate challengeRate pairRate lookupRate clientWriteRate authorization respond -> do
  authorized <- verifyMaintenanceAuth authorization
  yield (respond {ok: authorized})

handleFlushNonces = \authorization respond -> do
  authorized <- verifyMaintenanceAuth authorization
  yield (respond {ok: authorized, flushedCount: 0})

handleRotateSecret = \newSecret authorization respond -> do
  authorized <- verifyMaintenanceAuth authorization
  if not authorized then yield (respond {ok: False {}, error: "unauthorized"})
  else do
    atomic do set *runtimeMaintenanceSecret = newSecret
    yield (respond {ok: True {}, error: ""})

handleGetConfig = \authorization respond -> do
  authorized <- verifyMaintenanceAuth authorization
  if not authorized then yield (respond {ok: False {}, maxMessagesPerRecipient: 0, maxGossipHops: 0, pollTimeoutMs: 0, ackGracePeriod: 0})
  else yield (respond {ok: True {}, maxMessagesPerRecipient: maxMessagesPerRecipient, maxGossipHops: maxGossipHops, pollTimeoutMs: pollTimeoutMs, ackGracePeriod: ackGracePeriod})

-- /stats: zero-fill all metric fields we no longer compute.
handleStats = \authorization respond -> do
  authorized <- verifyMaintenanceAuth authorization
  if not authorized then yield (respond zeroStats)
  else do
    t <- now
    sa <- *startedAt
    sessions <- *sessions
    msgs <- *messages
    pres <- *presence
    fwds <- *forwards
    aids <- *ackedIds
    dids <- *deliveredIds
    aps <- *activePolls
    chs <- *challenges
    bp <- *blockedPeers
    pc <- *pruneCount
    hc <- *heartbeatCount
    lp <- *lastPrunedAt
    lh <- *lastHeartbeatAt
    dp <- *drainPhase
    pfc <- *pendingFederationCancels
    let sCount = count sessions
    let mCount = count msgs
    let pCount = count pres
    let fCount = count fwds
    let zeroFed = {enabled: federationEnabled, inFlight: 0, hungSlots: 0, avgLatencyMs: 0, maxLatencyMs: 0, callCount: 0, slowVerifies: 0, verifyFailures: 0, forwardFailures: 0, oldestForwardAge: 0, oldestAckAge: 0, recentGossip: 0, blockedPeers: count bp, drainCompletedAt: 0, forwardServers: 0, maxForwardQueueDepth: 0, topFailingPeers: [], pendingCancels: count pfc, gossipSuccess: 0, gossipFail: 0, latencyBuckets: {lt100: 0, lt500: 0, lt2000: 0, gte2000: 0}}
    let zeroRates = {send: 0, challenge: 0, federation: 0, federationPair: 0, global: 0, ip: 0, lookup: 0, recv: 0, pair: 0, gossipEvent: 0, verifyIp: 0, uniqueKeyIp: 0, pendingAckCleanups: 0, senderExpirations: 0, senderDeliveries: 0, rejectedGlobal: 0, rejectedIp: 0, rejectedAuth: 0, rejectedPerKey: 0, rejectedFederation: 0, clientCancels: 0, federationCancels: 0}
    let cap = {sessions: sCount, sessionsMax: maxSessions, sessionsPct: if maxSessions > 0 then sCount * 100 / maxSessions else 0, messages: mCount, messagesMax: maxMessages, messagesPct: if maxMessages > 0 then mCount * 100 / maxMessages else 0, totalMessageCount: mCount, presence: pCount, presenceMax: maxPresenceEntries, presencePct: if maxPresenceEntries > 0 then pCount * 100 / maxPresenceEntries else 0, forwards: fCount, forwardsMax: maxForwardsEntries, forwardsPct: if maxForwardsEntries > 0 then fCount * 100 / maxForwardsEntries else 0, challenges: count chs, challengesMax: maxChallenges, ackedIds: count aids, ackedIdsMax: maxAckedIds, ackOverflow: 0, ackOverflowMax: 0, deliveredIds: count dids, deliveredIdsMax: maxDeliveredIds, forwardNonces: 0, forwardNoncesMax: 0, nonceEvictions: 0, activePolls: count aps, activePollsMax: maxActivePolls, recipientCounts: 0, messageBucketMax: 0, messageBucketMin: 0}
    let timing = {pruneCount: pc, pruneRunning: 0, heartbeatCount: hc, uptime: t - sa, lastPruneAt: lp, lastHeartbeatAt: lh, draining: dp > 0, drainPhase: dp, totalEntries: sCount + mCount + pCount + fCount, activeRequests: 0, peakActiveRequests: 0, pollAvgMs: 0, pollMaxMs: 0, pollCount: 0, pollLatencyBuckets: {lt50: 0, lt200: 0, lt1000: 0, gte1000: 0}, sendAvgMs: 0, sendMaxMs: 0, sendCount: 0, sendLatencyBuckets: {lt50: 0, lt200: 0, lt1000: 0, gte1000: 0}, authAvgMs: 0, authMaxMs: 0, authCount: 0}
    yield (respond {ok: True {}, version: serverBuildVersion, capacity: cap, federation: zeroFed, rates: zeroRates, timing: timing})

zeroStats = {ok: False {}, version: serverBuildVersion, capacity: {sessions: 0, sessionsMax: 0, sessionsPct: 0, messages: 0, messagesMax: 0, messagesPct: 0, totalMessageCount: 0, presence: 0, presenceMax: 0, presencePct: 0, forwards: 0, forwardsMax: 0, forwardsPct: 0, challenges: 0, challengesMax: 0, ackedIds: 0, ackedIdsMax: 0, ackOverflow: 0, ackOverflowMax: 0, deliveredIds: 0, deliveredIdsMax: 0, forwardNonces: 0, forwardNoncesMax: 0, nonceEvictions: 0, activePolls: 0, activePollsMax: 0, recipientCounts: 0, messageBucketMax: 0, messageBucketMin: 0}, federation: {enabled: False {}, inFlight: 0, hungSlots: 0, avgLatencyMs: 0, maxLatencyMs: 0, callCount: 0, slowVerifies: 0, verifyFailures: 0, forwardFailures: 0, oldestForwardAge: 0, oldestAckAge: 0, recentGossip: 0, blockedPeers: 0, drainCompletedAt: 0, forwardServers: 0, maxForwardQueueDepth: 0, topFailingPeers: [], pendingCancels: 0, gossipSuccess: 0, gossipFail: 0, latencyBuckets: {lt100: 0, lt500: 0, lt2000: 0, gte2000: 0}}, rates: {send: 0, challenge: 0, federation: 0, federationPair: 0, global: 0, ip: 0, lookup: 0, recv: 0, pair: 0, gossipEvent: 0, verifyIp: 0, uniqueKeyIp: 0, pendingAckCleanups: 0, senderExpirations: 0, senderDeliveries: 0, rejectedGlobal: 0, rejectedIp: 0, rejectedAuth: 0, rejectedPerKey: 0, rejectedFederation: 0, clientCancels: 0, federationCancels: 0}, timing: {pruneCount: 0, pruneRunning: 0, heartbeatCount: 0, uptime: 0, lastPruneAt: 0, lastHeartbeatAt: 0, draining: False {}, drainPhase: 0, totalEntries: 0, activeRequests: 0, peakActiveRequests: 0, pollAvgMs: 0, pollMaxMs: 0, pollCount: 0, pollLatencyBuckets: {lt50: 0, lt200: 0, lt1000: 0, gte1000: 0}, sendAvgMs: 0, sendMaxMs: 0, sendCount: 0, sendLatencyBuckets: {lt50: 0, lt200: 0, lt1000: 0, gte1000: 0}, authAvgMs: 0, authMaxMs: 0, authCount: 0}}

handleStatsPeers = \authorization respond -> do
  authorized <- verifyMaintenanceAuth authorization
  if not authorized then yield (respond {peers: [], ok: False {}})
  else do
    t <- now
    failures <- *forwardFailures
    fwds <- *forwards
    let peers = do
      f <- failures
      let pending = count (do x <- fwds; where x.toServer == f.server; yield x)
      yield {server: f.server, failures: f.failures, lastFailedAt: f.failedAt, firstFailedAt: f.firstFailedAt, backoffMs: retryBackoff f.failures, retriable: shouldRetryServer f.server t failures, pendingForwards: pending, avgLatencyMs: 0, maxLatencyMs: 0, latencySamples: 0, gossipEventsPerMin: 0}
    yield (respond {peers: peers, ok: True {}})

handleStatsKey = \pubkey authorization respond -> do
  authorized <- verifyMaintenanceAuth authorization
  if not authorized then yield (respond {messages: 0, presence: [], sessions: 0, forwards: 0, forwardDetails: [], activePolls: 0, ok: False {}})
  else do
    t <- now
    msgs <- *messages
    pres <- *presence
    ses <- *sessions
    fwds <- *forwards
    aps <- *activePolls
    let m = count (do x <- msgs; where x.toKey == pubkey; yield x)
    let p = do x <- pres; where x.pubkey == pubkey && x.expiresAt > t; yield {server: x.server, expiresAt: x.expiresAt}
    let s = count (do x <- ses; where x.pubkey == pubkey; yield x)
    let myFwds = do x <- fwds; where x.toKey == pubkey; yield x
    let f = count myFwds
    let fd = do x <- myFwds; yield {server: x.toServer, retries: x.retries, createdAt: x.createdAt}
    let a = count (do x <- aps; where x.pubkey == pubkey; yield x)
    yield (respond {messages: m, presence: p, sessions: s, forwards: f, forwardDetails: fd, activePolls: a, ok: True {}})

handleTopRecipients = \limit authorization respond -> do
  authorized <- verifyMaintenanceAuth authorization
  if not authorized then yield (respond {recipients: [], ok: False {}, total: 0})
  else do
    msgs <- *messages
    let counts = fold (\acc m ->
      if any acc (\a -> a.pubkey == m.toKey)
        then do a <- acc; yield (if a.pubkey == m.toKey then {pubkey: a.pubkey, count: a.count + 1} else a)
        else union acc [{pubkey: m.toKey, count: 1}]) [] msgs
    let sorted = sortBy (\c -> 0 - c.count) counts
    let effLimit = if limit <= 0 then 20 else clamp 1 100 limit
    yield (respond {recipients: takeRelation effLimit sorted, ok: True {}, total: count counts})

handleStatsForwards = \authorization respond -> do
  authorized <- verifyMaintenanceAuth authorization
  if not authorized then yield (respond {servers: [], ok: False {}, total: 0})
  else do
    t <- now
    fwds <- *forwards
    let servers = collectPeers fwds (\f -> f.toServer)
    let result = do
      s <- servers
      let svFwds = do f <- fwds; where f.toServer == s; yield f
      let oldest = case minBy svFwds (\f -> f.createdAt) of Nothing {} -> 0; Just {value: x} -> t - x.createdAt
      let retries = fold (\acc f -> acc + f.retries) 0 svFwds
      yield {server: s, count: count svFwds, oldestAge: oldest, totalRetries: retries}
    yield (respond {servers: result, ok: True {}, total: count fwds})

handleStatsRates = \authorization respond -> do
  authorized <- verifyMaintenanceAuth authorization
  if not authorized then yield (respond {ok: False {}, scalePct: 0, globalRequest: 0, ipRate: 0, sendRate: 0, federationRate: 0, authGlobal: 0, recvRate: 0, challengeRate: 0, pairRate: 0, lookupRate: 0, clientWriteRate: 0})
  else yield (respond {ok: True {}, scalePct: 100, globalRequest: maxGlobalRequestRate, ipRate: maxIpRatePerIp, sendRate: maxSendRatePerKey, federationRate: maxFederationRatePerServer, authGlobal: maxAuthGlobalRate, recvRate: maxRecvRatePerKey, challengeRate: maxChallengeRatePerKey, pairRate: maxPairRatePerPair, lookupRate: maxLookupRatePerKey, clientWriteRate: maxClientWriteRatePerKey})

handleMetrics = \authorization respond -> do
  t <- now
  msgs <- *messages
  ses <- *sessions
  pres <- *presence
  fwds <- *forwards
  aps <- *activePolls
  sa <- *startedAt
  dp <- *drainPhase
  let metrics = "skrepka_messages_total " ++ show (count msgs) ++ "\nskrepka_sessions_total " ++ show (count ses) ++ "\nskrepka_presence_total " ++ show (count pres) ++ "\nskrepka_forwards_total " ++ show (count fwds) ++ "\nskrepka_active_polls " ++ show (count aps) ++ "\nskrepka_uptime_seconds " ++ show ((t - sa) / 1000) ++ "\nskrepka_draining " ++ (if dp > 0 then "1" else "0") ++ "\n"
  yield (respond {metrics: metrics, ok: True {}})

-- ============================================
-- Dispatch
-- ============================================

serve = \req -> case req of
  ReqChallenge {pubkey, clientIp, respond} -> handleChallenge pubkey clientIp respond
  VerifyAuth {pubkey, challenge, signature, revokeOthers, clientIp, respond} -> handleVerifyAuth pubkey challenge signature revokeOthers clientIp respond
  RevokeSession {targetToken, authorization, clientIp, respond} -> handleRevoke targetToken authorization clientIp respond
  Logout {authorization, clientIp, respond} -> handleLogout authorization clientIp respond
  Poll {cursor, generation, watchKeys, authorization, clientIp, respond} -> handlePoll cursor generation watchKeys authorization clientIp respond
  SendMessage {to, encryptedBlob, timestamp, messageId, expiresInMs, priority, authorization, clientIp, respond} -> handleSendMessage to encryptedBlob timestamp messageId expiresInMs priority authorization clientIp respond
  MessageStatus {to, messageId, authorization, clientIp, respond} -> handleMessageStatus to messageId authorization clientIp respond
  AckMessages {messageIds, authorization, clientIp, respond} -> handleAckMessages messageIds authorization clientIp respond
  SendBatch {messages, authorization, clientIp, respond} -> handleSendBatch messages authorization clientIp respond
  ListMessages {offset, authorization, clientIp, respond} -> handleListMessages offset authorization clientIp respond
  DeleteMessages {messageIds, authorization, clientIp, respond} -> handleDeleteMessages messageIds authorization clientIp respond
  CancelMessage {messageId, to, authorization, clientIp, respond} -> handleCancelMessage messageId to authorization clientIp respond
  CancelBatch {cancels, authorization, clientIp, respond} -> handleCancelBatch cancels authorization clientIp respond
  LookupPresence {pubkey, authorization, clientIp, respond} -> handleLookupPresence pubkey authorization clientIp respond
  BatchLookupPresence {pubkeys, authorization, clientIp, respond} -> handleBatchLookupPresence pubkeys authorization clientIp respond
  RecvGossip {events, hopsRemaining, fromServer, requestTimestamp, correlationId, protocolVersion, authorization, respond} -> handleRecvGossip events hopsRemaining fromServer requestTimestamp correlationId authorization respond
  ForwardMessage {toKey, encryptedBlob, timestamp, originServer, messageId, fromServer, requestTimestamp, correlationId, expiresAt, priority, protocolVersion, authorization, respond} -> handleForwardMessage toKey encryptedBlob timestamp originServer messageId fromServer requestTimestamp correlationId expiresAt priority authorization respond
  FederationAck {messageIds, originServer, fromServer, requestTimestamp, correlationId, protocolVersion, authorization, respond} -> handleFederationAck messageIds originServer fromServer requestTimestamp correlationId authorization respond
  FederationCancel {messageId, toKey, fromServer, requestTimestamp, correlationId, protocolVersion, authorization, respond} -> handleFederationCancel messageId toKey fromServer requestTimestamp correlationId authorization respond
  FederationBatchCancel {cancels, fromServer, requestTimestamp, correlationId, protocolVersion, authorization, respond} -> handleFederationBatchCancel cancels fromServer requestTimestamp correlationId authorization respond
  FederationBatchForward {forwards, fromServer, requestTimestamp, correlationId, protocolVersion, authorization, respond} -> handleFederationBatchForward forwards fromServer requestTimestamp correlationId authorization respond
  FederationDeliveryReceipt {messageIds, toKeys, fromServer, requestTimestamp, correlationId, protocolVersion, authorization, respond} -> handleFederationDeliveryReceipt messageIds toKeys fromServer requestTimestamp correlationId authorization respond
  VerifyToken {token, scope, clientIp, respond} -> handleVerifyToken token scope clientIp respond
  FederationPubkey {respond} -> handleFederationPubkey respond
  Prune {authorization, respond} -> handlePrune authorization respond
  Drain {phase, authorization, respond} -> handleDrain phase authorization respond
  Shutdown {authorization, respond} -> handleShutdown authorization respond
  Undrain {authorization, respond} -> handleUndrain authorization respond
  BlockPeer {server, authorization, respond} -> handleBlockPeer server authorization respond
  UnblockPeer {server, authorization, respond} -> handleUnblockPeer server authorization respond
  ListBlocked {authorization, respond} -> handleListBlocked authorization respond
  PingPeer {server, authorization, respond} -> handlePingPeer server authorization respond
  AdminListSessions {pubkey, authorization, respond} -> handleAdminListSessions pubkey authorization respond
  AdminRevokeSessions {pubkey, authorization, respond} -> handleAdminRevokeSessions pubkey authorization respond
  AdminListAllSessions {limit, authorization, respond} -> handleAdminListAllSessions limit authorization respond
  AdminPurgeMessages {pubkey, authorization, respond} -> handleAdminPurgeMessages pubkey authorization respond
  AdminRevokeIp {ip, authorization, respond} -> handleAdminRevokeIp ip authorization respond
  GetRateLimits {authorization, respond} -> handleGetRateLimits authorization respond
  SetRateLimits {globalRequest, ipRate, sendRate, federationRate, authGlobal, recvRate, challengeRate, pairRate, lookupRate, clientWriteRate, authorization, respond} -> handleSetRateLimits globalRequest ipRate sendRate federationRate authGlobal recvRate challengeRate pairRate lookupRate clientWriteRate authorization respond
  FlushNonces {authorization, respond} -> handleFlushNonces authorization respond
  AllowPeer {server, authorization, respond} -> handleAllowPeer server authorization respond
  UnallowPeer {server, authorization, respond} -> handleUnallowPeer server authorization respond
  ListAllowed {authorization, respond} -> handleListAllowed authorization respond
  Reconcile {authorization, respond} -> handleReconcile authorization respond
  RotateSecret {newSecret, authorization, respond} -> handleRotateSecret newSecret authorization respond
  GetConfig {authorization, respond} -> handleGetConfig authorization respond
  Health {authorization, respond} -> handleHealth authorization respond
  Stats {authorization, respond} -> handleStats authorization respond
  StatsPeers {authorization, respond} -> handleStatsPeers authorization respond
  StatsKey {pubkey, authorization, respond} -> handleStatsKey pubkey authorization respond
  TopRecipients {limit, authorization, respond} -> handleTopRecipients limit authorization respond
  StatsForwards {authorization, respond} -> handleStatsForwards authorization respond
  StatsRates {authorization, respond} -> handleStatsRates authorization respond
  Metrics {authorization, respond} -> handleMetrics authorization respond
  Ready {respond} -> handleReady respond

-- ============================================
-- Background loops
-- ============================================

backgroundPrune = do
  sleep backgroundPruneInterval
  dp <- *drainPhase
  if dp >= 2 then do
    sleep backgroundPruneInterval
    backgroundPrune
  else do
    t <- now
    atomic do
      pc <- *pruneCount
      set *pruneCount = pc + 1
    pruneAndRetry t
    backgroundPrune

pollHeartbeat = do
  sleep pollTimeoutMs
  t <- now
  atomic do
    set *pollWakeup = t
    set *lastHeartbeatAt = t
    hc <- *heartbeatCount
    set *heartbeatCount = hc + 1
  pollHeartbeat

-- ============================================
-- Entry Point
-- ============================================

main = do
  t <- now
  genJitter <- randomInt 1000000
  atomic do
    set *startedAt = t
    set *serverGeneration = t * 1000 + genJitter
  logInfo ("Skrepka relay server starting on port " ++ show listenPort ++ "...")
  logInfo ("  federation: " ++ if federationEnabled then "enabled" else "disabled")
  fork backgroundPrune
  fork pollHeartbeat
  listen listenPort serve
