-- Drain phase: 0=normal (accepting), 1=soft drain (block new auth, serve existing sessions),
-- 2=full drain (reject all client requests). Allows staged shutdown:
-- phase 1 lets active clients finish while preventing new connections.
*drainPhase : Int

-- Drain generation: monotonically increasing counter, bumped on each drain initiation.
-- Flush forks check this before writing to prevent stale drain operations (started before
-- an undrain+redrain cycle) from interfering with the current drain's state.
*drainGeneration : Int

-- Shutdown requested: when True, background loops exit after drain completes.
-- Set by /maintenance/shutdown; cannot be undone (requires process restart).
*shutdownRequested : Bool

*pruneRunning : Timestamp

*pruneGeneration : Int

-- Tracks the duration of the last completed prune cycle (ms) for dynamic stuck detection.
-- Updated after each successful prune. Initial 0 = use fixed 5x fallback.
*lastPruneDuration : Int<Ms>

*ipRates : [IpRateEntry]

*lookupRates : [LookupRateEntry]

-- Separate rate limiter for client write operations (ack, delete) — prevents ack bursts from starving lookups
*clientWriteRates : [LookupRateEntry]

*recvRates : [RecvRateEntry]

