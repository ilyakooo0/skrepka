-- Skrepka Relay Server (maximally simplified)
-- Single-server implementation of the Skrepka protocol (v0.1).
-- Every collection is a flat list; rate limiters are plain count-per-window.
-- Token comparison is plain `==` (timing-attack vulnerable), retry backoff is linear,
-- and many helpers are inlined. Performance suffers; clarity is the only goal.

-- ============================================
-- Configuration
-- ============================================
-- Top-level constants: bind address, federation identity, capacity ceilings,
-- per-key/window rate limits, expiry/backoff/TTL durations, and protocol version.
-- Values written here are defaults; every scalar (Int/Float/Text/Bool/Maybe ...)
-- top-level constant can be overridden at startup via `--name=value` on the
-- command line (see Knot's `knot_override_lookup`). Run with `--help` for the
-- full list.

-- This server's canonical federation identity. Used as the `server` field in
-- presence/gossip events, in signed federation challenges, and for self-checks
-- (`isLocalServer`). Not a bind address — the listener accepts connections on
-- every interface regardless of this value. May also differ from the URL
-- clients use to reach the server (e.g. behind a reverse proxy or alternate
-- DNS name); peers must resolve this name to reach us for federation.
--
-- Must be unique per deployment. Every operator participating in federation
-- has to recompile with their own public hostname here — peers reject events
-- whose origin fails `isBadServerName` (which blocks the default "localhost"
-- and other private/reserved names), so two default-built servers cannot
-- federate with each other. The default is only suitable for a single-node,
-- non-federated deployment.
serverHost : Text
serverHost = "localhost"
-- Network interface the HTTP listener binds to. "0.0.0.0" accepts connections
-- on every IPv4 interface (the typical default behind a reverse proxy);
-- "127.0.0.1" restricts the listener to localhost-only; "::" / "::1" do the
-- IPv6 equivalents. Override with `--bindHost=...` at startup. Unrelated to
-- `serverHost` above — this is the kernel-level bind address; that is the
-- federation identity peers see.
bindHost : Text
bindHost = "0.0.0.0"
-- TCP port for incoming HTTP connections.
listenPort : Int
listenPort = 8080
-- URL scheme used when contacting peer federation servers.
federationScheme : Text
federationScheme = "https://"
-- The Ed25519 federation keypair lives in `*federationPrivateKeyHex` /
-- `*federationPublicKeyHex` refs and is generated on first startup; see `main`.

-- Storage retention for messages and dedup-id records. Mailbox rows live this
-- long after `receivedAt`; expired rows are pruned by `pruneExpired` (30 days).
messageMaxAge : Int<Ms>
messageMaxAge = 2592000000
-- Length (chars) of a hex-encoded Ed25519 pubkey (32 bytes → 64 hex).
pubkeyLen : Int
pubkeyLen = 64
-- Max length of a hex-encoded message body / opaque blob (40 MiB hex ≈ 20 MiB bytes).
maxBlobLen : Int
maxBlobLen = 41943040
-- Length of a hex-encoded Ed25519 signature (64 bytes → 128 hex).
signatureLen : Int
signatureLen = 128
-- Cap on the number of message IDs accepted in a single ack/lookup request.
maxMessageIds : Int
maxMessageIds = 100
-- Cap on items in a batched send request.
maxBatchSize : Int
maxBatchSize = 100
-- Cap on gossip events accepted or emitted in a single federation exchange.
maxGossipEvents : Int
maxGossipEvents = 100
-- Cap on events returned by one long-poll response.
maxPollEvents : Int
maxPollEvents = 50
-- Allowance for clock drift when validating client timestamps (5 s).
clockSkewTolerance : Int<Ms>
clockSkewTolerance = 5000
-- Per-peer ceiling on outstanding forward attempts.
maxForwardsPerServer : Int
maxForwardsPerServer = 2000
-- Max accepted length of a server hostname.
maxServerNameLen : Int
maxServerNameLen = 128
-- Max accepted length of a hex-encoded message ID.
maxMessageIdLen : Int
maxMessageIdLen = 128
-- Ceiling on outstanding auth challenges held in memory.
maxChallenges : Int
maxChallenges = 10000
-- Ceiling on concurrent active sessions.
maxSessions : Int
maxSessions = 10000
-- Ceiling on remembered delivered message IDs.
maxDeliveredIds : Int
maxDeliveredIds = 10000
-- Per-pubkey ceiling on outstanding challenges (prevents one key from exhausting the pool).
maxChallengesPerKey : Int
maxChallengesPerKey = 5
-- Per-pubkey ceiling on concurrent sessions.
maxSessionsPerKey : Int
maxSessionsPerKey = 10
-- Validity window for an auth challenge before it must be re-issued (1 min).
challengeExpiry : Int<Ms>
challengeExpiry = 60000
-- Challenge requests permitted per key inside its rate window.
maxChallengeRatePerKey : Int
maxChallengeRatePerKey = 5
-- Window over which the per-key challenge rate is measured (1 s).
challengeRateWindowMs : Int<Ms>
challengeRateWindowMs = 1000
-- Send-message requests permitted per key per window.
maxSendRatePerKey : Int
maxSendRatePerKey = 20
-- Window for the per-key send rate limit (1 s).
sendRateWindowMs : Int<Ms>
sendRateWindowMs = 1000
-- Receive/poll requests permitted per key per window.
maxRecvRatePerKey : Int
maxRecvRatePerKey = 10
-- Window for the per-key receive rate limit (1 s).
recvRateWindowMs : Int<Ms>
recvRateWindowMs = 1000
-- Messages permitted per (sender, recipient) pair within the pair window.
maxPairRatePerPair : Int
maxPairRatePerPair = 30
-- Window for the per-pair rate limit (1 min).
pairRateWindowMs : Int<Ms>
pairRateWindowMs = 60000
-- Federation requests permitted from a single peer server per window.
maxFederationRatePerServer : Int
maxFederationRatePerServer = 50
-- Window for the per-peer federation rate limit (1 s).
federationRateWindowMs : Int<Ms>
federationRateWindowMs = 1000
-- Presence/key lookups permitted per key per window.
maxLookupRatePerKey : Int
maxLookupRatePerKey = 5
-- Window for the per-key lookup rate limit (1 s).
lookupRateWindowMs : Int<Ms>
lookupRateWindowMs = 1000
-- Other client write requests permitted per key per window.
maxClientWriteRatePerKey : Int
maxClientWriteRatePerKey = 10
-- Window for the per-key client-write rate limit (1 s).
clientWriteRateWindowMs : Int<Ms>
clientWriteRateWindowMs = 1000
-- Requests permitted per source IP per window (covers unauthenticated traffic).
maxIpRatePerIp : Int
maxIpRatePerIp = 10
-- Window for the per-IP rate limit (1 s).
ipRateWindowMs : Int<Ms>
ipRateWindowMs = 1000
-- Global ceiling on total request rate across all clients.
maxGlobalRequestRate : Int
maxGlobalRequestRate = 1000
-- Window for the global request rate limit (1 s).
globalRateWindowMs : Int<Ms>
globalRateWindowMs = 1000
-- Global ceiling on auth-endpoint requests (challenge + verify combined).
maxAuthGlobalRate : Int
maxAuthGlobalRate = 200
-- Window for the global auth rate limit (1 s).
authGlobalRateWindowMs : Int<Ms>
authGlobalRateWindowMs = 1000

-- How long a session token remains valid after issue (1 hour).
sessionExpiry : Int<Ms>
sessionExpiry = 3600000
-- How long a received "online" presence gossip is considered fresh (90 min).
-- Receivers anchor the TTL to their own wall clock at receive time, so this
-- value isn't carried on the wire.
onlineGossipTtl : Int<Ms>
onlineGossipTtl = 5400000
-- Times to retry a federation forward before giving up.
maxForwardRetries : Int
maxForwardRetries = 10

-- Base delay for federation retry backoff (linear, not exponential — 30 s).
retryBackoffBase : Int<Ms>
retryBackoffBase = 30000
-- Cap on federation retry backoff (8 min).
retryBackoffMax : Int<Ms>
retryBackoffMax = 480000

-- Cadence of the background prune/cleanup task (30 s).
backgroundPruneInterval : Int<Ms>
backgroundPruneInterval = 30000
-- Long-poll hold timeout before returning empty to the client (25 s).
pollTimeoutMs : Int<Ms>
pollTimeoutMs = 25000
-- Concurrent active long-polls permitted per pubkey.
maxPollsPerKey : Int
maxPollsPerKey = 3
-- Cadence at which this server refreshes its own presence to peers (5 min).
presenceRefreshInterval : Int<Ms>
presenceRefreshInterval = 300000

-- Window during which a delivered-but-unacked message is retained for re-delivery (2 min).
ackGracePeriod : Int<Ms>
ackGracePeriod = 120000

-- Human-readable build identifier returned by the /health endpoint.
serverBuildVersion : Text
serverBuildVersion = "2026-04-27-simple"

-- Master switch for federation; when False the server runs in single-node mode.
federationEnabled : Bool
federationEnabled = True {}
federationUrl : Text -> Text
federationUrl = \server -> federationScheme ++ server
-- When True, reject requests that arrive without a client-IP header (for IP-based rate limits).
requireClientIp : Bool
requireClientIp = True {}

-- Drop the Ms unit and convert milliseconds to seconds.
msToS : Int<Ms> -> Int<S>
msToS = \ms -> stripUnit ms / 1000

-- Drop the S unit and convert seconds to milliseconds.
sToMs : Int<S> -> Int<Ms>
sToMs = \s -> stripUnit s * 1000

-- ============================================
-- Types
-- ============================================
-- Wire/state shapes plus refinement aliases for hex/server-name validation.
-- Hex types are bounded length + lowercase-hex; server names are lowercased
-- and stripped of trailing dots, with a deny-list filter (`isBadServerName`)
-- applied where SSRF is a concern.

-- One event in a /poll response: the opaque cipher blob addressed to the
-- polling pubkey. The server cannot read the blob; clients derive any
-- per-message id locally as `messageIdOf encryptedBlob`.
type PollEvent = {encryptedBlob: BlobHex}

-- Kind of presence event flowing through federation gossip. `GossipUnknown` is
-- the parser's fallback for forward-compatibility with future event types.
data GossipEventType = GossipOnline {} | GossipOffline {} | GossipUnknown {}

impl ToJSON GossipEventType where
  toJson et = toJson (case et of
    GossipOnline {} -> "online"
    GossipOffline {} -> "offline"
    GossipUnknown {} -> "unknown")

impl FromJSON GossipEventType where
  parseJson t = (\s -> if s == "online" then GossipOnline {} else if s == "offline" then GossipOffline {} else GossipUnknown {}) (parseJson t : Text)

-- One presence change exchanged between federated servers.
type GossipEvent = {eventType: GossipEventType, pubkey: PubkeyHex}

-- /messages signals failure via the per-entry `error` field on each result:
-- empty = success (delivered, federated, queued, or silent duplicate),
-- non-empty = "rate_limited" | "self_send". A non-empty top-level `error`
-- ("draining" | "rate_limited" | "unauthorized") means the request was
-- rejected before any entry was processed and `results` is empty.
-- The sender's UI treats every success the same and learns "they got it"
-- only via the recipient's E2E ack.

-- True when `s` is non-empty lowercase hex of even length, with `maxLen` ceiling.
isValidBoundedHex : Int -> Text -> Bool
isValidBoundedHex = \maxLen s -> not tooLong s maxLen && isValidHex s
-- True when `s` is lowercase hex of exactly `exactLen` characters (even by definition).
isValidExactHex : Int -> Text -> Bool
isValidExactHex = \exactLen s -> count (chars s) == exactLen && isValidHex s
-- Hex-encoded Ed25519 public key (32 bytes → 64 chars exact).
type PubkeyHex = Text where isValidExactHex pubkeyLen
-- Hex-encoded ciphertext or opaque blob; capped at `maxBlobLen` (~20 MiB).
type BlobHex = Text where isValidBoundedHex maxBlobLen
-- Hex-encoded Ed25519 signature (64 bytes → 128 chars exact).
type SignatureHex = Text where isValidExactHex signatureLen
isValidMessageId : Text -> Bool
isValidMessageId = isValidBoundedHex maxMessageIdLen
-- Hex-encoded message id, length ≤ `maxMessageIdLen`.
type MessageIdHex = Text where isValidMessageId
-- Normalized hostname (lowercased, no trailing dot, length-bounded).
isAnyServerName : Text -> Bool
isAnyServerName = \s -> not tooLong s maxServerNameLen && s == normalizeServerName s
-- A normalized hostname that also passes the SSRF deny-list (`isBadServerName`).
isValidServerName : Text -> Bool
isValidServerName = \s -> isAnyServerName s && not isBadServerName s
-- Peer hostname suitable for outbound federation calls.
type ServerName = Text where isValidServerName
-- Normalized hostname with no SSRF filter; used when the value comes from
-- presence rows that the client only ever sees masked to "remote".
type AnyServerName = Text where isAnyServerName

-- Wall-clock time in milliseconds since epoch.
type Timestamp = Int<Ms>

-- Outstanding nonce issued by /auth/challenge; consumed by /auth/verify.
type Challenge = {pubkey: PubkeyHex, challenge: Text, expiresAt: Timestamp, ip: Text}
-- An issued bearer token bound to (pubkey, ip, expiry).
type Session = {
  token: Text,
  pubkey: PubkeyHex,
  expiresAt: Timestamp,
  ip: Text,
  createdAt: Timestamp
}
-- Mailbox row: a stored message awaiting recipient pickup or federation forward.
-- Identity is `messageIdOf encryptedBlob` (BLAKE3 of the ciphertext); we don't
-- persist it because it's deterministically derivable. Storage TTL is fixed
-- at `messageMaxAge`, so expiry is derived from `receivedAt`. Any send time
-- the sender wants to convey lives inside `encryptedBlob` (the server cannot
-- read it).
type Message = {toKey: PubkeyHex, encryptedBlob: BlobHex, receivedAt: Timestamp}
-- Last-known location of a pubkey, either local (`server == serverHostN`) or
-- learned from a peer via gossip. Multiple entries per pubkey are allowed.
type PresenceEntry = {pubkey: PubkeyHex, server: AnyServerName, expiresAt: Timestamp}
-- A message queued for cross-server delivery to `toServer`. `retries` is
-- incremented by `retryPendingForwards` until `maxForwardRetries` is hit.
-- Identity is derived from `encryptedBlob` (see `Message`).
type ForwardEntry = {
  toServer: ServerName,
  createdAt: Timestamp,
  toKey: PubkeyHex,
  encryptedBlob: BlobHex,
  retries: Int
}
-- Replay-protection record: a message id we already delivered locally.
type DeliveredEntry = {messageId: MessageIdHex, toKey: PubkeyHex, deliveredAt: Timestamp}
-- Running failure counter for a peer; keyed by `server`. Drives `retryBackoff`.
type ForwardFailure = {server: Text, failedAt: Timestamp, failures: Int, firstFailedAt: Timestamp}
-- One fixed-window rate counter. `key` identifies the subject (pubkey, ip,
-- server, or composite "sender|recipient" string).
type RateEntry = {key: Text, windowStart: Timestamp, count: Int}
-- A live long-poll slot held by a pubkey; used to cap concurrency per key.
type ActivePoll = {pubkey: PubkeyHex, startedAt: Timestamp}

-- ============================================
-- Persisted State (all flat lists, no sharding)
-- ============================================
-- Mutable refs (`*x`) holding the entire server state in memory. Every list
-- scan is O(n); scaling is the first thing the production version replaces.
-- Grouped here: auth (challenges/sessions), mailbox (messages/forwards/acks),
-- presence, rate-limit windows, drain phase, and bookkeeping counters.

*challenges : [Challenge]
*sessions : [Session]
*messages : [Message]
*presence : [PresenceEntry]
*forwards : [ForwardEntry]
*deliveredIds : [DeliveredEntry]
*forwardFailures : [ForwardFailure]
*activePolls : [ActivePoll]

*sendRates : [RateEntry]
*recvRates : [RateEntry]
*pairRates : [RateEntry]
*challengeRates : [RateEntry]
*lookupRates : [RateEntry]
*clientWriteRates : [RateEntry]
*federationRates : [RateEntry]
*ipRates : [RateEntry]

*globalRateCount : Int
*globalRateWindowStart : Timestamp
*authGlobalRateCount : Int
*authGlobalRateWindowStart : Timestamp

*seqCounter : Timestamp
*pollWakeup : Timestamp
*lastPrunedAt : Timestamp
*lastHeartbeatAt : Timestamp
*lastPresenceRefresh : Timestamp
*startedAt : Timestamp
*serverGeneration : Int

*drainPhase : Int
*drainCompletedAt : Timestamp

*runtimeMaintenanceSecret : Text

*federationPrivateKeyHex : Text
*federationPublicKeyHex : Text

*blockedPeers : [Text]
*allowedPeers : [Text]

*pruneCount : Int
*heartbeatCount : Int

-- ============================================
-- Routes (response shapes preserved; removed metric fields are zero-filled)
-- ============================================
-- Public HTTP surface, grouped by audience:
--   AuthApi          -- challenge/verify/revoke/logout (client identity)
--   ClientApi        -- /poll, send/batch/list/ack/delete, presence lookup
--   FederationApi    -- inter-server gossip, forward, ack, delivery receipts
--   FederationPubkey -- exposes this server's federation Ed25519 public key
--   MaintenanceApi   -- operator endpoints (drain, prune, peer allow/block, admin)
--   HealthApi/StatsApi/MetricsApi/ReadyApi -- observability
-- Response field shapes are kept stable for backwards compatibility even when
-- the underlying value is no longer computed (zero-filled).

route AuthApi where
  POST {pubkey: PubkeyHex} /auth/challenge headers {clientIp: Text} -> {challenge: Text, ok: Bool, expiresAt: Timestamp, retryAfterMs: Int, error: Text} = ReqChallenge
  POST {pubkey: PubkeyHex, challenge: Text, signature: SignatureHex, revokeOthers: Bool} /auth/verify headers {clientIp: Text} -> {token: Text, expiresAt: Timestamp, error: Text} = VerifyAuth
  POST {targetToken: Text} /auth/revoke headers {authorization: Text, clientIp: Text} -> {ok: Bool, authorized: Bool} = RevokeSession
  POST /auth/logout headers {authorization: Text, clientIp: Text} -> {ok: Bool, authorized: Bool} = Logout

route ClientApi where
  POST {cursor: Timestamp, generation: Int} /poll headers {authorization: Text, clientIp: Text} -> {events: [PollEvent], cursor: Timestamp, authorized: Bool, rateLimited: Bool, draining: Bool, generation: Int, heartbeat: Bool, retryAfterMs: Int, cursorReset: Bool, hasMore: Bool, cursorStale: Bool, loadPct: Int} = Poll
  POST {messages: [{to: PubkeyHex, encryptedBlob: BlobHex}]} /messages headers {authorization: Text, clientIp: Text} -> {results: [{messageId: MessageIdHex, error: Text}], error: Text, retryAfterMs: Int} = SendMessages
  POST {to: PubkeyHex, messageId: MessageIdHex} /messages/status headers {authorization: Text, clientIp: Text} -> {status: Text, authorized: Bool} = MessageStatus
  POST {messageIds: [MessageIdHex]} /messages/ack headers {authorization: Text, clientIp: Text} -> {ok: Bool, authorized: Bool, ackedCount: Int, error: Text} = AckMessages
  POST {offset: Int} /messages/list headers {authorization: Text, clientIp: Text} -> {messages: [{messageId: MessageIdHex, receivedAt: Timestamp}], authorized: Bool, count: Int, error: Text} = ListMessages
  POST {messageIds: [MessageIdHex]} /messages/delete headers {authorization: Text, clientIp: Text} -> {ok: Bool, authorized: Bool, deletedCount: Int, error: Text} = DeleteMessages
  GET /lookup/{pubkey: PubkeyHex} headers {authorization: Text, clientIp: Text} -> {server: AnyServerName, authorized: Bool, error: Text} = LookupPresence
  POST {pubkeys: [PubkeyHex]} /lookup/batch headers {authorization: Text, clientIp: Text} -> {results: [{pubkey: PubkeyHex, server: AnyServerName}], authorized: Bool, error: Text} = BatchLookupPresence

route FederationApi where
  POST {events: [GossipEvent], fromServer: ServerName, requestTimestamp: Timestamp, correlationId: Text} /federation/gossip headers {authorization: Text} -> {ok: Bool, error: Text, retryAfterMs: Int} = RecvGossip
  POST {toKey: PubkeyHex, encryptedBlob: BlobHex, messageId: MessageIdHex, fromServer: ServerName, requestTimestamp: Timestamp, correlationId: Text} /federation/forward headers {authorization: Text} -> {ok: Bool, error: Text, retryAfterMs: Int} = ForwardMessage
  POST {forwards: [{toKey: PubkeyHex, encryptedBlob: BlobHex, messageId: MessageIdHex}], fromServer: ServerName, requestTimestamp: Timestamp, correlationId: Text} /federation/forward-batch headers {authorization: Text} -> {ok: Bool, error: Text, results: [{messageId: MessageIdHex, ok: Bool}], retryAfterMs: Int} = FederationBatchForward

route FederationPubkeyApi where
  GET /federation/pubkey -> {pubkey: Text, ok: Bool} = FederationPubkey

route MaintenanceApi where
  POST /maintenance/prune headers {authorization: Text} -> {ok: Bool} = Prune
  POST {phase: Int} /maintenance/drain headers {authorization: Text} -> {ok: Bool, drained: Int, phase: Int} = Drain
  POST /maintenance/undrain headers {authorization: Text} -> {ok: Bool} = Undrain
  POST /maintenance/shutdown headers {authorization: Text} -> {ok: Bool, drained: Int} = Shutdown
  POST {server: ServerName} /maintenance/block headers {authorization: Text} -> {ok: Bool, blocked: Int} = BlockPeer
  POST {server: ServerName} /maintenance/unblock headers {authorization: Text} -> {ok: Bool, unblocked: Bool} = UnblockPeer
  GET /maintenance/blocked headers {authorization: Text} -> {peers: [Text], ok: Bool} = ListBlocked
  POST {server: ServerName} /maintenance/ping headers {authorization: Text} -> {ok: Bool, latencyMs: Int, error: Text} = PingPeer
  GET /maintenance/sessions/{pubkey: PubkeyHex} headers {authorization: Text} -> {sessions: [{token: Text, expiresAt: Timestamp, ip: Text, createdAt: Timestamp}], count: Int, ok: Bool} = AdminListSessions
  POST {pubkey: PubkeyHex} /maintenance/sessions/revoke-all headers {authorization: Text} -> {ok: Bool, revokedCount: Int} = AdminRevokeSessions
  POST {pubkey: PubkeyHex} /maintenance/messages/purge headers {authorization: Text} -> {ok: Bool, purgedCount: Int} = AdminPurgeMessages
  POST {ip: Text} /maintenance/sessions/revoke-ip headers {authorization: Text} -> {ok: Bool, revokedCount: Int, affectedKeys: Int} = AdminRevokeIp
  POST {limit: Int} /maintenance/sessions/list headers {authorization: Text} -> {sessions: [{pubkey: PubkeyHex, count: Int, ips: [Text], latestExpiry: Timestamp}], ok: Bool, total: Int} = AdminListAllSessions
  GET /maintenance/rate-limits headers {authorization: Text} -> {ok: Bool, globalRequest: Int, ipRate: Int, sendRate: Int, federationRate: Int, authGlobal: Int, recvRate: Int, challengeRate: Int, pairRate: Int, lookupRate: Int, clientWriteRate: Int} = GetRateLimits
  POST {globalRequest: Int, ipRate: Int, sendRate: Int, federationRate: Int, authGlobal: Int, recvRate: Int, challengeRate: Int, pairRate: Int, lookupRate: Int, clientWriteRate: Int} /maintenance/rate-limits headers {authorization: Text} -> {ok: Bool} = SetRateLimits
  POST /maintenance/nonces/flush headers {authorization: Text} -> {ok: Bool, flushedCount: Int} = FlushNonces
  POST {server: ServerName} /maintenance/allow headers {authorization: Text} -> {ok: Bool, allowed: Int} = AllowPeer
  POST {server: ServerName} /maintenance/unallow headers {authorization: Text} -> {ok: Bool, removed: Bool} = UnallowPeer
  GET /maintenance/allowed headers {authorization: Text} -> {peers: [Text], ok: Bool} = ListAllowed
  POST /maintenance/reconcile headers {authorization: Text} -> {ok: Bool, messageDrift: Int, presenceDrift: Int, sessionDrift: Int} = Reconcile
  POST {newSecret: Text} /maintenance/rotate-secret headers {authorization: Text} -> {ok: Bool, error: Text} = RotateSecret
  GET /maintenance/config headers {authorization: Text} -> {ok: Bool, pollTimeoutMs: Int, ackGracePeriod: Int} = GetConfig

route HealthApi where
  GET /health headers {authorization: Text} -> {ok: Bool, version: Text, pruneHealthy: Bool, heartbeatHealthy: Bool, capacityHealthy: Bool, capacityWarning: Bool, federationHealthy: Bool, watchdogHealthy: Bool, nonceHealthy: Bool, forwardQueueHealthy: Bool, requestPressureHealthy: Bool, draining: Bool, degradedPeers: Int} = Health

-- Per-peer health snapshot for /stats/peers. Latency/gossip-rate fields are
-- zero-filled in this simplified server.
type PeerStatus = {
  server: Text,
  failures: Int,
  lastFailedAt: Timestamp,
  firstFailedAt: Timestamp,
  backoffMs: Int,
  retriable: Bool,
  pendingForwards: Int,
  avgLatencyMs: Int,
  maxLatencyMs: Int,
  latencySamples: Int,
  gossipEventsPerMin: Int
}
-- Single presence row exposed via /stats/key (server + expiry only).
type KeyPresenceEntry = {server: Text, expiresAt: Timestamp}
-- Mailbox depth ranking entry for /stats/top-recipients.
type RecipientCount = {pubkey: PubkeyHex, count: Int}

route StatsApi where
  GET /stats headers {authorization: Text} -> {ok: Bool, version: Text, capacity: {sessions: Int, sessionsMax: Int, sessionsPct: Int, messages: Int, totalMessageCount: Int, presence: Int, forwards: Int, challenges: Int, challengesMax: Int, deliveredIds: Int, deliveredIdsMax: Int, forwardNonces: Int, forwardNoncesMax: Int, nonceEvictions: Int, activePolls: Int, recipientCounts: Int, messageBucketMax: Int, messageBucketMin: Int}, federation: {enabled: Bool, inFlight: Int, hungSlots: Int, avgLatencyMs: Int, maxLatencyMs: Int, callCount: Int, slowVerifies: Int, verifyFailures: Int, forwardFailures: Int, oldestForwardAge: Int, oldestAckAge: Int, recentGossip: Int, blockedPeers: Int, drainCompletedAt: Timestamp, forwardServers: Int, maxForwardQueueDepth: Int, topFailingPeers: [{server: Text, failures: Int}], gossipSuccess: Int, gossipFail: Int, latencyBuckets: {lt100: Int, lt500: Int, lt2000: Int, gte2000: Int}}, rates: {send: Int, challenge: Int, federation: Int, federationPair: Int, global: Int, ip: Int, lookup: Int, recv: Int, pair: Int, gossipEvent: Int, verifyIp: Int, uniqueKeyIp: Int, pendingAckCleanups: Int, rejectedGlobal: Int, rejectedIp: Int, rejectedAuth: Int, rejectedPerKey: Int, rejectedFederation: Int}, timing: {pruneCount: Int, pruneRunning: Timestamp, heartbeatCount: Int, uptime: Int, lastPruneAt: Timestamp, lastHeartbeatAt: Timestamp, draining: Bool, drainPhase: Int, totalEntries: Int, activeRequests: Int, peakActiveRequests: Int, pollAvgMs: Int, pollMaxMs: Int, pollCount: Int, pollLatencyBuckets: {lt50: Int, lt200: Int, lt1000: Int, gte1000: Int}, sendAvgMs: Int, sendMaxMs: Int, sendCount: Int, sendLatencyBuckets: {lt50: Int, lt200: Int, lt1000: Int, gte1000: Int}, authAvgMs: Int, authMaxMs: Int, authCount: Int}} = Stats
  GET /stats/peers headers {authorization: Text} -> {peers: [PeerStatus], ok: Bool} = StatsPeers
  GET /stats/key/{pubkey: PubkeyHex} headers {authorization: Text} -> {messages: Int, presence: [KeyPresenceEntry], sessions: Int, forwards: Int, forwardDetails: [{server: Text, retries: Int, createdAt: Timestamp}], activePolls: Int, ok: Bool} = StatsKey
  POST {limit: Int} /stats/top-recipients headers {authorization: Text} -> {recipients: [RecipientCount], ok: Bool, total: Int} = TopRecipients
  GET /stats/forwards headers {authorization: Text} -> {servers: [{server: Text, count: Int, oldestAge: Int, totalRetries: Int}], ok: Bool, total: Int} = StatsForwards
  GET /stats/rates headers {authorization: Text} -> {ok: Bool, scalePct: Int, globalRequest: Int, ipRate: Int, sendRate: Int, federationRate: Int, authGlobal: Int, recvRate: Int, challengeRate: Int, pairRate: Int, lookupRate: Int, clientWriteRate: Int} = StatsRates

route MetricsApi where
  GET /metrics headers {authorization: Text} -> {metrics: Text, ok: Bool} = Metrics

route ReadyApi where
  GET /ready -> {ready: Bool} = Ready

route Api = AuthApi | ClientApi | FederationApi | FederationPubkeyApi | MaintenanceApi | HealthApi | StatsApi | MetricsApi | ReadyApi

-- ============================================
-- Generic helpers
-- ============================================
-- List/predicate combinators (filter/any/none/findFirst/...), token generation,
-- and small text/server-name utilities used throughout the rest of the file.
-- Everything is intentionally O(n) over flat lists; performance is sacrificed
-- for clarity per the file header.

filter : a b -> (b -> Bool) -> a b
filter = \xs pred -> do
  x <- xs
  where pred x
  yield x
removeWhere : a b -> (b -> Bool) -> a b
removeWhere = \xs pred -> filter xs (\x -> not pred x)
pluck : a b -> (b -> c) -> a c
pluck = \xs f -> do
  x <- xs
  yield (f x)
mapWhere : a b -> (b -> Bool) -> (b -> c) -> a c
mapWhere = \xs pred -> pluck (filter xs pred)
countWhere : a b -> (b -> Bool) -> Int
countWhere = \xs pred -> count (filter xs pred)
any : [a] -> (a -> Bool) -> Bool
any = \xs pred -> countWhere xs pred > 0
none : [a] -> (a -> Bool) -> Bool
none = \xs pred -> not any xs pred
all : [a] -> (a -> Bool) -> Bool
all = \xs pred -> none xs (\x -> not pred x)
findFirst : [a] -> (a -> Bool) -> Maybe a
findFirst = \xs pred -> headOf (filter xs pred)
when : Bool -> IO {} {} -> IO {} {}
when = \cond action -> if cond then action else yield {}
min : a -> a -> a
min = \a b -> if a < b then a else b
max : a -> a -> a
max = \a b -> if a > b then a else b
clamp : a -> a -> a -> a
clamp = \lo hi x -> max lo (min hi x)
abs : Int -> Int
abs = \x -> if x < 0 then 0 - x else x
-- Pair each element with its 0-based index.
withIndex : [a] -> [{i: Int, v: a}]
withIndex = fold (\acc x -> union acc [{i: count acc, v: x}]) []

-- First element of a list, or Nothing for an empty list.
headOf : [a] -> Maybe a
headOf = \items -> fold (\_ x -> Just {value: x}) (Nothing {}) (takeRelation 1 items)

-- Cap to maxN by dropping the smallest-key entries (LRU-style). Always sorts.
capList : [a] -> Int -> (a -> b) -> [a]
capList = \items maxN getKey -> dropRelation (max 0 (count items - maxN)) (sortBy getKey items)

-- Integer percentage with zero-denominator guard.
pct : Int -> Int -> Int
pct = \cur maxN -> if maxN > 0 then cur * 100 / maxN else 0

-- Common ack/delete tail: pull matching messages, drop them and their forwards.
removeForKey : (forall r. {toKey: PubkeyHex, encryptedBlob: BlobHex | r} -> Bool) -> IO {rw *forwards, rw *messages} [Message]
removeForKey = \pred -> do
  msgs <- *messages
  fwds <- *forwards
  *messages = removeWhere msgs pred
  *forwards = removeWhere fwds pred
  yield (filter msgs pred)

-- Cap pred-matching entries to maxN-1 (caller adds one more).
capPerKey : [a] -> (a -> Bool) -> Int -> (a -> b) -> [a]
capPerKey = \items pred maxN getKey -> union (removeWhere items pred) (capList (filter items pred) (maxN - 1) getKey)

-- Shared empty/error shape for /poll. Only a few fields ever vary.
emptyPollResp : Timestamp -> Bool -> Bool -> Bool -> Int -> Int -> Bool -> {events: [PollEvent], cursor: Timestamp, authorized: Bool, rateLimited: Bool, draining: Bool, generation: Int, heartbeat: Bool, retryAfterMs: Int, cursorReset: Bool, hasMore: Bool, cursorStale: Bool, loadPct: Int}
emptyPollResp = \cursor authorized rateLimited draining gen retryAfterMs cursorWasReset -> {
  events: [],
  cursor,
  authorized,
  rateLimited,
  draining,
  generation: gen,
  heartbeat: False {},
  retryAfterMs,
  cursorReset: cursorWasReset,
  hasMore: False {},
  cursorStale: False {},
  loadPct: 0
}

-- Sequence an IO action over each item, in order.
forEach : [a] -> (a -> IO {} {}) -> IO {} {}
forEach = \items action -> case single (takeRelation 1 items) of
  Nothing {} -> yield {}
  Just {value: x} -> do
    action x
    forEach (dropRelation 1 items) action

-- Like forEach, but collects each action's result into a list.
mapEach : [a] -> (a -> IO {} b) -> IO {} [b]
mapEach = \items action -> case headOf items of
  Nothing {} -> yield []
  Just {value: x} -> do
    r <- action x
    rest <- mapEach (dropRelation 1 items) action
    yield (union [r] rest)

-- Hex tokens: one random hex char per recursive call.
genTokenN : Int -> IO {random} Text
genTokenN = \n -> if n <= 0
then yield ""
else do
  d <- randomInt 16
  rest <- genTokenN (n - 1)
  yield (take 1 (drop d "0123456789abcdef") ++ rest)

-- Standard 48-char hex token used for session bearers and federation nonces.
genToken : IO {random} Text
genToken = genTokenN 48

-- Canonical message identity: BLAKE3 of the encrypted blob, hex-encoded.
-- Binding the id to the payload means a hostile peer cannot multiply-store
-- the same ciphertext under different ids on /federation/forward — same
-- blob always collides with the existing dedup key.
messageIdOf : BlobHex -> MessageIdHex
messageIdOf = \blob -> bytesToHex (hash blob)

-- True when `s` exceeds `maxLen` characters.
tooLong : Text -> Int -> Bool
tooLong = \s maxLen -> count (chars s) > maxLen

-- True when `s` is non-empty, even-length, and only lowercase hex digits.
isValidHex : Text -> Bool
isValidHex = \s -> (\cs -> (\n -> n > 0 && n / 2 * 2 == n && all cs (\c -> contains c "0123456789abcdef")) (count cs)) (chars s)

-- Recursively strip every trailing "." from `s` (DNS root form).
stripTrailingDot : Text -> Text
stripTrailingDot = \s -> if containsSuffix "." s
then stripTrailingDot (take (count (chars s) - 1) s)
else s

-- Canonical form of a hostname: lowercase, no trailing dot.
normalizeServerName : Text -> Text
normalizeServerName = \s -> toLower (stripTrailingDot s)

-- This server's own hostname in canonical form (used everywhere for self-checks).
serverHostN : Text
serverHostN = normalizeServerName serverHost
-- True when `s` refers to this server.
isLocalServer : Text -> Bool
isLocalServer = \s -> s == serverHostN
-- True when `s` refers to any server other than this one.
isRemote : Text -> Bool
isRemote = \s -> not isLocalServer s

-- True when `s` starts with `pre`.
hasPrefix : Text -> Text -> Bool
hasPrefix = \pre s -> take (count (chars pre)) s == pre

-- True when `s` ends with `suffix`.
containsSuffix : Text -> Text -> Bool
containsSuffix = \suffix s -> drop (max 0 (count (chars s) - count (chars suffix))) s == suffix

-- Block private/reserved/internal hostnames (SSRF defense). Skips obscure encoding
-- tricks (octal, hex, percent-encoding) but covers the high-value cases.
isBadServerName : Text -> Bool
isBadServerName = \sn -> sn == "" || sn == "localhost" || not all (chars sn) (\c -> contains c "0123456789abcdefghijklmnopqrstuvwxyz-.:") || any [
  ".",
  ":",
  "[",
  "127.",
  "10.",
  "192.168.",
  "169.254.",
  "0.",
  "::"
] (\p -> hasPrefix p sn) || any [".localhost", ".local", ".internal", ".arpa", ".onion"] (\s -> containsSuffix s sn)

-- ============================================
-- Auth helpers
-- ============================================
-- Bearer token extraction, session lookup, maintenance secret check, and the
-- `gateAuth`/`gateClientWrite`/`gateLookup` combinators that every client
-- handler funnels through (drain → global rate → per-key rate → session).
-- Federation requests use a separate path (`withFederationAuth`) using
-- Ed25519-signed auth verified via the peer's published public key.

-- Plain ip match (sessions with empty ip skip the check).
matchIp : Text -> Text -> Bool
matchIp = \clientIp sessionIp -> sessionIp == "" || clientIp == sessionIp

-- Pull the token out of an `Authorization: Bearer <token>` header. Returns
-- Nothing if the prefix is missing or the token is empty.
extractToken : Text -> Maybe Text
extractToken = \h -> if hasPrefix "Bearer " h && drop 7 h != ""
then Just {value: drop 7 h}
else Nothing {}

-- True when the header carries a Bearer token equal to the runtime maintenance
-- secret. Plain `==` comparison; not constant-time (see file header).
verifyMaintenanceAuth : Text -> IO {r *runtimeMaintenanceSecret} Bool
verifyMaintenanceAuth = \authorization -> do
  secret <- *runtimeMaintenanceSecret
  yield (secret != "" && extractToken authorization == Just {value: secret})

-- Branch on maintenance-secret auth: run `onAuth` when the bearer matches,
-- `onUnauth` otherwise.
withMaintAuth : Text -> IO {| effs} a -> IO {| effs} a -> IO {r *runtimeMaintenanceSecret | effs} a
withMaintAuth = \authorization onUnauth onAuth -> do
  authorized <- verifyMaintenanceAuth authorization
  if authorized then onAuth else onUnauth

-- Common gate for handlers: optional drain check, global rate, session auth.
-- mkErr is called with one of: "draining", "rate_limited", "unauthorized".
gateAuth : Bool -> Text -> Text -> Timestamp -> (resp -> ret) -> (Text -> resp) -> (PubkeyHex -> IO {} ret) -> IO {r *drainPhase, rw *globalRateCount, rw *globalRateWindowStart, r *sessions} ret
gateAuth = \checkDrain auth ip t respond mkErr onAuth -> do
  dp <- *drainPhase
  g <- checkGlobalRate t
  let err = \e -> yield (respond (mkErr e))
  if checkDrain && dp >= 2
  then err "draining"
  else if g then err "rate_limited" else withSessionAuth auth t ip (err "unauthorized") onAuth

-- gateAuth + per-key rate gate. `rateResp` is the response value when the per-key gate trips.
gateClientWrite : Text -> Text -> Int<Ms> -> (a -> b) -> (Text -> a) -> a -> (Text -> IO {} b) -> IO {r *drainPhase, rw *globalRateCount, rw *globalRateWindowStart, r *sessions} b
gateClientWrite = \auth ip t respond mkErr rateResp onAuth ->
  gateAuth (True {}) auth ip t respond mkErr (\pk -> do
    lim <- atomic do
      rates <- *clientWriteRates
      let r = checkRate rates pk maxClientWriteRatePerKey clientWriteRateWindowMs t
      -- TODO: make this no be a `replace`
      *clientWriteRates = r.entries
      yield r.limited
    if lim then yield (respond rateResp) else onAuth pk)

-- Variant of `gateClientWrite` that skips the drain check (lookups still work
-- while draining) and uses the per-key lookup-rate window instead.
gateLookup : Text -> Text -> Int<Ms> -> (a -> b) -> (Text -> a) -> a -> (Text -> IO {} b) -> IO {r *drainPhase, rw *globalRateCount, rw *globalRateWindowStart, r *sessions} b
gateLookup = \auth ip t respond mkErr rateResp onAuth ->
  gateAuth (False {}) auth ip t respond mkErr (\pk -> do
    lim <- atomic do
      rates <- *lookupRates
      let r = checkRate rates pk maxLookupRatePerKey lookupRateWindowMs t
      -- TODO: make this no be a `replace`
      *lookupRates = r.entries
      yield r.limited
    if lim then yield (respond rateResp) else onAuth pk)

-- Resolve a Bearer token to its session pubkey if the session is unexpired and
-- the client IP matches. Runs `onAuth pubkey` on success, `onUnauth` otherwise.
withSessionAuth : Text -> Int<Ms> -> Text -> IO {| e} a -> (PubkeyHex -> IO {| e} a) -> IO {r *sessions | e} a
withSessionAuth = \authorization t clientIp onUnauth onAuth -> do
  ses <- *sessions
  case extractToken authorization of
    Nothing {} -> onUnauth
    Just {value: token} -> case findFirst ses (\s -> s.expiresAt > t && s.token == token && matchIp clientIp s.ip) of
      Just {value: s} -> onAuth s.pubkey
      _ -> onUnauth

-- Build the `Signed <hexsig>:<nonce>` header for an outbound federation call.
-- Signs the canonical "scope|timestamp|fromServer|nonce" string with our
-- federation private key (the peer fetches our public key via /federation/pubkey
-- to verify). Returns "" if no keypair has been generated yet.
generateFederationAuth : Text -> a -> IO {r *federationPrivateKeyHex, random} Text
generateFederationAuth = \scope requestTimestamp -> do
  hex <- *federationPrivateKeyHex
  let privKey = if hex == "" then Nothing {} else bytesFromHex hex
  case privKey of
    Just {value: pk} -> do
      nonce <- genTokenN 48
      yield ("Signed " ++ bytesToHex (sign pk (textToBytes (scope ++ "|" ++ show requestTimestamp ++ "|" ++ serverHostN ++ "|" ++ nonce))) ++ ":" ++ nonce)
    _ -> yield ""

-- Verify a federation request: Ed25519 signature over scope|ts|fromServer|nonce, key fetched from peer.
verifyFederationAuth : Text -> Text -> Text -> a -> IO {network} {} Bool
verifyFederationAuth = \authorization fromServer scope requestTimestamp -> do
  if hasPrefix "Signed " authorization then do
    let payload = drop 7 authorization
    if payload == "" || tooLong payload (signatureLen + 25) then yield False {}
    else do
      -- Split payload on first ':' into {sig, nonce}.
      let cs = chars payload
      let sepIdx = case findFirst (withIndex cs) (\p -> p.v == ":") of
            Just {value: p} -> p.i
            _ -> count cs
      let sig = take sepIdx payload
      let nonce = drop (sepIdx + 1) payload
      result <- fetch (federationUrl fromServer) (FederationPubkey {})
      case result of
        Ok {value: r} -> case bytesFromHex r.pubkey of
          Just {value: pk} -> case bytesFromHex sig of
            Just {value: sigBytes} -> yield (r.ok && r.pubkey != "" && verify pk (textToBytes (scope ++ "|" ++ show requestTimestamp ++ "|" ++ fromServer ++ (if nonce == "" then "" else "|" ++ nonce))) sigBytes)
            _ -> yield False {}
          _ -> yield False {}
        _ -> yield False {}
  else yield False {}

-- Combined gate for inbound federation calls. Order of checks (each short-
-- circuits with an error code in the response):
--   1. peer not block-listed; 2. peer in allow-list (if any); 3. caller-supplied
--   `precondition` holds; 4. clock skew within `clockSkewTolerance`;
--   5. Ed25519 signature verifies; 6. per-peer federation rate limit.
withFederationAuth = \authorization t respond fromServer scope requestTimestamp precondition action -> do
  blocked <- *blockedPeers
  allowed <- *allowedPeers
  let err = \e r -> yield (respond {ok: False {}, error: e, retryAfterMs: r})
  let preErr = if elem fromServer blocked
  then "blocked"
  else if count allowed > 0 && not elem fromServer allowed
  then "not_allowed"
  else if not precondition
  then "invalid_request"
  else if requestTimestamp > 0 && abs (requestTimestamp - t) > clockSkewTolerance
  then "clock_skew"
  else ""
  if preErr != ""
  then err preErr 0
  else do
    verified <- verifyFederationAuth authorization fromServer scope requestTimestamp
    if not verified
    then err "unauthorized" 0
    else do
      limited <- checkServerRateGate fromServer t
      if limited then err "rate_limited" federationRateWindowMs else action

-- ============================================
-- Rate limiting (plain count-per-window, no sliding interpolation)
-- ============================================
-- Two flavors of fixed-window counters:
--   * Per-key (`checkRate`) — keyed by pubkey, ip, server, or pair string;
--     entries live in a `RateEntry` list ref capped at 5000 with LRU eviction.
--   * Global (`checkGlobalRate`/`checkAuthGlobalRate`) — single counter+windowStart
--     pair, used for the request-wide and auth-wide ceilings.
-- `authPreCheck` composes drain + global + ip + auth-global into a one-shot
-- gate for unauthenticated handlers (challenge/verify).

-- Returns {limited, entries}. Increments count when the key fits within the window.
checkRate : [RateEntry] -> Text -> Int -> Int<Ms> -> Timestamp -> {limited: Bool, entries: [RateEntry]}
checkRate = \entries key maxRate windowMs t -> (\cur -> if cur.count > maxRate then {limited: True {}, entries} else {limited: False {}, entries: capList (union (removeWhere entries (\x -> x.key == key)) [{key, cur.windowStart, cur.count}]) 5000 (\r -> r.windowStart)}) (case findFirst entries (\r -> r.key == key && t - r.windowStart < windowMs) of
  Just {value: r} -> {r.windowStart, count: r.count + 1}
  _ -> {windowStart: t, count: 1})

-- Single-counter global rate gate. Resets the counter when the window expires;
-- returns True when the limit has been hit (caller responds rate_limited).
checkGlobalRate : Timestamp -> IO {rw *globalRateCount, rw *globalRateWindowStart} Bool
checkGlobalRate = \t -> atomic (do
  ws <- *globalRateWindowStart
  c <- *globalRateCount
  if t - ws >= globalRateWindowMs
  then do
    *globalRateWindowStart = t
    *globalRateCount = 1
    yield (False {})
  else if c >= maxGlobalRequestRate
  then yield (True {})
  else do
    *globalRateCount = c + 1
    yield (False {}))

-- Same shape as `checkGlobalRate` but charged only by the auth endpoints
-- (challenge + verify). Stops a single attacker from exhausting the global
-- counter via auth churn.
checkAuthGlobalRate = \t -> atomic (do
  ws <- *authGlobalRateWindowStart
  c <- *authGlobalRateCount
  if t - ws >= authGlobalRateWindowMs
  then do
    *authGlobalRateWindowStart = t
    *authGlobalRateCount = 1
    yield (False {})
  else if c >= maxAuthGlobalRate
  then yield (True {})
  else do
    *authGlobalRateCount = c + 1
    yield (False {}))

-- Per-source-IP rate gate (skipped when the IP is unknown — see `requireClientIp`).
checkIpRateGate : Text -> Int<Ms> -> IO {rw *ipRates} Bool
checkIpRateGate = \ip t -> if ip == ""
then yield (False {})
else atomic (do
  rates <- *ipRates
  let r = checkRate rates ip maxIpRatePerIp ipRateWindowMs t
  *ipRates = r.entries
  yield r.limited)

-- Per-peer federation rate gate; charged inside `withFederationAuth`.
checkServerRateGate : Text -> Int -> IO {rw *federationRates} Bool
checkServerRateGate = \server t -> atomic (do
  rates <- *federationRates
  let r = checkRate rates server maxFederationRatePerServer federationRateWindowMs t
  *federationRates = r.entries
  yield r.limited)

-- Pre-auth gate: drain + global + ip + auth-global. Returns "" when ok, else an error code.
authPreCheck : Text -> Int<Ms> -> IO {rw *authGlobalRateCount, rw *authGlobalRateWindowStart, r *drainPhase, rw *globalRateCount, rw *globalRateWindowStart, rw *ipRates} Text
authPreCheck = \clientIp t -> do
  dp <- *drainPhase
  g <- checkGlobalRate t
  i <- checkIpRateGate clientIp t
  a <- checkAuthGlobalRate t
  yield (if dp >= 1
  then "draining"
  else if g
  then "global_rate_limited"
  else if i then "ip_rate_limited" else if a then "auth_rate_limited" else "")

-- ============================================
-- Federation failure tracking (simple, no circuit breaker)
-- ============================================
-- Linear backoff per peer: each consecutive failure multiplies the delay by
-- `retryBackoffBase` (capped at `retryBackoffMax`). `shouldRetryServer` is the
-- single read-side gate; `recordFailure`/`clearFailure` are the write side.
-- There is no half-open state — a single success clears all accumulated failures.

-- Linear backoff: `retryBackoffBase * failures`, capped at `retryBackoffMax`.
retryBackoff : Int -> Int<Ms>
retryBackoff = \failures -> min retryBackoffMax (retryBackoffBase * max 1 failures)

-- True when enough time has passed since the last failure for `server` to be
-- worth retrying (or no failure recorded at all).
shouldRetryServer : Text -> Timestamp -> [ForwardFailure] -> Bool
shouldRetryServer = \server t failures -> none failures (\f -> f.server == server && t - f.failedAt < retryBackoff f.failures)

-- Bump the failure counter for `server`. Preserves `firstFailedAt` across
-- subsequent failures so health views can show the outage age.
recordFailure : Text -> IO {rw *forwardFailures, clock} {}
recordFailure = \server -> do
  t <- now
  atomic (do
    failures <- *forwardFailures
    let same = \f -> f.server == server
    let prev = case findFirst failures same of
      Just {value: f} -> {failures: f.failures + 1, f.firstFailedAt}
      _ -> {failures: 1, firstFailedAt: t}
    *forwardFailures = union (removeWhere failures same) [
      {server, failedAt: t, prev.failures, prev.firstFailedAt}
    ])

-- Drop the failure record for `server` (called after any successful peer call).
-- Single-success recovery — there is no half-open state.
clearFailure : Text -> IO {rw *forwardFailures} {}
clearFailure = \server -> atomic (do
  forwardFailures <- *forwardFailures
  *forwardFailures = filter forwardFailures (\f -> f.server != server))

-- ============================================
-- Common utility queries
-- ============================================
-- Pure helpers shared by send/poll/federation paths: monotonic sequence
-- generation, presence lookup, and duplicate detection across
-- (messages, deliveredIds).

-- Strictly-monotonic next sequence timestamp: max of wall clock and prior+1.
-- Guarantees /poll cursors order events even when many arrive in the same ms.
nextSeqTs : Timestamp -> Timestamp -> Timestamp
nextSeqTs = \t seqCounter -> max t (seqCounter + 1)

-- Drop duplicates and cap to `maxMessageIds` (defense against bloated requests).
dedupMessageIds : [MessageIdHex] -> [MessageIdHex]
dedupMessageIds = \ids -> takeRelation maxMessageIds ids

-- All unexpired presence rows for a given pubkey (may include both local and
-- remote entries — the recipient may live on multiple servers simultaneously).
presenceForKey : [PresenceEntry] -> PubkeyHex -> Timestamp -> [PresenceEntry]
presenceForKey = \presence pubkey t -> filter presence (\p -> p.pubkey == pubkey && p.expiresAt > t)

-- Resolve a key's server for client lookup, masking remote identities behind "remote".
maskedServer : [PresenceEntry] -> PubkeyHex -> Timestamp -> Text
maskedServer = \pres pubkey t -> (\here -> if any here (\p -> isLocalServer p.server) then serverHostN else if count here > 0 then "remote" else "") (presenceForKey pres pubkey t)

-- Replay-protection check. A message is a duplicate if either:
--   * a live mailbox row exists with the same (encryptedBlob, toKey) -- since
--     id := messageIdOf encryptedBlob, same blob ⇒ same id; or
--   * a delivered-id tombstone matches (messageId, toKey).
-- The blob comparison avoids hashing every live row on each check; the
-- tombstone log only stores the id, so we compare it directly.
isDuplicateMessage : BlobHex -> PubkeyHex -> [Message] -> [DeliveredEntry] -> Bool
isDuplicateMessage = \blob toKey msgs dids -> any msgs (\m -> m.toKey == toKey && m.encryptedBlob == blob) || (\mid -> any dids (\d -> d.toKey == toKey && d.messageId == mid)) (messageIdOf blob)

-- Project items through `getServer`, drop our own hostname, and dedupe.
-- Used to derive peer recipient lists from forwards/presence/etc.
collectPeers : [a] -> (a -> Text) -> [Text]
collectPeers = \items getServer -> filter (pluck items getServer) isRemote

-- All distinct remote hostnames currently appearing in `presence` (the gossip
-- broadcast set we know about, less ourselves).
knownPeerServersFromPresence : [PresenceEntry] -> [Text]
knownPeerServersFromPresence = \presence -> collectPeers presence (\p -> p.server)

-- ============================================
-- Pruning
-- ============================================
-- Single sweep that drops expired entries from every state ref in one atomic
-- block. Returns the locally-expired presence rows whose pubkey has no other
-- live local session, so the caller can broadcast offline gossip for them.

-- One sweep over every state ref: drops expired rows in a single atomic block.
-- Returns the locally-expired presence rows whose pubkey has no other live
-- local session, so the caller can broadcast offline gossip for them.
pruneExpired : Int<Ms> -> IO {rw *activePolls, rw *challenges, rw *deliveredIds, rw *forwardFailures, rw *forwards, rw *messages, rw *presence, rw *sessions} [{expiresAt: Timestamp, pubkey: PubkeyHex, server: AnyServerName}]
pruneExpired = \t -> atomic do
  ch <- *challenges
  *challenges = filter ch (\x -> x.expiresAt > t)
  ses <- *sessions
  *sessions = filter ses (\x -> x.expiresAt > t)
  msgs <- *messages
  *messages = filter msgs (\m -> t - m.receivedAt < messageMaxAge)
  fwds <- *forwards
  *forwards = filter fwds (\f -> t - f.createdAt < messageMaxAge)
  dids <- *deliveredIds
  *deliveredIds = filter dids (\d -> t - d.deliveredAt < messageMaxAge)
  ff <- *forwardFailures
  *forwardFailures = filter ff (\f -> t - f.failedAt < 86400000)
  aps <- *activePolls
  *activePolls = filter aps (\p -> t - p.startedAt < pollTimeoutMs * 3)
  -- presence: remember locally-expired keys for offline gossip
  pres <- *presence
  *presence = filter pres (\p -> p.expiresAt > t)
  let stillLive = \pk -> any pres (\k -> isLocalServer k.server && k.pubkey == pk && k.expiresAt > t)
  yield (filter pres (\p -> p.expiresAt <= t && isLocalServer p.server && not (stillLive p.pubkey)))

-- ============================================
-- Federation gossip
-- ============================================
-- Construction and outbound dispatch of presence gossip events. Failures from
-- a peer record into `forwardFailures` (shared with forward retries) so both
-- subsystems back off together.

-- Build a gossip event with the originating pubkey's status.
mkGossip : GossipEventType -> PubkeyHex -> GossipEvent
mkGossip = \etype pk -> {eventType: etype, pubkey: pk}

-- Fan out one bundle of gossip events to each peer, skipping peers in backoff.
-- Records or clears federation-failure counters per call.
sendBatchedGossip : [Text] -> [GossipEvent] -> IO {} {}
sendBatchedGossip = \peers events -> forEach peers (\server -> do
  t <- now
  failures <- *forwardFailures
  when (shouldRetryServer server t failures) (do
    auth <- generateFederationAuth "gossip" t
    result <- fetch (federationUrl server) (RecvGossip {
      authorization: auth,
      events,
      fromServer: serverHostN,
      requestTimestamp: t,
      correlationId: ""
    })
    case result of
      Err _ -> recordFailure server
      Ok _ -> clearFailure server))

-- Tell known peers that the listed local pubkeys just went offline. No-op when
-- federation is disabled or the list is empty.
broadcastOfflineGossip : [{pubkey: PubkeyHex | a}] -> IO {r *presence} {}
broadcastOfflineGossip = \expiredLocal -> do
  presence <- *presence
  when (federationEnabled && count expiredLocal > 0) (sendBatchedGossip (knownPeerServersFromPresence presence) (pluck expiredLocal (\p -> mkGossip (GossipOffline {}) p.pubkey)))

-- ============================================
-- Forward retries
-- ============================================
-- `retryPendingForwards` walks queued cross-server forwards in batches per
-- destination, increments retry counts, and gives up after `maxForwardRetries`.
-- `forwardQueuedToServer` is the catch-up path triggered when a remote key
-- comes online: any messages already buffered for that pubkey are enqueued
-- as forwards to the newly-known server.

-- Walk pending forwards grouped by destination, retry each (up to maxBatchSize
-- per peer) using `/federation/forward`. Drops successful entries; for failures
-- bumps the retry count and gives up after `maxForwardRetries`.
retryPendingForwards : IO {r *blockedPeers, r *forwardFailures, r *forwards, clock} {}
retryPendingForwards = do
  t <- now
  fwds <- *forwards
  failures <- *forwardFailures
  blocked <- *blockedPeers
  forEach (filter (collectPeers fwds (\f -> f.toServer)) (\s -> shouldRetryServer s t failures && not elem s blocked)) (\server -> forEach (takeRelation maxBatchSize (filter fwds (\f -> f.toServer == server))) (\f -> do
    t2 <- now
    let messageId = messageIdOf f.encryptedBlob
    auth <- generateFederationAuth ("forward:" ++ messageId) t2
    result <- fetch (federationUrl server) (ForwardMessage {
      f.toKey,
      f.encryptedBlob,
      messageId,
      fromServer: serverHostN,
      requestTimestamp: t2,
      authorization: auth,
      correlationId: ""
    })
    success <- case result of
      Err _ -> do
        recordFailure server
        yield (False {})
      Ok {value: r} -> do
        when r.ok (clearFailure server)
        yield r.ok
    let isMatch = \x -> x.encryptedBlob == f.encryptedBlob && x.toServer == server
    let isDone = \x -> isMatch x && (success || x.retries + 1 >= maxForwardRetries)
    atomic (do
      cur <- *forwards
      *forwards = pluck (removeWhere cur isDone) (\x -> if isMatch x
      then {x.toServer, x.createdAt, x.toKey, x.encryptedBlob, retries: x.retries + 1}
      else x))))

-- Forward queued messages to a server when a remote key comes online.
forwardQueuedToServer : PubkeyHex -> ServerName -> Int<Ms> -> IO {rw *forwards, r *messages} {}
forwardQueuedToServer = \pubkey server t -> atomic (do
  msgs <- *messages
  fwds <- *forwards
  let candidates = filter msgs (\m -> m.toKey == pubkey && none fwds (\f -> f.encryptedBlob == m.encryptedBlob && f.toServer == server))
  let newFwds = pluck (takeRelation maxForwardsPerServer candidates) (\m -> {
    toServer: server,
    createdAt: t,
    m.toKey,
    m.encryptedBlob,
    retries: 0
  })
  *forwards = union fwds newFwds)

-- ============================================
-- Background loops
-- ============================================
-- Composite tick run from `backgroundPrune` (and on demand via /maintenance/prune):
-- expire stale rows, then opportunistically retry pending forwards and refresh
-- local presence so peers don't see us go offline mid-session.

-- One composite background tick: prune expired state, gossip offline for
-- locally-expired keys, retry pending forwards, and (occasionally) refresh
-- local presence so peers don't see us drop off.
pruneAndRetry = \t -> do
  *lastPrunedAt = t
  expiredLocal <- pruneExpired t
  fork (broadcastOfflineGossip expiredLocal)
  when federationEnabled (do
    fork retryPendingForwards
    lastRefresh <- *lastPresenceRefresh
    when (t - lastRefresh >= presenceRefreshInterval) (do
      *lastPresenceRefresh = t
      refreshLocalPresence t))

-- Extend the expiry of local presence rows whose backing session is still live
-- but the presence entry is past half its window. Re-broadcasts an `online`
-- event for the refreshed entries so peers don't time them out.
refreshLocalPresence : Int<Ms> -> IO {rw *presence, r *sessions} {}
refreshLocalPresence = \t -> do
  refreshState <- atomic (do
    sessions <- *sessions
    presence <- *presence
    let sessionKeys = map (\s -> s.pubkey) sessions
    let needsRefresh = \p -> isLocalServer p.server && elem p.pubkey sessionKeys && p.expiresAt - t < sessionExpiry / 2
    let kept = filter presence (\p -> not needsRefresh p)
    let refreshed = map (\p -> {p.pubkey, p.server, expiresAt: t + sessionExpiry}) (filter presence needsRefresh)
    let updated = union kept refreshed
    *presence = updated
    yield {refreshed, peers: knownPeerServersFromPresence updated})
  when (count refreshState.refreshed > 0) (fork (sendBatchedGossip refreshState.peers (pluck refreshState.refreshed (\p -> mkGossip (GossipOnline {}) p.pubkey))))

-- ============================================
-- Handler: challenge / verify / revoke / logout
-- ============================================
-- Identity is a public key; there are no accounts. The flow is:
--   1. Client requests a fresh nonce (`handleChallenge`).
--   2. Client signs the nonce with its private key and submits the signature
--      together with the original challenge (`handleVerifyAuth`).
--   3. Server returns a Bearer token bound to (pubkey, ip, expiry); the new
--      session also installs a local presence row and gossips an `online`
--      event to known peers.
-- `handleRevoke` lets a session revoke its peers (same pubkey, different
-- token); `handleLogout` invalidates the caller's own token and, if no
-- sibling sessions remain, gossips an `offline` event.

-- POST /auth/challenge: issue a fresh signed-nonce challenge for `pubkey`.
-- Capped per-key (maxChallengesPerKey) and rate-limited; the IP is recorded
-- so /auth/verify can require the same client.
handleChallenge : PubkeyHex -> Text -> ({challenge: Text, error: Text, expiresAt: Int, ok: Bool, retryAfterMs: Int} -> a) -> IO {rw *authGlobalRateCount, rw *authGlobalRateWindowStart, rw *challengeRates, rw *challenges, r *drainPhase, rw *globalRateCount, rw *globalRateWindowStart, rw *ipRates, clock, random} a
handleChallenge = \pubkey clientIp respond -> do
  t <- now
  preErr <- if requireClientIp && clientIp == ""
  then yield "client_ip_required"
  else authPreCheck clientIp t
  if preErr != ""
  then yield (respond {challenge: "", ok: False {}, expiresAt: 0, retryAfterMs: 0, error: preErr})
  else do
    challenge <- genToken
    result <- atomic (do
      ch <- *challenges
      let cappedActive = capPerKey (filter ch (\c -> c.expiresAt > t)) (\c -> c.pubkey == pubkey) maxChallengesPerKey (\c -> c.expiresAt)
      if count cappedActive >= maxChallenges
      then yield {ok: False {}, error: "capacity"}
      else do
        chRates <- *challengeRates
        let chR = checkRate chRates pubkey maxChallengeRatePerKey challengeRateWindowMs t
        *challengeRates = chR.entries
        if chR.limited
        then yield {ok: False {}, error: "rate_limited"}
        else do
          *challenges = union cappedActive [
            {pubkey, challenge, expiresAt: t + challengeExpiry, ip: clientIp}
          ]
          yield {ok: True {}, error: ""})
    yield (respond {
      challenge: if result.ok then challenge else "",
      result.ok,
      expiresAt: if result.ok then t + challengeExpiry else 0,
      retryAfterMs: 0,
      result.error
    })

-- POST /auth/verify: validate `signature` over `challenge` for `pubkey`.
-- On success, mints a session token, records local presence (`pubkey` is now
-- live on this server), and gossips an `online` event to known peers. If
-- `revokeOthers` is set, all other sessions for the same pubkey are dropped.
handleVerifyAuth : PubkeyHex -> Text -> Text -> Bool -> Text -> ({error: Text, expiresAt: Int, token: Text} -> a) -> IO {rw *authGlobalRateCount, rw *authGlobalRateWindowStart, rw *challenges, r *drainPhase, rw *globalRateCount, rw *globalRateWindowStart, rw *ipRates, rw *presence, rw *sessions, clock, random} a
handleVerifyAuth = \pubkey challenge signature revokeOthers clientIp respond -> do
  t <- now
  preErr <- authPreCheck clientIp t
  if preErr != ""
  then yield (respond {token: "", expiresAt: 0, error: preErr})
  else do
    let expiry = t + sessionExpiry
    token <- genToken
    result <- atomic (do
      ch <- *challenges
      dp <- *drainPhase
      let same = \c -> c.pubkey == pubkey && c.challenge == challenge
      let sigValid = case bytesFromHex pubkey of
        Just {value: pk} -> case bytesFromHex signature of
          Just {value: sigBytes} -> verify pk (textToBytes challenge) sigBytes
          _ -> False {}
        _ -> False {}
      let valid = dp < 1 && any ch (\c -> same c && c.expiresAt > t && matchIp clientIp c.ip) && sigValid
      if not valid
      then yield {valid: False {}, peers: []}
      else do
        *challenges = removeWhere ch same
        ses <- *sessions
        let mine = \s -> s.pubkey == pubkey
        let pruned = if revokeOthers
        then removeWhere ses mine
        else capPerKey ses mine maxSessionsPerKey (\s -> s.expiresAt)
        let newSession = {token, pubkey, expiresAt: expiry, ip: clientIp, createdAt: t}
        *sessions = capList (union pruned [newSession]) maxSessions (\s -> s.expiresAt)
        pres <- *presence
        let prunedPres = removeWhere pres (\p -> p.pubkey == pubkey && isLocalServer p.server)
        let newPres = union prunedPres [{pubkey, server: serverHostN, expiresAt: expiry}]
        *presence = newPres
        yield {valid: True {}, peers: knownPeerServersFromPresence newPres})
    if not result.valid
    then yield (respond {token: "", expiresAt: 0, error: "invalid"})
    else do
      when federationEnabled (fork (sendBatchedGossip result.peers [
        mkGossip (GossipOnline {}) pubkey
      ]))
      yield (respond {token, expiresAt: expiry, error: ""})

-- POST /auth/revoke: caller (any session for the pubkey) revokes a sibling
-- session by token. Returns ok=False if no such sibling existed.
handleRevoke : Text -> Text -> Text -> ({authorized: Bool, ok: Bool} -> a) -> IO {r *drainPhase, rw *globalRateCount, rw *globalRateWindowStart, r *sessions, clock} a
handleRevoke = \targetToken authorization clientIp respond -> do
  t <- now
  gateAuth (False {}) authorization clientIp t respond (\_ -> {ok: False {}, authorized: False {}}) (\caller -> do
    result <- atomic (do
      ses <- *sessions
      let pred = \s -> s.pubkey == caller && s.token == targetToken
      *sessions = removeWhere ses pred
      yield (any ses pred))
    yield (respond {ok: result, authorized: True {}}))

-- POST /auth/logout: drop the caller's own session. If this was the last
-- session for the pubkey, also clear local presence and gossip offline.
handleLogout : Text -> Text -> ({authorized: Bool, ok: Bool} -> a) -> IO {rw *presence, rw *sessions, clock} a
handleLogout = \authorization clientIp respond -> do
  t <- now
  let myToken = case extractToken authorization of
    Just {value: tk} -> tk
    _ -> ""
  removed <- atomic withSessionAuth authorization t clientIp (yield {
    ok: False {},
    pubkey: "",
    peers: []
  }) (\pubkey -> do
    ses <- *sessions
    *sessions = removeWhere ses (\s -> s.token == myToken)
    after <- *sessions
    peers <- if any after (\s -> s.pubkey == pubkey)
    then yield []
    else do
      pres <- *presence
      *presence = removeWhere pres (\p -> p.pubkey == pubkey && isLocalServer p.server)
      yield (knownPeerServersFromPresence pres)
    yield {ok: True {}, pubkey, peers})
  when (removed.ok && federationEnabled) (fork (sendBatchedGossip removed.peers [
    mkGossip (GossipOffline {}) removed.pubkey
  ]))
  yield (respond {removed.ok, authorized: removed.ok})

-- ============================================
-- Handler: poll
-- ============================================
-- Long-poll. The client supplies a cursor (last-seen `receivedAt`) and the
-- server's last-known `generation` (server identity for cursor validity). We:
--   * If the generation mismatches, reset the cursor and signal `cursorReset`.
--   * Ack-and-drop everything <= the cursor (treating poll progress as ack).
--   * Wait on `pollWakeup` (bumped by send/heartbeat) and return new events
--     plus piggybacked sender-side expirations/deliveries.
-- Per-pubkey concurrency is capped via `activePolls` to bound long-poll holds.

-- POST /poll: top-level dispatch. Validates drain/global gates, detects a
-- generation mismatch (server restart) to force a cursor reset, then hands
-- off to `pollOnce` for the actual long-poll body.
handlePoll : Int -> Int -> Text -> Text -> ({authorized: Bool, cursor: Timestamp, cursorReset: Bool, cursorStale: Bool, draining: Bool, events: [PollEvent], generation: Int, hasMore: Bool, heartbeat: Bool, loadPct: Int, rateLimited: Bool, retryAfterMs: Int} -> Response) -> IO {r *drainPhase, r *pollWakeup, r *serverGeneration, r *sessions, rw *activePolls, rw *forwards, rw *globalRateCount, rw *globalRateWindowStart, rw *messages, clock} Response
handlePoll = \cursor generation authorization clientIp respond -> do
  t <- now
  serverGen <- *serverGeneration
  dp <- *drainPhase
  g <- checkGlobalRate t
  let cursorWasReset = generation != serverGen && cursor > 0
  let er = \auth rate drain retryRate -> yield (respond (emptyPollResp 0 auth rate drain serverGen retryRate cursorWasReset))
  if dp >= 2
  then er (True {}) (False {}) (True {}) 0
  else if g
  then er (False {}) (True {}) (False {}) globalRateWindowMs
  else pollOnce authorization (if cursorWasReset then 0 else cursor) cursorWasReset clientIp serverGen respond t

-- Body of a single poll. Treats the cursor advance as an implicit ack
-- (`ackPolledMessages`), acquires a per-pubkey poll slot, runs `doPoll` to
-- collect events (or block until wakeup), then assembles the response.
pollOnce : Text -> Int -> Bool -> Text -> Int -> ({authorized: Bool, cursor: Timestamp, cursorReset: Bool, cursorStale: Bool, draining: Bool, events: [PollEvent], generation: Int, hasMore: Bool, heartbeat: Bool, loadPct: Int, rateLimited: Bool, retryAfterMs: Int} -> Response) -> Int<Ms> -> IO {r *pollWakeup, r *sessions, rw *activePolls, rw *forwards, rw *messages, clock} Response
pollOnce = \authorization cursor cursorWasReset clientIp serverGen respond t -> do
  setup <- atomic withSessionAuth authorization t clientIp (yield (Nothing {})) (\pubkey -> do
    let clampedCursor = clamp 0 t cursor
    when (clampedCursor > 0) (ackPolledMessages pubkey clampedCursor)
    startWakeup <- *pollWakeup
    yield (Just {value: {pubkey, clampedCursor, startWakeup}}))
  case setup of
    Nothing {} -> yield (respond (emptyPollResp 0 (False {}) (False {}) (False {}) serverGen 0 cursorWasReset))
    Just {value: s} -> do
      acquired <- atomic (do
        aps <- *activePolls
        if countWhere aps (\p -> p.pubkey == s.pubkey) >= maxPollsPerKey
        then yield (False {})
        else do
          *activePolls = union aps [{s.pubkey, startedAt: t}]
          yield (True {}))
      if not acquired
      then yield (respond (emptyPollResp cursor (True {}) (True {}) (False {}) serverGen pollTimeoutMs cursorWasReset))
      else do
        pollResult <- doPoll s t
        atomic (do aps <- *activePolls; *activePolls = filter aps (\p -> p.pubkey != s.pubkey))
        yield (respond {
          pollResult.events,
          pollResult.cursor,
          authorized: True {},
          rateLimited: False {},
          draining: False {},
          generation: serverGen,
          heartbeat: count pollResult.events == 0,
          retryAfterMs: 0,
          cursorReset: cursorWasReset,
          pollResult.hasMore,
          cursorStale: False {},
          loadPct: 0
        })

-- One pass: collect events at `t`. If empty, retry-wait on `pollWakeup`
-- (bumped by send/heartbeat) and re-collect once at the new wall time.
doPoll : {clampedCursor: Int, pubkey: PubkeyHex, startWakeup: Timestamp} -> Int<Ms> -> IO {r *pollWakeup, clock} {cursor: Int<Ms>, events: [{encryptedBlob: BlobHex}], hasMore: Bool}
doPoll = \s t -> do
  let collectAt = \tnow -> atomic (do
    msgs <- *messages
    yield (collectPollEvents msgs s.pubkey s.clampedCursor tnow))
  initial <- collectAt t
  if count initial.events > 0
  then yield initial
  else do
    atomic (do wakeup <- *pollWakeup; if wakeup > s.startWakeup then yield {} else retry)
    t2 <- now
    collectAt t2

-- Pull this pubkey's unexpired messages newer than `cursor`, sort by
-- receivedAt, take up to `maxPollEvents`, and report `hasMore` if truncated.
collectPollEvents : [Message] -> PubkeyHex -> Timestamp -> Timestamp -> {events: [PollEvent], cursor: Timestamp, hasMore: Bool}
collectPollEvents = \messages pubkey cursor t -> (\myMsgs -> (\limited -> {events: pluck limited (\m -> {m.encryptedBlob}), cursor: fold (\acc m -> max acc m.receivedAt) cursor limited, hasMore: count myMsgs > count limited}) (takeRelation maxPollEvents (sortBy (\m -> m.receivedAt) myMsgs))) (filter messages (\m -> m.toKey == pubkey && t - m.receivedAt < messageMaxAge && m.receivedAt > cursor))

-- Treat the supplied cursor as an ack: drop all messages with
-- receivedAt <= cursor, plus their pending forwards.
ackPolledMessages : PubkeyHex -> Int -> IO {rw *forwards, rw *messages} {}
ackPolledMessages = \pubkey cursor -> do
  msgs <- *messages
  let matches = \m -> m.toKey == pubkey && m.receivedAt <= cursor
  let toAck = filter msgs matches
  let blobs = pluck toAck (\m -> m.encryptedBlob)
  *messages = removeWhere msgs matches
  fwds <- *forwards
  *forwards = filter fwds (\f -> not (f.toKey == pubkey && elem f.encryptedBlob blobs))

-- ============================================
-- Handler: send
-- ============================================
-- Accept a message for a recipient pubkey. Placement (live local session,
-- federated forward, or held-for-presence) is internal; the response only
-- says whether the message was accepted (`error: ""`) or refused (`error:
-- "draining" | "rate_limited" | "unauthorized" | "self_send"`). Duplicates
-- are silently treated as success so retries are idempotent.
-- Send is gated by drain phase, global rate, and the per-sender / per-pair /
-- per-recipient rate limits charged together inside `sendMessageCore`.
-- Federated forwards are kicked off in a background fork after the atomic.

-- POST /messages: send a list of ciphertexts. Each entry runs through
-- `sendMessageCore` separately so per-entry rate limits/errors don't abort
-- the rest; federated forwards are forked per entry. Top-level `error`
-- carries global gate failures ("draining" | "rate_limited" | "unauthorized")
-- and short-circuits with empty `results`.
handleSendMessages : [{encryptedBlob: BlobHex, to: PubkeyHex | a}] -> Text -> Text -> ({error: Text, results: [{error: Text, messageId: MessageIdHex}], retryAfterMs: Int} -> b) -> IO {r *drainPhase, rw *globalRateCount, rw *globalRateWindowStart, r *sessions, clock} b
handleSendMessages = \messages authorization clientIp respond -> do
  t <- now
  let mkErr = \e -> {results: [], error: e, retryAfterMs: 0}
  gateAuth (True {}) authorization clientIp t respond mkErr (\senderKey -> do
    results <- mapEach (takeRelation maxBatchSize messages) (\m -> do
      let effMsgId = messageIdOf m.encryptedBlob
      r <- atomic (do sendMessageCore senderKey m.to m.encryptedBlob t)
      when federationEnabled (fork (forkForwardsTo m.to m.encryptedBlob r.remoteServers))
      yield {messageId: effMsgId, r.error})
    yield (respond {results, error: "", retryAfterMs: 0}))

-- Atomic core of /messages. Charges send/pair/recv rate
-- counters together (so any limit denies the message), enforces caps and
-- self-send/duplicate rejections, allocates a monotonic receivedAt via
-- `seqCounter`, appends the message, and pre-stages forwards for any remote
-- presence rows that already exist for `to`. Returns the error code (empty
-- on success or silent duplicate) and the list of remote servers the caller
-- should kick forwards to.
sendMessageCore : PubkeyHex -> PubkeyHex -> BlobHex -> Int<Ms> -> IO {r *deliveredIds, rw *forwards, rw *messages, rw *pairRates, rw *pollWakeup, r *presence, rw *recvRates, rw *sendRates, rw *seqCounter} {remoteServers: [Text], error: Text}
sendMessageCore = \senderKey to encryptedBlob t -> do
  msgs <- *messages
  dids <- *deliveredIds
  sRates <- *sendRates
  let sR = checkRate sRates senderKey maxSendRatePerKey sendRateWindowMs t
  *sendRates = sR.entries
  let srLim = sR.limited
  pRates <- *pairRates
  let pR = checkRate pRates (senderKey ++ "|" ++ to) maxPairRatePerPair pairRateWindowMs t
  *pairRates = pR.entries
  let prLim = pR.limited
  rRates <- *recvRates
  let rR = checkRate rRates to maxRecvRatePerKey recvRateWindowMs t
  *recvRates = rR.entries
  let rrLim = rR.limited
  let reject = \e -> yield {error: e, remoteServers: []}
  if senderKey == to
  then reject "self_send"
  else if isDuplicateMessage encryptedBlob to msgs dids
  then reject ""
  else if srLim || prLim || rrLim
  then reject "rate_limited"
  else do
    pres <- *presence
    seq <- *seqCounter
    let seqTs = nextSeqTs t seq
    *seqCounter = seqTs
    *messages = union msgs [{toKey: to, encryptedBlob, receivedAt: seqTs}]
    *pollWakeup = seqTs
    let toPresence = presenceForKey pres to t
    let remoteServers = collectPeers toPresence (\p -> p.server)
    when federationEnabled (do
      fwds <- *forwards
      let newFwds = mapWhere remoteServers (\s -> none fwds (\f -> f.encryptedBlob == encryptedBlob && f.toServer == s)) (\s -> {
        toServer: s,
        createdAt: t,
        toKey: to,
        encryptedBlob,
        retries: 0
      })
      *forwards = union fwds newFwds)
    yield {error: "", remoteServers}

-- Fire one /federation/forward call per pre-staged server. On success the
-- corresponding row in `forwards` is pruned, and if no other forwards remain
-- for this blob AND the recipient has no local presence, the backing
-- `*messages` row is dropped too: the origin's job is done and the message
-- now lives on the receiving peer's mailbox. On failure the forwards row
-- stays so `retryPendingForwards` can re-attempt with backoff.
forkForwardsTo : PubkeyHex -> BlobHex -> [Text] -> IO {} {}
forkForwardsTo = \to encryptedBlob servers -> forEach servers (\server -> do
  let effMsgId = messageIdOf encryptedBlob
  fwds <- *forwards
  let same = \x -> x.encryptedBlob == encryptedBlob && x.toServer == server
  case findFirst fwds same of
    Nothing {} -> yield {}
    Just {value: f} -> do
      t <- now
      auth <- generateFederationAuth ("forward:" ++ effMsgId) t
      result <- fetch (federationUrl server) (ForwardMessage {
        toKey: to,
        encryptedBlob,
        messageId: effMsgId,
        fromServer: serverHostN,
        requestTimestamp: t,
        authorization: auth,
        correlationId: ""
      })
      case result of
        Err _ -> recordFailure server
        Ok {value: r} -> when r.ok (do
          clearFailure server
          atomic (do
            fwds2 <- *forwards
            let remaining = filter fwds2 (\x -> not same x)
            *forwards = remaining
            pres <- *presence
            let stillLocal = any pres (\p -> p.pubkey == to && isLocalServer p.server && p.expiresAt > t)
            let othersPending = any remaining (\x -> x.encryptedBlob == encryptedBlob)
            when (not stillLocal && not othersPending) (do
              msgs <- *messages
              *messages = filter msgs (\m -> m.encryptedBlob != encryptedBlob)))))

-- ============================================
-- Handler: lookup
-- ============================================
-- Presence resolution for clients deciding where to send. Remote presence is
-- masked to the literal string "remote" rather than leaking the peer hostname
-- (the routing decision is the server's, not the sender's).

-- GET /lookup/{pubkey}: return our local server name if the key is here,
-- "remote" if known on a peer, "" otherwise. Peer hostnames are deliberately
-- masked (see section header).
handleLookupPresence : PubkeyHex -> Text -> Text -> ({authorized: Bool, error: Text, server: Text} -> a) -> IO {r *drainPhase, rw *globalRateCount, rw *globalRateWindowStart, r *sessions, clock} a
handleLookupPresence = \pubkey authorization clientIp respond -> do
  t <- now
  let mkErr = \e -> {server: "", authorized: False {}, error: if e == "rate_limited" then e else ""}
  gateLookup authorization clientIp t respond mkErr {
    server: "",
    authorized: True {},
    error: "rate_limited"
  } (\_ -> do
    pres <- *presence
    yield (respond {server: maskedServer pres pubkey t, authorized: True {}, error: ""}))

-- POST /lookup/batch: same masking as `handleLookupPresence`, but for up to
-- 50 pubkeys in one round-trip.
handleBatchLookupPresence : [PubkeyHex] -> Text -> Text -> ({authorized: Bool, error: Text, results: [{pubkey: PubkeyHex, server: Text}]} -> a) -> IO {r *drainPhase, rw *globalRateCount, rw *globalRateWindowStart, r *sessions, clock} a
handleBatchLookupPresence = \pubkeys authorization clientIp respond -> do
  t <- now
  let mkErr = \e -> {
    results: [],
    authorized: False {},
    error: if e == "rate_limited" then e else ""
  }
  gateLookup authorization clientIp t respond mkErr {
    results: [],
    authorized: True {},
    error: "rate_limited"
  } (\_ -> do
    pres <- *presence
    let results = pluck (takeRelation 50 pubkeys) (\k -> {pubkey: k, server: maskedServer pres k t})
    yield (respond {results, authorized: True {}, error: ""}))

-- POST /messages/status: classify a message as
-- pending (in mailbox), forwarding (en-route to a peer),
-- delivered (acked or terminal), or unknown.
handleMessageStatus : PubkeyHex -> MessageIdHex -> Text -> Text -> ({authorized: Bool, status: Text} -> a) -> IO {r *drainPhase, rw *globalRateCount, rw *globalRateWindowStart, r *sessions, clock} a
handleMessageStatus = \to messageId authorization clientIp respond -> do
  t <- now
  let mkErr = \_ -> {status: "", authorized: False {}}
  gateAuth (False {}) authorization clientIp t respond mkErr (\_ -> do
    msgs <- *messages
    fwds <- *forwards
    dids <- *deliveredIds
    let blobMatches = \x -> messageIdOf x.encryptedBlob == messageId && x.toKey == to
    let didMatches = \d -> d.messageId == messageId && d.toKey == to
    let s = if any msgs blobMatches
    then "pending"
    else if any fwds blobMatches
    then "forwarding"
    else if any dids didMatches then "delivered" else "unknown"
    yield (respond {status: s, authorized: True {}}))

-- ============================================
-- Handler: ack / list / delete
-- ============================================
-- Mailbox mutation by the recipient (ack, list, delete).

-- POST /messages/ack: explicit ack by message id (alternative to the implicit
-- cursor-based ack in /poll). Drops mailbox+forward rows.
handleAckMessages : [MessageIdHex] -> Text -> Text -> ({ackedCount: Int, authorized: Bool, error: Text, ok: Bool} -> a) -> IO {r *drainPhase, rw *globalRateCount, rw *globalRateWindowStart, r *sessions, clock} a
handleAckMessages = \messageIds authorization clientIp respond -> do
  t <- now
  let mkErr = \e -> {ok: False {}, authorized: False {}, ackedCount: 0, error: e}
  gateClientWrite authorization clientIp t respond mkErr {
    ok: False {},
    authorized: True {},
    ackedCount: 0,
    error: "rate_limited"
  } (\pubkey -> do
    ackedCount <- atomic (do
      toAck <- removeForKey (\x -> x.toKey == pubkey && elem (messageIdOf x.encryptedBlob) (dedupMessageIds messageIds))
      yield (count toAck))
    yield (respond {ok: True {}, authorized: True {}, ackedCount, error: ""}))

-- POST /messages/list: paginated peek at the caller's mailbox without acking.
-- Returns metadata only (no ciphertext) plus the total count.
handleListMessages : Int -> Text -> Text -> ({authorized: Bool, count: Int, error: Text, messages: [{messageId: MessageIdHex, receivedAt: Int<Ms>}]} -> a) -> IO {r *drainPhase, rw *globalRateCount, rw *globalRateWindowStart, r *sessions, clock} a
handleListMessages = \offset authorization clientIp respond -> do
  t <- now
  let mkErr = \e -> {
    messages: [],
    authorized: False {},
    count: 0,
    error: if e == "rate_limited" then e else ""
  }
  gateAuth (True {}) authorization clientIp t respond mkErr (\pubkey -> do
    lim <- atomic (do
      rates <- *lookupRates
      let r = checkRate rates pubkey maxLookupRatePerKey lookupRateWindowMs t
      *lookupRates = r.entries
      yield r.limited)
    if lim
    then yield (respond {messages: [], authorized: True {}, count: 0, error: "rate_limited"})
    else do
      msgs <- *messages
      let myMsgs = sortBy (\m -> m.receivedAt) (filter msgs (\m -> m.toKey == pubkey && t - m.receivedAt < messageMaxAge))
      let total = count myMsgs
      let page = pluck (takeRelation maxPollEvents (dropRelation (clamp 0 total offset) myMsgs)) (\m -> {
        messageId: messageIdOf m.encryptedBlob,
        m.receivedAt
      })
      yield (respond {messages: page, authorized: True {}, count: total, error: ""}))

-- POST /messages/delete: same effect as ack from the recipient's side, with
-- a "delete" semantic for the response.
handleDeleteMessages : [MessageIdHex] -> Text -> Text -> ({authorized: Bool, deletedCount: Int, error: Text, ok: Bool} -> a) -> IO {r *drainPhase, rw *globalRateCount, rw *globalRateWindowStart, r *sessions, clock} a
handleDeleteMessages = \messageIds authorization clientIp respond -> do
  t <- now
  let mkErr = \e -> {
    ok: False {},
    authorized: False {},
    deletedCount: 0,
    error: if e == "draining" then "" else e
  }
  gateClientWrite authorization clientIp t respond mkErr {
    ok: False {},
    authorized: True {},
    deletedCount: 0,
    error: "rate_limited"
  } (\pubkey -> do
    deletedCount <- atomic (do
      toDel <- removeForKey (\x -> x.toKey == pubkey && elem (messageIdOf x.encryptedBlob) (dedupMessageIds messageIds))
      yield (count toDel))
    yield (respond {ok: True {}, authorized: True {}, deletedCount, error: ""}))

-- ============================================
-- Handler: federation receive
-- ============================================
-- Inbound endpoints called peer-to-peer. Every handler funnels through
-- `withFederationAuth` which checks: peer block/allow lists, request
-- precondition (e.g. expected origin/server constraints), clock skew vs the
-- request timestamp, Ed25519 signature auth, and per-peer rate limit.

-- GET /federation/pubkey: publish the Ed25519 public key peers should use to
-- verify our `Signed ...` federation auth headers. Returns ok=False when the
-- keypair has not yet been generated (should not happen post-startup).
handleFederationPubkey : ({pubkey: Text, ok: Bool} -> ret) -> IO {r *federationPublicKeyHex} ret
handleFederationPubkey = \respond -> do
  hex <- *federationPublicKeyHex
  yield (respond {pubkey: hex, ok: hex != ""})

-- POST /federation/gossip: ingest peer presence events. The transport-level
-- `fromServer` is the home server for every event. Drops every (pubkey,
-- fromServer) row touched by this batch, then re-adds fresh-TTL rows for
-- pubkeys with a `GossipOnline` event (so Online wins on collision). For keys
-- that transition offline → online, flushes any locally-buffered messages via
-- `forwardQueuedToServer`.
handleRecvGossip : [{eventType: <GossipOffline {} | GossipOnline {} | a>, pubkey: PubkeyHex | b}] -> Text -> Int -> Text -> ({error: Text, ok: Bool, retryAfterMs: Int} -> c) -> IO {r *allowedPeers, r *blockedPeers, rw *federationRates, rw *presence, clock, network} c
handleRecvGossip = \events fromServer requestTimestamp authorization respond -> do
  t <- now
  withFederationAuth authorization t respond fromServer "gossip" requestTimestamp (isRemote fromServer && count events <= maxGossipEvents) (do
    newlyOnline <- atomic (do
      pres <- *presence
      let touchedPubkeys = pluck events (\e -> e.pubkey)
      let onlinePubkeys = pluck (filter events (\e -> case e.eventType of
        GossipOnline {} -> True {}
        _ -> False {})) (\e -> e.pubkey)
      let kept = filter pres (\p -> p.server != fromServer || not elem p.pubkey touchedPubkeys)
      let added = map (\pk -> {pubkey: pk, server: fromServer, expiresAt: t + onlineGossipTtl}) onlinePubkeys
      *presence = union kept added
      yield (filter onlinePubkeys (\pk -> none pres (\p -> p.pubkey == pk && p.server == fromServer && p.expiresAt > t))))
    fork (forEach newlyOnline (\pk -> forwardQueuedToServer pk fromServer t))
    yield (respond {ok: True {}, error: "", retryAfterMs: 0}))

-- Store a federated/forwarded message into the local mailbox. Caller wraps in `atomic`.
-- Returns "" on success (including duplicates), otherwise an error code:
-- "no_presence" | "rate_limited" (only when checkRecvRate).
--
-- The presence gate requires the recipient to be **currently locally online**
-- (not just visible to gossip somewhere). Without that, an A → B forward based
-- on stale gossip about R could land on B with no actively-polling client and
-- get stuck. If B refuses, A retries via `retryPendingForwards` against the
-- next presence target.
storeFederated : PubkeyHex -> BlobHex -> Bool -> Int<Ms> -> IO {r *deliveredIds, rw *messages, rw *pollWakeup, r *presence, rw *recvRates, rw *seqCounter} Text
storeFederated = \toKey encryptedBlob checkRecvRate t -> do
  pres <- *presence
  msgs <- *messages
  dids <- *deliveredIds
  if not any pres (\p -> p.pubkey == toKey && isLocalServer p.server && p.expiresAt > t)
  then yield "no_presence"
  else if isDuplicateMessage encryptedBlob toKey msgs dids
  then yield ""
  else do
    limited <- if checkRecvRate
    then do
      rRates <- *recvRates
      let r = checkRate rRates toKey maxRecvRatePerKey recvRateWindowMs t
      *recvRates = r.entries
      yield r.limited
    else yield (False {})
    if limited
    then yield "rate_limited"
    else do
      seq <- *seqCounter
      let seqTs = nextSeqTs t seq
      *seqCounter = seqTs
      *messages = union msgs [{toKey, encryptedBlob, receivedAt: seqTs}]
      *pollWakeup = seqTs
      yield ""

-- POST /federation/forward: receive a single federated message destined for
-- a local key. Delegates the actual store decision to `storeFederated`,
-- which returns "" on success (including the duplicate case). The peer-
-- supplied messageId in the request body is ignored: we derive the id from
-- the blob ourselves so a hostile peer cannot bypass dedup by varying the
-- id. Honest senders derive the same value, so the "forward:" ++ messageId
-- auth scope still verifies.
handleForwardMessage : PubkeyHex -> BlobHex -> Text -> Text -> Int -> Text -> ({error: Text, ok: Bool, retryAfterMs: Int} -> a) -> IO {r *allowedPeers, r *blockedPeers, rw *federationRates, r *deliveredIds, rw *messages, rw *pollWakeup, r *presence, rw *recvRates, rw *seqCounter, clock, network} a
handleForwardMessage = \toKey encryptedBlob _ fromServer requestTimestamp authorization respond -> do
  let messageId = messageIdOf encryptedBlob
  t <- now
  withFederationAuth authorization t respond fromServer ("forward:" ++ messageId) requestTimestamp (isRemote fromServer) (do
    result <- atomic storeFederated toKey encryptedBlob (True {}) t
    yield (respond {ok: result == "", error: result, retryAfterMs: 0}))

-- POST /federation/forward-batch: bulk variant of `handleForwardMessage`.
-- Skips per-entry recv-rate charging (the per-server federation rate limit
-- already gates the call as a whole).
handleFederationBatchForward : [{encryptedBlob: BlobHex, messageId: MessageIdHex, toKey: PubkeyHex | a}] -> Text -> Int -> Text -> ({error: Text, ok: Bool, results: [{messageId: MessageIdHex, ok: Bool}], retryAfterMs: Int} -> b) -> IO {r *allowedPeers, r *blockedPeers, rw *federationRates, clock, network} b
handleFederationBatchForward = \forwards fromServer requestTimestamp authorization respond -> do
  t <- now
  let batchRespond = \r -> respond {r.ok, r.error, results: [], r.retryAfterMs}
  withFederationAuth authorization t batchRespond fromServer "forward-batch" requestTimestamp (isRemote fromServer && count forwards <= maxBatchSize) (do
    results <- mapEach (takeRelation maxBatchSize forwards) (\e -> do
      -- Recompute id from blob; ignore e.messageId (untrusted, peer-chosen).
      let messageId = messageIdOf e.encryptedBlob
      result <- atomic storeFederated e.toKey e.encryptedBlob (False {}) t
      yield {messageId, ok: result == ""})
    yield (respond {ok: True {}, error: "", results, retryAfterMs: 0}))

-- ============================================
-- Maintenance handlers
-- ============================================
-- Operator endpoints, all gated by `runtimeMaintenanceSecret` (Bearer header).
-- Drain is two-phase: phase 1 stops accepting new auth, phase 2 also clears
-- local presence and gossips offline. Admin endpoints can revoke sessions by
-- pubkey or IP, purge a recipient's mailbox, list aggregated session activity,
-- block/allow peers, rotate the maintenance secret, and read live config.

-- POST /maintenance/drain: phase 1 stops accepting new auth (challenges,
-- verify); phase 2 additionally clears local presence and broadcasts offline
-- gossip for every locally-live key so peers can reroute. Idempotent.
handleDrain : Int -> Text -> ({drained: Int, ok: Bool, phase: Int} -> a) -> IO {rw *drainCompletedAt, rw *drainPhase, rw *pollWakeup, rw *presence, r *runtimeMaintenanceSecret, clock} a
handleDrain = \phase authorization respond -> withMaintAuth authorization (yield (respond {
  ok: False {},
  drained: 0,
  phase: 0
})) (do
  let effectivePhase = if phase == 1 then 1 else 2
  t <- now
  drainResult <- atomic (do
    *drainPhase = effectivePhase
    *drainCompletedAt = t
    if effectivePhase == 1
    then yield {peers: [], localKeys: []}
    else do
      pres <- *presence
      let isLocalLive = \p -> isLocalServer p.server && p.expiresAt > t
      *presence = removeWhere pres isLocalLive
      *pollWakeup = t
      yield {peers: knownPeerServersFromPresence pres, localKeys: filter pres isLocalLive})
  when (effectivePhase == 2 && count drainResult.localKeys > 0 && federationEnabled) (fork (sendBatchedGossip drainResult.peers (pluck drainResult.localKeys (\p -> mkGossip (GossipOffline {}) p.pubkey))))
  yield (respond {ok: True {}, drained: count drainResult.localKeys, phase: effectivePhase}))

-- POST /maintenance/undrain: clear drain state and resume normal operation.
-- Does not restore presence — clients must re-authenticate to repopulate.
handleUndrain : Text -> ({ok: Bool} -> a) -> IO {rw *drainCompletedAt, rw *drainPhase, r *runtimeMaintenanceSecret} a
handleUndrain = \authorization respond -> withMaintAuth authorization (yield (respond {ok: False {}})) (do
  atomic (do *drainPhase = 0; *drainCompletedAt = 0)
  yield (respond {ok: True {}}))

-- POST /maintenance/shutdown: convenience wrapper that performs a phase-2
-- drain and reports the count of presence rows cleared.
handleShutdown : Text -> ({drained: Int, ok: Bool} -> a) -> IO {rw *drainCompletedAt, rw *drainPhase, rw *pollWakeup, rw *presence, r *runtimeMaintenanceSecret, clock} a
handleShutdown = \authorization respond -> handleDrain 2 authorization (\r -> respond {
  r.ok,
  r.drained
})

-- POST /maintenance/prune: trigger an out-of-band `pruneAndRetry` tick.
-- Useful when the operator wants to force expiry/forward retries without
-- waiting for the next `backgroundPrune` interval.
handlePrune : Text -> ({ok: Bool} -> a) -> IO {r *runtimeMaintenanceSecret, rw *activePolls, r *blockedPeers, rw *challenges, rw *deliveredIds, rw *forwardFailures, rw *forwards, rw *lastPresenceRefresh, rw *lastPrunedAt, rw *messages, rw *presence, rw *sessions, clock} a
handlePrune = \authorization respond -> do
  t <- now
  authorized <- verifyMaintenanceAuth authorization
  when authorized (fork (pruneAndRetry t))
  yield (respond {ok: authorized})

-- POST /maintenance/reconcile: stub. Production builds run a state
-- reconciliation pass here; this simplified server reports zero drift.
handleReconcile : Text -> ({messageDrift: Int, ok: Bool, presenceDrift: Int, sessionDrift: Int} -> a) -> IO {r *runtimeMaintenanceSecret} a
handleReconcile = \authorization respond -> do
  authorized <- verifyMaintenanceAuth authorization
  yield (respond {ok: authorized, messageDrift: 0, presenceDrift: 0, sessionDrift: 0})

-- GET /health: aggregate readiness flags. During an initial warmup window
-- (3 prune intervals after startup) prune/heartbeat checks always pass to
-- avoid false negatives before the background loops have ticked.
handleHealth : a -> ({capacityHealthy: Bool, capacityWarning: Bool, degradedPeers: Int, draining: Bool, federationHealthy: Bool, forwardQueueHealthy: Bool, heartbeatHealthy: Bool, nonceHealthy: Bool, ok: Bool, pruneHealthy: Bool, requestPressureHealthy: Bool, version: Text, watchdogHealthy: Bool} -> b) -> IO {r *drainPhase, r *lastHeartbeatAt, r *lastPrunedAt, r *startedAt, clock} b
handleHealth = \authorization respond -> do
  t <- now
  lastPrune <- *lastPrunedAt
  lastHb <- *lastHeartbeatAt
  sa <- *startedAt
  dp <- *drainPhase
  let warmup = t - sa < backgroundPruneInterval * 3
  let pruneOk = warmup || t - lastPrune < backgroundPruneInterval * 3
  let heartbeatOk = warmup || t - lastHb < pollTimeoutMs * 3
  yield (respond {
    ok: dp == 0 && pruneOk && heartbeatOk,
    version: serverBuildVersion,
    pruneHealthy: pruneOk,
    heartbeatHealthy: heartbeatOk,
    capacityHealthy: True {},
    capacityWarning: False {},
    federationHealthy: True {},
    watchdogHealthy: True {},
    nonceHealthy: True {},
    forwardQueueHealthy: True {},
    requestPressureHealthy: True {},
    draining: dp > 0,
    degradedPeers: 0
  })

-- GET /ready: signals readiness once the first background prune has run
-- (load-balancer / orchestrator probe).
handleReady : ({ready: Bool} -> a) -> IO {r *lastPrunedAt, r *startedAt} a
handleReady = \respond -> do
  sa <- *startedAt
  lastPrune <- *lastPrunedAt
  yield (respond {ready: lastPrune > 0 && lastPrune >= sa})

-- POST /maintenance/block: deny-list a peer. Outbound retries skip blocked
-- peers; inbound federation calls from blocked peers fail in `withFederationAuth`.
handleBlockPeer : Text -> Text -> ({blocked: Int, ok: Bool} -> a) -> IO {rw *blockedPeers, r *runtimeMaintenanceSecret} a
handleBlockPeer = \server authorization respond -> withMaintAuth authorization (yield (respond {
  ok: False {},
  blocked: 0
})) (do
  n <- atomic (do
    current <- *blockedPeers
    let updated = union current [server]
    *blockedPeers = updated
    yield (count updated))
  yield (respond {ok: True {}, blocked: n}))

-- POST /maintenance/unblock: remove a peer from the deny-list.
handleUnblockPeer : Text -> Text -> ({ok: Bool, unblocked: Bool} -> a) -> IO {rw *blockedPeers, r *runtimeMaintenanceSecret} a
handleUnblockPeer = \server authorization respond -> withMaintAuth authorization (yield (respond {
  ok: False {},
  unblocked: False {}
})) (do
  removed <- atomic (do
    current <- *blockedPeers
    *blockedPeers = removeWhere current (\x -> x == server)
    yield (elem server current))
  yield (respond {ok: True {}, unblocked: removed}))

-- GET /maintenance/blocked: list the deny-listed peers (empty for unauthorized).
handleListBlocked : Text -> ({ok: Bool, peers: [Text]} -> a) -> IO {r *blockedPeers, r *runtimeMaintenanceSecret} a
handleListBlocked = \authorization respond -> do
  ok <- verifyMaintenanceAuth authorization
  list <- *blockedPeers
  yield (respond {peers: if ok then list else [], ok})

-- POST /maintenance/allow: when the allowed-peers list is non-empty, only
-- federation calls from listed peers are accepted (whitelist mode). An empty
-- list disables the whitelist.
handleAllowPeer : Text -> Text -> ({allowed: Int, ok: Bool} -> a) -> IO {rw *allowedPeers, r *runtimeMaintenanceSecret} a
handleAllowPeer = \server authorization respond -> withMaintAuth authorization (yield (respond {
  ok: False {},
  allowed: 0
})) (do
  n <- atomic (do
    current <- *allowedPeers
    let updated = union current [server]
    *allowedPeers = updated
    yield (count updated))
  yield (respond {ok: True {}, allowed: n}))

-- POST /maintenance/unallow: remove an entry from the allow-list. If the
-- list becomes empty, the whitelist gate disengages.
handleUnallowPeer : Text -> Text -> ({ok: Bool, removed: Bool} -> a) -> IO {rw *allowedPeers, r *runtimeMaintenanceSecret} a
handleUnallowPeer = \server authorization respond -> withMaintAuth authorization (yield (respond {
  ok: False {},
  removed: False {}
})) (do
  removed <- atomic (do
    current <- *allowedPeers
    *allowedPeers = removeWhere current (\x -> x == server)
    yield (elem server current))
  yield (respond {ok: True {}, removed}))

-- GET /maintenance/allowed: list the allow-listed peers (empty for unauthorized).
handleListAllowed : Text -> ({ok: Bool, peers: [Text]} -> a) -> IO {r *allowedPeers, r *runtimeMaintenanceSecret} a
handleListAllowed = \authorization respond -> do
  ok <- verifyMaintenanceAuth authorization
  list <- *allowedPeers
  yield (respond {peers: if ok then list else [], ok})

-- POST /maintenance/ping: send a zero-event gossip to a peer and return the
-- round-trip latency. Useful for diagnosing federation reachability without
-- waiting for organic traffic.
handlePingPeer : Text -> Text -> ({error: Text, latencyMs: Int, ok: Bool} -> a) -> IO {r *federationPrivateKeyHex, r *runtimeMaintenanceSecret, network, clock, random} a
handlePingPeer = \server authorization respond -> withMaintAuth authorization (yield (respond {
  ok: False {},
  latencyMs: 0,
  error: "unauthorized"
})) (do
  startTime <- now
  auth <- generateFederationAuth "gossip" startTime
  result <- fetch (federationUrl server) (RecvGossip {
    authorization: auth,
    events: [],
    fromServer: serverHostN,
    requestTimestamp: startTime,
    correlationId: ""
  })
  endTime <- now
  case result of
    Err e -> yield (respond {ok: False {}, latencyMs: endTime - startTime, error: show e})
    Ok {value: r} -> yield (respond {r.ok, latencyMs: endTime - startTime, r.error}))

-- GET /maintenance/sessions/{pubkey}: list a single user's active sessions.
-- Token values are masked ("***") — operators see expiry, ip, createdAt only.
handleAdminListSessions : PubkeyHex -> Text -> ({count: Int, ok: Bool, sessions: [{createdAt: Int<Ms>, expiresAt: Int<Ms>, ip: Text, token: Text}]} -> a) -> IO {r *runtimeMaintenanceSecret, r *sessions} a
handleAdminListSessions = \pubkey authorization respond -> do
  ok <- verifyMaintenanceAuth authorization
  ses <- *sessions
  let mine = if ok
  then mapWhere ses (\s -> s.pubkey == pubkey) (\s -> {token: "***", s.expiresAt, s.ip, s.createdAt})
  else []
  yield (respond {sessions: mine, count: count mine, ok})

-- POST /maintenance/sessions/revoke-all: drop every session and local presence
-- row for `pubkey`. Operator-side kick for a compromised key.
handleAdminRevokeSessions : PubkeyHex -> Text -> ({ok: Bool, revokedCount: Int} -> a) -> IO {rw *presence, r *runtimeMaintenanceSecret, rw *sessions} a
handleAdminRevokeSessions = \pubkey authorization respond -> withMaintAuth authorization (yield (respond {
  ok: False {},
  revokedCount: 0
})) (do
  revoked <- atomic (do
    ses <- *sessions
    let same = \s -> s.pubkey == pubkey
    *sessions = removeWhere ses same
    pres <- *presence
    *presence = filter pres (\p -> p.pubkey != pubkey || isRemote p.server)
    yield (countWhere ses same))
  yield (respond {ok: True {}, revokedCount: revoked}))

-- POST /maintenance/messages/purge: drop all queued/forwarding messages
-- destined for `pubkey`. With the federation ack flow gone, there's nothing
-- to ack back — peers will discover the absence on their next forward attempt.
handleAdminPurgeMessages : PubkeyHex -> Text -> ({ok: Bool, purgedCount: Int} -> a) -> IO {rw *forwards, rw *messages, r *runtimeMaintenanceSecret} a
handleAdminPurgeMessages = \pubkey authorization respond -> withMaintAuth authorization (yield (respond {
  ok: False {},
  purgedCount: 0
})) (do
  purged <- atomic (do
    msgs <- *messages
    let mine = \m -> m.toKey == pubkey
    let purgedMsgs = filter msgs mine
    *messages = removeWhere msgs mine
    fwds <- *forwards
    *forwards = filter fwds (\f -> f.toKey != pubkey)
    yield (count purgedMsgs))
  yield (respond {ok: True {}, purgedCount: purged}))

-- POST /maintenance/sessions/revoke-ip: kill every session bound to a given
-- client IP, regardless of pubkey. Reports total revoked + distinct keys.
handleAdminRevokeIp : Text -> Text -> ({affectedKeys: Int, ok: Bool, revokedCount: Int} -> a) -> IO {r *runtimeMaintenanceSecret, rw *sessions} a
handleAdminRevokeIp = \ip authorization respond -> withMaintAuth authorization (yield (respond {
  ok: False {},
  revokedCount: 0,
  affectedKeys: 0
})) (do
  keys <- if ip == ""
  then yield []
  else atomic (do
    ses <- *sessions
    let same = \s -> s.ip == ip
    *sessions = removeWhere ses same
    yield (mapWhere ses same (\s -> s.pubkey)))
  yield (respond {ok: ip != "", revokedCount: count keys, affectedKeys: count keys}))

-- POST /maintenance/sessions/list: paged session inventory aggregated by
-- pubkey (count, distinct ips, latest expiry). Sorted by descending count.
handleAdminListAllSessions : Int -> Text -> ({ok: Bool, sessions: [{count: Int, ips: [Text], latestExpiry: Int, pubkey: PubkeyHex}], total: Int} -> a) -> IO {r *runtimeMaintenanceSecret, r *sessions, clock} a
handleAdminListAllSessions = \limit authorization respond -> withMaintAuth authorization (yield (respond {
  sessions: [],
  ok: False {},
  total: 0
})) (do
  t <- now
  ses <- *sessions
  let active = filter ses (\s -> s.expiresAt > t)
  let grouped = pluck (pluck active (\s -> s.pubkey)) (\pk -> (\mine -> {pubkey: pk, count: count mine, ips: mapWhere mine (\s -> s.ip != "") (\s -> s.ip), latestExpiry: fold (\acc s -> max acc s.expiresAt) 0 mine}) (filter active (\s -> s.pubkey == pk)))
  let cap = clamp 1 500 (if limit <= 0 then 100 else limit)
  let top = takeRelation cap (sortBy (\g -> 0 - g.count) grouped)
  yield (respond {sessions: top, ok: True {}, total: count grouped}))

-- GET /maintenance/rate-limits: expose the configured rate ceilings. Returns
-- zeros for unauthenticated callers (response shape stays stable).
handleGetRateLimits : Text -> ({authGlobal: Int, challengeRate: Int, clientWriteRate: Int, federationRate: Int, globalRequest: Int, ipRate: Int, lookupRate: Int, ok: Bool, pairRate: Int, recvRate: Int, sendRate: Int} -> a) -> IO {r *runtimeMaintenanceSecret} a
handleGetRateLimits = \authorization respond -> do
  ok <- verifyMaintenanceAuth authorization
  let v = \x -> if ok then x else 0
  yield (respond {
    ok,
    globalRequest: v maxGlobalRequestRate,
    ipRate: v maxIpRatePerIp,
    sendRate: v maxSendRatePerKey,
    federationRate: v maxFederationRatePerServer,
    authGlobal: v maxAuthGlobalRate,
    recvRate: v maxRecvRatePerKey,
    challengeRate: v maxChallengeRatePerKey,
    pairRate: v maxPairRatePerPair,
    lookupRate: v maxLookupRatePerKey,
    clientWriteRate: v maxClientWriteRatePerKey
  })

-- POST /maintenance/rate-limits: stub. Rate ceilings are compile-time constants
-- in this simplified server, so this just authorizes and returns ok=true.
handleSetRateLimits : a -> b -> c -> d -> e -> f -> g -> h -> i -> j -> Text -> ({ok: Bool} -> k) -> IO {r *runtimeMaintenanceSecret} k
handleSetRateLimits = \globalRequest ipRate sendRate federationRate authGlobal recvRate challengeRate pairRate lookupRate clientWriteRate authorization respond -> do
  authorized <- verifyMaintenanceAuth authorization
  yield (respond {ok: authorized})

-- POST /maintenance/nonces/flush: stub. Nonce caches were removed; the
-- endpoint is preserved so older operator tooling keeps working.
handleFlushNonces : Text -> ({flushedCount: Int, ok: Bool} -> a) -> IO {r *runtimeMaintenanceSecret} a
handleFlushNonces = \authorization respond -> do
  authorized <- verifyMaintenanceAuth authorization
  yield (respond {ok: authorized, flushedCount: 0})

-- POST /maintenance/rotate-secret: replace the maintenance Bearer secret.
-- The old secret authenticates the rotation; subsequent calls must use the
-- new value.
handleRotateSecret : Text -> Text -> ({error: Text, ok: Bool} -> a) -> IO {rw *runtimeMaintenanceSecret} a
handleRotateSecret = \newSecret authorization respond -> withMaintAuth authorization (yield (respond {
  ok: False {},
  error: "unauthorized"
})) (do
  atomic *runtimeMaintenanceSecret = newSecret
  yield (respond {ok: True {}, error: ""}))

-- GET /maintenance/config: expose a small set of operationally-relevant
-- compile-time constants (poll timeout, ack grace).
handleGetConfig : Text -> ({ackGracePeriod: Int, ok: Bool, pollTimeoutMs: Int} -> a) -> IO {r *runtimeMaintenanceSecret} a
handleGetConfig = \authorization respond -> do
  ok <- verifyMaintenanceAuth authorization
  let v = \x -> if ok then x else 0
  yield (respond {ok, pollTimeoutMs: v pollTimeoutMs, ackGracePeriod: v ackGracePeriod})

-- GET /stats: capacity gauges + minimal federation/timing snapshot. Most of
-- the historical metric fields are zero-filled (see `zeroStats`) — only the
-- counts that come straight from the state refs are populated.
handleStats : Text -> ({capacity: {activePolls: Int, challenges: Int, challengesMax: Int, deliveredIds: Int, deliveredIdsMax: Int, forwardNonces: Int, forwardNoncesMax: Int, forwards: Int, messageBucketMax: Int, messageBucketMin: Int, messages: Int, nonceEvictions: Int, presence: Int, recipientCounts: Int, sessions: Int, sessionsMax: Int, sessionsPct: Int, totalMessageCount: Int}, federation: {avgLatencyMs: Int, blockedPeers: Int, callCount: Int, drainCompletedAt: Timestamp, enabled: Bool, forwardFailures: Int, forwardServers: Int, gossipFail: Int, gossipSuccess: Int, hungSlots: Int, inFlight: Int, latencyBuckets: {gte2000: Int, lt100: Int, lt2000: Int, lt500: Int}, maxForwardQueueDepth: Int, maxLatencyMs: Int, oldestAckAge: Int, oldestForwardAge: Int, recentGossip: Int, slowVerifies: Int, topFailingPeers: [{failures: Int, server: Text}], verifyFailures: Int}, ok: Bool, rates: {challenge: Int, federation: Int, federationPair: Int, global: Int, gossipEvent: Int, ip: Int, lookup: Int, pair: Int, pendingAckCleanups: Int, recv: Int, rejectedAuth: Int, rejectedFederation: Int, rejectedGlobal: Int, rejectedIp: Int, rejectedPerKey: Int, send: Int, uniqueKeyIp: Int, verifyIp: Int}, timing: {activeRequests: Int, authAvgMs: Int, authCount: Int, authMaxMs: Int, drainPhase: Int, draining: Bool, heartbeatCount: Int, lastHeartbeatAt: Timestamp, lastPruneAt: Timestamp, peakActiveRequests: Int, pollAvgMs: Int, pollCount: Int, pollLatencyBuckets: {gte1000: Int, lt1000: Int, lt200: Int, lt50: Int}, pollMaxMs: Int, pruneCount: Int, pruneRunning: Timestamp, sendAvgMs: Int, sendCount: Int, sendLatencyBuckets: {gte1000: Int, lt1000: Int, lt200: Int, lt50: Int}, sendMaxMs: Int, totalEntries: Int, uptime: Int}, version: Text} -> a) -> IO {r *activePolls, r *blockedPeers, r *challenges, r *deliveredIds, r *drainPhase, r *forwards, r *heartbeatCount, r *lastHeartbeatAt, r *lastPrunedAt, r *messages, r *presence, r *pruneCount, r *runtimeMaintenanceSecret, r *sessions, r *startedAt, clock} a
handleStats = \authorization respond -> withMaintAuth authorization (yield (respond zeroStats)) (do
  t <- now
  sa <- *startedAt
  sessions <- *sessions
  msgs <- *messages
  pres <- *presence
  fwds <- *forwards
  dids <- *deliveredIds
  aps <- *activePolls
  chs <- *challenges
  bp <- *blockedPeers
  pc <- *pruneCount
  hc <- *heartbeatCount
  lp <- *lastPrunedAt
  lh <- *lastHeartbeatAt
  dp <- *drainPhase
  let sCount = count sessions
  let mCount = count msgs
  let pCount = count pres
  let fCount = count fwds
  yield (respond {
    ok: True {},
    version: serverBuildVersion,
    capacity: {
      sessions: sCount,
      sessionsMax: maxSessions,
      sessionsPct: pct sCount maxSessions,
      messages: mCount,
      totalMessageCount: mCount,
      presence: pCount,
      forwards: fCount,
      challenges: count chs,
      challengesMax: maxChallenges,
      deliveredIds: count dids,
      deliveredIdsMax: maxDeliveredIds,
      forwardNonces: 0,
      forwardNoncesMax: 0,
      nonceEvictions: 0,
      activePolls: count aps,
      recipientCounts: 0,
      messageBucketMax: 0,
      messageBucketMin: 0
    },
    federation: {
      enabled: federationEnabled,
      inFlight: 0,
      hungSlots: 0,
      avgLatencyMs: 0,
      maxLatencyMs: 0,
      callCount: 0,
      slowVerifies: 0,
      verifyFailures: 0,
      forwardFailures: 0,
      oldestForwardAge: 0,
      oldestAckAge: 0,
      recentGossip: 0,
      blockedPeers: count bp,
      drainCompletedAt: 0,
      forwardServers: 0,
      maxForwardQueueDepth: 0,
      topFailingPeers: [],
      gossipSuccess: 0,
      gossipFail: 0,
      latencyBuckets: {lt100: 0, lt500: 0, lt2000: 0, gte2000: 0}
    },
    rates: {
      send: 0,
      challenge: 0,
      federation: 0,
      federationPair: 0,
      global: 0,
      ip: 0,
      lookup: 0,
      recv: 0,
      pair: 0,
      gossipEvent: 0,
      verifyIp: 0,
      uniqueKeyIp: 0,
      pendingAckCleanups: 0,
      rejectedGlobal: 0,
      rejectedIp: 0,
      rejectedAuth: 0,
      rejectedPerKey: 0,
      rejectedFederation: 0
    },
    timing: {
      pruneCount: pc,
      pruneRunning: 0,
      heartbeatCount: hc,
      uptime: t - sa,
      lastPruneAt: lp,
      lastHeartbeatAt: lh,
      draining: dp > 0,
      drainPhase: dp,
      totalEntries: sCount + mCount + pCount + fCount,
      activeRequests: 0,
      peakActiveRequests: 0,
      pollAvgMs: 0,
      pollMaxMs: 0,
      pollCount: 0,
      pollLatencyBuckets: {lt50: 0, lt200: 0, lt1000: 0, gte1000: 0},
      sendAvgMs: 0,
      sendMaxMs: 0,
      sendCount: 0,
      sendLatencyBuckets: {lt50: 0, lt200: 0, lt1000: 0, gte1000: 0},
      authAvgMs: 0,
      authMaxMs: 0,
      authCount: 0
    }
  }))

-- All-zero /stats payload returned to unauthorized callers. The shape is kept
-- in lockstep with the response in `handleStats` so older operator tooling
-- never sees a missing field.
zeroStats : {capacity: {activePolls: Int, challenges: Int, challengesMax: Int, deliveredIds: Int, deliveredIdsMax: Int, forwardNonces: Int, forwardNoncesMax: Int, forwards: Int, messageBucketMax: Int, messageBucketMin: Int, messages: Int, nonceEvictions: Int, presence: Int, recipientCounts: Int, sessions: Int, sessionsMax: Int, sessionsPct: Int, totalMessageCount: Int}, federation: {avgLatencyMs: Int, blockedPeers: Int, callCount: Int, drainCompletedAt: Timestamp, enabled: Bool, forwardFailures: Int, forwardServers: Int, gossipFail: Int, gossipSuccess: Int, hungSlots: Int, inFlight: Int, latencyBuckets: {gte2000: Int, lt100: Int, lt2000: Int, lt500: Int}, maxForwardQueueDepth: Int, maxLatencyMs: Int, oldestAckAge: Int, oldestForwardAge: Int, recentGossip: Int, slowVerifies: Int, topFailingPeers: [{failures: Int, server: Text}], verifyFailures: Int}, ok: Bool, rates: {challenge: Int, federation: Int, federationPair: Int, global: Int, gossipEvent: Int, ip: Int, lookup: Int, pair: Int, pendingAckCleanups: Int, recv: Int, rejectedAuth: Int, rejectedFederation: Int, rejectedGlobal: Int, rejectedIp: Int, rejectedPerKey: Int, send: Int, uniqueKeyIp: Int, verifyIp: Int}, timing: {activeRequests: Int, authAvgMs: Int, authCount: Int, authMaxMs: Int, drainPhase: Int, draining: Bool, heartbeatCount: Int, lastHeartbeatAt: Timestamp, lastPruneAt: Timestamp, peakActiveRequests: Int, pollAvgMs: Int, pollCount: Int, pollLatencyBuckets: {gte1000: Int, lt1000: Int, lt200: Int, lt50: Int}, pollMaxMs: Int, pruneCount: Int, pruneRunning: Timestamp, sendAvgMs: Int, sendCount: Int, sendLatencyBuckets: {gte1000: Int, lt1000: Int, lt200: Int, lt50: Int}, sendMaxMs: Int, totalEntries: Int, uptime: Int}, version: Text}
zeroStats = {
  ok: False {},
  version: serverBuildVersion,
  capacity: {
    sessions: 0,
    sessionsMax: 0,
    sessionsPct: 0,
    messages: 0,
    totalMessageCount: 0,
    presence: 0,
    forwards: 0,
    challenges: 0,
    challengesMax: 0,
    deliveredIds: 0,
    deliveredIdsMax: 0,
    forwardNonces: 0,
    forwardNoncesMax: 0,
    nonceEvictions: 0,
    activePolls: 0,
    recipientCounts: 0,
    messageBucketMax: 0,
    messageBucketMin: 0
  },
  federation: {
    enabled: False {},
    inFlight: 0,
    hungSlots: 0,
    avgLatencyMs: 0,
    maxLatencyMs: 0,
    callCount: 0,
    slowVerifies: 0,
    verifyFailures: 0,
    forwardFailures: 0,
    oldestForwardAge: 0,
    oldestAckAge: 0,
    recentGossip: 0,
    blockedPeers: 0,
    drainCompletedAt: 0,
    forwardServers: 0,
    maxForwardQueueDepth: 0,
    topFailingPeers: [],
    gossipSuccess: 0,
    gossipFail: 0,
    latencyBuckets: {lt100: 0, lt500: 0, lt2000: 0, gte2000: 0}
  },
  rates: {
    send: 0,
    challenge: 0,
    federation: 0,
    federationPair: 0,
    global: 0,
    ip: 0,
    lookup: 0,
    recv: 0,
    pair: 0,
    gossipEvent: 0,
    verifyIp: 0,
    uniqueKeyIp: 0,
    pendingAckCleanups: 0,
    rejectedGlobal: 0,
    rejectedIp: 0,
    rejectedAuth: 0,
    rejectedPerKey: 0,
    rejectedFederation: 0
  },
  timing: {
    pruneCount: 0,
    pruneRunning: 0,
    heartbeatCount: 0,
    uptime: 0,
    lastPruneAt: 0,
    lastHeartbeatAt: 0,
    draining: False {},
    drainPhase: 0,
    totalEntries: 0,
    activeRequests: 0,
    peakActiveRequests: 0,
    pollAvgMs: 0,
    pollMaxMs: 0,
    pollCount: 0,
    pollLatencyBuckets: {lt50: 0, lt200: 0, lt1000: 0, gte1000: 0},
    sendAvgMs: 0,
