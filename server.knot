    = StatsRates

route MetricsApi where
  GET /metrics headers {authorization: Text} -> {metrics: Text, ok: Bool} = Metrics

route ReadyApi where
  GET /ready -> {ready: Bool} = Ready

route Api = AuthApi | ClientApi | FederationApi | FederationVerifyApi | FederationPubkeyApi | MaintenanceApi | HealthApi | StatsApi | MetricsApi | ReadyApi

-- ============================================
-- Generic helpers
-- ============================================

id = \x -> x
filter = \xs pred -> do x <- xs; where pred x; yield x
removeWhere = \xs pred -> filter xs (\x -> not (pred x))
pluck = \xs f -> do x <- xs; yield (f x)
mapWhere = \xs pred -> pluck (filter xs pred)
countWhere = \xs pred -> count (filter xs pred)
any : [a] -> (a -> Bool) -> Bool
any = \xs pred -> countWhere xs pred > 0
none : [a] -> (a -> Bool) -> Bool
none = \xs pred -> not (any xs pred)
all : [a] -> (a -> Bool) -> Bool
all = \xs pred -> countWhere xs pred == count xs
elem = \xs x -> any xs (\y -> y == x)
findFirst = \xs pred -> headOf (filter xs pred)
when = \cond action -> if cond then action else yield {}
min = \a b -> if a < b then a else b
max = \a b -> if a > b then a else b
clamp = \lo hi x -> max lo (min hi x)
mod = \n m -> n - n / m * m
abs = \x -> if x < 0 then 0 - x else x

-- Dedup: keeps first occurrence (O(n^2)).
unique = \items -> fold (\acc x -> if elem acc x then acc else union acc [x]) [] items

-- Replace a ref's contents with the entries that satisfy `keep`. Caller controls atomicity.
pruneRef = \ref keep -> do
  cur <- *ref
  set *ref = filter cur keep

-- Append `items` to a ref, then cap by `getKey` (drops oldest on overflow).
appendCapped = \ref items maxN getKey -> do
  cur <- *ref
  set *ref = capList (union cur items) maxN getKey

-- Add `server` to the named list ref if absent. Returns the new total.
addServerToList = \listRef server -> atomic do
  current <- *listRef
  let updated = unique (union current [server])
  set *listRef = updated
  yield (count updated)

-- Remove `server` from the named list ref. Returns whether it was present.
removeServerFromList = \listRef server -> atomic do
  current <- *listRef
  set *listRef = removeWhere current (\x -> x == server)
  yield (elem current server)

headOf = \items -> fold (\_ x -> Just {value: x}) Nothing {} (take 1 items)

-- Cap to maxN by dropping the single entry with the smallest key (LRU-style).
capList = \items maxN getKey ->
  if count items > maxN then drop 1 (sortBy getKey items) else items

-- Integer percentage with zero-denominator guard.
pct = \cur maxN -> if maxN > 0 then cur * 100 / maxN else 0

-- Read entries matching `pred` (transformed by `extract`) and prune them in one step.
collectAndPrune = \ref pred extract -> do
  items <- *ref
  pruneRef ref (\x -> not (pred x))
  yield (mapWhere items pred extract)

-- Common ack/delete tail: pull matching messages, drop them and their forwards.
removeForKey = \pred -> do
  msgs <- *messages
  let toRemove = filter msgs pred
  set *messages = removeWhere msgs pred
  pruneRef forwards (\f -> not (pred f))
  yield toRemove

-- If `pred` matches at least maxN items, drop the oldest matching one.
capPerKey = \items pred maxN getKey ->
  let mine = filter items pred in
  if count mine >= maxN
    then union (removeWhere items pred) (drop 1 (sortBy getKey mine))
    else items

-- Shared empty/error shape for /poll. Only a few fields ever vary.
emptyPollResp = \cursor authorized rateLimited draining gen retryAfterMs cursorWasReset ->
  {events: [], cursor: cursor, authorized: authorized, rateLimited: rateLimited, draining: draining, generation: gen, presenceUpdates: [], heartbeat: False {}, retryAfterMs: retryAfterMs, cursorReset: cursorWasReset, hasMore: False {}, cursorStale: False {}, messageExpirations: [], messageDeliveries: [], droppedDeliveryReceipts: 0, droppedExpirationNotifs: 0, loadPct: 0, messageCancellations: []}

-- Shared error shape for /messages send.
sendErrResp = \status err -> {status: status, messageId: "", retryAfterMs: 0, error: err, loadPct: 0}

-- True when a send produced (or matched) a deliverable message.
isSendSuccess = \s -> case s of
  MsDelivered {} -> True {}
  MsFederated {} -> True {}
  MsQueued {} -> True {}
  MsDuplicate {} -> True {}
  _ -> False {}

-- Sequence an IO action over each unique item (dedup by getKey).
forEach = \items getKey action -> case headOf items of
  Nothing {} -> yield {}
  Just {value: x} -> do
    action x
    forEach (filter items (\y -> getKey y != getKey x)) getKey action

-- Like forEach, but collects each action's result into a list.
mapEach = \items getKey action -> case headOf items of
  Nothing {} -> yield []
  Just {value: x} -> do
    r <- action x
    rest <- mapEach (filter items (\y -> getKey y != getKey x)) getKey action
    yield (union [r] rest)

-- Hex tokens: one random hex char per recursive call.
genTokenN = \n -> if n <= 0 then yield "" else do
  d <- randomInt 16
  rest <- genTokenN (n - 1)
  yield (take 1 (drop d "0123456789abcdef") ++ rest)

genToken = genTokenN 48

-- Use the supplied message id when non-empty, otherwise generate a fresh one.
resolveMessageId = \mid -> if mid != "" then yield mid else genToken

tooLong : Text -> Int -> Bool
tooLong = \s maxLen -> count (chars s) > maxLen

isValidHex : Text -> Bool
isValidHex = \s -> let cs = chars s in let n = count cs in n > 0 && mod n 2 == 0 && all cs (\c -> contains c "0123456789abcdef")

normalizeHex : Text -> Text
normalizeHex = \s -> bytesToHex (bytesFromHex s)

stripTrailingDot : Text -> Text
stripTrailingDot = \s -> if containsSuffix "." s then stripTrailingDot (take (count (chars s) - 1) s) else s

normalizeServerName : Text -> Text
normalizeServerName = \s -> toLower (stripTrailingDot s)

serverHostN : Text
serverHostN = normalizeServerName serverHost
isLocalServer : Text -> Bool
isLocalServer = \s -> s == serverHostN

hasPrefix : Text -> Text -> Bool
hasPrefix = \pre s -> take (count (chars pre)) s == pre

containsSuffix : Text -> Text -> Bool
containsSuffix = \suffix s ->
  drop (max 0 (count (chars s) - count (chars suffix))) s == suffix

-- Block private/reserved/internal hostnames (SSRF defense). Skips obscure encoding
-- tricks (octal, hex, percent-encoding) but covers the high-value cases.
isBadServerName : Text -> Bool
isBadServerName = \sn ->
  sn == "" || sn == "localhost"
  || not (all (chars sn) (\c -> contains c "0123456789abcdefghijklmnopqrstuvwxyz-.:"))
  || any [".", ":", "[", "127.", "10.", "192.168.", "169.254.", "0.", "::"] (\p -> hasPrefix p sn)
  || any [".localhost", ".local", ".internal", ".arpa", ".onion"] (\s -> containsSuffix s sn)

-- ============================================
-- Auth helpers
-- ============================================

-- Plain ip match (sessions with empty ip skip the check).
matchIp = \clientIp sessionIp -> sessionIp == "" || clientIp == sessionIp

extractToken = \authHeader ->
  let token = drop 7 authHeader in
  if hasPrefix "Bearer " authHeader && token != "" && not (tooLong token maxTokenLen)
    then Just {value: token}
    else Nothing {}

verifyMaintenanceAuth : Text -> IO Bool
verifyMaintenanceAuth = \authorization -> do
  secret <- *runtimeMaintenanceSecret
  yield (secret != "" && extractToken authorization == Just {value: secret})

withMaintAuth = \authorization onUnauth onAuth -> do
  authorized <- verifyMaintenanceAuth authorization
  if authorized then onAuth else onUnauth

-- Common gate for handlers: optional drain check, global rate, session auth.
-- mkErr is called with one of: "draining", "rate_limited", "unauthorized".
gateAuth = \checkDrain auth ip t respond mkErr onAuth -> do
  dp <- *drainPhase
  g <- checkGlobalRate t
  let err = \e -> yield (respond (mkErr e))
  if checkDrain && dp >= 2 then err "draining"
  else if g then err "rate_limited"
  else withSessionAuth auth t ip (err "unauthorized") onAuth

-- gateAuth + per-key rate gate. `rateResp` is the response value when the per-key gate trips.
gateRated = \checkDrain auth ip rateRef maxRate windowMs t respond mkErr rateResp onAuth ->
  gateAuth checkDrain auth ip t respond mkErr (\pk -> do
    lim <- checkPubkeyRateGate rateRef pk maxRate windowMs t
    if lim then yield (respond rateResp) else onAuth pk)

gateClientWrite = \auth ip t respond mkErr rateResp onAuth ->
  gateRated (True {}) auth ip clientWriteRates maxClientWriteRatePerKey clientWriteRateWindowMs t respond mkErr rateResp onAuth

gateLookup = \auth ip t respond mkErr rateResp onAuth ->
  gateRated (False {}) auth ip lookupRates maxLookupRatePerKey lookupRateWindowMs t respond mkErr rateResp onAuth

withSessionAuth = \authorization t clientIp onUnauth onAuth ->
  case extractToken authorization of
    Nothing {} -> onUnauth
    Just {value: token} -> do
      ses <- *sessions
      case findFirst ses (\s -> s.expiresAt > t && s.token == token && matchIp clientIp s.ip) of
        Just {value: s} -> onAuth s.pubkey
        _ -> onUnauth

generateFederationAuth : Text -> Timestamp -> IO {network} Text
generateFederationAuth = \scope requestTimestamp ->
  if serverFederationPrivateKeyHex != ""
    then do
      nonce <- genTokenN 48
      yield ("Signed " ++ bytesToHex (sign (bytesFromHex serverFederationPrivateKeyHex) (textToBytes (scope ++ "|" ++ show requestTimestamp ++ "|" ++ serverHostN ++ "|" ++ nonce))) ++ ":" ++ nonce)
    else do
      token <- genToken
      t <- now
      atomic do
        pending <- *pendingVerifications
        set *pendingVerifications = capList (union pending [{token: token, createdAt: t, scope: scope}]) maxPendingVerifications (\p -> p.createdAt)
      yield ("Bearer " ++ token)

-- Verify a federation request: signed (Ed25519 over scope|ts|fromServer|nonce) or callback Bearer token.
verifyFederationAuth = \authorization fromServer scope requestTimestamp -> do
  if hasPrefix "Signed " authorization then do
    let payload = drop 7 authorization
    if payload == "" || tooLong payload (maxSignatureLen + 25) then yield False
    else do
      -- Split payload on first ':' into {sig, nonce} via a fold over chars.
      let parts = fold (\acc c ->
            if acc.split then {sig: acc.sig, nonce: acc.nonce ++ c, split: True {}}
            else if c == ":" then {sig: acc.sig, nonce: "", split: True {}}
            else {sig: acc.sig ++ c, nonce: "", split: False {}}) {sig: "", nonce: "", split: False {}} (chars payload)
      result <- fetch (federationUrl fromServer) (FederationPubkey {})
      case result of
        Ok r -> yield (r.ok && r.pubkey != "" && verify (bytesFromHex r.pubkey) (textToBytes (scope ++ "|" ++ show requestTimestamp ++ "|" ++ fromServer ++ (if parts.nonce == "" then "" else "|" ++ parts.nonce))) (bytesFromHex parts.sig))
        _ -> yield False
  else case extractToken authorization of
    Just {value: token} -> do
      result <- fetch (federationUrl fromServer) (VerifyToken {token: token, scope: scope})
      case result of Ok r -> yield r.ok; _ -> yield False
    _ -> yield False

withFederationAuth = \authorization t respond fromServer scope requestTimestamp precondition action -> do
  blocked <- *blockedPeers
  allowed <- *allowedPeers
  let err = \e retry -> respond {ok: False {}, error: e, retryAfterMs: retry}
  if elem blocked fromServer then yield (err "blocked" 0)
  else if count allowed > 0 && not (elem allowed fromServer) then yield (err "not_allowed" 0)
  else if not precondition then yield (err "invalid_request" 0)
  else if requestTimestamp > 0 && abs (requestTimestamp - t) > clockSkewTolerance then yield (err "clock_skew" 0)
  else do
    verified <- verifyFederationAuth authorization fromServer scope requestTimestamp
    if not verified then yield (err "unauthorized" 0)
    else do
      limited <- checkServerRateGate fromServer t
      if limited then yield (err "rate_limited" federationRateWindowMs)
      else action

-- ============================================
-- Rate limiting (plain count-per-window, no sliding interpolation)
-- ============================================

-- Returns {limited, entries}. Increments count when the key fits within the window.
-- Simplified: drop any stale/matching entry, then either reject or insert a fresh entry.
checkRate = \entries key maxRate windowMs maxEntries t ->
  let cur = case findFirst entries (\r -> r.key == key && t - r.windowStart < windowMs) of
        Just {value: r} -> {windowStart: r.windowStart, count: r.count + 1}
        _ -> {windowStart: t, count: 1} in
  if cur.count > maxRate
    then {limited: True {}, entries: entries}
    else {limited: False {}, entries: capList (union (removeWhere entries (\x -> x.key == key)) [{key: key, windowStart: cur.windowStart, count: cur.count}]) maxEntries (\r -> r.windowStart)}

checkWindowRate = \windowRef countRef windowMs maxRate t -> atomic do
  ws <- *windowRef
  c <- *countRef
  if t - ws >= windowMs then do
    set *windowRef = t
    set *countRef = 1
    yield False
  else if c >= maxRate then yield True
  else do
    set *countRef = c + 1
    yield False

checkGlobalRate = checkWindowRate globalRateWindowStart globalRateCount globalRateWindowMs maxGlobalRequestRate
checkAuthGlobalRate = checkWindowRate authGlobalRateWindowStart authGlobalRateCount authGlobalRateWindowMs maxAuthGlobalRate

checkIpRateGate = \ip t ->
  if ip == "" then yield False
  else checkPubkeyRateGate ipRates ip maxIpRatePerIp ipRateWindowMs t

-- Non-atomic version: caller must wrap in `atomic do`.
chargeRate = \rateRef key maxRate windowMs t -> do
  rates <- *rateRef
  let r = checkRate rates key maxRate windowMs 5000 t
  set *rateRef = r.entries
  yield r.limited

checkPubkeyRateGate = \rateRef pubkey maxRate windowMs t -> atomic
  (chargeRate rateRef pubkey maxRate windowMs t)

checkServerRateGate = \server ->
  checkPubkeyRateGate federationRates server maxFederationRatePerServer federationRateWindowMs

-- Pre-auth gate: drain + global + ip + auth-global. Returns "" when ok, else an error code.
authPreCheck = \clientIp t -> do
  dp <- *drainPhase
  g <- checkGlobalRate t
  i <- checkIpRateGate clientIp t
  a <- checkAuthGlobalRate t
  yield (if dp >= 1 then "draining"
    else if g then "global_rate_limited"
    else if i then "ip_rate_limited"
    else if a then "auth_rate_limited"
    else "")

-- ============================================
-- Federation failure tracking (simple, no circuit breaker)
-- ============================================

retryBackoff : Int -> Int<Ms>
retryBackoff = \failures -> min retryBackoffMax (retryBackoffBase * max 1 failures)

shouldRetryServer : Text -> Timestamp -> [ForwardFailure] -> Bool
shouldRetryServer = \server t failures ->
  none failures (\f -> f.server == server && t - f.failedAt < retryBackoff f.failures)

recordFailure = \server -> do
  t <- now
  atomic do
    failures <- *forwardFailures
    let same = \f -> f.server == server
    let prev = case findFirst failures same of
          Just {value: f} -> {count: f.failures, firstFailedAt: f.firstFailedAt}
          _ -> {count: 0, firstFailedAt: t}
    set *forwardFailures = union (removeWhere failures same)
      [{server: server, failedAt: t, failures: min (prev.count + 1) 10, firstFailedAt: prev.firstFailedAt}]

clearFailure = \server -> atomic (pruneRef forwardFailures (\f -> f.server != server))

-- ============================================
-- Common utility queries
-- ============================================

clampTtl : Int<S> -> Int<S>
clampTtl = clamp 1 maxPresenceTtl

clampTimestamp : Timestamp -> Timestamp -> Timestamp
clampTimestamp = \timestamp t -> clamp (t - messageMaxAge) t timestamp

effectiveMessageTtl : Int<Ms> -> Int<Ms>
effectiveMessageTtl = \e -> if e <= 0 then unackedMessageMaxAge else clamp minMessageTtl unackedMessageMaxAge e

nextSeqTs : Timestamp -> Timestamp -> Timestamp
nextSeqTs = \t seqCounter -> max t (seqCounter + 1)

dedupMessageIds : [MessageIdHex] -> [MessageIdHex]
dedupMessageIds = \ids -> takeRelation maxMessageIds (unique ids)

presenceForKey = \presence pubkey t ->
  filter presence (\p -> p.pubkey == pubkey && p.expiresAt > t)

-- Resolve a key's server for client lookup, masking remote identities behind "remote".
maskedServer = \pres pubkey t ->
  let entries = presenceForKey pres pubkey t in
  if any entries (\p -> isLocalServer p.server) then serverHostN
  else if count entries > 0 then "remote"
  else ""

hasMessage : MessageIdHex -> PubkeyHex -> [{messageId: MessageIdHex, toKey: PubkeyHex | a}] -> Bool
hasMessage = \mid toKey items -> any items (\x -> x.messageId == mid && x.toKey == toKey)

isDuplicateMessage = \mid toKey msgs aids dids ->
  hasMessage mid toKey msgs || hasMessage mid toKey aids || hasMessage mid toKey dids

collectPeers : [a] -> (a -> Text) -> [Text]
collectPeers = \items getServer ->
  unique (filter (pluck items getServer) (\s -> not (isLocalServer s)))

knownPeerServersFromPresence : [PresenceEntry] -> [Text]
knownPeerServersFromPresence = \presence -> collectPeers presence (\p -> p.server)

-- Last-write-wins merge by (pubkey, server), keeping the entry with the larger expiresAt.
mergePresence = \existing incoming ->
  fold (\acc e ->
    let same = \x -> x.pubkey == e.pubkey && x.server == e.server in
    if any acc (\x -> same x && x.expiresAt >= e.expiresAt) then acc
    else union (removeWhere acc same) [e]) existing incoming

-- ============================================
-- Pruning
-- ============================================

pruneExpired = \t -> atomic do
  pruneRef challenges (\x -> x.expiresAt > t)
  pruneRef sessions (\x -> x.expiresAt > t)
  pruneRef messages (\m -> m.expiresAt > t)
  pruneRef forwards (\f -> f.expiresAt > t)
  pruneRef ackedIds (\a -> t - a.ackedAt < messageMaxAge)
  pruneRef deliveredIds (\d -> t - d.deliveredAt < messageMaxAge)
  pruneRef forwardFailures (\f -> t - f.failedAt < 86400000)
  pruneRef activePolls (\p -> t - p.startedAt < pollTimeoutMs * 3)
  pruneRef pendingVerifications (\p -> t - p.createdAt < verificationTokenExpiry)
  pruneRef senderExpirations (\x -> t - x.expiredAt < unackedMessageMaxAge)
  pruneRef senderDeliveries (\x -> t - x.deliveredAt < unackedMessageMaxAge)
  pruneRef cancelNotifications (\x -> t - x.cancelledAt < unackedMessageMaxAge)
  pruneRef pendingFederationCancels (\x -> t - x.createdAt < messageMaxAge)
  -- presence: remember locally-expired keys for offline gossip
  pres <- *presence
  pruneRef presence (\p -> p.expiresAt > t)
  let stillLive = \pk -> any pres (\k -> isLocalServer k.server && k.pubkey == pk && k.expiresAt > t)
  yield (filter pres (\p -> p.expiresAt <= t && isLocalServer p.server && not (stillLive p.pubkey)))

-- ============================================
-- Federation gossip
-- ============================================

-- Build a gossip event with this server's identity.
mkGossip = \etype pk t ttl ->
  {eventType: etype, pubkey: pk, server: serverHostN, timestamp: t, ttl: ttl, seenBy: [serverHostN]}

-- Build an acked entry for a federated message.
mkAckedEntry = \m t -> {messageId: m.messageId, toKey: m.toKey, ackedAt: t, originServer: m.originServer, retries: 0}

-- Record federation acks and sender deliveries for a batch of just-removed messages.
-- Returns the federated-ack entries (the caller flushes them remotely later).
recordAcksAndDeliveries = \toAck t -> do
  let ackedFed = mapWhere toAck (\m -> m.originServer != "") (\m -> mkAckedEntry m t)
  appendCapped ackedIds ackedFed maxAckedIds (\a -> a.ackedAt)
  appendCapped senderDeliveries (mapWhere toAck (\m -> m.senderKey != "" && m.originServer == "")
    (\m -> {senderKey: m.senderKey, messageId: m.messageId, toKey: m.toKey, deliveredAt: t})) 10000 (\d -> d.deliveredAt)
  yield ackedFed

-- Common cancel block: drop matching messages + forwards, record cancel notification.
-- Returns the federated forward servers that had the message (for caller follow-up).
applyCancel = \msgs matches to mid t -> do
  set *messages = removeWhere msgs matches
  fwds <- *forwards
  set *forwards = removeWhere fwds matches
  appendCapped cancelNotifications [{toKey: to, messageId: mid, cancelledAt: t}] 10000 (\c -> c.cancelledAt)
  yield (collectPeers (filter fwds matches) (\f -> f.toServer))

-- Cancel one message if `ownerPred` holds for it; returns whether a cancel happened.
cancelOne = \mid to ownerPred t -> atomic do
  let matches = \x -> x.messageId == mid && x.toKey == to
  msgs <- *messages
  if any msgs (\m -> matches m && ownerPred m) then do
    _ <- applyCancel msgs matches to mid t
    yield True
  else yield False

sendBatchedGossip = \peers events hops -> forEach peers id (\server -> do
  t <- now
  failures <- *forwardFailures
  when (shouldRetryServer server t failures) (do
    auth <- generateFederationAuth "gossip" t
    result <- fetch (federationUrl server) (RecvGossip {
      authorization: auth,
      events: events, hopsRemaining: hops, fromServer: serverHostN,
      requestTimestamp: t, correlationId: "", protocolVersion: federationProtocolVersion})
    case result of
      Err _ -> recordFailure server
      Ok _ -> clearFailure server))

broadcastOfflineGossip = \t expiredLocal -> do
  presence <- *presence
  when (federationEnabled && count expiredLocal > 0)
    (sendBatchedGossip (knownPeerServersFromPresence presence) (pluck expiredLocal (\p -> mkGossip (GossipOffline {}) p.pubkey t offlineGossipMinTtl)) gossipOriginHops)

-- ============================================
-- Forward retries and acks
-- ============================================

retryPendingForwards = do
  t <- now
  fwds <- *forwards
  failures <- *forwardFailures
  blocked <- *blockedPeers
  forEach (filter (collectPeers fwds (\f -> f.toServer)) (\s -> shouldRetryServer s t failures && not (elem blocked s))) id (\server ->
    forEach (takeRelation maxBatchSize (filter fwds (\f -> f.toServer == server))) (\f -> f.messageId) (\f -> do
      t2 <- now
      auth <- generateFederationAuth ("forward:" ++ f.messageId) t2
      result <- fetch (federationUrl server) (ForwardMessage {
        toKey: f.toKey, encryptedBlob: f.encryptedBlob,
        timestamp: f.timestamp, originServer: f.originServer, messageId: f.messageId,
        fromServer: serverHostN, requestTimestamp: t2,
        authorization: auth, correlationId: "",
        expiresAt: f.expiresAt, priority: f.priority, protocolVersion: federationProtocolVersion})
      success <- case result of
        Err _ -> do recordFailure server; yield False
        Ok r -> do when r.ok (clearFailure server); yield r.ok
      let isMatch = \x -> x.messageId == f.messageId && x.toServer == server
      let isDone = \x -> isMatch x && (success || x.retries + 1 >= maxForwardRetries)
      atomic do
        cur <- *forwards
        set *forwards = pluck (removeWhere cur isDone) (\x ->
          if isMatch x
            then {messageId: x.messageId, toServer: x.toServer, createdAt: x.createdAt, toKey: x.toKey, encryptedBlob: x.encryptedBlob, timestamp: x.timestamp, originServer: x.originServer, retries: x.retries + 1, expiresAt: x.expiresAt, priority: x.priority, senderKey: x.senderKey}
            else x)))

sendAcksAndClean = \pendingAcks ->
  forEach (collectPeers pendingAcks (\a -> a.originServer)) id (\server -> do
    let mids = mapWhere pendingAcks (\a -> a.originServer == server) (\a -> a.messageId)
    t <- now
    auth <- generateFederationAuth "ack" t
    result <- fetch (federationUrl server) (FederationAck {
      authorization: auth,
      messageIds: mids, originServer: server, fromServer: serverHostN,
      requestTimestamp: t, correlationId: "", protocolVersion: federationProtocolVersion})
    case result of
      Err _ -> recordFailure server
      Ok _ -> do
        clearFailure server
        atomic (pruneRef ackedIds (\a -> not (a.originServer == server && elem mids a.messageId))))

-- Forward queued messages to a server when a remote key comes online.
forwardQueuedToServer = \pubkey server t -> atomic do
  msgs <- *messages
  fwds <- *forwards
  let candidates = filter msgs (\m -> m.toKey == pubkey && none fwds (\f -> f.messageId == m.messageId && f.toServer == server))
  let newFwds = pluck (takeRelation maxForwardsPerServer candidates) (\m ->
    {messageId: m.messageId, toServer: server, createdAt: t, toKey: m.toKey, encryptedBlob: m.encryptedBlob, timestamp: m.timestamp, originServer: (if m.originServer == "" then serverHostN else m.originServer), retries: 0, expiresAt: m.expiresAt, priority: m.priority, senderKey: m.senderKey})
  set *forwards = capList (union fwds newFwds) maxForwardsEntries (\f -> f.createdAt)

-- ============================================
-- Background loops
-- ============================================

pruneAndRetry = \t -> do
  atomic do set *lastPrunedAt = t
  expiredLocal <- pruneExpired t
  fork (broadcastOfflineGossip t expiredLocal)
  when federationEnabled (do
    fork retryPendingForwards
    aids <- *ackedIds
    fork (sendAcksAndClean (filter aids (\a -> not (isLocalServer a.originServer))))
    lastRefresh <- *lastPresenceRefresh
    when (t - lastRefresh >= presenceRefreshInterval) (do
      atomic do set *lastPresenceRefresh = t
      refreshLocalPresence t))
  yield {}

refreshLocalPresence = \t -> do
  refreshState <- atomic do
    sessions <- *sessions
    presence <- *presence
    let newExpiry = t + sessionExpiry
    let sessionKeys = unique (pluck sessions (\s -> s.pubkey))
    let updated = pluck presence (\p ->
      if isLocalServer p.server && elem sessionKeys p.pubkey && p.expiresAt - t < sessionExpiry / 2
        then {pubkey: p.pubkey, server: p.server, expiresAt: newExpiry, timestamp: t}
        else p)
    set *presence = updated
    yield {refreshed: filter updated (\p -> isLocalServer p.server && p.expiresAt == newExpiry), peers: knownPeerServersFromPresence updated}
  when (count refreshState.refreshed > 0)
    (fork (sendBatchedGossip refreshState.peers (pluck refreshState.refreshed (\p -> mkGossip (GossipOnline {}) p.pubkey t (clampTtl (sessionExpiry / 1000)))) gossipOriginHops))

-- ============================================
-- Handler: challenge / verify / revoke / logout
-- ============================================

handleChallenge = \pubkey clientIp respond -> do
  t <- now
  preErr <- if requireClientIp && clientIp == "" then yield "client_ip_required" else authPreCheck clientIp t
  if preErr != "" then yield (respond {challenge: "", ok: False {}, expiresAt: 0, retryAfterMs: 0, error: preErr})
  else do
    challenge <- genToken
    result <- atomic do
      ch <- *challenges
      let cappedActive = capPerKey (filter ch (\c -> c.expiresAt > t)) (\c -> c.pubkey == pubkey) maxChallengesPerKey (\c -> c.expiresAt)
      if count cappedActive >= maxChallenges then yield {ok: False {}, error: "capacity"}
      else do
        limited <- chargeRate challengeRates pubkey maxChallengeRatePerKey challengeRateWindowMs t
        if limited then yield {ok: False {}, error: "rate_limited"}
        else do
          set *challenges = union cappedActive [{pubkey: pubkey, challenge: challenge, expiresAt: t + challengeExpiry, ip: clientIp}]
          yield {ok: True {}, error: ""}
    yield (respond {challenge: if result.ok then challenge else "", ok: result.ok, expiresAt: if result.ok then t + challengeExpiry else 0, retryAfterMs: 0, error: result.error})

handleVerifyAuth = \pubkey challenge signature revokeOthers clientIp respond -> do
  t <- now
  preErr <- authPreCheck clientIp t
  if preErr != "" then yield (respond {token: "", expiresAt: 0, error: preErr})
  else do
    let expiry = t + sessionExpiry
    token <- genToken
    result <- atomic do
      ch <- *challenges
      dp <- *drainPhase
      let same = \c -> c.pubkey == pubkey && c.challenge == challenge
      if dp >= 1
         || none ch (\c -> same c && c.expiresAt > t && matchIp clientIp c.ip)
         || not (verify (bytesFromHex pubkey) (textToBytes challenge) (bytesFromHex signature))
      then yield {valid: False {}, peers: []}
      else do
        set *challenges = removeWhere ch same
        ses <- *sessions
        let mine = \s -> s.pubkey == pubkey
        let pruned = if revokeOthers then removeWhere ses mine else capPerKey ses mine maxSessionsPerKey (\s -> s.expiresAt)
        let newSession = {token: token, pubkey: pubkey, expiresAt: expiry, ip: clientIp, createdAt: t}
        set *sessions = capList (union pruned [newSession]) maxSessions (\s -> s.expiresAt)
        pres <- *presence
        let prunedPres = removeWhere pres (\p -> p.pubkey == pubkey && isLocalServer p.server)
        let newPres = capList (union prunedPres [{pubkey: pubkey, server: serverHostN, expiresAt: expiry, timestamp: t}]) maxPresenceEntries (\p -> p.expiresAt)
        set *presence = newPres
        yield {valid: True {}, peers: knownPeerServersFromPresence newPres}
    if not result.valid then yield (respond {token: "", expiresAt: 0, error: "invalid"})
    else do
      when federationEnabled
        (fork (sendBatchedGossip result.peers [mkGossip (GossipOnline {}) pubkey t onlineGossipTtl] gossipOriginHops))
      yield (respond {token: token, expiresAt: expiry, error: ""})

handleRevoke = \targetToken authorization clientIp respond -> do
  t <- now
  gateAuth (False {}) authorization clientIp t respond (\_ -> {ok: False {}, authorized: False {}}) (\caller -> do
    result <- atomic do
      ses <- *sessions
      let pred = \s -> s.pubkey == caller && s.token == targetToken
      set *sessions = removeWhere ses pred
      yield (any ses pred)
    yield (respond {ok: result, authorized: True {}}))

handleLogout = \authorization clientIp respond -> do
  t <- now
  let myToken = extractToken authorization
  removed <- atomic (withSessionAuth authorization t clientIp
    (yield {ok: False {}, pubkey: "", peers: []})
    (\pubkey -> do
      ses <- *sessions
      set *sessions = removeWhere ses (\s -> Just {value: s.token} == myToken)
      after <- *sessions
      peers <- if any after (\s -> s.pubkey == pubkey) then yield []
        else do
          pres <- *presence
          set *presence = removeWhere pres (\p -> p.pubkey == pubkey && isLocalServer p.server)
          yield (knownPeerServersFromPresence pres)
      yield {ok: True {}, pubkey: pubkey, peers: peers}))
  when (removed.ok && federationEnabled)
    (fork (sendBatchedGossip removed.peers [mkGossip (GossipOffline {}) removed.pubkey t offlineGossipMinTtl] gossipOriginHops))
  yield (respond {ok: removed.ok, authorized: removed.ok})

-- ============================================
-- Handler: poll
-- ============================================

handlePoll = \cursor generation watchKeys authorization clientIp respond -> do
  t <- now
  serverGen <- *serverGeneration
  dp <- *drainPhase
  g <- checkGlobalRate t
  let cursorWasReset = generation != serverGen && cursor > 0
  let er = \auth rate drain retry -> yield (respond (emptyPollResp 0 auth rate drain serverGen retry cursorWasReset))
  if dp >= 2 then er (True {}) (False {}) (True {}) 0
  else if g then er (False {}) (True {}) (False {}) globalRateWindowMs
  else pollOnce authorization (if cursorWasReset then 0 else cursor) cursorWasReset (takeRelation maxWatchKeys watchKeys) clientIp serverGen respond t

pollOnce = \authorization cursor cursorWasReset watchKeys clientIp serverGen respond t -> do
  setup <- atomic (withSessionAuth authorization t clientIp
    (yield Nothing {})
    (\pubkey -> do
      let clampedCursor = clamp 0 t cursor
      pendingAcks <- if clampedCursor > 0 then ackPolledMessages pubkey clampedCursor t else yield []
      startWakeup <- *pollWakeup
      yield (Just {value: {pubkey: pubkey, clampedCursor: clampedCursor, startWakeup: startWakeup, pendingAcks: pendingAcks}})))
  case setup of
    Nothing {} -> yield (respond (emptyPollResp 0 (False {}) (False {}) (False {}) serverGen 0 cursorWasReset))
    Just {value: s} -> do
      acquired <- atomic do
        aps <- *activePolls
        if countWhere aps (\p -> p.pubkey == s.pubkey) >= maxPollsPerKey then yield False
        else do
          appendCapped activePolls [{pubkey: s.pubkey, startedAt: t}] maxActivePolls (\p -> p.startedAt)
          yield True
      if not acquired
        then yield (respond (emptyPollResp cursor (True {}) (True {}) (False {}) serverGen pollTimeoutMs cursorWasReset))
        else do
          pollResult <- doPoll s t
          atomic (pruneRef activePolls (\p -> p.pubkey != s.pubkey))
          when federationEnabled (fork (sendAcksAndClean s.pendingAcks))
          presenceUpdates <- atomic do
            t2 <- now
            pres <- *presence
            yield (pluck watchKeys (\k -> {pubkey: k, online: count (presenceForKey pres k t2) > 0}))
          drains <- atomic do
            myExp <- collectAndPrune senderExpirations (\x -> x.senderKey == s.pubkey) (\x -> {messageId: x.messageId, toKey: x.toKey, expiredAt: x.expiredAt})
            myDel <- collectAndPrune senderDeliveries (\x -> x.senderKey == s.pubkey) (\x -> {messageId: x.messageId, toKey: x.toKey, deliveredAt: x.deliveredAt})
            myCancels <- collectAndPrune cancelNotifications (\x -> x.toKey == s.pubkey) (\x -> {messageId: x.messageId, cancelledAt: x.cancelledAt})
            yield {expirations: myExp, deliveries: myDel, cancellations: myCancels}
          yield (respond {events: pollResult.events, cursor: pollResult.cursor, authorized: True {}, rateLimited: False {}, draining: False {}, generation: serverGen, presenceUpdates: presenceUpdates, heartbeat: count pollResult.events == 0, retryAfterMs: 0, cursorReset: cursorWasReset, hasMore: pollResult.hasMore, cursorStale: False {}, messageExpirations: drains.expirations, messageDeliveries: drains.deliveries, droppedDeliveryReceipts: 0, droppedExpirationNotifs: 0, loadPct: 0, messageCancellations: drains.cancellations})

doPoll = \s t -> do
  let collectAt = \tnow -> atomic do
    msgs <- *messages
    yield (collectPollEvents msgs s.pubkey s.clampedCursor tnow)
  initial <- collectAt t
  if count initial.events > 0 then yield initial
  else do
    atomic do
      wakeup <- *pollWakeup
      if wakeup > s.startWakeup then yield {} else retry
    t2 <- now
    collectAt t2

collectPollEvents = \messages pubkey cursor t ->
  let myMsgs = filter messages (\m -> m.toKey == pubkey && m.expiresAt > t && m.receivedAt > cursor) in
  let limited = takeRelation maxPollEvents (sortBy (\m -> m.receivedAt) myMsgs) in
  {events: pluck limited (\m -> {id: m.messageId, eventType: "message", payload: {toKey: m.toKey, encryptedBlob: m.encryptedBlob, timestamp: m.timestamp, expiresAt: m.expiresAt}}),
   cursor: fold (\acc m -> max acc m.receivedAt) cursor limited,
   hasMore: count myMsgs > count limited}

ackPolledMessages = \pubkey cursor t -> do
  msgs <- *messages
  let matches = \m -> m.toKey == pubkey && m.receivedAt <= cursor
  let toAck = filter msgs matches
  let mids = pluck toAck (\m -> m.messageId)
  set *messages = removeWhere msgs matches
  pruneRef forwards (\f -> not (f.toKey == pubkey && elem mids f.messageId))
  recordAcksAndDeliveries toAck t

-- ============================================
-- Handler: send
-- ============================================

handleSendMessage = \to encryptedBlob timestamp messageId expiresInMs priority authorization clientIp respond -> do
  t <- now
  dp <- *drainPhase
  g <- checkGlobalRate t
  effMsgId <- resolveMessageId messageId
  let err = \s e -> yield (respond (sendErrResp s e))
  if dp >= 2 then err (MsDraining {}) "draining"
  else if g then err (MsRateLimited {}) "rate_limited"
  else if t - timestamp > messageMaxAge then err (MsRejected {}) "stale_timestamp"
  else do
    let clampedTs = clampTimestamp timestamp t
    result <- atomic do
      withSessionAuth authorization t clientIp
        (yield {status: MsUnauthorized {}, remoteServers: []})
        (\senderKey -> sendMessageCore senderKey to encryptedBlob clampedTs effMsgId expiresInMs (clamp 0 maxMessagePriority priority) t)
    when federationEnabled
      (fork (forkForwardsTo effMsgId to encryptedBlob clampedTs result.remoteServers))
    let ok = isSendSuccess result.status
    yield (respond {status: result.status, messageId: if ok then effMsgId else "", retryAfterMs: 0, error: if ok then "" else "rejected", loadPct: 0})

sendMessageCore = \senderKey to encryptedBlob clampedTs effMsgId expiresInMs msgPriority t -> do
  msgs <- *messages
  aids <- *ackedIds
  dids <- *deliveredIds
  srLim <- chargeRate sendRates senderKey maxSendRatePerKey sendRateWindowMs t
  prLim <- chargeRate pairRates (senderKey ++ "|" ++ to) maxPairRatePerPair pairRateWindowMs t
  rrLim <- chargeRate recvRates to maxRecvRatePerKey recvRateWindowMs t
  let reject = \s -> yield {status: s, remoteServers: []}
  if senderKey == to then reject (MsRejected {})
  else if isDuplicateMessage effMsgId to msgs aids dids then reject (MsDuplicate {})
  else if srLim || prLim || rrLim then reject (MsRateLimited {})
  else if count msgs >= maxMessages then reject (MsRejected {})
  else if countWhere msgs (\m -> m.toKey == to) >= maxMessagesPerRecipient then reject (MsQueued {})
  else do
    pres <- *presence
    seq <- *seqCounter
    let seqTs = nextSeqTs t seq
    set *seqCounter = seqTs
    let expiresAt = seqTs + effectiveMessageTtl expiresInMs
    set *messages = union msgs [{messageId: effMsgId, toKey: to, encryptedBlob: encryptedBlob, timestamp: clampedTs, originServer: "", receivedAt: seqTs, expiresAt: expiresAt, senderKey: senderKey, priority: msgPriority}]
    set *pollWakeup = seqTs
    let toPresence = presenceForKey pres to t
    let remoteServers = collectPeers toPresence (\p -> p.server)
    forwardsEnqueued <- if federationEnabled then do
        fwds <- *forwards
        let newFwds = mapWhere remoteServers (\s -> none fwds (\f -> f.messageId == effMsgId && f.toServer == s)) (\s -> {messageId: effMsgId, toServer: s, createdAt: t, toKey: to, encryptedBlob: encryptedBlob, timestamp: clampedTs, originServer: serverHostN, retries: 0, expiresAt: expiresAt, priority: msgPriority, senderKey: senderKey})
        appendCapped forwards newFwds maxForwardsEntries (\f -> f.createdAt)
        yield (count newFwds > 0)
      else yield False
    yield {status: if any toPresence (\p -> isLocalServer p.server) then MsDelivered {} else if forwardsEnqueued then MsFederated {} else MsQueued {}, remoteServers: remoteServers}

forkForwardsTo = \effMsgId to encryptedBlob clampedTs servers ->
  forEach servers id (\server -> do
    fwds <- *forwards
    let same = \x -> x.messageId == effMsgId && x.toServer == server
    case findFirst fwds same of
      Nothing {} -> yield {}
      Just {value: f} -> do
        t <- now
        auth <- generateFederationAuth ("forward:" ++ effMsgId) t
        result <- fetch (federationUrl server) (ForwardMessage {
          toKey: to, encryptedBlob: encryptedBlob,
          timestamp: clampedTs, originServer: serverHostN, messageId: effMsgId,
          fromServer: serverHostN, requestTimestamp: t,
          authorization: auth, correlationId: "",
          expiresAt: f.expiresAt, priority: f.priority, protocolVersion: federationProtocolVersion})
        case result of
          Err _ -> recordFailure server
          Ok r -> when r.ok (do
            clearFailure server
            atomic (pruneRef forwards (\x -> not (same x)))))

-- ============================================
-- Handler: lookup
-- ============================================

handleLookupPresence = \pubkey authorization clientIp respond -> do
  t <- now
  let mkErr = \e -> {server: "", authorized: False {}, error: if e == "rate_limited" then "rate_limited" else ""}
  gateLookup authorization clientIp t respond mkErr
    {server: "", authorized: True {}, error: "rate_limited"} (\_ -> do
      pres <- *presence
      yield (respond {server: maskedServer pres pubkey t, authorized: True {}, error: ""}))

handleBatchLookupPresence = \pubkeys authorization clientIp respond -> do
  t <- now
  let mkErr = \e -> {results: [], authorized: False {}, error: if e == "rate_limited" then "rate_limited" else ""}
  gateLookup authorization clientIp t respond mkErr
    {results: [], authorized: True {}, error: "rate_limited"} (\_ -> do
      pres <- *presence
      let results = do
        k <- takeRelation 50 pubkeys
        yield {pubkey: k, server: maskedServer pres k t}
      yield (respond {results: results, authorized: True {}, error: ""}))

handleMessageStatus = \to messageId authorization clientIp respond -> do
  t <- now
  let mkErr = \_ -> {status: "", authorized: False {}}
  gateAuth (False {}) authorization clientIp t respond mkErr (\_ -> do
    msgs <- *messages
    fwds <- *forwards
    aids <- *ackedIds
    dids <- *deliveredIds
    let matches = \x -> x.messageId == messageId && x.toKey == to
    let s = if any msgs matches then "pending"
          else if any fwds matches then "forwarding"
          else if any aids matches || any dids matches then "delivered"
          else "unknown"
    yield (respond {status: s, authorized: True {}}))

-- ============================================
-- Handler: ack / list / delete / cancel
-- ============================================

handleAckMessages = \messageIds authorization clientIp respond -> do
  t <- now
  let mkErr = \e -> {ok: False {}, authorized: False {}, ackedCount: 0, error: e}
  gateClientWrite authorization clientIp t respond mkErr
    {ok: False {}, authorized: True {}, ackedCount: 0, error: "rate_limited"} (\pubkey -> do
      let dedupedIds = dedupMessageIds messageIds
      let matches = \x -> x.toKey == pubkey && elem dedupedIds x.messageId
      result <- atomic do
        toAck <- removeForKey matches
        ackedFed <- recordAcksAndDeliveries toAck t
        yield {ackedCount: count toAck, pendingAcks: ackedFed}
      when federationEnabled (fork (sendAcksAndClean result.pendingAcks))
      yield (respond {ok: True {}, authorized: True {}, ackedCount: result.ackedCount, error: ""}))

handleListMessages = \offset authorization clientIp respond -> do
  t <- now
  let mkErr = \e -> {messages: [], authorized: False {}, count: 0, error: if e == "rate_limited" then "rate_limited" else ""}
  gateRated (True {}) authorization clientIp lookupRates maxLookupRatePerKey lookupRateWindowMs t respond mkErr
    {messages: [], authorized: True {}, count: 0, error: "rate_limited"} (\pubkey -> do
      msgs <- *messages
      let myMsgs = sortBy (\m -> m.receivedAt) (filter msgs (\m -> m.toKey == pubkey && m.expiresAt > t))
      let total = count myMsgs
      let page = pluck (takeRelation maxPollEvents (drop (clamp 0 total offset) myMsgs)) (\m -> {messageId: m.messageId, timestamp: m.timestamp, receivedAt: m.receivedAt})
      yield (respond {messages: page, authorized: True {}, count: total, error: ""}))

handleDeleteMessages = \messageIds authorization clientIp respond -> do
  t <- now
  let mkErr = \e -> {ok: False {}, authorized: False {}, deletedCount: 0, error: if e == "draining" then "" else e}
  gateClientWrite authorization clientIp t respond mkErr
    {ok: False {}, authorized: True {}, deletedCount: 0, error: "rate_limited"} (\pubkey -> do
      let dedupedIds = dedupMessageIds messageIds
      let matches = \x -> x.toKey == pubkey && elem dedupedIds x.messageId
      result <- atomic do
        toDel <- removeForKey matches
        let ackedFed = mapWhere toDel (\m -> m.originServer != "") (\m -> mkAckedEntry m t)
        appendCapped ackedIds ackedFed maxAckedIds (\a -> a.ackedAt)
        yield {deletedCount: count toDel, pendingAcks: ackedFed}
      when federationEnabled (fork (sendAcksAndClean result.pendingAcks))
      yield (respond {ok: True {}, authorized: True {}, deletedCount: result.deletedCount, error: ""}))

handleCancelMessage = \messageId to authorization clientIp respond -> do
  t <- now
  let mkErr = \e -> {ok: False {}, authorized: False {}, cancelled: False {}, error: if e == "draining" then "" else e}
  gateClientWrite authorization clientIp t respond mkErr
    {ok: False {}, authorized: True {}, cancelled: False {}, error: "rate_limited"} (\senderKey -> do
      let matches = \x -> x.messageId == messageId && x.toKey == to
      result <- atomic do
        msgs <- *messages
        if any msgs (\m -> matches m && m.originServer == "" && m.senderKey == senderKey) then do
          fwdServers <- applyCancel msgs matches to messageId t
          pres <- *presence
          yield {cancelled: True {}, cancelServers: unique (union (collectPeers (presenceForKey pres to t) (\p -> p.server)) fwdServers)}
        else yield {cancelled: False {}, cancelServers: []}
      when (result.cancelled && federationEnabled)
        (fork (sendCancelToEach messageId to result.cancelServers))
      yield (respond {ok: True {}, authorized: True {}, cancelled: result.cancelled, error: ""}))

sendCancelToEach = \messageId to servers ->
  forEach servers id (\server -> do
    t <- now
    auth <- generateFederationAuth ("cancel:" ++ messageId) t
    result <- fetch (federationUrl server) (FederationCancel {
      messageId: messageId, toKey: to, fromServer: serverHostN,
      requestTimestamp: t, correlationId: "", authorization: auth,
      protocolVersion: federationProtocolVersion})
    when (case result of Err _ -> True {}; Ok r -> not r.ok) (atomic
      (appendCapped pendingFederationCancels [{messageId: messageId, toKey: to, toServer: server, createdAt: t, retries: 0}] 10000 (\c -> c.createdAt))))

handleCancelBatch = \cancels authorization clientIp respond -> do
  t <- now
  let mkErr = \e -> {results: [], authorized: False {}, error: if e == "draining" then "" else e}
  gateClientWrite authorization clientIp t respond mkErr
    {results: [], authorized: True {}, error: "rate_limited"} (\senderKey -> do
      results <- mapEach (takeRelation maxBatchSize cancels) (\e -> e.messageId) (\e -> do
        r <- cancelOne e.messageId e.to (\m -> m.originServer == "" && m.senderKey == senderKey) t
        yield {messageId: e.messageId, cancelled: r})
      yield (respond {results: results, authorized: True {}, error: ""}))

handleSendBatch = \messages authorization clientIp respond -> do
  t <- now
  let mkErr = \_ -> {results: [], authorized: False {}, retryAfterMs: 0}
  gateAuth (True {}) authorization clientIp t respond mkErr (\senderKey -> do
    results <- mapEach (takeRelation maxBatchSize messages) id (\m -> do
      effMsgId <- resolveMessageId m.messageId
      let clampedTs = clampTimestamp m.timestamp t
      r <- if t - m.timestamp > messageMaxAge
        then yield {status: MsRejected {}, remoteServers: []}
        else atomic do sendMessageCore senderKey m.to m.encryptedBlob clampedTs effMsgId m.expiresInMs (clamp 0 maxMessagePriority m.priority) t
      when federationEnabled
        (fork (forkForwardsTo effMsgId m.to m.encryptedBlob clampedTs r.remoteServers))
      yield {messageId: effMsgId, status: r.status})
    yield (respond {results: results, authorized: True {}, retryAfterMs: 0}))

-- ============================================
-- Handler: federation receive
-- ============================================

handleVerifyToken = \token scope clientIp respond -> do
  t <- now
  g <- checkGlobalRate t
  ipLim <- checkIpRateGate clientIp t
  if scope == "" || g || ipLim then yield (respond {ok: False {}})
  else do
    found <- atomic do
      pending <- *pendingVerifications
      let same = \p -> p.scope == scope && p.token == token
      let match = any pending (\p -> same p && t - p.createdAt < verificationTokenExpiry)
      when match (set *pendingVerifications = removeWhere pending same)
      yield match
    yield (respond {ok: found})

handleFederationPubkey = \respond -> do
  yield (respond {pubkey: serverFederationPublicKeyHex, ok: serverFederationPublicKeyHex != ""})

handleRecvGossip = \events hopsRemaining fromServer requestTimestamp correlationId authorization respond -> do
  t <- now
  withFederationAuth authorization t respond fromServer "gossip" requestTimestamp (clamp 0 maxGossipHops hopsRemaining >= 1 && not (isLocalServer fromServer) && count events <= maxGossipEvents) (do
    newlyOnline <- atomic do
      pres <- *presence
      let validEvents = do
        e <- events
        where not (isLocalServer e.server) && e.timestamp <= t + clockSkewTolerance
        let expiresAt = min e.timestamp t + clampTtl e.ttl * 1000
        where expiresAt > t
        yield {pubkey: e.pubkey, server: e.server, expiresAt: expiresAt, timestamp: e.timestamp, eventType: e.eventType}
      let isOnline = \v -> case v.eventType of GossipOnline {} -> True {}; _ -> False {}
      let isOffline = \v -> case v.eventType of GossipOffline {} -> True {}; _ -> False {}
      let online = mapWhere validEvents isOnline (\v -> {pubkey: v.pubkey, server: v.server, expiresAt: v.expiresAt, timestamp: v.timestamp})
      let offline = mapWhere validEvents isOffline (\v -> {pubkey: v.pubkey, server: v.server, timestamp: v.timestamp})
      set *presence = capList (mergePresence (filter pres (\p -> none offline (\o -> o.pubkey == p.pubkey && o.server == p.server && o.timestamp > p.timestamp))) online) maxPresenceEntries (\p -> p.expiresAt)
      yield (mapWhere online (\e -> none pres (\p -> p.pubkey == e.pubkey && p.server == e.server && p.expiresAt >= e.expiresAt)) (\e -> {pubkey: e.pubkey, server: e.server}))
    fork (forEach newlyOnline (\tgt -> tgt.pubkey ++ "|" ++ tgt.server) (\tgt -> forwardQueuedToServer tgt.pubkey tgt.server t))
    yield (respond {ok: True {}, error: "", retryAfterMs: 0}))

-- Store a federated/forwarded message into the local mailbox. Caller wraps in `atomic`.
-- Returns "" on success (including duplicates), otherwise an error code:
-- "no_presence" | "global_full" | "mailbox_full" | "rate_limited" (only when checkRecvRate).
storeFederated = \toKey encryptedBlob timestamp originServer messageId expiresAt priority checkRecvRate t -> do
  pres <- *presence
  msgs <- *messages
  aids <- *ackedIds
  dids <- *deliveredIds
  if not (any pres (\p -> p.pubkey == toKey && p.expiresAt > t)) then yield "no_presence"
  else if isDuplicateMessage messageId toKey msgs aids dids then yield ""
  else if count msgs >= maxMessages then yield "global_full"
  else if countWhere msgs (\m -> m.toKey == toKey) >= maxMessagesPerRecipient then yield "mailbox_full"
  else do
    limited <- if checkRecvRate then chargeRate recvRates toKey maxRecvRatePerKey recvRateWindowMs t else yield False
    if limited then yield "rate_limited"
    else do
      seq <- *seqCounter
      let seqTs = nextSeqTs t seq
      let cappedExpiry = if expiresAt > t then min expiresAt (seqTs + unackedMessageMaxAge) else seqTs + unackedMessageMaxAge
      set *seqCounter = seqTs
      set *messages = union msgs [{messageId: messageId, toKey: toKey, encryptedBlob: encryptedBlob, timestamp: clampTimestamp timestamp t, originServer: originServer, receivedAt: seqTs, expiresAt: cappedExpiry, senderKey: "", priority: clamp 0 maxMessagePriority priority}]
      set *pollWakeup = seqTs
      yield ""

handleForwardMessage = \toKey encryptedBlob timestamp originServer messageId fromServer requestTimestamp correlationId expiresAt priority authorization respond -> do
  t <- now
  withFederationAuth authorization t respond fromServer ("forward:" ++ messageId) requestTimestamp (not (isLocalServer originServer) && not (isLocalServer fromServer)) (do
    if t - timestamp > messageMaxAge
      then yield (respond {ok: False {}, error: "stale_timestamp", retryAfterMs: 0})
      else do
        result <- atomic (storeFederated toKey encryptedBlob timestamp originServer messageId expiresAt priority (True {}) t)
        yield (respond {ok: result == "", error: result, retryAfterMs: 0}))

handleFederationAck = \messageIds originServer fromServer requestTimestamp correlationId authorization respond -> do
  t <- now
  let ackRespond = \r -> respond {ok: r.ok, error: r.error, ackedCount: 0, results: [], retryAfterMs: r.retryAfterMs}
  withFederationAuth authorization t ackRespond fromServer "ack" requestTimestamp (isLocalServer originServer && not (isLocalServer fromServer)) (do
    let dedupedIds = dedupMessageIds messageIds
    result <- atomic do
      fwds <- *forwards
      let isAcked = \f -> f.toServer == fromServer && elem dedupedIds f.messageId
      let removed = filter fwds isAcked
      let remainingFwds = removeWhere fwds isAcked
      set *forwards = remainingFwds
      msgs <- *messages
      let removedIds = pluck removed (\f -> f.messageId)
      pres <- *presence
      let toReap = filter msgs (\m ->
        elem removedIds m.messageId
        && t - m.receivedAt >= ackGracePeriod
        && none pres (\p -> p.pubkey == m.toKey && isLocalServer p.server && p.expiresAt > t)
        && none remainingFwds (\f -> f.messageId == m.messageId && f.toKey == m.toKey))
      set *messages = removeWhere msgs (\m -> hasMessage m.messageId m.toKey toReap)
      yield {ackedCount: count removed, results: pluck dedupedIds (\mid -> {messageId: mid, found: any removed (\f -> f.messageId == mid)})}
    yield (respond {ok: True {}, error: "", ackedCount: result.ackedCount, results: result.results, retryAfterMs: 0}))

handleFederationCancel = \messageId toKey fromServer requestTimestamp correlationId authorization respond -> do
  t <- now
  let cancelRespond = \r -> respond {ok: r.ok, error: r.error, cancelled: False {}, retryAfterMs: r.retryAfterMs}
  withFederationAuth authorization t cancelRespond fromServer ("cancel:" ++ messageId) requestTimestamp (not (isLocalServer fromServer)) (do
    cancelled <- cancelOne messageId toKey (\m -> m.originServer == fromServer) t
    yield (respond {ok: True {}, error: "", cancelled: cancelled, retryAfterMs: 0}))

handleFederationBatchCancel = \cancels fromServer requestTimestamp correlationId authorization respond -> do
  t <- now
  let batchRespond = \r -> respond {ok: r.ok, error: r.error, results: [], retryAfterMs: r.retryAfterMs}
  withFederationAuth authorization t batchRespond fromServer "cancel-batch" requestTimestamp (not (isLocalServer fromServer) && count cancels <= maxBatchSize) (do
    results <- mapEach (takeRelation maxBatchSize cancels) (\e -> e.messageId) (\e -> do
      cancelled <- cancelOne e.messageId e.toKey (\m -> m.originServer == fromServer) t
      yield {messageId: e.messageId, cancelled: cancelled})
    yield (respond {ok: True {}, error: "", results: results, retryAfterMs: 0}))

handleFederationBatchForward = \forwards fromServer requestTimestamp correlationId authorization respond -> do
  t <- now
  let batchRespond = \r -> respond {ok: r.ok, error: r.error, results: [], retryAfterMs: r.retryAfterMs}
  withFederationAuth authorization t batchRespond fromServer "forward-batch" requestTimestamp (not (isLocalServer fromServer) && count forwards <= maxBatchSize) (do
    results <- mapEach (takeRelation maxBatchSize forwards) (\e -> e.messageId) (\e -> do
      ok <- if isLocalServer e.originServer || t - e.timestamp > messageMaxAge then yield False
        else do
          result <- atomic (storeFederated e.toKey e.encryptedBlob e.timestamp e.originServer e.messageId e.expiresAt e.priority (False {}) t)
          yield (result == "")
      yield {messageId: e.messageId, ok: ok})
    yield (respond {ok: True {}, error: "", results: results, retryAfterMs: 0}))

handleFederationDeliveryReceipt = \messageIds toKeys fromServer requestTimestamp correlationId authorization respond -> do
  t <- now
  let receiptRespond = \r -> respond {ok: r.ok, error: r.error, receivedCount: 0, retryAfterMs: r.retryAfterMs}
  withFederationAuth authorization t receiptRespond fromServer "delivery-receipt" requestTimestamp (not (isLocalServer fromServer) && count messageIds <= maxMessageIds) (do
    if count messageIds != count toKeys
      then yield (respond {ok: False {}, error: "mismatched_lengths", receivedCount: 0, retryAfterMs: 0})
      else do
        let pairs = do
          mp <- withIndex messageIds
          kp <- withIndex toKeys
          where mp.i == kp.i
          yield {messageId: mp.v, toKey: kp.v}
        atomic do
          msgs <- *messages
          appendCapped senderDeliveries (do
            p <- pairs
            m <- msgs
            where m.messageId == p.messageId && m.toKey == p.toKey && m.senderKey != "" && m.originServer == ""
            yield {senderKey: m.senderKey, messageId: p.messageId, toKey: p.toKey, deliveredAt: t}) 10000 (\d -> d.deliveredAt)
        yield (respond {ok: True {}, error: "", receivedCount: count pairs, retryAfterMs: 0}))

-- Index a list (1-based by virtue of `count` of the partial fold).
withIndex = fold (\acc x -> union acc [{i: count acc, v: x}]) []

-- ============================================
-- Maintenance handlers
-- ============================================

handleDrain = \phase authorization respond -> withMaintAuth authorization
  (yield (respond {ok: False {}, drained: 0, phase: 0}))
  (do
    let effectivePhase = if phase == 1 then 1 else 2
    t <- now
    drainResult <- atomic do
      set *drainPhase = effectivePhase
      set *drainCompletedAt = t
      if effectivePhase == 1 then yield {peers: [], localKeys: []}
      else do
        pres <- *presence
        let localEntries = filter pres (\p -> isLocalServer p.server && p.expiresAt > t)
        set *presence = filter pres (\p -> not (isLocalServer p.server) || p.expiresAt <= t)
        set *pollWakeup = t
        yield {peers: knownPeerServersFromPresence pres, localKeys: localEntries}
    when (effectivePhase == 2 && count drainResult.localKeys > 0 && federationEnabled)
      (fork (sendBatchedGossip drainResult.peers (pluck drainResult.localKeys (\p -> mkGossip (GossipOffline {}) p.pubkey t offlineGossipMinTtl)) gossipOriginHops))
    yield (respond {ok: True {}, drained: count drainResult.localKeys, phase: effectivePhase}))

handleUndrain = \authorization respond -> withMaintAuth authorization
  (yield (respond {ok: False {}}))
  (do
    atomic do
      set *drainPhase = 0
      set *drainCompletedAt = 0
    yield (respond {ok: True {}}))

handleShutdown = \authorization respond ->
  handleDrain 2 authorization (\r -> respond {ok: r.ok, drained: r.drained})

handlePrune = \authorization respond -> do
  t <- now
  authorized <- verifyMaintenanceAuth authorization
  when authorized (fork (pruneAndRetry t))
  yield (respond {ok: authorized})

handleReconcile = \authorization respond -> do
  authorized <- verifyMaintenanceAuth authorization
  yield (respond {ok: authorized, messageDrift: 0, presenceDrift: 0, sessionDrift: 0})

handleHealth = \authorization respond -> do
  t <- now
  lastPrune <- *lastPrunedAt
  lastHb <- *lastHeartbeatAt
  sa <- *startedAt
  dp <- *drainPhase
  let warmup = t - sa < backgroundPruneInterval * 3
  let pruneOk = warmup || t - lastPrune < backgroundPruneInterval * 3
  let heartbeatOk = warmup || t - lastHb < pollTimeoutMs * 3
  yield (respond {ok: dp == 0 && pruneOk && heartbeatOk, version: serverBuildVersion, pruneHealthy: pruneOk, heartbeatHealthy: heartbeatOk, capacityHealthy: True {}, capacityWarning: False {}, federationHealthy: True {}, watchdogHealthy: True {}, nonceHealthy: True {}, forwardQueueHealthy: True {}, requestPressureHealthy: True {}, draining: dp > 0, degradedPeers: 0})

handleReady = \respond -> do
  sa <- *startedAt
  lastPrune <- *lastPrunedAt
  yield (respond {ready: lastPrune > 0 && lastPrune >= sa})

handleBlockPeer = \server authorization respond -> withMaintAuth authorization
  (yield (respond {ok: False {}, blocked: 0}))
  (do n <- addServerToList blockedPeers server; yield (respond {ok: True {}, blocked: n}))

handleUnblockPeer = \server authorization respond -> withMaintAuth authorization
  (yield (respond {ok: False {}, unblocked: False {}}))
  (do removed <- removeServerFromList blockedPeers server; yield (respond {ok: True {}, unblocked: removed}))

handleListPeersResp = \listRef authorization respond -> do
  ok <- verifyMaintenanceAuth authorization
  list <- *listRef
  yield (respond {peers: if ok then list else [], ok: ok})

handleListBlocked = handleListPeersResp blockedPeers

handleAllowPeer = \server authorization respond -> withMaintAuth authorization
  (yield (respond {ok: False {}, allowed: 0}))
  (do n <- addServerToList allowedPeers server; yield (respond {ok: True {}, allowed: n}))

handleUnallowPeer = \server authorization respond -> withMaintAuth authorization
  (yield (respond {ok: False {}, removed: False {}}))
  (do removed <- removeServerFromList allowedPeers server; yield (respond {ok: True {}, removed: removed}))

handleListAllowed = handleListPeersResp allowedPeers

handlePingPeer = \server authorization respond -> withMaintAuth authorization
  (yield (respond {ok: False {}, latencyMs: 0, error: "unauthorized"}))
  (do
    startTime <- now
    auth <- generateFederationAuth "gossip" startTime
    result <- fetch (federationUrl server) (RecvGossip {
      authorization: auth,
      events: [], hopsRemaining: 1, fromServer: serverHostN,
      requestTimestamp: startTime, correlationId: "", protocolVersion: federationProtocolVersion})
    endTime <- now
    case result of
      Err e -> yield (respond {ok: False {}, latencyMs: endTime - startTime, error: show e})
      Ok r -> yield (respond {ok: r.ok, latencyMs: endTime - startTime, error: r.error}))

handleAdminListSessions = \pubkey authorization respond -> do
  ok <- verifyMaintenanceAuth authorization
  ses <- *sessions
  let mine = if ok then mapWhere ses (\s -> s.pubkey == pubkey) (\s -> {token: "***", expiresAt: s.expiresAt, ip: s.ip, createdAt: s.createdAt}) else []
  yield (respond {sessions: mine, count: count mine, ok: ok})

handleAdminRevokeSessions = \pubkey authorization respond -> withMaintAuth authorization
  (yield (respond {ok: False {}, revokedCount: 0}))
  (do
    revoked <- atomic do
      ses <- *sessions
      let same = \s -> s.pubkey == pubkey
      set *sessions = removeWhere ses same
      pruneRef presence (\p -> p.pubkey != pubkey || not (isLocalServer p.server))
      yield (countWhere ses same)
    yield (respond {ok: True {}, revokedCount: revoked}))

handleAdminPurgeMessages = \pubkey authorization respond -> withMaintAuth authorization
  (yield (respond {ok: False {}, purgedCount: 0}))
  (do
    t <- now
    purged <- atomic do
      msgs <- *messages
      let mine = \m -> m.toKey == pubkey
      let purgedMsgs = filter msgs mine
      set *messages = removeWhere msgs mine
      pruneRef forwards (\f -> f.toKey != pubkey)
      appendCapped ackedIds (mapWhere purgedMsgs (\m -> m.originServer != "") (\m -> mkAckedEntry m t)) maxAckedIds (\a -> a.ackedAt)
      yield (count purgedMsgs)
    yield (respond {ok: True {}, purgedCount: purged}))

handleAdminRevokeIp = \ip authorization respond -> withMaintAuth authorization
  (yield (respond {ok: False {}, revokedCount: 0, affectedKeys: 0}))
  (do
    keys <- if ip == "" then yield [] else atomic do
      ses <- *sessions
      let same = \s -> s.ip == ip
      set *sessions = removeWhere ses same
      yield (mapWhere ses same (\s -> s.pubkey))
    let uniqueKeys = unique keys
    yield (respond {ok: ip != "", revokedCount: count keys, affectedKeys: count uniqueKeys}))

handleAdminListAllSessions = \limit authorization respond -> withMaintAuth authorization
  (yield (respond {sessions: [], ok: False {}, total: 0}))
  (do
    t <- now
    ses <- *sessions
    let active = filter ses (\s -> s.expiresAt > t)
    let grouped = pluck (unique (pluck active (\s -> s.pubkey))) (\pk ->
      let mine = filter active (\s -> s.pubkey == pk) in
      {pubkey: pk,
       count: count mine,
       ips: unique (mapWhere mine (\s -> s.ip != "") (\s -> s.ip)),
       latestExpiry: fold (\acc s -> max acc s.expiresAt) 0 mine})
    let cap = if limit <= 0 then 100 else clamp 1 500 limit
    let top = takeRelation cap (sortBy (\g -> 0 - g.count) grouped)
    yield (respond {sessions: top, ok: True {}, total: count grouped}))

handleGetRateLimits = \authorization respond -> do
  ok <- verifyMaintenanceAuth authorization
  let v = \x -> if ok then x else 0
  yield (respond {ok: ok, globalRequest: v maxGlobalRequestRate, ipRate: v maxIpRatePerIp, sendRate: v maxSendRatePerKey, federationRate: v maxFederationRatePerServer, authGlobal: v maxAuthGlobalRate, recvRate: v maxRecvRatePerKey, challengeRate: v maxChallengeRatePerKey, pairRate: v maxPairRatePerPair, lookupRate: v maxLookupRatePerKey, clientWriteRate: v maxClientWriteRatePerKey})

handleSetRateLimits = \globalRequest ipRate sendRate federationRate authGlobal recvRate challengeRate pairRate lookupRate clientWriteRate authorization respond -> do
  authorized <- verifyMaintenanceAuth authorization
  yield (respond {ok: authorized})

handleFlushNonces = \authorization respond -> do
  authorized <- verifyMaintenanceAuth authorization
  yield (respond {ok: authorized, flushedCount: 0})

handleRotateSecret = \newSecret authorization respond -> withMaintAuth authorization
  (yield (respond {ok: False {}, error: "unauthorized"}))
  (do
    atomic do set *runtimeMaintenanceSecret = newSecret
    yield (respond {ok: True {}, error: ""}))

handleGetConfig = \authorization respond -> do
  ok <- verifyMaintenanceAuth authorization
  let v = \x -> if ok then x else 0
  yield (respond {ok: ok, maxMessagesPerRecipient: v maxMessagesPerRecipient, maxGossipHops: v maxGossipHops, pollTimeoutMs: v pollTimeoutMs, ackGracePeriod: v ackGracePeriod})

-- /stats: zero-fill all metric fields we no longer compute.
handleStats = \authorization respond -> withMaintAuth authorization
  (yield (respond zeroStats))
  (do
    t <- now
    sa <- *startedAt
    sessions <- *sessions
    msgs <- *messages
    pres <- *presence
    fwds <- *forwards
    aids <- *ackedIds
    dids <- *deliveredIds
    aps <- *activePolls
    chs <- *challenges
    bp <- *blockedPeers
    pc <- *pruneCount
    hc <- *heartbeatCount
    lp <- *lastPrunedAt
    lh <- *lastHeartbeatAt
    dp <- *drainPhase
    pfc <- *pendingFederationCancels
    let sCount = count sessions
    let mCount = count msgs
    let pCount = count pres
    let fCount = count fwds
    yield (respond {ok: True {}, version: serverBuildVersion,
      capacity: {sessions: sCount, sessionsMax: maxSessions, sessionsPct: pct sCount maxSessions, messages: mCount, messagesMax: maxMessages, messagesPct: pct mCount maxMessages, totalMessageCount: mCount, presence: pCount, presenceMax: maxPresenceEntries, presencePct: pct pCount maxPresenceEntries, forwards: fCount, forwardsMax: maxForwardsEntries, forwardsPct: pct fCount maxForwardsEntries, challenges: count chs, challengesMax: maxChallenges, ackedIds: count aids, ackedIdsMax: maxAckedIds, ackOverflow: 0, ackOverflowMax: 0, deliveredIds: count dids, deliveredIdsMax: maxDeliveredIds, forwardNonces: 0, forwardNoncesMax: 0, nonceEvictions: 0, activePolls: count aps, activePollsMax: maxActivePolls, recipientCounts: 0, messageBucketMax: 0, messageBucketMin: 0},
      federation: {enabled: federationEnabled, inFlight: 0, hungSlots: 0, avgLatencyMs: 0, maxLatencyMs: 0, callCount: 0, slowVerifies: 0, verifyFailures: 0, forwardFailures: 0, oldestForwardAge: 0, oldestAckAge: 0, recentGossip: 0, blockedPeers: count bp, drainCompletedAt: 0, forwardServers: 0, maxForwardQueueDepth: 0, topFailingPeers: [], pendingCancels: count pfc, gossipSuccess: 0, gossipFail: 0, latencyBuckets: {lt100: 0, lt500: 0, lt2000: 0, gte2000: 0}},
      rates: {send: 0, challenge: 0, federation: 0, federationPair: 0, global: 0, ip: 0, lookup: 0, recv: 0, pair: 0, gossipEvent: 0, verifyIp: 0, uniqueKeyIp: 0, pendingAckCleanups: 0, senderExpirations: 0, senderDeliveries: 0, rejectedGlobal: 0, rejectedIp: 0, rejectedAuth: 0, rejectedPerKey: 0, rejectedFederation: 0, clientCancels: 0, federationCancels: 0},
      timing: {pruneCount: pc, pruneRunning: 0, heartbeatCount: hc, uptime: t - sa, lastPruneAt: lp, lastHeartbeatAt: lh, draining: dp > 0, drainPhase: dp, totalEntries: sCount + mCount + pCount + fCount, activeRequests: 0, peakActiveRequests: 0, pollAvgMs: 0, pollMaxMs: 0, pollCount: 0, pollLatencyBuckets: {lt50: 0, lt200: 0, lt1000: 0, gte1000: 0}, sendAvgMs: 0, sendMaxMs: 0, sendCount: 0, sendLatencyBuckets: {lt50: 0, lt200: 0, lt1000: 0, gte1000: 0}, authAvgMs: 0, authMaxMs: 0, authCount: 0}}))

zeroStats = {ok: False {}, version: serverBuildVersion, capacity: {sessions: 0, sessionsMax: 0, sessionsPct: 0, messages: 0, messagesMax: 0, messagesPct: 0, totalMessageCount: 0, presence: 0, presenceMax: 0, presencePct: 0, forwards: 0, forwardsMax: 0, forwardsPct: 0, challenges: 0, challengesMax: 0, ackedIds: 0, ackedIdsMax: 0, ackOverflow: 0, ackOverflowMax: 0, deliveredIds: 0, deliveredIdsMax: 0, forwardNonces: 0, forwardNoncesMax: 0, nonceEvictions: 0, activePolls: 0, activePollsMax: 0, recipientCounts: 0, messageBucketMax: 0, messageBucketMin: 0}, federation: {enabled: False {}, inFlight: 0, hungSlots: 0, avgLatencyMs: 0, maxLatencyMs: 0, callCount: 0, slowVerifies: 0, verifyFailures: 0, forwardFailures: 0, oldestForwardAge: 0, oldestAckAge: 0, recentGossip: 0, blockedPeers: 0, drainCompletedAt: 0, forwardServers: 0, maxForwardQueueDepth: 0, topFailingPeers: [], pendingCancels: 0, gossipSuccess: 0, gossipFail: 0, latencyBuckets: {lt100: 0, lt500: 0, lt2000: 0, gte2000: 0}}, rates: {send: 0, challenge: 0, federation: 0, federationPair: 0, global: 0, ip: 0, lookup: 0, recv: 0, pair: 0, gossipEvent: 0, verifyIp: 0, uniqueKeyIp: 0, pendingAckCleanups: 0, senderExpirations: 0, senderDeliveries: 0, rejectedGlobal: 0, rejectedIp: 0, rejectedAuth: 0, rejectedPerKey: 0, rejectedFederation: 0, clientCancels: 0, federationCancels: 0}, timing: {pruneCount: 0, pruneRunning: 0, heartbeatCount: 0, uptime: 0, lastPruneAt: 0, lastHeartbeatAt: 0, draining: False {}, drainPhase: 0, totalEntries: 0, activeRequests: 0, peakActiveRequests: 0, pollAvgMs: 0, pollMaxMs: 0, pollCount: 0, pollLatencyBuckets: {lt50: 0, lt200: 0, lt1000: 0, gte1000: 0}, sendAvgMs: 0, sendMaxMs: 0, sendCount: 0, sendLatencyBuckets: {lt50: 0, lt200: 0, lt1000: 0, gte1000: 0}, authAvgMs: 0, authMaxMs: 0, authCount: 0}}

handleStatsPeers = \authorization respond -> withMaintAuth authorization
  (yield (respond {peers: [], ok: False {}}))
  (do
    t <- now
    failures <- *forwardFailures
    fwds <- *forwards
    yield (respond {peers: pluck failures (\f ->
      {server: f.server, failures: f.failures, lastFailedAt: f.failedAt, firstFailedAt: f.firstFailedAt, backoffMs: retryBackoff f.failures, retriable: shouldRetryServer f.server t failures, pendingForwards: countWhere fwds (\x -> x.toServer == f.server), avgLatencyMs: 0, maxLatencyMs: 0, latencySamples: 0, gossipEventsPerMin: 0}), ok: True {}}))

handleStatsKey = \pubkey authorization respond -> withMaintAuth authorization
  (yield (respond {messages: 0, presence: [], sessions: 0, forwards: 0, forwardDetails: [], activePolls: 0, ok: False {}}))
  (do
    t <- now
    msgs <- *messages
    pres <- *presence
    ses <- *sessions
    fwds <- *forwards
    aps <- *activePolls
    let myFwds = filter fwds (\x -> x.toKey == pubkey)
    yield (respond {
      messages: countWhere msgs (\x -> x.toKey == pubkey),
      presence: mapWhere pres (\x -> x.pubkey == pubkey && x.expiresAt > t) (\x -> {server: x.server, expiresAt: x.expiresAt}),
      sessions: countWhere ses (\x -> x.pubkey == pubkey),
      forwards: count myFwds,
      forwardDetails: pluck myFwds (\x -> {server: x.toServer, retries: x.retries, createdAt: x.createdAt}),
      activePolls: countWhere aps (\x -> x.pubkey == pubkey),
      ok: True {}}))

handleTopRecipients = \limit authorization respond -> withMaintAuth authorization
  (yield (respond {recipients: [], ok: False {}, total: 0}))
  (do
    msgs <- *messages
    let counts = pluck (unique (pluck msgs (\m -> m.toKey))) (\pk -> {pubkey: pk, count: countWhere msgs (\m -> m.toKey == pk)})
    let cap = if limit <= 0 then 20 else clamp 1 100 limit
    let top = takeRelation cap (sortBy (\c -> 0 - c.count) counts)
    yield (respond {recipients: top, ok: True {}, total: count counts}))

handleStatsForwards = \authorization respond -> withMaintAuth authorization
  (yield (respond {servers: [], ok: False {}, total: 0}))
  (do
    t <- now
    fwds <- *forwards
    yield (respond {
      servers: pluck (collectPeers fwds (\f -> f.toServer)) (\s ->
        let svFwds = filter fwds (\f -> f.toServer == s) in
        {server: s, count: count svFwds, oldestAge: t - fold (\acc f -> min acc f.createdAt) t svFwds, totalRetries: fold (\acc f -> acc + f.retries) 0 svFwds}),
      ok: True {},
      total: count fwds}))

handleStatsRates = \authorization respond -> do
  ok <- verifyMaintenanceAuth authorization
  let v = \x -> if ok then x else 0
  yield (respond {ok: ok, scalePct: v 100, globalRequest: v maxGlobalRequestRate, ipRate: v maxIpRatePerIp, sendRate: v maxSendRatePerKey, federationRate: v maxFederationRatePerServer, authGlobal: v maxAuthGlobalRate, recvRate: v maxRecvRatePerKey, challengeRate: v maxChallengeRatePerKey, pairRate: v maxPairRatePerPair, lookupRate: v maxLookupRatePerKey, clientWriteRate: v maxClientWriteRatePerKey})

handleMetrics = \authorization respond -> do
  t <- now
  msgs <- *messages
  ses <- *sessions
  pres <- *presence
  fwds <- *forwards
  aps <- *activePolls
  sa <- *startedAt
  dp <- *drainPhase
  yield (respond {metrics: fold (\acc r -> acc ++ r.k ++ " " ++ show r.v ++ "\n") "" [
    {k: "skrepka_messages_total", v: count msgs},
    {k: "skrepka_sessions_total", v: count ses},
    {k: "skrepka_presence_total", v: count pres},
    {k: "skrepka_forwards_total", v: count fwds},
    {k: "skrepka_active_polls", v: count aps},
    {k: "skrepka_uptime_seconds", v: (t - sa) / 1000},
    {k: "skrepka_draining", v: if dp > 0 then 1 else 0}], ok: True {}})

-- ============================================
-- Dispatch
-- ============================================

serve = \req -> case req of
  ReqChallenge {pubkey, clientIp, respond} -> handleChallenge pubkey clientIp respond
  VerifyAuth {pubkey, challenge, signature, revokeOthers, clientIp, respond} -> handleVerifyAuth pubkey challenge signature revokeOthers clientIp respond
  RevokeSession {targetToken, authorization, clientIp, respond} -> handleRevoke targetToken authorization clientIp respond
  Logout {authorization, clientIp, respond} -> handleLogout authorization clientIp respond
  Poll {cursor, generation, watchKeys, authorization, clientIp, respond} -> handlePoll cursor generation watchKeys authorization clientIp respond
  SendMessage {to, encryptedBlob, timestamp, messageId, expiresInMs, priority, authorization, clientIp, respond} -> handleSendMessage to encryptedBlob timestamp messageId expiresInMs priority authorization clientIp respond
  MessageStatus {to, messageId, authorization, clientIp, respond} -> handleMessageStatus to messageId authorization clientIp respond
  AckMessages {messageIds, authorization, clientIp, respond} -> handleAckMessages messageIds authorization clientIp respond
  SendBatch {messages, authorization, clientIp, respond} -> handleSendBatch messages authorization clientIp respond
  ListMessages {offset, authorization, clientIp, respond} -> handleListMessages offset authorization clientIp respond
  DeleteMessages {messageIds, authorization, clientIp, respond} -> handleDeleteMessages messageIds authorization clientIp respond
  CancelMessage {messageId, to, authorization, clientIp, respond} -> handleCancelMessage messageId to authorization clientIp respond
  CancelBatch {cancels, authorization, clientIp, respond} -> handleCancelBatch cancels authorization clientIp respond
  LookupPresence {pubkey, authorization, clientIp, respond} -> handleLookupPresence pubkey authorization clientIp respond
  BatchLookupPresence {pubkeys, authorization, clientIp, respond} -> handleBatchLookupPresence pubkeys authorization clientIp respond
  RecvGossip {events, hopsRemaining, fromServer, requestTimestamp, correlationId, protocolVersion, authorization, respond} -> handleRecvGossip events hopsRemaining fromServer requestTimestamp correlationId authorization respond
  ForwardMessage {toKey, encryptedBlob, timestamp, originServer, messageId, fromServer, requestTimestamp, correlationId, expiresAt, priority, protocolVersion, authorization, respond} -> handleForwardMessage toKey encryptedBlob timestamp originServer messageId fromServer requestTimestamp correlationId expiresAt priority authorization respond
  FederationAck {messageIds, originServer, fromServer, requestTimestamp, correlationId, protocolVersion, authorization, respond} -> handleFederationAck messageIds originServer fromServer requestTimestamp correlationId authorization respond
  FederationCancel {messageId, toKey, fromServer, requestTimestamp, correlationId, protocolVersion, authorization, respond} -> handleFederationCancel messageId toKey fromServer requestTimestamp correlationId authorization respond
  FederationBatchCancel {cancels, fromServer, requestTimestamp, correlationId, protocolVersion, authorization, respond} -> handleFederationBatchCancel cancels fromServer requestTimestamp correlationId authorization respond
  FederationBatchForward {forwards, fromServer, requestTimestamp, correlationId, protocolVersion, authorization, respond} -> handleFederationBatchForward forwards fromServer requestTimestamp correlationId authorization respond
  FederationDeliveryReceipt {messageIds, toKeys, fromServer, requestTimestamp, correlationId, protocolVersion, authorization, respond} -> handleFederationDeliveryReceipt messageIds toKeys fromServer requestTimestamp correlationId authorization respond
  VerifyToken {token, scope, clientIp, respond} -> handleVerifyToken token scope clientIp respond
  FederationPubkey {respond} -> handleFederationPubkey respond
  Prune {authorization, respond} -> handlePrune authorization respond
  Drain {phase, authorization, respond} -> handleDrain phase authorization respond
  Shutdown {authorization, respond} -> handleShutdown authorization respond
  Undrain {authorization, respond} -> handleUndrain authorization respond
  BlockPeer {server, authorization, respond} -> handleBlockPeer server authorization respond
  UnblockPeer {server, authorization, respond} -> handleUnblockPeer server authorization respond
  ListBlocked {authorization, respond} -> handleListBlocked authorization respond
  PingPeer {server, authorization, respond} -> handlePingPeer server authorization respond
  AdminListSessions {pubkey, authorization, respond} -> handleAdminListSessions pubkey authorization respond
  AdminRevokeSessions {pubkey, authorization, respond} -> handleAdminRevokeSessions pubkey authorization respond
  AdminListAllSessions {limit, authorization, respond} -> handleAdminListAllSessions limit authorization respond
  AdminPurgeMessages {pubkey, authorization, respond} -> handleAdminPurgeMessages pubkey authorization respond
  AdminRevokeIp {ip, authorization, respond} -> handleAdminRevokeIp ip authorization respond
  GetRateLimits {authorization, respond} -> handleGetRateLimits authorization respond
  SetRateLimits {globalRequest, ipRate, sendRate, federationRate, authGlobal, recvRate, challengeRate, pairRate, lookupRate, clientWriteRate, authorization, respond} -> handleSetRateLimits globalRequest ipRate sendRate federationRate authGlobal recvRate challengeRate pairRate lookupRate clientWriteRate authorization respond
  FlushNonces {authorization, respond} -> handleFlushNonces authorization respond
  AllowPeer {server, authorization, respond} -> handleAllowPeer server authorization respond
  UnallowPeer {server, authorization, respond} -> handleUnallowPeer server authorization respond
  ListAllowed {authorization, respond} -> handleListAllowed authorization respond
  Reconcile {authorization, respond} -> handleReconcile authorization respond
  RotateSecret {newSecret, authorization, respond} -> handleRotateSecret newSecret authorization respond
  GetConfig {authorization, respond} -> handleGetConfig authorization respond
  Health {authorization, respond} -> handleHealth authorization respond
  Stats {authorization, respond} -> handleStats authorization respond
  StatsPeers {authorization, respond} -> handleStatsPeers authorization respond
  StatsKey {pubkey, authorization, respond} -> handleStatsKey pubkey authorization respond
  TopRecipients {limit, authorization, respond} -> handleTopRecipients limit authorization respond
  StatsForwards {authorization, respond} -> handleStatsForwards authorization respond
  StatsRates {authorization, respond} -> handleStatsRates authorization respond
  Metrics {authorization, respond} -> handleMetrics authorization respond
  Ready {respond} -> handleReady respond

-- ============================================
-- Background loops
-- ============================================

backgroundPrune = do
  sleep backgroundPruneInterval
  dp <- *drainPhase
  when (dp < 2) (do
    t <- now
    atomic do
      pc <- *pruneCount
      set *pruneCount = pc + 1
    pruneAndRetry t)
  backgroundPrune

pollHeartbeat = do
  sleep pollTimeoutMs
  t <- now
  atomic do
    set *pollWakeup = t
    set *lastHeartbeatAt = t
    hc <- *heartbeatCount
    set *heartbeatCount = hc + 1
  pollHeartbeat

-- ============================================
-- Entry Point
-- ============================================

main = do
  t <- now
  genJitter <- randomInt 1000000
  atomic do
    set *startedAt = t
    set *serverGeneration = t * 1000 + genJitter
  logInfo ("Skrepka relay server starting on port " ++ show listenPort ++ "...")
  logInfo ("  federation: " ++ if federationEnabled then "enabled" else "disabled")
  fork backgroundPrune
  fork pollHeartbeat
  listen listenPort serve
