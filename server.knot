-- Skrepka Relay Server
-- Single-server implementation of the Skrepka protocol (v0.1)
-- Binary data (keys, signatures, blobs) uses hex encoding (bytesToHex/bytesFromHex)
--
-- Architecture:
--   Clients authenticate via Ed25519 challenge-response, then poll for messages via long-polling.
--   Messages are E2E encrypted blobs routed by recipient pubkey.
--   Federation: servers gossip presence info and forward messages for keys homed elsewhere.
--   Presence tracks which server a pubkey was last seen on (online/offline via gossip).
--   All state is in-memory; background tasks handle pruning and retry of failed federation ops.

-- ============================================
-- Configuration
-- ============================================

-- Server identity and federation credentials
serverHost = "localhost:8080"
listenPort = 8080
maintenanceSecret = "" -- set to enable /maintenance/* and /stats endpoints
federationScheme = "https://" -- scheme for federation HTTP calls
-- Ed25519 federation signing keys (hex-encoded). When both are set, outbound federation
-- requests are signed instead of using verify callbacks (eliminates the round-trip).
-- Inbound requests with "Signed" auth are verified locally; "Bearer" auth falls back
-- to the existing verify callback for backward compatibility with older peers.
-- Empty = signing disabled, use verify callbacks only.
serverFederationPrivateKeyHex = ""
serverFederationPublicKeyHex = ""
-- NOTE: listenHost is not configurable — Knot's listen primitive only accepts a port.
-- To restrict the bind address (e.g., 127.0.0.1 behind a reverse proxy), use
-- firewall rules (e.g., iptables -A INPUT -p tcp --dport 8080 -s 127.0.0.1 -j ACCEPT)
-- or a container network namespace.
-- TODO: If Knot adds a listen-with-host API, add listenHost = "0.0.0.0" config here.
-- NOTE: Outbound federation HTTP calls have no runtime-level timeout. The fetchFederation
-- wrapper tracks in-flight requests per server and skips servers with outstanding requests
-- older than federationFetchTimeoutMs (see shouldRetryServerEx). This prevents a single
-- slow peer from consuming all concurrency slots, though truly hung connections still hold
-- one slot until the forked task terminates.
-- Message and data size limits
-- IMPORTANT: Knot has no HTTP-layer request body size limit. Field-level length checks
-- (maxBlobLen, maxPubkeyLen, etc.) validate after JSON parsing, so a multi-GB body is
-- fully parsed before rejection. Deploy behind a reverse proxy with a body size limit:
--   Caddy:  request_body { max_size 256KB }
--   nginx:  client_max_body_size 256k;
--   HAProxy: tune.maxrewrite 256k
-- Without this, the server is vulnerable to large-payload DoS attacks. The maxBlobLen
-- limit (64KB hex = 32KB binary) bounds legitimate message payloads; batch requests
-- may be larger but are authenticated via maintenance secret.
-- TODO: If Knot adds HTTP-layer configuration, enforce a request body size limit natively.
messageMaxAge : Int<Ms>
messageMaxAge = 2592000000 -- 30 days
maxPresenceTtl : Int<S>
maxPresenceTtl = 3600 -- max presence TTL from gossip
maxPubkeyLen = 256
maxBlobLen = 65536
maxSignatureLen = 256
maxIpLen = 45 -- max length of an IP address string (IPv6 = 45 chars); used in matchIp instead of maxServerNameLen
maxMessageIds = 100
maxBatchSize = 100 -- max messages per batch request (bounds recursion depth in sendBatchInner)
maxMessagePriority = 10 -- max priority value (clamped on ingress)
maxGossipEvents = 100
maxPollEvents = 50
-- Fraction of maxPollEvents reserved for priority-0 messages (normal priority).
-- Prevents high-priority floods from completely starving normal messages.
-- With maxPollEvents=50 and reservedPollFraction=5, at least 10 slots (50/5)
-- are reserved for priority-0 when both priority levels have pending messages.
-- 0 = disable reservation (old behavior: strict priority ordering).
reservedPollFraction = 5
maxPresenceEntries = 10000
maxMessagesPerRecipient = 500
maxMessages = 100000 -- global cap on total stored messages across all recipients
-- Global capacity limits for in-memory collections
clockSkewTolerance : Int<Ms>
clockSkewTolerance = 5000 -- 5 seconds tolerance for clock skew between federated servers
maxForwardsEntries = 10000
maxForwardsPerKey = 50 -- max pending forwards per recipient pubkey (prevents one key from starving others)
maxForwardsPerSenderPerKey = 10 -- max pending forwards per sender-recipient pair (prevents one sender from monopolizing a recipient's queue)
maxForwardsPerServer = 2000 -- max pending forwards per destination server (prevents one unreachable peer from starving others)
maxServerNameLen = 128
maxMessageIdLen = 128
maxCorrelationIdLen = 128
maxTokenLen = 256
maxChallenges = 10000
maxSessions = 10000
maxAckedIds = 10000
maxAckOverflow = 200 -- overflow buffer for acks that couldn't be sent yet
maxDeliveredIds = 10000
-- Per-key limits and rate limiting
maxChallengesPerKey = 5
maxSessionsPerKey = 10
challengeExpiry : Int<Ms>
challengeExpiry = 60000 -- 1 minute
maxChallengeRatePerKey = 5 -- max challenge requests per key per window
maxChallengeRateEntries = 1000
challengeRateWindowMs : Int<Ms>
challengeRateWindowMs = 1000
maxSendRatePerKey = 20 -- max messages sent per key per window
sendRateWindowMs : Int<Ms>
sendRateWindowMs = 1000
maxSendRateEntries = 1000
-- Per-key revoke rate limiting (separate from challenge to prevent challenge floods from blocking revocations)
maxRevokeRatePerKey = 5 -- max revoke requests per key per window
revokeRateWindowMs : Int<Ms>
revokeRateWindowMs = 1000
maxRevokeRateEntries = 1000
-- Per-recipient receive rate limiting
maxRecvRatePerKey = 10 -- max messages received by a key per window (across all senders)
recvRateWindowMs : Int<Ms>
recvRateWindowMs = 1000
maxRecvRateEntries = 1000
-- Per-sender-per-recipient rate limiting (prevents one sender from filling a recipient's mailbox)
maxPairRatePerPair = 30 -- max messages per sender-recipient pair per window
pairRateWindowMs : Int<Ms>
pairRateWindowMs = 60000 -- 1 minute
maxPairRateEntries = 5000
-- Federation rate limiting (per-server)
maxFederationRatePerServer = 50 -- max federation requests per server per window
federationRateWindowMs : Int<Ms>
federationRateWindowMs = 1000
maxFederationRateEntries = 100
-- Per-server-per-recipient rate limiting for federation forwards
maxFederationPairRatePerPair = 10 -- max forwards per fromServer-recipient pair per window
federationPairRateWindowMs : Int<Ms>
federationPairRateWindowMs = 60000 -- 1 minute
maxFederationPairRateEntries = 5000
-- Global request rate limiting
maxActiveRequests = 500 -- max concurrent requests before rejecting with overloaded (0 = disable)
maxGlobalRequestRate = 1000 -- max total requests per window
globalRateWindowMs : Int<Ms>
globalRateWindowMs = 1000
-- Auth-tier global rate limiting (prevents auth flooding from starving client operations)
maxAuthGlobalRate = 200 -- max auth requests (challenge + verify + revoke) per window
authGlobalRateWindowMs : Int<Ms>
authGlobalRateWindowMs = 1000
-- Session and gossip timing
sessionExpiry : Int<Ms>
sessionExpiry = 3600000 -- 1 hour
maxSessionLifetime : Int<Ms>
maxSessionLifetime = 86400000 -- 24 hours; absolute session lifetime (forces re-auth even if sliding window keeps refreshing)
onlineGossipTtl : Int<S>
onlineGossipTtl = 5400 -- 1.5 hours; 1.5x sessionExpiry to prevent presence expiring before session refresh gossips
offlineGossipMinTtl : Int<S>
offlineGossipMinTtl = 60 -- minimum TTL for offline gossip events
maxFederationConcurrency = 10 -- max concurrent outbound federation requests per cycle
maxForwardRetriesPerServer = 100
maxForwardRetries = 10 -- max retries per individual forward entry before dropping
maxAckRetries = 10 -- max retries per ack entry before dropping to deliveredIds
maxGossipHops = 5 -- max hops a gossip event can propagate across servers
maxThirdPartyGossipHops = 2 -- max re-broadcast hops for relayed (third-party) gossip events
gossipOriginHops = 2 -- hops set when this server originates a gossip event
gossipDedupWindow : Int<Ms>
gossipDedupWindow = 60000 -- suppress re-broadcast of identical gossip events within this window
maxRecentGossip = 1000
-- Exponential backoff for failed federation forwards
retryBackoffBase : Int<Ms>
retryBackoffBase = 30000 -- 30 seconds
retryBackoffMax : Int<Ms>
retryBackoffMax = 480000 -- 8 minutes
maxForwardFailures = 1000 -- max tracked server failure records
maxServerDowntime : Int<Ms>
maxServerDowntime = 86400000 -- 24 hours; stop retrying a server after this duration of consecutive failures
-- Federation in-flight tracking: skip servers with outstanding requests older than this threshold
federationFetchTimeoutMs : Int<Ms>
federationFetchTimeoutMs = 30000 -- 30 seconds; consider server unresponsive if fetch hasn't returned
-- Verify callback latency threshold: warn when federation verify round-trips exceed this.
-- Shorter than federationFetchTimeoutMs because verify is a single lightweight POST
-- (no payload); slow verifies indicate network issues or overloaded peers.
federationVerifyTimeoutMs : Int<Ms>
federationVerifyTimeoutMs = 10000 -- 10 seconds
maxFederationInFlight = 100
-- Federation circuit breaker: pause all outbound federation when this many unique peer
-- servers have active (non-expired) failure records. Prevents wasted retries and log spam
-- when the local network is down. Set to 0 to disable.
federationCircuitBreakerThreshold = 3
-- Federation replay dedup: track recent (server, timestamp) pairs to reject exact replays
maxRecentFederationRequests = 1000
-- Forward nonce dedup: tracks (messageId, toKey) pairs to catch replays
-- beyond the lifetime of messages/ackedIds/deliveredIds
maxForwardNonces = 100000
maxNoncesPerBucket = maxForwardNonces / 16 + 1 -- per-bucket cap for 16-way sharded nonces
forwardNonceRetention : Int<Ms>
forwardNonceRetention = messageMaxAge * 2 -- 60 days; extends 30 days beyond message dedup
-- Message reconciliation: full scan runs every Nth prune cycle or when cheap drift check detects mismatch.
-- Cheap check (sum rcBucket totals vs totalMessageCount) runs every cycle; full scan only when needed.
reconciliationFullCycleInterval = 50 -- full reconciliation every 50th prune cycle (~25 min)
-- Cheap drift threshold: only trigger full message reconciliation when the cheap check
-- (sum of rcBucket totals vs totalMessageCount) exceeds this threshold. Small drifts from
-- concurrent bucket pruning self-correct on the next cycle. 0 = always reconcile on drift.
reconciliationDriftThreshold = 10
-- Lightweight reconciliation interval: presence/session/forward counter reconciliation
-- runs every Nth prune cycle. Between cycles, cached counters are trusted. Message
-- reconciliation has its own interval (reconciliationFullCycleInterval).
lightReconciliationInterval = 5

-- Federation latency metric window
federationLatencyWindowMs : Int<Ms>
federationLatencyWindowMs = 300000 -- 5 minutes; reset latency metrics after this interval

-- Federation latency histogram thresholds (ms). Counts how many calls fell into each bucket:
-- [0, t1), [t1, t2), [t2, t3), [t3, +inf). Operators use these to approximate P95/P99.
federationLatencyT1 : Int<Ms>
federationLatencyT1 = 100 -- fast (local network / same datacenter)
federationLatencyT2 : Int<Ms>
federationLatencyT2 = 500 -- normal (cross-region)
federationLatencyT3 : Int<Ms>
federationLatencyT3 = 2000 -- slow (degraded or distant peer)

-- Server build version: included in /health and /stats responses for deployment verification.
-- Update this string when deploying a new build so operators can confirm which version is running.
serverBuildVersion = "2026-04-26g"

-- Federation protocol version: included in gossip/forward/ack requests.
-- Peers log warnings when they receive requests from older versions.
-- Backward compatible: older peers ignore unknown fields (Knot's JSON parser
-- drops unknown keys). 0 = pre-versioning peer (field missing or unset).
federationProtocolVersion = 15

-- Max seenBy list length in gossip events (bounds memory and bandwidth per event)
maxSeenByLen = 20

-- Per-peer gossip event volume limiting (prevents flooding via large batches of unique pubkeys)
maxGossipEventsPerServer = 500 -- max total gossip events per server per window
gossipEventRateWindowMs : Int<Ms>
gossipEventRateWindowMs = 60000 -- 1 minute
maxGossipEventRateEntries = 100
-- Gossip batch backoff: when a single gossip request carries more than this many fresh events,
-- delay re-broadcast by a random interval up to gossipBatchBackoffMs. Prevents amplification
-- storms when peers recover from downtime and send bursts of presence updates.
gossipBatchBackoffThreshold = 50
gossipBatchBackoffMs : Int<Ms>
gossipBatchBackoffMs = 5000 -- max random delay before re-gossiping large batches
-- Global federation connection cap (bounds total concurrent outbound connections across all paths)
maxGlobalFederationConcurrency = 30
-- Peer blocklist: max blocked servers tracked at runtime (managed via /maintenance/block, /maintenance/unblock)
maxBlockedPeers = 100
-- Peer allowlist: when non-empty, only these servers can federate with us (managed via /maintenance/allow, /maintenance/unallow)
maxAllowedPeers = 100

-- Drain timeout: max time for drain flush operations before force-completing
drainTimeoutMs : Int<Ms>
drainTimeoutMs = 120000 -- 2 minutes; covers forward retries + ack sends + gossip + in-flight wait
-- Background task intervals
backgroundPruneInterval : Int<Ms>
backgroundPruneInterval = 30000 -- 30 seconds; also retries failed forwards/acks
pollTimeoutMs : Int<Ms>
pollTimeoutMs = 25000 -- long-poll heartbeat interval (how long a poll blocks before returning empty)
maxPollsPerKey = 3 -- max concurrent long-poll connections per pubkey
maxActivePolls = 5000
maxWatchKeys = 50
presenceRefreshInterval : Int<Ms>
presenceRefreshInterval = 300000 -- 5 minutes
-- Refresh entries expiring within 1.5 refresh intervals. At 2x, entries with 8-10 min
-- remaining would be refreshed every cycle (wasteful gossip). 1.5x catches entries
-- likely to expire before the next refresh without over-refreshing healthy ones.
presenceRefreshThreshold : Int<Ms>
presenceRefreshThreshold = presenceRefreshInterval + presenceRefreshInterval / 2
federationEnabled = True {}
-- WARNING: DNS rebinding risk — federationUrl resolves DNS at fetch time, not at
-- ServerName validation time. A hostname passing isBadServerName could rebind to a
-- private IP between validation and fetch. Mitigate at the network layer (e.g.,
-- firewall rules blocking outbound connections to RFC1918 ranges from the server process).
-- TODO: If Knot adds a resolved-IP introspection API (e.g., fetchWithResolvedIp),
-- validate the resolved IP against isBadServerName before completing the request.
federationUrl = \server -> federationScheme ++ server
-- Callback verification: outbound federation requests include a random single-use token;
-- the receiver calls back to /federation/verify to confirm the sender actually issued it.
maxPendingVerifications = 10000
verificationTokenExpiry : Int<Ms>
verificationTokenExpiry = 30000 -- 30 seconds
-- Peer public key cache (for Ed25519 federation signing)
maxPeerPublicKeys = 100
peerKeyTtlMs : Int<Ms>
peerKeyTtlMs = 86400000 -- 24 hours; peer keys change rarely (server restart or rotation)
peerKeyRefetchCooldownMs : Int<Ms>
peerKeyRefetchCooldownMs = 60000 -- 1 minute; minimum interval between re-fetch attempts per server
-- Require ClientIp header on auth requests. When True, challenge requests with
-- empty clientIp are rejected. Prevents unbound sessions if the reverse proxy is
-- temporarily misconfigured (no ClientIp header forwarding). Sessions created without
-- IP binding permanently accept requests from any IP.
requireClientIp = True {}
-- IP-based rate limiting (reverse proxy sets ClientIp header)
maxIpRatePerIp = 10 -- max auth requests per IP per window
ipRateWindowMs : Int<Ms>
ipRateWindowMs = 1000
maxIpRateEntries = 5000
-- Per-IP unique key tracking (detects key-rotation abuse: single IP authenticating many distinct pubkeys)
maxUniqueKeysPerIp = 20 -- max distinct pubkeys per IP per window before throttling
uniqueKeyIpWindowMs : Int<Ms>
uniqueKeyIpWindowMs = 60000 -- 1 minute
maxUniqueKeyIpEntries = 5000
-- Lookup rate limiting (per-key, on presence lookups)
maxLookupRatePerKey = 5 -- max lookups per key per window
lookupRateWindowMs : Int<Ms>
lookupRateWindowMs = 1000
maxLookupRateEntries = 1000
-- Client write operation rate limiting (per-key, on ack/delete — separate from read-only lookups)
maxClientWriteRatePerKey = 10 -- max ack/delete requests per key per window
clientWriteRateWindowMs : Int<Ms>
clientWriteRateWindowMs = 1000
maxClientWriteRateEntries = 1000
-- Federation verify rate limiting (per-IP, tighter than general IP rate)
maxVerifyRatePerIp = 5 -- max verify requests per IP per window
verifyRateWindowMs : Int<Ms>
verifyRateWindowMs = 1000
maxVerifyRateEntries = 1000
-- Unacked message aging (messages pruned after this regardless of ack status)
unackedMessageMaxAge : Int<Ms>
unackedMessageMaxAge = 604800000 -- 7 days
-- Minimum sender-specified message TTL (prevents abuse with ultra-short TTLs that
-- expire before the recipient can poll). 0 in the request = use unackedMessageMaxAge.
minMessageTtl : Int<Ms>
minMessageTtl = 60000 -- 1 minute
-- Grace period before federation ack can delete the original message (allows local client to poll)
ackGracePeriod : Int<Ms>
ackGracePeriod = 120000 -- 2 minutes; allows clients on slow connections or backgrounded apps
-- to poll before federation ack reclaims the origin message
-- Deferred ack cleanup capacity
maxPendingAckCleanups = 10000
-- Per-key deferred ack cleanup cap (prevents one noisy key from dominating the queue)
maxPendingAckCleanupsPerKey = 100

-- Message expiration notifications: track expired locally-originated messages so senders
-- can learn their message was never read (returned in poll response).
maxSenderExpirations = 10000
maxSenderExpirationsPerKey = 100
-- Delivery receipts: track when a locally-originated message is polled/acked by the recipient
-- so senders can learn their message was delivered (returned in poll response).
maxSenderDeliveries = 10000
maxSenderDeliveriesPerKey = 100
-- Cancel notifications: track when a message is retracted so the recipient can remove it from their UI.
-- Populated when /messages/cancel, /federation/cancel, or /federation/cancel-batch succeeds.
maxCancelNotifications = 10000
maxCancelNotificationsPerKey = 100
-- Max pubkeys in a batch lookup request
maxBatchLookupKeys = 50
-- Max per-sender drop counter entries (bounds memory for per-sender receipt/expiration drop tracking)
maxDroppedCountEntries = 1000
-- Max pending federation cancel entries (bounds memory for cancel retry queue)
maxPendingCancels = 10000
-- Max retries per cancel entry before dropping (uses same backoff as forward retries)
maxCancelRetries = 10

-- Verify callback caching: cache successful verifications per-server to reduce
-- outbound HTTP calls. A peer sending N requests/second forces N verify callbacks;
-- caching the success for a short window amortizes the cost.
-- Adaptive: scales from verificationCacheMinMs to verificationCacheMaxMs based on
-- recent request volume from the peer (higher volume = longer cache = fewer callbacks).
verificationCacheMinMs : Int<Ms>
verificationCacheMinMs = 2000 -- 2 seconds; base cache for low-traffic peers
verificationCacheMaxMs : Int<Ms>
verificationCacheMaxMs = 10000 -- 10 seconds; max cache for high-traffic peers
maxVerificationCache = 100
-- Health endpoint rate limiting (global, since /health has no clientIp)
maxHealthRate = 100 -- max health checks per window
healthRateWindowMs : Int<Ms>
healthRateWindowMs = 1000
-- Health check thresholds (background task freshness)
healthPruneMaxAge : Int<Ms>
healthPruneMaxAge = backgroundPruneInterval * 3
healthHeartbeatMaxAge : Int<Ms>
healthHeartbeatMaxAge = pollTimeoutMs * 3
healthWatchdogMaxAge : Int<Ms>
healthWatchdogMaxAge = backgroundPruneInterval * 15 -- watchdog runs every ~5 prune intervals
-- Forward queue age health threshold: flag unhealthy when multiple destination servers
-- have pending forwards older than this. A single stuck peer shouldn't mark the whole
-- server unhealthy — only widespread queue buildup indicates a systemic problem.
healthForwardQueueMaxAge : Int<Ms>
healthForwardQueueMaxAge = retryBackoffMax * 3 -- ~24 minutes; 3x max backoff gives retries time to succeed
-- Minimum number of destination servers with stale queues before flagging unhealthy.
-- 1 = old behavior (any stale server triggers unhealthy). 2+ = tolerate isolated peer issues.
healthForwardQueueMinStaleServers = 2

-- ============================================
-- Types
-- ============================================

-- Event delivered to a polling client: an encrypted message blob
type PollEvent = {id: MessageIdHex, eventType: Text, payload: {encryptedBlob: BlobHex, timestamp: Timestamp, toKey: PubkeyHex, expiresAt: Timestamp}}

-- Gossip events propagate presence changes between federated servers
data GossipEventType = GossipOnline {} | GossipOffline {} | GossipUnknown {}

impl ToJSON GossipEventType where
  toJson et = toJson (case et of
    GossipOnline {} -> "online"
    GossipOffline {} -> "offline"
    GossipUnknown {} -> "unknown")

impl FromJSON GossipEventType where
  parseJson t =
    let s : Text = parseJson t in
    if s == "online" then GossipOnline {}
    else if s == "offline" then GossipOffline {}
    else GossipUnknown {}

-- Wire format for gossip events sent between servers
-- seenBy: list of server names that have already received this event.
-- Used to suppress redundant re-broadcast: when re-gossiping, skip peers already in seenBy.
-- Pre-v11 peers send [] (Knot ignores unknown fields on parse, sends [] for missing lists).
type GossipEvent = {eventType: GossipEventType, pubkey: PubkeyHex, server: ServerName, timestamp: Timestamp, ttl: Int<S>, seenBy: [Text]}

-- A gossip event that passed validation (timestamp not in future, TTL > 0, not expired)
type ValidGossipEntry = {pubkey: PubkeyHex, server: ServerName, expiresAt: Timestamp, timestamp: Timestamp, ttl: Int<S>}

-- Status returned to the sender after SendMessage
-- Delivered: recipient is online locally; Federated: forwarded to remote server;
-- Queued: stored but recipient location unknown; Unauthorized/Rejected: not accepted
data MessageStatus = MsDelivered {} | MsFederated {} | MsQueued {} | MsUnauthorized {} | MsRejected {} | MsRateLimited {} | MsDuplicate {} | MsDraining {}

impl ToJSON MessageStatus where
  toJson ms = toJson (case ms of
    MsDelivered {} -> "delivered"
    MsFederated {} -> "federated"
    MsQueued {} -> "queued"
    MsUnauthorized {} -> "unauthorized"
    MsRejected {} -> "rejected"
    MsRateLimited {} -> "rate_limited"
    MsDuplicate {} -> "duplicate"
    MsDraining {} -> "draining")

-- Validated hex-encoded types with maximum length constraints
isValidBoundedHex : Int -> Text -> Bool
isValidBoundedHex = \maxLen s -> not (tooLong s maxLen) && isValidHex s && s == normalizeHex s
type PubkeyHex = Text where isValidBoundedHex maxPubkeyLen
type BlobHex = Text where isValidBoundedHex maxBlobLen
type SignatureHex = Text where isValidBoundedHex maxSignatureLen
isValidMessageId : Text -> Bool
isValidMessageId = isValidBoundedHex maxMessageIdLen
type MessageIdHex = Text where isValidMessageId
type OptionalMessageId = Text where \s -> s == "" || isValidMessageId s
-- ServerName: validated server hostname (rejects private IPs, localhost, etc.)
-- AnyServerName: normalized server name without the security checks (used in presence lookups)
isValidServerName : Text -> Bool
isValidServerName = \s -> not (tooLong s maxServerNameLen) && s == normalizeServerName s && not (isBadServerName s)
type ServerName = Text where isValidServerName
type AnyServerName = Text where \s -> not (tooLong s maxServerNameLen) && s == normalizeServerName s

type Timestamp = Int<Ms>

-- Pending challenge for Ed25519 challenge-response auth
type Challenge = {pubkey: PubkeyHex, challenge: Text, expiresAt: Timestamp, ip: Text}
-- Authenticated session; token is a random hex string
type Session = {token: Text, pubkey: PubkeyHex, expiresAt: Timestamp, ip: Text, createdAt: Timestamp}
-- Stored message; originServer is "" for locally-originated messages, set to sender server for federated forwards.
-- Messages with expiresAt <= now are pruned and excluded from polls.
-- senderKey: pubkey of the authenticated sender (locally-originated only; "" for federation forwards).
-- Used by /messages/cancel to verify the caller is the actual sender.
-- priority: 0 = normal (default), higher = more urgent. High-priority messages are
-- forwarded first during federation retries. Clamped to [0, 10] on ingress.
type Message = {messageId: MessageIdHex, toKey: PubkeyHex, encryptedBlob: BlobHex, timestamp: Timestamp, originServer: Text, receivedAt: Timestamp, expiresAt: Timestamp, senderKey: Text, priority: Int}
-- Presence: tracks that a pubkey is online at a given server, with expiry
type PresenceEntry = {pubkey: PubkeyHex, server: AnyServerName, expiresAt: Timestamp, timestamp: Timestamp}
-- Queued federation forward: message waiting to be delivered to a remote server.
-- senderKey: pubkey of the authenticated sender (locally-originated only; "" for federation relays).
-- Used by fedDeliveryReceipts to generate delivery receipts even if the original message was pruned.
type ForwardEntry = {messageId: MessageIdHex, toServer: ServerName, createdAt: Timestamp, toKey: PubkeyHex, encryptedBlob: BlobHex, timestamp: Timestamp, originServer: Text, retries: Int, expiresAt: Timestamp, priority: Int, senderKey: Text}
-- Tracks message IDs that were acked by a polling client, pending federation ack back to origin
type AckedEntry = {messageId: MessageIdHex, toKey: PubkeyHex, ackedAt: Timestamp, originServer: ServerName, retries: Int}
-- Terminal state: message delivered and ack confirmed (used for dedup after ack overflow)
type DeliveredEntry = {messageId: MessageIdHex, toKey: PubkeyHex, deliveredAt: Timestamp}
-- Tracks consecutive failures per federation peer for exponential backoff
type ForwardFailure = {server: Text, failedAt: Timestamp, failures: Int, firstFailedAt: Timestamp}
-- Sliding-window rate limit state per pubkey.
-- prevCount: count from the previous window, used for sliding-window interpolation.
-- Effective count = prevCount * (1 - elapsed/windowMs) + count, preventing 2x burst at window boundaries.
type SendRateEntry = {pubkey: PubkeyHex, windowStart: Timestamp, count: Int, prevCount: Int}
type RecvRateEntry = {pubkey: PubkeyHex, windowStart: Timestamp, count: Int, prevCount: Int}
type PairRateEntry = {sender: PubkeyHex, recipient: PubkeyHex, windowStart: Timestamp, count: Int, prevCount: Int}
type ChallengeRateEntry = {pubkey: PubkeyHex, windowStart: Timestamp, count: Int, prevCount: Int}
-- Sliding-window rate limit state per federation peer server
type FederationRateEntry = {server: Text, windowStart: Timestamp, count: Int, prevCount: Int}
type FederationPairRateEntry = {server: Text, recipient: PubkeyHex, windowStart: Timestamp, count: Int, prevCount: Int}
-- Tracks active long-poll connections to enforce per-key concurrency limits
type ActivePoll = {pubkey: PubkeyHex, startedAt: Timestamp}
data AuthResult = Authorized {pubkey: PubkeyHex, ip: Text} | Unauthorized {}
data ForwardResult = ForwardDuplicate {} | ForwardRejected {} | ForwardStored {}

type IpRateEntry = {ip: Text, windowStart: Timestamp, count: Int, prevCount: Int}
type LookupRateEntry = {pubkey: PubkeyHex, windowStart: Timestamp, count: Int, prevCount: Int}
-- Tracks recently re-broadcast gossip events to suppress amplification from duplicate cycles
type RecentGossipEntry = {pubkey: PubkeyHex, server: Text, timestamp: Timestamp, seenAt: Timestamp}
type PeerStatus = {server: Text, failures: Int, lastFailedAt: Timestamp, firstFailedAt: Timestamp, backoffMs: Int, retriable: Bool, pendingForwards: Int, avgLatencyMs: Int, maxLatencyMs: Int, latencySamples: Int, gossipEventsPerMin: Int}
type KeyPresenceEntry = {server: Text, expiresAt: Timestamp}
type RecipientCount = {pubkey: PubkeyHex, count: Int}
type FederationInFlightEntry = {server: Text, count: Int, firstStartedAt: Timestamp}
-- Tracks recent federation request (server, timestamp) pairs for replay detection
type RecentFederationRequest = {server: Text, timestamp: Timestamp, seenAt: Timestamp}
type GossipEventRateEntry = {server: Text, windowStart: Timestamp, count: Int, prevCount: Int}
-- Tracks unique pubkeys authenticated per IP (key-rotation abuse detection)
type UniqueKeyIpEntry = {ip: Text, keys: [PubkeyHex], windowStart: Timestamp}

-- Forward nonce for extended replay protection
type ForwardNonce = {messageId: MessageIdHex, toKey: PubkeyHex, seenAt: Timestamp}

-- Batch send types
type BatchMessage = {to: PubkeyHex, encryptedBlob: BlobHex, timestamp: Timestamp, messageId: OptionalMessageId, expiresInMs: Int, priority: Int}
type BatchResult = {messageId: OptionalMessageId, status: MessageStatus}

-- Batch cancel types
type BatchCancelEntry = {messageId: MessageIdHex, to: PubkeyHex}
type BatchCancelResult = {messageId: MessageIdHex, cancelled: Bool}

-- Pending federation cancel: queued when /messages/cancel or /messages/cancel-batch
-- fails to deliver a cancel to a remote server. Retried during the prune cycle.
type PendingFederationCancel = {messageId: MessageIdHex, toKey: PubkeyHex, toServer: ServerName, createdAt: Timestamp, retries: Int}

-- Sender expiration notification: tracks when a locally-originated message expired unread.
-- Pruned after messageMaxAge. Included in the sender's next poll response.
type SenderExpiration = {senderKey: Text, messageId: MessageIdHex, toKey: PubkeyHex, expiredAt: Timestamp}

-- Sender delivery receipt: tracks when a locally-originated message was polled/acked by
-- the recipient. Included in the sender's next poll response for delivery confirmation.
-- Only for locally-originated messages (senderKey != ""); federated messages have no senderKey.
type SenderDelivery = {senderKey: Text, messageId: MessageIdHex, toKey: PubkeyHex, deliveredAt: Timestamp}

-- Cancel notification: tracks when a message was retracted by the sender. Delivered to
-- the recipient via their next poll response so clients can remove the message from the UI.
-- Keyed by toKey (recipient). cancelledAt is when the cancel was processed on this server.
type CancelNotification = {toKey: PubkeyHex, messageId: MessageIdHex, cancelledAt: Timestamp}

-- ============================================
-- Persisted State
-- ============================================
-- All state is in-memory (no disk persistence). Prefixed with * (mutable refs).
-- Atomic blocks provide transactional consistency for reads + writes.

*challenges : [Challenge]

-- Sessions sharded into 16 buckets by first hex char of token.
-- Hot-path auth scans only one bucket (~1/16 of sessions).
-- TODO: If Knot adds indexed arrays or maps, replace the 16 manual bucket
-- refs and their if-else dispatch chains with a single indexed collection.
-- This would eliminate ~1500 lines of mechanical boilerplate:
--   - 10 sharded collections (sessions, messages, presence, forwards, acked,
--     delivered, nonces, recipientCounts, messageSignals, fwdBuckets)
--   - Each has: 16 mutable refs, read/write/readAll/writeAll/countAll/transform functions
--   - writeAll* functions share an identical 16-way partition fold pattern
--   - The partition fold and 16-write pattern could become: partitionByBucket items getKey writeBucket
*sessionBucket0 : [Session]
*sessionBucket1 : [Session]
*sessionBucket2 : [Session]
*sessionBucket3 : [Session]
*sessionBucket4 : [Session]
*sessionBucket5 : [Session]
*sessionBucket6 : [Session]
