-- Skrepka Relay Server
-- Single-server implementation of the Skrepka protocol (v0.1)
-- Binary data (keys, signatures, blobs) uses hex encoding (bytesToHex/bytesFromHex)
--
-- Architecture:
--   Clients authenticate via Ed25519 challenge-response, then poll for messages via long-polling.
--   Messages are E2E encrypted blobs routed by recipient pubkey.
--   Federation: servers gossip presence info and forward messages for keys homed elsewhere.
--   Presence tracks which server a pubkey was last seen on (online/offline via gossip).
--   All state is in-memory; background tasks handle pruning and retry of failed federation ops.

-- ============================================
-- Configuration
-- ============================================

-- Server identity and federation credentials
serverHost = "localhost:8080"
federationSecret = "" -- must be set to enable federation
maintenanceSecret = "" -- set to enable /maintenance/prune independently of federation
federationScheme = "https://" -- scheme for federation HTTP calls
-- NOTE: Outbound federation HTTP calls have no runtime-level timeout. The fetchFederation
-- wrapper tracks in-flight requests per server and skips servers with outstanding requests
-- older than federationFetchTimeoutMs (see shouldRetryServerEx). This prevents a single
-- slow peer from consuming all concurrency slots, though truly hung connections still hold
-- one slot until the forked task terminates.
-- Per-peer federation secrets (overrides global federationSecret for specific peers)
-- Format: [{server: "peer.example.com", secret: "peer-specific-secret"}]
federationPeerSecrets : [{server: Text, secret: Text}]
federationPeerSecrets = []
-- Message and data size limits
messageMaxAge : Int<Ms>
messageMaxAge = 2592000000 -- 30 days
maxPresenceTtl : Int<S>
maxPresenceTtl = 3600 -- max presence TTL from gossip
maxPubkeyLen = 256
maxBlobLen = 65536
maxSignatureLen = 256
maxMessageIds = 100
maxGossipEvents = 100
maxPollEvents = 50
maxPresenceEntries = 10000
maxMessagesPerRecipient = 500
maxMessages = 100000 -- global cap on total stored messages across all recipients
-- Global capacity limits for in-memory collections
clockSkewTolerance : Int<Ms>
clockSkewTolerance = 5000 -- 5 seconds tolerance for clock skew between federated servers
maxForwardsEntries = 10000
maxServerNameLen = 128
maxMessageIdLen = 128
maxTokenLen = 256
maxChallenges = 10000
maxSessions = 10000
maxAckedIds = 10000
maxAckOverflow = 200 -- overflow buffer for acks that couldn't be sent yet
maxDeliveredIds = 10000
-- Per-key limits and rate limiting
maxChallengesPerKey = 5
maxSessionsPerKey = 10
challengeExpiry : Int<Ms>
challengeExpiry = 60000 -- 1 minute
maxChallengeRatePerKey = 5 -- max challenge requests per key per window
maxChallengeRateEntries = 1000
challengeRateWindowMs : Int<Ms>
challengeRateWindowMs = 1000
maxSendRatePerKey = 20 -- max messages sent per key per window
sendRateWindowMs : Int<Ms>
sendRateWindowMs = 1000
maxSendRateEntries = 1000
-- Per-recipient receive rate limiting
maxRecvRatePerKey = 10 -- max messages received by a key per window (across all senders)
recvRateWindowMs : Int<Ms>
recvRateWindowMs = 1000
maxRecvRateEntries = 1000
-- Federation rate limiting (per-server)
maxFederationRatePerServer = 50 -- max federation requests per server per window
federationRateWindowMs : Int<Ms>
federationRateWindowMs = 1000
maxFederationRateEntries = 100
-- Global request rate limiting
maxGlobalRequestRate = 1000 -- max total requests per window
globalRateWindowMs : Int<Ms>
globalRateWindowMs = 1000
-- Auth-tier global rate limiting (prevents auth flooding from starving client operations)
maxAuthGlobalRate = 200 -- max auth requests (challenge + verify + revoke) per window
authGlobalRateWindowMs : Int<Ms>
authGlobalRateWindowMs = 1000
-- Session and gossip timing
sessionExpiry : Int<Ms>
sessionExpiry = 3600000 -- 1 hour
onlineGossipTtl : Int<S>
onlineGossipTtl = 3600 -- 1 hour; TTL announced when a key authenticates
offlineGossipMinTtl : Int<S>
offlineGossipMinTtl = 60 -- minimum TTL for offline gossip events
maxFederationConcurrency = 10 -- max concurrent outbound federation requests per cycle
maxForwardRetriesPerServer = 100
maxGossipHops = 5 -- max hops a gossip event can propagate across servers
gossipOriginHops = 2 -- hops set when this server originates a gossip event
gossipDedupWindow : Int<Ms>
gossipDedupWindow = 60000 -- suppress re-broadcast of identical gossip events within this window
maxRecentGossip = 1000
-- Exponential backoff for failed federation forwards
retryBackoffBase : Int<Ms>
retryBackoffBase = 30000 -- 30 seconds
retryBackoffMax : Int<Ms>
retryBackoffMax = 480000 -- 8 minutes
maxForwardFailures = 1000 -- max tracked server failure records
maxServerDowntime : Int<Ms>
maxServerDowntime = 86400000 -- 24 hours; stop retrying a server after this duration of consecutive failures
-- Federation in-flight tracking: skip servers with outstanding requests older than this threshold
federationFetchTimeoutMs : Int<Ms>
federationFetchTimeoutMs = 30000 -- 30 seconds; consider server unresponsive if fetch hasn't returned
maxFederationInFlight = 100

-- Federation latency metric window
federationLatencyWindowMs : Int<Ms>
federationLatencyWindowMs = 300000 -- 5 minutes; reset latency metrics after this interval

-- Background task intervals
backgroundPruneInterval : Int<Ms>
backgroundPruneInterval = 30000 -- 30 seconds; also retries failed forwards/acks
pollTimeoutMs : Int<Ms>
pollTimeoutMs = 25000 -- long-poll heartbeat interval (how long a poll blocks before returning empty)
maxPollsPerKey = 3 -- max concurrent long-poll connections per pubkey
maxActivePolls = 5000
maxWatchKeys = 50
presenceRefreshInterval : Int<Ms>
presenceRefreshInterval = 300000 -- 5 minutes
presenceRefreshThreshold : Int<Ms>
presenceRefreshThreshold = presenceRefreshInterval * 2 -- refresh entries expiring within this window
federationEnabled = federationSecret != ""
federationAuth = "Bearer " ++ federationSecret
federationUrl = \server -> federationScheme ++ server
-- IP-based rate limiting (reverse proxy sets ClientIp header)
maxIpRatePerIp = 10 -- max auth requests per IP per window
ipRateWindowMs : Int<Ms>
ipRateWindowMs = 1000
maxIpRateEntries = 5000
-- Lookup rate limiting (per-key, on presence lookups)
maxLookupRatePerKey = 5 -- max lookups per key per window
lookupRateWindowMs : Int<Ms>
lookupRateWindowMs = 1000
maxLookupRateEntries = 1000
-- Unacked message aging (messages pruned after this regardless of ack status)
unackedMessageMaxAge : Int<Ms>
unackedMessageMaxAge = 604800000 -- 7 days
-- Grace period before federation ack can delete the original message (allows local client to poll)
ackGracePeriod : Int<Ms>
ackGracePeriod = 30000 -- 30 seconds
-- Health check thresholds (background task freshness)
healthPruneMaxAge : Int<Ms>
healthPruneMaxAge = backgroundPruneInterval * 3
healthHeartbeatMaxAge : Int<Ms>
healthHeartbeatMaxAge = pollTimeoutMs * 3

-- ============================================
-- Types
-- ============================================

-- Event delivered to a polling client: an encrypted message blob
type PollEvent = {id: MessageIdHex, eventType: Text, payload: {encryptedBlob: BlobHex, timestamp: Timestamp, toKey: PubkeyHex}}

-- Gossip events propagate presence changes between federated servers
data GossipEventType = GossipOnline {} | GossipOffline {} | GossipUnknown {}

impl ToJSON GossipEventType where
  toJson et = toJson (case et of
    GossipOnline {} -> "online"
    GossipOffline {} -> "offline"
    GossipUnknown {} -> "unknown")

impl FromJSON GossipEventType where
  parseJson t =
    let s : Text = parseJson t in
    if s == "online" then GossipOnline {}
    else if s == "offline" then GossipOffline {}
    else GossipUnknown {}

-- Wire format for gossip events sent between servers
type GossipEvent = {eventType: GossipEventType, pubkey: PubkeyHex, server: ServerName, timestamp: Timestamp, ttl: Int<S>}

-- A gossip event that passed validation (timestamp not in future, TTL > 0, not expired)
type ValidGossipEntry = {pubkey: PubkeyHex, server: ServerName, expiresAt: Timestamp, timestamp: Timestamp, ttl: Int<S>}

-- Status returned to the sender after SendMessage
-- Delivered: recipient is online locally; Federated: forwarded to remote server;
-- Queued: stored but recipient location unknown; Unauthorized/Rejected: not accepted
data MessageStatus = MsDelivered {} | MsFederated {} | MsQueued {} | MsUnauthorized {} | MsRejected {} | MsRateLimited {} | MsDuplicate {} | MsDraining {}

impl ToJSON MessageStatus where
  toJson ms = toJson (case ms of
    MsDelivered {} -> "delivered"
    MsFederated {} -> "federated"
    MsQueued {} -> "queued"
    MsUnauthorized {} -> "unauthorized"
    MsRejected {} -> "rejected"
    MsRateLimited {} -> "rate_limited"
    MsDuplicate {} -> "duplicate"
    MsDraining {} -> "draining")

-- Internal delivery status (same as MessageStatus but without error variants)
data DeliveryStatus = DsDelivered {} | DsFederated {} | DsQueued {}

-- Validated hex-encoded types with maximum length constraints
isValidBoundedHex : Int -> Text -> Bool
isValidBoundedHex = \maxLen s -> not (tooLong s maxLen) && isValidHex s && s == normalizeHex s
type PubkeyHex = Text where isValidBoundedHex maxPubkeyLen
type BlobHex = Text where isValidBoundedHex maxBlobLen
type SignatureHex = Text where isValidBoundedHex maxSignatureLen
isValidMessageId : Text -> Bool
isValidMessageId = isValidBoundedHex maxMessageIdLen
type MessageIdHex = Text where isValidMessageId
type OptionalMessageId = Text where \s -> s == "" || isValidMessageId s
-- ServerName: validated server hostname (rejects private IPs, localhost, etc.)
-- AnyServerName: normalized server name without the security checks (used in presence lookups)
isValidServerName : Text -> Bool
isValidServerName = \s -> not (tooLong s maxServerNameLen) && s == normalizeServerName s && not (isBadServerName s)
type ServerName = Text where isValidServerName
type AnyServerName = Text where \s -> not (tooLong s maxServerNameLen) && s == normalizeServerName s

type Timestamp = Int<Ms>

-- Pending challenge for Ed25519 challenge-response auth
type Challenge = {pubkey: PubkeyHex, challenge: Text, expiresAt: Timestamp, ip: Text}
-- Authenticated session; token is a random hex string
type Session = {token: Text, pubkey: PubkeyHex, expiresAt: Timestamp, ip: Text}
-- Stored message; originServer is "" for locally-originated messages, set to sender server for federated forwards
type Message = {messageId: MessageIdHex, toKey: PubkeyHex, encryptedBlob: BlobHex, timestamp: Timestamp, originServer: Text, receivedAt: Timestamp}
-- Presence: tracks that a pubkey is online at a given server, with expiry
type PresenceEntry = {pubkey: PubkeyHex, server: AnyServerName, expiresAt: Timestamp, timestamp: Timestamp}
-- Queued federation forward: message waiting to be delivered to a remote server
type ForwardEntry = {messageId: MessageIdHex, toServer: ServerName, createdAt: Timestamp, toKey: PubkeyHex, encryptedBlob: BlobHex, timestamp: Timestamp, originServer: Text}
-- Tracks message IDs that were acked by a polling client, pending federation ack back to origin
type AckedEntry = {messageId: MessageIdHex, toKey: PubkeyHex, ackedAt: Timestamp, originServer: ServerName}
-- Terminal state: message delivered and ack confirmed (used for dedup after ack overflow)
type DeliveredEntry = {messageId: MessageIdHex, toKey: PubkeyHex, deliveredAt: Timestamp}
-- Tracks consecutive failures per federation peer for exponential backoff
type ForwardFailure = {server: Text, failedAt: Timestamp, failures: Int, firstFailedAt: Timestamp}
-- Sliding-window rate limit state per pubkey
type SendRateEntry = {pubkey: PubkeyHex, windowStart: Timestamp, count: Int}
type RecvRateEntry = {pubkey: PubkeyHex, windowStart: Timestamp, count: Int}
type ChallengeRateEntry = {pubkey: PubkeyHex, windowStart: Timestamp, count: Int}
-- Sliding-window rate limit state per federation peer server
type FederationRateEntry = {server: Text, windowStart: Timestamp, count: Int}
-- Tracks active long-poll connections to enforce per-key concurrency limits
type ActivePoll = {pubkey: PubkeyHex, startedAt: Timestamp}
data AuthResult = Authorized {pubkey: PubkeyHex, ip: Text} | Unauthorized {}
data SendResult = SendFailed {status: MessageStatus} | SendDone {delivery: DeliveryStatus, remoteServers: [ServerName]} | SendDuplicate {}
data ForwardResult = ForwardDuplicate {} | ForwardRejected {} | ForwardStored {}

type IpRateEntry = {ip: Text, windowStart: Timestamp, count: Int}
type LookupRateEntry = {pubkey: PubkeyHex, windowStart: Timestamp, count: Int}
-- Tracks recently re-broadcast gossip events to suppress amplification from duplicate cycles
type RecentGossipEntry = {pubkey: PubkeyHex, server: Text, timestamp: Timestamp, seenAt: Timestamp}
type PeerStatus = {server: Text, failures: Int, lastFailedAt: Timestamp, firstFailedAt: Timestamp, backoffMs: Int, retriable: Bool}
type KeyPresenceEntry = {server: Text, expiresAt: Timestamp}
type RecipientCount = {pubkey: PubkeyHex, count: Int}
type FederationInFlightEntry = {server: Text, count: Int, firstStartedAt: Timestamp}

-- ============================================
-- Persisted State
-- ============================================
-- All state is in-memory (no disk persistence). Prefixed with * (mutable refs).
-- Atomic blocks provide transactional consistency for reads + writes.

*challenges : [Challenge]

-- Sessions sharded into 16 buckets by first hex char of token.
-- Hot-path auth scans only one bucket (~1/16 of sessions).
*sessionBucket0 : [Session]
*sessionBucket1 : [Session]
*sessionBucket2 : [Session]
*sessionBucket3 : [Session]
*sessionBucket4 : [Session]
*sessionBucket5 : [Session]
*sessionBucket6 : [Session]
*sessionBucket7 : [Session]
*sessionBucket8 : [Session]
*sessionBucket9 : [Session]
*sessionBucket10 : [Session]
*sessionBucket11 : [Session]
*sessionBucket12 : [Session]
*sessionBucket13 : [Session]
*sessionBucket14 : [Session]
*sessionBucket15 : [Session]

-- Messages sharded into 16 buckets by first hex char of recipient pubkey (toKey).
-- Hot-path operations (poll, send, ack) scan only one bucket (~1/16 of messages).
*messageBucket0 : [Message]
*messageBucket1 : [Message]
*messageBucket2 : [Message]
*messageBucket3 : [Message]
*messageBucket4 : [Message]
*messageBucket5 : [Message]
*messageBucket6 : [Message]
*messageBucket7 : [Message]
*messageBucket8 : [Message]
*messageBucket9 : [Message]
*messageBucket10 : [Message]
*messageBucket11 : [Message]
*messageBucket12 : [Message]
*messageBucket13 : [Message]
*messageBucket14 : [Message]
*messageBucket15 : [Message]

*totalMessageCount : Int

*presence : [PresenceEntry]

-- Monotonic counter ensuring unique receivedAt ordering even within the same millisecond
*seqCounter : Timestamp

*forwards : [ForwardEntry]

-- Messages acked by local recipients, pending federation ack to origin server
*ackedIds : [AckedEntry]

*lastPrunedAt : Timestamp

*forwardFailures : [ForwardFailure]

*sendRates : [SendRateEntry]

*lastPresenceRefresh : Timestamp

*challengeRates : [ChallengeRateEntry]

-- Heartbeat signal: incremented periodically to wake all blocking long-polls
*pollWakeup : Timestamp

-- Per-bucket message signals (16 buckets, keyed by first hex digit of pubkey).
-- Updated when a message is stored for a recipient; polls for that pubkey's
-- bucket watch for changes to avoid waking unrelated polls.
*messageSignal0 : Timestamp
*messageSignal1 : Timestamp
*messageSignal2 : Timestamp
*messageSignal3 : Timestamp
*messageSignal4 : Timestamp
*messageSignal5 : Timestamp
*messageSignal6 : Timestamp
*messageSignal7 : Timestamp
*messageSignal8 : Timestamp
*messageSignal9 : Timestamp
*messageSignal10 : Timestamp
*messageSignal11 : Timestamp
*messageSignal12 : Timestamp
*messageSignal13 : Timestamp
*messageSignal14 : Timestamp
*messageSignal15 : Timestamp

*activePolls : [ActivePoll]

-- Overflow buffer: acks evicted from ackedIds before they could be sent to origin
*ackOverflow : [AckedEntry]

-- Final dedup set: messages confirmed delivered (ack sent or overflow drained)
*deliveredIds : [DeliveredEntry]

*federationRates : [FederationRateEntry]

*globalRateCount : Int

*globalRateWindowStart : Timestamp

-- Background task cycle counters (exposed via /stats for health monitoring)
*pruneCount : Int

*heartbeatCount : Int

*startedAt : Timestamp

*lastHeartbeatAt : Timestamp

*draining : Bool

*pruneRunning : Timestamp

*pruneGeneration : Int

*ipRates : [IpRateEntry]

*lookupRates : [LookupRateEntry]

*recvRates : [RecvRateEntry]

*recentGossip : [RecentGossipEntry]

*lastFederationSuccessAt : Timestamp

-- Per-recipient message counts (avoids O(n) scan of all messages on send/forward)
*recipientMsgCounts : [RecipientCount]

-- Tracks outstanding federation fetches per server (detects hung connections)
*federationInFlight : [FederationInFlightEntry]

-- Federation latency tracking (for /stats)
*federationLatencyTotal : Int<Ms>
*federationLatencyCount : Int
*federationLatencyMax : Int<Ms>

-- Server instance generation (epoch timestamp, for cursor staleness detection)
*serverGeneration : Int

-- Timestamp when drain federation ops completed (0 if in progress or not draining)
*drainCompletedAt : Timestamp

-- Last time federation latency metrics were reset (for windowed averages)
*federationLatencyResetAt : Timestamp

-- Total session count across all buckets (avoids O(16) recount on monitoring paths)
*totalSessionCount : Int

-- Auth-tier global rate limiting state
*authGlobalRateCount : Int
*authGlobalRateWindowStart : Timestamp

-- Max concurrent background prune forks (prevents resource exhaustion from stuck recovery)
*activePruneForks : Int

-- ============================================
-- Routes
-- ============================================

-- Authentication: Ed25519 challenge-response flow
-- 1. Client POSTs pubkey to /auth/challenge, gets a random challenge string
-- 2. Client signs the challenge with their private key and POSTs to /auth/verify
-- 3. Server verifies signature, returns a session token
route AuthApi where
  /auth
    POST {pubkey: PubkeyHex} /challenge headers {clientIp: Text}
      -> {challenge: Text, ok: Bool, expiresAt: Timestamp}
      = ReqChallenge
    POST {pubkey: PubkeyHex, challenge: Text, signature: SignatureHex, revokeOthers: Bool} /verify headers {clientIp: Text}
      -> {token: Text, expiresAt: Timestamp}
      = VerifyAuth
    POST {targetToken: Text} /revoke headers {authorization: Text, clientIp: Text}
      -> {ok: Bool, authorized: Bool}
      = RevokeSession
    -- Voluntary disconnect: removes session and gossips offline if last session for this key
    POST {} /logout headers {authorization: Text, clientIp: Text}
      -> {ok: Bool, authorized: Bool}
      = Logout

-- Client-facing API (requires session token in Authorization header)
route ClientApi where
  -- Long-poll for new messages; cursor tracks last-seen receivedAt timestamp
  POST {cursor: Timestamp, generation: Int, watchKeys: [PubkeyHex]} /poll headers {authorization: Text, clientIp: Text}
    -> {events: [PollEvent], cursor: Timestamp, authorized: Bool, rateLimited: Bool, draining: Bool, generation: Int, presenceUpdates: [{pubkey: PubkeyHex, online: Bool}]}
    = Poll
  /messages
    -- Send an E2E encrypted message to a recipient pubkey
    POST {to: PubkeyHex, encryptedBlob: BlobHex, timestamp: Timestamp, messageId: OptionalMessageId} / headers {authorization: Text, clientIp: Text}
      -> {status: MessageStatus, messageId: OptionalMessageId}
      = SendMessage
    -- Check delivery status of a sent message (caller must know recipient to prove ownership)
    POST {to: PubkeyHex, messageId: MessageIdHex} /status headers {authorization: Text, clientIp: Text}
      -> {status: Text, authorized: Bool}
      = MessageStatus
  -- Look up which server a pubkey is present on (for federation routing)
  GET /lookup/{pubkey: PubkeyHex} headers {authorization: Text, clientIp: Text}
    -> {server: AnyServerName, authorized: Bool}
    = LookupPresence

-- Server-to-server federation API (requires federation secret)
route FederationApi where
  /federation
    -- Receive presence gossip events from a peer server
    POST {events: [GossipEvent], hopsRemaining: Int, fromServer: ServerName} /gossip headers {authorization: Text}
      -> {ok: Bool, error: Text}
      = RecvGossip
    -- Receive a forwarded message from a peer server on behalf of a sender
    POST {toKey: PubkeyHex, encryptedBlob: BlobHex, timestamp: Timestamp, originServer: ServerName, messageId: MessageIdHex, fromServer: ServerName} /forward headers {authorization: Text}
      -> {ok: Bool, error: Text}
      = ForwardMessage
    -- Acknowledge delivery of messages back to the origin server
    POST {messageIds: [MessageIdHex], originServer: ServerName, fromServer: ServerName} /ack headers {authorization: Text}
      -> {ok: Bool, error: Text}
      = FederationAck

-- Triggers pruning of expired state and retry of pending federation ops
route MaintenanceApi where
  POST {} /maintenance/prune headers {authorization: Text}
    -> {ok: Bool}
    = Prune
  POST {} /maintenance/drain headers {authorization: Text}
    -> {ok: Bool, drained: Int}
    = Drain
  POST {} /maintenance/undrain headers {authorization: Text}
    -> {ok: Bool}
    = Undrain

route HealthApi where
  GET /health -> {ok: Bool, pruneHealthy: Bool, heartbeatHealthy: Bool, capacityHealthy: Bool, federationHealthy: Bool} = Health

-- Returns counts of in-memory collections (requires federation or maintenance secret)
route StatsApi where
  GET /stats headers {authorization: Text}
    -> {sessions: Int, sessionsMax: Int, messages: Int, messagesMax: Int, presence: Int, presenceMax: Int, forwards: Int, forwardsMax: Int, challenges: Int, challengesMax: Int, ackedIds: Int, ackedIdsMax: Int, ackOverflow: Int, ackOverflowMax: Int, deliveredIds: Int, deliveredIdsMax: Int, forwardFailures: Int, activePolls: Int, activePollsMax: Int, sendRates: Int, challengeRates: Int, federationRates: Int, globalRateCount: Int, ipRates: Int, lookupRates: Int, recvRates: Int, pruneCount: Int, pruneRunning: Timestamp, heartbeatCount: Int, uptime: Int, lastPruneAt: Timestamp, lastHeartbeatAt: Timestamp, draining: Bool, federationEnabled: Bool, recentGossip: Int, totalMessageCount: Int, recipientCounts: Int, federationInFlight: Int, messagesPct: Int, presencePct: Int, forwardsPct: Int, sessionsPct: Int, federationAvgLatencyMs: Int, federationMaxLatencyMs: Int, federationCallCount: Int, drainCompletedAt: Timestamp, ok: Bool}
    = Stats
  GET /stats/peers headers {authorization: Text}
    -> {peers: [PeerStatus], ok: Bool}
    = StatsPeers
  GET /stats/key/{pubkey: PubkeyHex} headers {authorization: Text}
    -> {messages: Int, presence: [KeyPresenceEntry], sessions: Int, forwards: Int, activePolls: Int, ok: Bool}
    = StatsKey

route Api = AuthApi | ClientApi | FederationApi | MaintenanceApi | HealthApi | StatsApi

-- ============================================
-- Helpers
-- ============================================

any : [a] -> (a -> Bool) -> Bool
any = \xs pred -> fold (\acc x -> if acc then acc else pred x) (False {}) xs
none : [a] -> (a -> Bool) -> Bool
none = \xs pred -> not (any xs pred)
when = \cond action -> if cond then action else yield {}
whenOk = \result action -> case result of
  Ok _ -> action
  Err _ -> yield {}
clamp = \lo hi x -> if x < lo then lo else if x > hi then hi else x
min = \a b -> if a < b then a else b
max = \a b -> if a > b then a else b
headOf = \items -> fold (\acc x -> case acc of
  Nothing {} -> Just {value: x}
  _ -> acc) Nothing {} items

maxBy = \items getKey -> fold (\acc x -> case acc of
  Nothing {} -> Just {value: x}
  Just {value: v} -> if getKey x > getKey v then Just {value: x} else acc) Nothing {} items

minBy = \items getKey -> fold (\acc x -> case acc of
  Nothing {} -> Just {value: x}
  Just {value: v} -> if getKey x < getKey v then Just {value: x} else acc) Nothing {} items

-- Hex encoding utilities for token generation
hexDigit : Int -> Text
hexDigit = \n -> take 1 (drop (clamp 0 15 n) "0123456789abcdef")

byteToHex : Int -> Text
byteToHex = \n -> hexDigit (n / 16) ++ hexDigit (n - (n / 16) * 16)

-- Encode a 24-bit integer as 6 hex characters (3 bytes)
intTo3Hex : Int -> Text
intTo3Hex = \n ->
  let b0 = n / 65536 in
  let r0 = n - b0 * 65536 in
  let b1 = r0 / 256 in
  let b2 = r0 - b1 * 256 in
  byteToHex b0 ++ byteToHex b1 ++ byteToHex b2

-- Generate a random hex token (n chunks of 3 bytes each = 6n hex chars)
genTokenN = \n -> if n <= 0 then yield "" else do
  chunk <- randomInt 16777216
  rest <- genTokenN (n - 1)
  yield (intTo3Hex chunk ++ rest)

-- Default token: 8 chunks = 48 hex chars = 24 bytes of randomness
genToken = genTokenN 8

tooLong : Text -> Int -> Bool
tooLong = \s maxLen -> drop maxLen s != ""

isHexChar : Text -> Bool
isHexChar = \c -> contains c "0123456789abcdef"

isValidHexPairs : Text -> Bool
isValidHexPairs = \s ->
  if s == "" then True {}
  else if drop 1 s == "" then False {}
  else if isHexChar (take 1 s) && isHexChar (take 1 (drop 1 s)) then isValidHexPairs (drop 2 s)
  else False {}

isValidHex : Text -> Bool
isValidHex = \s -> s != "" && isValidHexPairs s

normalizeHex : Text -> Text
normalizeHex = \s -> bytesToHex (bytesFromHex s)

isDigitChar : Text -> Bool
isDigitChar = \c -> contains c "0123456789"

isAllowedServerChar : Text -> Bool
isAllowedServerChar = \c -> contains c "0123456789abcdefghijklmnopqrstuvwxyz-.:"

containsBadUrlChar : Text -> Bool
containsBadUrlChar = \s -> any (chars s) (\c -> not (isAllowedServerChar c))

-- Carrier-grade NAT range: 100.64.0.0/10 (RFC 6598)
isCgnatRange : Text -> Bool
isCgnatRange = \s ->
  take 4 s == "100."
  && let d4 = take 1 (drop 4 s) in
  let d5 = take 1 (drop 5 s) in
  let d6 = take 1 (drop 6 s) in
  let d7 = take 1 (drop 7 s) in
  let twoDigitOctet = d6 == "." && isAllDigitsOrDotsUntilColonOrEnd (drop 7 s) in
  let threeDigitOctet = d7 == "." && isAllDigitsOrDotsUntilColonOrEnd (drop 8 s) in
  ((contains d4 "789" && isDigitChar d5 && twoDigitOctet)
  || (d4 == "6" && contains d5 "456789" && twoDigitOctet)
  || (d4 == "1" && contains d5 "01" && isDigitChar d6 && threeDigitOctet)
  || (d4 == "1" && d5 == "2" && contains d6 "01234567" && threeDigitOctet))

containsMultipleColons : Text -> Bool
containsMultipleColons = \s -> count (do c <- chars s; where c == ":"; yield c) > 1

hasPatternAfterDot : (Text -> Bool) -> Text -> Bool
hasPatternAfterDot = \pred s ->
  if s == "" then False {}
  else if take 1 s == "." && pred (drop 1 s) then True {}
  else hasPatternAfterDot pred (drop 1 s)

isOctalStart : Text -> Bool
isOctalStart = \s -> take 1 s == "0" && isDigitChar (take 1 (drop 1 s)) && isAllDigitsOrDotsUntilColonOrEnd (drop 2 s)
hasOctalOctet : Text -> Bool
hasOctalOctet = \s -> isOctalStart s || hasPatternAfterDot isOctalStart s

isHexStart : Text -> Bool
isHexStart = \s -> take 2 s == "0x" || take 2 s == "0X"
hasHexPrefix : Text -> Bool
hasHexPrefix = \s -> isHexStart s || hasPatternAfterDot isHexStart s

isAllDigitsOrDotsUntilColonOrEnd : Text -> Bool
isAllDigitsOrDotsUntilColonOrEnd = \s ->
  if s == "" then True {}
  else if take 1 s == ":" then True {}
  else if isDigitChar (take 1 s) || take 1 s == "." then isAllDigitsOrDotsUntilColonOrEnd (drop 1 s)
  else False {}

isTrailingDots : Text -> Bool
isTrailingDots = \s ->
  if s == "" then True {}
  else if take 1 s == ":" then True {}
  else if take 1 s == "." then isTrailingDots (drop 1 s)
  else False {}

stripTrailingDot : Text -> Text
stripTrailingDot = \s ->
  if s == "" then ""
  else if take 1 s == "." && isTrailingDots (drop 1 s) then stripTrailingDot (drop 1 s)
  else take 1 s ++ stripTrailingDot (drop 1 s)

normalizeServerName : Text -> Text
normalizeServerName = \s -> toLower (stripTrailingDot s)

serverHostN : Text
serverHostN = normalizeServerName serverHost
isLocalServer : Text -> Bool
isLocalServer = \s -> s == serverHostN

containsSuffixN : Text -> Int -> Text -> Bool
containsSuffixN = \suffix suffixLen s ->
  if s == "" then False {}
  else if take suffixLen s == suffix && (drop suffixLen s == "" || take 1 (drop suffixLen s) == ":") then True {}
  else containsSuffixN suffix suffixLen (drop 1 s)

containsSuffix : Text -> Text -> Bool
containsSuffix = \suffix s -> containsSuffixN suffix (count (chars suffix)) s

is172Private : Text -> Bool
is172Private = \sn ->
  take 4 sn == "172."
  && let d1 = take 1 (drop 4 sn) in
  let d2 = take 1 (drop 5 sn) in
  take 1 (drop 6 sn) == "."
  && isDigitChar (take 1 (drop 7 sn))
  && ((d1 == "1" && contains d2 "6789")
    || (d1 == "2" && isDigitChar d2)
    || (d1 == "3" && contains d2 "01"))

isHighOctetPrefix : Text -> Bool
isHighOctetPrefix = \sn ->
  take 1 sn == "2"
  && let d2 = take 1 (drop 1 sn) in
  let d3 = take 1 (drop 2 sn) in
  take 1 (drop 3 sn) == "."
  && isDigitChar (take 1 (drop 4 sn))
  && ((d2 == "2" && contains d3 "456789")
    || (contains d2 "34" && isDigitChar d3)
    || (d2 == "5" && contains d3 "012345"))

matchesHostname : Text -> Text -> Bool
matchesHostname = \sn name ->
  let nameLen = count (chars name) in
  take nameLen sn == name && (drop nameLen sn == "" || take 1 (drop nameLen sn) == ":")

matchesHostnameOrSubdomain : Text -> Text -> Bool
matchesHostnameOrSubdomain = \sn name ->
  matchesHostname sn name || containsSuffix ("." ++ name) sn

hasDotBeforePort : Text -> Bool
hasDotBeforePort = \s ->
  if s == "" then False {}
  else if take 1 s == ":" then False {}
  else if take 1 s == "." then True {}
  else hasDotBeforePort (drop 1 s)

-- DNS rebinding / SSRF protection: reject server names that resolve to private/reserved addresses.
-- Blocks localhost, private RFC1918 ranges, link-local, loopback, CGNAT, documentation ranges,
-- IPv6 shorthand, octal/hex IP tricks, bare IPs without dots, and .arpa domains.
isBadServerName : Text -> Bool
isBadServerName = \sn ->
  let fc = take 1 sn in
  fc == ""
  || fc == "."
  || fc == ":"
  || containsBadUrlChar sn
  || not (hasDotBeforePort sn)
  || matchesHostnameOrSubdomain sn "localhost"
  || matchesHostname sn "localhost.localdomain"
  || matchesHostnameOrSubdomain sn "local"
  || matchesHostnameOrSubdomain sn "internal"
  || matchesHostnameOrSubdomain sn "metadata"
  || take 4 sn == "127." || take 3 sn == "10."
  || take 8 sn == "192.168." || take 8 sn == "169.254."
  || take 2 sn == "0." || fc == "["
  || is172Private sn
  || take 7 sn == "198.18." || take 7 sn == "198.19."
  || take 8 sn == "192.0.0."
  || take 8 sn == "192.0.2."
  || take 10 sn == "192.88.99."
  || take 11 sn == "198.51.100."
  || take 10 sn == "203.0.113."
  || take 2 sn == "::"
  || isCgnatRange sn
  || containsMultipleColons sn
  || hasOctalOctet sn
  || hasHexPrefix sn
  || (isDigitChar fc && isAllDigitsOrDotsUntilColonOrEnd sn)
  || isHighOctetPrefix sn
  || containsSuffix ".arpa" sn
  || containsSuffix ".onion" sn
  || containsSuffix ".i2p" sn
  || containsSuffix ".corp" sn
  || containsSuffix ".home" sn
  || containsSuffix ".lan" sn
  || containsSuffix ".intranet" sn
  || containsSuffix ".test" sn
  || containsSuffix ".example" sn
  || containsSuffix ".invalid" sn

-- Look up a non-expired session matching the given token (constant-time comparison).
-- Caller passes the appropriate session bucket (sharded by token prefix).
authenticateSession : [Session] -> Text -> Timestamp -> AuthResult
authenticateSession = \sessions token t ->
  case headOf (do s <- sessions; where s.expiresAt > t && safeCompare s.token token; yield s) of
    Nothing {} -> Unauthorized {}
    Just {value: s} -> Authorized {pubkey: s.pubkey, ip: s.ip}

-- Extract bearer token from "Authorization: Bearer <token>" header
extractToken = \authHeader ->
  let token = drop 7 authHeader in
  if toLower (take 7 authHeader) == "bearer " && not (tooLong token maxTokenLen)
    then Just {value: token}
    else Nothing {}

-- Constant-time secret comparison (prevents timing attacks on federation/maintenance secrets)
verifySecret : Text -> Text -> Bool
verifySecret = \token secret ->
  secret != "" && safeCompare token secret

verifyAuthWith : (Text -> Bool) -> Text -> Bool
verifyAuthWith = \check authorization ->
  case extractToken authorization of
    Nothing {} -> False {}
    Just {value: token} -> check token

verifyFederationAuth : Text -> Bool
verifyFederationAuth = verifyAuthWith (\token -> verifySecret token federationSecret)

-- Per-peer federation auth: checks peer-specific secret first, falls back to global
verifyFederationAuthForServer : Text -> Text -> Bool
verifyFederationAuthForServer = \fromServer authorization ->
  verifyAuthWith (\token ->
    case headOf (do p <- federationPeerSecrets; where normalizeServerName p.server == fromServer; yield p) of
      Just {value: p} -> verifySecret token p.secret
      Nothing {} -> verifySecret token federationSecret
  ) authorization

verifyMaintenanceAuth : Text -> Bool
verifyMaintenanceAuth = verifyAuthWith (\token -> verifySecret token federationSecret || verifySecret token maintenanceSecret)

-- Outbound federation auth: use per-peer secret if configured, otherwise global
federationAuthForServer : Text -> Text
federationAuthForServer = \server ->
  case headOf (do p <- federationPeerSecrets; where normalizeServerName p.server == server; yield p) of
    Just {value: p} -> "Bearer " ++ p.secret
    Nothing {} -> federationAuth

-- ============================================
-- Session Bucket Helpers
-- ============================================
-- Sessions are sharded into 16 buckets by the first hex char of the token.
-- This reduces auth scan from O(n) to O(n/16) on the hot path.

tokenBucket : Text -> Int
tokenBucket = \token -> clamp 0 15 (hexCharIndex (take 1 token))

readSessionBucket : Int -> IO [Session]
readSessionBucket = \b ->
  if b == 0 then do s <- *sessionBucket0; yield s
  else if b == 1 then do s <- *sessionBucket1; yield s
  else if b == 2 then do s <- *sessionBucket2; yield s
  else if b == 3 then do s <- *sessionBucket3; yield s
  else if b == 4 then do s <- *sessionBucket4; yield s
  else if b == 5 then do s <- *sessionBucket5; yield s
  else if b == 6 then do s <- *sessionBucket6; yield s
  else if b == 7 then do s <- *sessionBucket7; yield s
  else if b == 8 then do s <- *sessionBucket8; yield s
  else if b == 9 then do s <- *sessionBucket9; yield s
  else if b == 10 then do s <- *sessionBucket10; yield s
  else if b == 11 then do s <- *sessionBucket11; yield s
  else if b == 12 then do s <- *sessionBucket12; yield s
  else if b == 13 then do s <- *sessionBucket13; yield s
  else if b == 14 then do s <- *sessionBucket14; yield s
  else do s <- *sessionBucket15; yield s

writeSessionBucket : Int -> [Session] -> IO ()
writeSessionBucket = \b sessions ->
  if b == 0 then set *sessionBucket0 = sessions
  else if b == 1 then set *sessionBucket1 = sessions
  else if b == 2 then set *sessionBucket2 = sessions
  else if b == 3 then set *sessionBucket3 = sessions
  else if b == 4 then set *sessionBucket4 = sessions
  else if b == 5 then set *sessionBucket5 = sessions
  else if b == 6 then set *sessionBucket6 = sessions
  else if b == 7 then set *sessionBucket7 = sessions
  else if b == 8 then set *sessionBucket8 = sessions
  else if b == 9 then set *sessionBucket9 = sessions
  else if b == 10 then set *sessionBucket10 = sessions
  else if b == 11 then set *sessionBucket11 = sessions
  else if b == 12 then set *sessionBucket12 = sessions
  else if b == 13 then set *sessionBucket13 = sessions
  else if b == 14 then set *sessionBucket14 = sessions
  else set *sessionBucket15 = sessions

-- Read all 16 session buckets (for per-key operations, prune, stats)
readAllSessions : IO [Session]
readAllSessions = do
  s0 <- *sessionBucket0
  s1 <- *sessionBucket1
  s2 <- *sessionBucket2
  s3 <- *sessionBucket3
  s4 <- *sessionBucket4
  s5 <- *sessionBucket5
  s6 <- *sessionBucket6
  s7 <- *sessionBucket7
  s8 <- *sessionBucket8
  s9 <- *sessionBucket9
  s10 <- *sessionBucket10
  s11 <- *sessionBucket11
  s12 <- *sessionBucket12
  s13 <- *sessionBucket13
  s14 <- *sessionBucket14
  s15 <- *sessionBucket15
  yield (union s0 (union s1 (union s2 (union s3 (union s4 (union s5 (union s6 (union s7 (union s8 (union s9 (union s10 (union s11 (union s12 (union s13 (union s14 s15)))))))))))))))

-- Count sessions across all 16 buckets without materializing the full list
countAllSessions : IO Int
countAllSessions = do
  s0 <- *sessionBucket0
  s1 <- *sessionBucket1
  s2 <- *sessionBucket2
  s3 <- *sessionBucket3
  s4 <- *sessionBucket4
  s5 <- *sessionBucket5
  s6 <- *sessionBucket6
  s7 <- *sessionBucket7
  s8 <- *sessionBucket8
  s9 <- *sessionBucket9
  s10 <- *sessionBucket10
  s11 <- *sessionBucket11
  s12 <- *sessionBucket12
  s13 <- *sessionBucket13
  s14 <- *sessionBucket14
  s15 <- *sessionBucket15
  yield (count s0 + count s1 + count s2 + count s3 + count s4 + count s5 + count s6 + count s7 + count s8 + count s9 + count s10 + count s11 + count s12 + count s13 + count s14 + count s15)

-- Apply a filter/transform to every session bucket
transformAllSessionBuckets : ([Session] -> [Session]) -> IO ()
transformAllSessionBuckets = \f -> do
  b0 <- *sessionBucket0; set *sessionBucket0 = f b0
  b1 <- *sessionBucket1; set *sessionBucket1 = f b1
  b2 <- *sessionBucket2; set *sessionBucket2 = f b2
  b3 <- *sessionBucket3; set *sessionBucket3 = f b3
  b4 <- *sessionBucket4; set *sessionBucket4 = f b4
  b5 <- *sessionBucket5; set *sessionBucket5 = f b5
  b6 <- *sessionBucket6; set *sessionBucket6 = f b6
  b7 <- *sessionBucket7; set *sessionBucket7 = f b7
  b8 <- *sessionBucket8; set *sessionBucket8 = f b8
  b9 <- *sessionBucket9; set *sessionBucket9 = f b9
  b10 <- *sessionBucket10; set *sessionBucket10 = f b10
  b11 <- *sessionBucket11; set *sessionBucket11 = f b11
  b12 <- *sessionBucket12; set *sessionBucket12 = f b12
  b13 <- *sessionBucket13; set *sessionBucket13 = f b13
  b14 <- *sessionBucket14; set *sessionBucket14 = f b14
  b15 <- *sessionBucket15; set *sessionBucket15 = f b15

-- ============================================
-- Message Bucket Helpers
-- ============================================
-- Messages are sharded into 16 buckets by the first hex char of the recipient pubkey.
-- This reduces poll/send/ack scans from O(n) to O(n/16) on the hot path.

readMessageBucket : Int -> IO [Message]
readMessageBucket = \b ->
  if b == 0 then do s <- *messageBucket0; yield s
  else if b == 1 then do s <- *messageBucket1; yield s
  else if b == 2 then do s <- *messageBucket2; yield s
  else if b == 3 then do s <- *messageBucket3; yield s
  else if b == 4 then do s <- *messageBucket4; yield s
  else if b == 5 then do s <- *messageBucket5; yield s
  else if b == 6 then do s <- *messageBucket6; yield s
  else if b == 7 then do s <- *messageBucket7; yield s
  else if b == 8 then do s <- *messageBucket8; yield s
  else if b == 9 then do s <- *messageBucket9; yield s
  else if b == 10 then do s <- *messageBucket10; yield s
  else if b == 11 then do s <- *messageBucket11; yield s
  else if b == 12 then do s <- *messageBucket12; yield s
  else if b == 13 then do s <- *messageBucket13; yield s
  else if b == 14 then do s <- *messageBucket14; yield s
  else do s <- *messageBucket15; yield s

writeMessageBucket : Int -> [Message] -> IO ()
writeMessageBucket = \b msgs ->
  if b == 0 then set *messageBucket0 = msgs
  else if b == 1 then set *messageBucket1 = msgs
  else if b == 2 then set *messageBucket2 = msgs
  else if b == 3 then set *messageBucket3 = msgs
  else if b == 4 then set *messageBucket4 = msgs
  else if b == 5 then set *messageBucket5 = msgs
  else if b == 6 then set *messageBucket6 = msgs
  else if b == 7 then set *messageBucket7 = msgs
  else if b == 8 then set *messageBucket8 = msgs
  else if b == 9 then set *messageBucket9 = msgs
  else if b == 10 then set *messageBucket10 = msgs
  else if b == 11 then set *messageBucket11 = msgs
  else if b == 12 then set *messageBucket12 = msgs
  else if b == 13 then set *messageBucket13 = msgs
  else if b == 14 then set *messageBucket14 = msgs
  else set *messageBucket15 = msgs

-- Read all 16 message buckets (for cold-path operations: federation ack, forward candidates, stats)
readAllMessages : IO [Message]
readAllMessages = do
  m0 <- *messageBucket0
  m1 <- *messageBucket1
  m2 <- *messageBucket2
  m3 <- *messageBucket3
  m4 <- *messageBucket4
  m5 <- *messageBucket5
  m6 <- *messageBucket6
  m7 <- *messageBucket7
  m8 <- *messageBucket8
  m9 <- *messageBucket9
  m10 <- *messageBucket10
  m11 <- *messageBucket11
  m12 <- *messageBucket12
  m13 <- *messageBucket13
  m14 <- *messageBucket14
  m15 <- *messageBucket15
  yield (union m0 (union m1 (union m2 (union m3 (union m4 (union m5 (union m6 (union m7 (union m8 (union m9 (union m10 (union m11 (union m12 (union m13 (union m14 m15)))))))))))))))

-- Apply a filter/transform to every message bucket
transformAllMessageBuckets : ([Message] -> [Message]) -> IO ()
transformAllMessageBuckets = \f -> do
  b0 <- *messageBucket0; set *messageBucket0 = f b0
  b1 <- *messageBucket1; set *messageBucket1 = f b1
  b2 <- *messageBucket2; set *messageBucket2 = f b2
  b3 <- *messageBucket3; set *messageBucket3 = f b3
  b4 <- *messageBucket4; set *messageBucket4 = f b4
  b5 <- *messageBucket5; set *messageBucket5 = f b5
  b6 <- *messageBucket6; set *messageBucket6 = f b6
  b7 <- *messageBucket7; set *messageBucket7 = f b7
  b8 <- *messageBucket8; set *messageBucket8 = f b8
  b9 <- *messageBucket9; set *messageBucket9 = f b9
  b10 <- *messageBucket10; set *messageBucket10 = f b10
  b11 <- *messageBucket11; set *messageBucket11 = f b11
  b12 <- *messageBucket12; set *messageBucket12 = f b12
  b13 <- *messageBucket13; set *messageBucket13 = f b13
  b14 <- *messageBucket14; set *messageBucket14 = f b14
  b15 <- *messageBucket15; set *messageBucket15 = f b15

-- Read only the message buckets at the given indices (avoids reading all 16)
readSelectedBuckets : [Int] -> IO [Message]
readSelectedBuckets = \buckets ->
  case headOf buckets of
    Nothing {} -> yield []
    Just {value: b} -> do
      let rest = do x <- buckets; where x != b; yield x
      msgs <- readMessageBucket b
      remaining <- readSelectedBuckets rest
      yield (union msgs remaining)

-- Transform only the message buckets at the given indices
transformSelectedBuckets : [Int] -> ([Message] -> [Message]) -> IO ()
transformSelectedBuckets = \buckets f ->
  case headOf buckets of
    Nothing {} -> yield {}
    Just {value: b} -> do
      let rest = do x <- buckets; where x != b; yield x
      msgs <- readMessageBucket b
      writeMessageBucket b (f msgs)
      transformSelectedBuckets rest f

-- Collect unique bucket indices for a set of pubkeys
uniqueBucketsFor = \items getKey ->
  fold (\acc x ->
    let b = pubkeyBucket (getKey x) in
    if any acc (\i -> i == b) then acc else union acc [b]) [] items

-- Prune a single message bucket and return kept count + per-recipient counts.
-- Since messages are sharded by recipient pubkey, each bucket's recipient counts
-- are disjoint from other buckets — simple union merges them.
pruneMessageBucketCounting = \b messageCutoff -> atomic do
  bucket <- readMessageBucket b
  let kept = do m <- bucket; where m.receivedAt > messageCutoff; yield m
  writeMessageBucket b kept
  yield {count: count kept, recipients: recomputeRecipientCounts kept}

-- ============================================
-- Recipient Count Helpers
-- ============================================
-- Per-recipient message counts avoid O(n) scan of all messages on send/forward.

getRecipientCount : PubkeyHex -> [RecipientCount] -> Int
getRecipientCount = \pubkey counts ->
  fold (\acc c -> if c.pubkey == pubkey then c.count else acc) 0 counts

adjustRecipientCount : [RecipientCount] -> PubkeyHex -> Int -> [RecipientCount]
adjustRecipientCount = \counts pubkey delta ->
  if delta == 0 then counts
  else if any counts (\c -> c.pubkey == pubkey)
    then do c <- counts; yield (if c.pubkey == pubkey then {pubkey: c.pubkey, count: max 0 (c.count + delta)} else c)
    else if delta > 0 then union counts [{pubkey: pubkey, count: delta}]
    else counts

-- Count items per toKey in a single pass: fold accumulates {pubkey, count} pairs,
-- incrementing existing entries or inserting new ones.
countByRecipient = \items ->
  fold (\acc x ->
    if any acc (\c -> c.pubkey == x.toKey)
      then do c <- acc; yield (if c.pubkey == x.toKey then {pubkey: c.pubkey, count: c.count + 1} else c)
      else union acc [{pubkey: x.toKey, count: 1}]) [] items

recomputeRecipientCounts : [Message] -> [RecipientCount]
recomputeRecipientCounts = countByRecipient

-- Batch-decrement recipient counts: subtract per-key removal counts in a single pass
-- instead of calling adjustRecipientCount in a loop.
batchDecrementRecipientCounts : [RecipientCount] -> [RecipientCount] -> [RecipientCount]
batchDecrementRecipientCounts = \counts removedCounts ->
  do c <- counts; yield {pubkey: c.pubkey, count: max 0 (c.count - getRecipientCount c.pubkey removedCounts)}

-- Check message dedup only (without counting — count comes from recipientMsgCounts)
checkMessageDup : [Message] -> Text -> PubkeyHex -> Bool
checkMessageDup = \messages messageId toKey ->
  messageId != "" && any messages (\m -> m.messageId == messageId && m.toKey == toKey)

-- ============================================
-- Federation In-Flight Tracking
-- ============================================
-- Tracks outstanding federation fetches per server. Servers with hung requests
-- (older than federationFetchTimeoutMs) are skipped to prevent slot exhaustion.

markFederationInFlight = \server -> do
  t <- now
  atomic do
    inFlight <- *federationInFlight
    let existing = headOf (do r <- inFlight; where r.server == server; yield r)
    case existing of
      Nothing {} -> set *federationInFlight =
        let updated = union inFlight [{server: server, count: 1, firstStartedAt: t}] in
        if count updated > maxFederationInFlight then evictOneOldest updated (\r -> r.firstStartedAt) else updated
      Just {} -> set *federationInFlight = do r <- inFlight; yield (if r.server == server then {server: r.server, count: r.count + 1, firstStartedAt: r.firstStartedAt} else r)

clearFederationInFlight = \server -> atomic do
  inFlight <- *federationInFlight
  set *federationInFlight = do r <- inFlight; yield (if r.server == server then {server: r.server, count: max 0 (r.count - 1), firstStartedAt: if r.count <= 1 then 0 else r.firstStartedAt} else r)

hasHungFederationRequest : Text -> Timestamp -> [FederationInFlightEntry] -> Bool
hasHungFederationRequest = \server t inFlight ->
  any inFlight (\r -> r.server == server && r.count > 0 && r.firstStartedAt > 0 && t - r.firstStartedAt >= federationFetchTimeoutMs)

-- Wrapper around fetch for federation calls: tracks in-flight state, logs slow responses, records failures
fetchFederation = \server request -> do
  markFederationInFlight server
  startTime <- now
  result <- fetch (federationUrl server) request
  clearFederationInFlight server
  endTime <- now
  let latency = endTime - startTime
  when (latency > federationFetchTimeoutMs)
    (println ("federation: slow response from " ++ server ++ " (" ++ show latency ++ "ms)"))
  atomic do
    total <- *federationLatencyTotal
    cnt <- *federationLatencyCount
    mx <- *federationLatencyMax
    set *federationLatencyTotal = total + latency
    set *federationLatencyCount = cnt + 1
    set *federationLatencyMax = if latency > mx then latency else mx
  yield result

clampTtl : Int<S> -> Int<S>
clampTtl = clamp 1 maxPresenceTtl

clampTimestamp : Timestamp -> Timestamp -> Timestamp
clampTimestamp = \timestamp t -> clamp (t - messageMaxAge) t timestamp

deliveryToMessageStatus : DeliveryStatus -> MessageStatus
deliveryToMessageStatus = \ds -> case ds of
  DsDelivered {} -> MsDelivered {}
  DsFederated {} -> MsFederated {}
  DsQueued {} -> MsQueued {}

isQueued : DeliveryStatus -> Bool
isQueued = \ds -> case ds of DsQueued {} -> True {}; _ -> False {}

-- Ensure strictly monotonic timestamps for message ordering
nextSeqTs : Timestamp -> Timestamp -> Timestamp
nextSeqTs = \t seqCounter -> if t > seqCounter then t else seqCounter + 1

-- Deduplicate message IDs, preserving order, capped at maxMessageIds
dedupMessageIds : [MessageIdHex] -> [MessageIdHex]
dedupMessageIds = \messageIds ->
  let capped = takeRelation maxMessageIds messageIds in
  fold (\acc mid ->
    if any acc (\a -> a == mid) then acc
    else union acc [mid]) [] capped


-- Constant-time string comparison to prevent timing side-channels.
-- Always iterates maxTokenLen characters regardless of input length;
-- rejects empty strings. Tracks both character mismatches and length
-- mismatch (one string ended before the other) within the loop itself,
-- avoiding variable-time count(chars) calls that would leak string length.
safeCompareLoop : Text -> Text -> Int -> Int -> Int -> Int
safeCompareLoop = \s1 s2 n diff lenDiff ->
  if n <= 0
    then diff + lenDiff
    else
      let c1 = take 1 s1 in
      let c2 = take 1 s2 in
      let newDiff = diff + (if c1 == c2 then 0 else 1) in
      let endMismatch = if c1 == "" then (if c2 == "" then 0 else 1) else (if c2 == "" then 1 else 0) in
      safeCompareLoop (drop 1 s1) (drop 1 s2) (n - 1) newDiff (lenDiff + endMismatch)

safeCompare : Text -> Text -> Bool
safeCompare = \a b ->
  if take 1 a == "" || take 1 b == "" then False {}
  else safeCompareLoop a b maxTokenLen 0 0 == 0

-- Generic sliding-window rate limiter. Returns whether the request is rate-limited
-- and the updated entries list. Callers provide match/create/update functions for their entry type.
checkRateWindow = \entries matchKey makeNew updateCount maxRate windowMs maxEntries t ->
  let entry = headOf (do r <- entries; where matchKey r; yield r) in
  let isNewWindow = case entry of Nothing {} -> True {}; Just {value: r} -> t - r.windowStart >= windowMs in
  let rateCount = case entry of Nothing {} -> 0; Just {value: r} -> if isNewWindow then 0 else r.count in
  if rateCount >= maxRate
    then {limited: True {}, entries: entries}
    else
      let newEntries = if isNewWindow
        then union (do r <- entries; where not (matchKey r); yield r) [makeNew t]
        else do r <- entries; yield (if matchKey r then updateCount r else r)
      in {limited: False {}, entries: if count newEntries > maxEntries then (do r <- newEntries; where t - r.windowStart < windowMs; yield r) else newEntries}

-- Extract the item with the smallest key and return both the item and remaining list
extractOldest = \items getKey ->
  fold (\acc x ->
    case acc.candidate of
      Nothing {} -> {candidate: Just {value: x}, items: acc.items}
      Just {value: c} ->
        if getKey x < getKey c
          then {candidate: Just {value: x}, items: union acc.items [c]}
          else {candidate: acc.candidate, items: union acc.items [x]}
    ) {candidate: Nothing {}, items: []} items

-- Remove the single item with the smallest key value (LRU-style eviction)
evictOneOldest = \items getKey ->
  let r = extractOldest items getKey in
  case r.candidate of
    Nothing {} -> items
    Just {} -> r.items

-- Remove the N items with the smallest key value. O(n*k) — efficient when k is small.
evictSmallest = \items n getKey ->
  if n <= 0 then {kept: items, evicted: []}
  else let r = extractOldest items getKey in
    case r.candidate of
      Nothing {} -> {kept: items, evicted: []}
      Just {value: c} ->
        let rest = evictSmallest r.items (n - 1) getKey in
        {kept: rest.kept, evicted: union [c] rest.evicted}

-- Enforce per-key capacity: if a key has >= maxPerKey items, evict the oldest for that key.
-- Also prunes expired items.
capPerKey = \items matchKey maxPerKey getExpiry t ->
  let active = do x <- items; where getExpiry x > t; yield x in
  let forKey = do x <- active; where matchKey x; yield x in
  if count forKey >= maxPerKey
    then let others = diff active forKey in
         union others (evictOneOldest forKey getExpiry)
    else active

-- Enforce global capacity: if at maxCount, evict the single oldest item
capGlobal = \items maxCount getKey ->
  if count items >= maxCount
    then evictOneOldest items getKey
    else items

-- Two-tier capacity enforcement: per-key first, then global
capPerKeyAndGlobal = \items matchKey maxPerKey getExpiry t maxGlobal ->
  capGlobal (capPerKey items matchKey maxPerKey getExpiry t) maxGlobal getExpiry

removeOneForKey = \items pubkey ->
  let forKey = do x <- items; where x.pubkey == pubkey; yield x in
  let others = do x <- items; where x.pubkey != pubkey; yield x in
  union others (evictOneOldest forKey (\x -> x.startedAt))

-- Extract unique remote (non-local) server names from a list of items.
-- O(n*k) where k = unique servers; acceptable since k is typically small (<20).
collectPeerServers : [a] -> (a -> Text) -> [Text]
collectPeerServers = \items getServer ->
  fold (\acc item ->
    let s = getServer item in
    if isLocalServer s then acc
    else if any acc (\a -> a == s) then acc
    else union acc [s]) [] items

samePubkeyServer = \a b -> a.pubkey == b.pubkey && a.server == b.server
pubkeyServer = \e -> {pubkey: e.pubkey, server: e.server}

-- Upsert items by key, keeping the fresher entry on conflict (last-write-wins by freshness)
mergeByKey = \sameKey getFreshness initial items ->
  fold (\acc e ->
    if any acc (\a -> sameKey a e && getFreshness a >= getFreshness e)
      then acc
      else union
        (do a <- acc; where not (sameKey a e); yield a)
        [e]) initial items

-- Merge presence entries by (pubkey, server), keeping the one with the latest expiresAt
mergeByPubkeyServer = mergeByKey samePubkeyServer (\x -> x.expiresAt)

-- Keep entries from setA that are not superseded by a newer-timestamped entry in setB
resolveByTimestamp = \setA setB ->
  do e <- setA; where none setB (\o -> samePubkeyServer o e && o.timestamp > e.timestamp); yield e

-- Remove presence entries that have a corresponding offline event with a newer timestamp
removeOffline = \presenceSet trustedOffline t ->
  diff presenceSet (do
    p <- presenceSet
    o <- trustedOffline
    where samePubkeyServer p o && min o.timestamp t > p.timestamp
    yield p)

-- Cap presence table after gossip merge. If over capacity, only allow updates to
-- existing entries and reclaim slots from expired ones for new entries.
capGossipPresence = \args ->
  if count args.afterOffline <= maxPresenceEntries
    then {finalPresence: args.afterOffline, appliedOnline: args.appliedOnline, withinCapacity: True {}}
    else
      let updatesOnly = existingPresenceUpdates args.trustedDeduped args.presence in
      let updatesOnlyMerged = mergeByPubkeyServer args.presence updatesOnly in
      let updatesOnlyAfterOffline = removeOffline updatesOnlyMerged args.trustedOffline args.t in
      let reclaimSlots = maxPresenceEntries - count updatesOnlyAfterOffline in
      let newEntries = newPresenceEntries args.trustedDeduped args.presence in
      let reclaimedEntries = takeRelation reclaimSlots newEntries in
      {finalPresence: union updatesOnlyAfterOffline reclaimedEntries,
       appliedOnline: union
        (appliedOnlineKeys updatesOnly args.presence)
        (do e <- reclaimedEntries; yield (pubkeyServer e)),
       withinCapacity: False {}}

hasMessage : MessageIdHex -> PubkeyHex -> [{messageId: MessageIdHex, toKey: PubkeyHex | a}] -> Bool
hasMessage = \mid toKey items -> any items (\x -> x.messageId == mid && x.toKey == toKey)

-- Validate incoming gossip events: reject local-server events, future timestamps,
-- and already-expired entries. Clamp TTLs and split into online/offline buckets.
validGossipEvents : [GossipEvent] -> Timestamp -> {online: [ValidGossipEntry], offline: [ValidGossipEntry]}
validGossipEvents = \events t ->
  let validate = \e ->
    if not (isLocalServer e.server) && e.timestamp <= t + clockSkewTolerance
      then let ttl = clampTtl e.ttl in
           let expiresAt = e.timestamp + ttl * 1000 in
           if expiresAt > t
             then [{pubkey: e.pubkey, server: e.server, expiresAt: expiresAt, timestamp: e.timestamp, ttl: ttl}]
             else []
      else []
  in fold (\acc e ->
    case e.eventType of
      GossipOnline {} -> {online: union acc.online (validate e), offline: acc.offline}
      GossipOffline {} -> {online: acc.online, offline: union acc.offline (validate e)}
      _ -> acc) {online: [], offline: []} events

-- Execute an action for each server, forking up to maxFederationConcurrency
-- and processing the remainder sequentially to bound resource usage.
sendToEach : [ServerName] -> (ServerName -> (a {})) -> a {}
sendToEach = \servers action -> sendToEachN servers action maxFederationConcurrency

sendToEachN = \servers action remaining ->
  case headOf servers of
    Nothing {} -> yield {}
    Just {value: server} -> do
      let rest = do s <- servers; where s != server; yield s
      if remaining > 0
        then do
          fork (action server)
          sendToEachN rest action (remaining - 1)
        else do
          action server
          sendToEachN rest action 0

-- Remove all expired entries from every collection. Returns expired local presence
-- entries (for broadcasting offline gossip) and the set of peer servers known before pruning.
pruneExpired = \t -> do
  -- Prune presence (must be atomic for before/after comparison)
  presenceResult <- atomic do
    presenceBefore <- *presence
    let peerServersBefore = collectPeerServers presenceBefore (\p -> p.server)
    let presenceAfter = do x <- presenceBefore; where x.expiresAt > t; yield x
    set *presence = presenceAfter
    yield {expiredLocal: expiredLocalPresence presenceBefore presenceAfter t, peerServers: peerServersBefore}
  -- Prune auth state
  atomic do
    challenges <- *challenges
    set *challenges = do x <- challenges; where x.expiresAt > t; yield x
    transformAllSessionBuckets (\bucket -> do x <- bucket; where x.expiresAt > t; yield x)
    sessionCount <- countAllSessions
    set *totalSessionCount = sessionCount
  -- Prune messages across all 16 buckets. Each bucket prune is atomic (short lock).
  -- Recipient counts are rebuilt incrementally per-bucket — since messages are sharded
  -- by recipient pubkey, each bucket's counts are disjoint, so simple union merges them.
  let messageCutoff = t - unackedMessageMaxAge
  r0 <- pruneMessageBucketCounting 0 messageCutoff
  r1 <- pruneMessageBucketCounting 1 messageCutoff
  r2 <- pruneMessageBucketCounting 2 messageCutoff
  r3 <- pruneMessageBucketCounting 3 messageCutoff
  r4 <- pruneMessageBucketCounting 4 messageCutoff
  r5 <- pruneMessageBucketCounting 5 messageCutoff
  r6 <- pruneMessageBucketCounting 6 messageCutoff
  r7 <- pruneMessageBucketCounting 7 messageCutoff
  r8 <- pruneMessageBucketCounting 8 messageCutoff
  r9 <- pruneMessageBucketCounting 9 messageCutoff
  r10 <- pruneMessageBucketCounting 10 messageCutoff
  r11 <- pruneMessageBucketCounting 11 messageCutoff
  r12 <- pruneMessageBucketCounting 12 messageCutoff
  r13 <- pruneMessageBucketCounting 13 messageCutoff
  r14 <- pruneMessageBucketCounting 14 messageCutoff
  r15 <- pruneMessageBucketCounting 15 messageCutoff
  let prunedTotal = r0.count + r1.count + r2.count + r3.count + r4.count + r5.count + r6.count + r7.count + r8.count + r9.count + r10.count + r11.count + r12.count + r13.count + r14.count + r15.count
  let prunedRecipients = union r0.recipients (union r1.recipients (union r2.recipients (union r3.recipients (union r4.recipients (union r5.recipients (union r6.recipients (union r7.recipients (union r8.recipients (union r9.recipients (union r10.recipients (union r11.recipients (union r12.recipients (union r13.recipients (union r14.recipients r15.recipients))))))))))))))
  atomic do
    set *totalMessageCount = prunedTotal
    set *recipientMsgCounts = prunedRecipients
  -- Prune federation state
  atomic do
    let retainCutoff = t - messageMaxAge
    forwards <- *forwards
    -- Clear all forwards when federation is disabled (they can never be retried)
    set *forwards = if not federationEnabled then []
      else do f <- forwards; where f.createdAt > retainCutoff; yield f
    ackedIds <- *ackedIds
    set *ackedIds = do a <- ackedIds; where a.ackedAt > retainCutoff; yield a
    forwardFailures <- *forwardFailures
    set *forwardFailures = do f <- forwardFailures; where t - f.failedAt < maxServerDowntime; yield f
    ackOverflow <- *ackOverflow
    set *ackOverflow = do a <- ackOverflow; where a.ackedAt > retainCutoff; yield a
    deliveredIds <- *deliveredIds
    set *deliveredIds = do d <- deliveredIds; where d.deliveredAt > retainCutoff; yield d
  -- Prune rate limiters (split into smaller atomic blocks to reduce lock contention)
  atomic do
    sendRates <- *sendRates
    set *sendRates = do r <- sendRates; where t - r.windowStart < sendRateWindowMs; yield r
    challengeRates <- *challengeRates
    set *challengeRates = do r <- challengeRates; where t - r.windowStart < challengeRateWindowMs; yield r
    recvRates <- *recvRates
    set *recvRates = do r <- recvRates; where t - r.windowStart < recvRateWindowMs; yield r
    -- Reset auth-tier global rate window
    authWS <- *authGlobalRateWindowStart
    when (t - authWS >= authGlobalRateWindowMs) (do
      set *authGlobalRateWindowStart = t
      set *authGlobalRateCount = 0)
  atomic do
    federationRates <- *federationRates
    set *federationRates = do r <- federationRates; where t - r.windowStart < federationRateWindowMs; yield r
    ipRates <- *ipRates
    set *ipRates = do r <- ipRates; where t - r.windowStart < ipRateWindowMs; yield r
    lookupRates <- *lookupRates
    set *lookupRates = do r <- lookupRates; where t - r.windowStart < lookupRateWindowMs; yield r
  atomic do
    activePolls <- *activePolls
    set *activePolls = do p <- activePolls; where t - p.startedAt < pollTimeoutMs * 3; yield p
    recentGossip <- *recentGossip
    set *recentGossip = do r <- recentGossip; where t - r.seenAt < gossipDedupWindow; yield r
    -- Clean up stale in-flight entries: remove zeroed entries and reset leaked slots
    -- where the forked task died without calling clearFederationInFlight.
    -- Uses 3x timeout threshold to allow the skip-hung-server logic to take effect first.
    inFlight <- *federationInFlight
    set *federationInFlight = do r <- inFlight; where r.count > 0 && (r.firstStartedAt == 0 || t - r.firstStartedAt < federationFetchTimeoutMs * 3); yield r
  yield presenceResult


splitAtN = \items n ->
  fold (\acc e ->
    if acc.n < n then {n: acc.n + 1, batch: union acc.batch [e], rest: acc.rest}
    else {n: acc.n, batch: acc.batch, rest: union acc.rest [e]})
    {n: 0, batch: [], rest: []} items

forEachBatch = \items batchSize process ->
  if count items == 0 then yield {}
  else do
    let split = splitAtN items batchSize
    process split.batch
    forEachBatch split.rest batchSize process

sendBatchedGossipToServer : ServerName -> [GossipEvent] -> Int -> IO {network} {}
sendBatchedGossipToServer = \server allEvents hops ->
  forEachBatch allEvents maxGossipEvents (\batch -> do
    result <- fetchFederation server (RecvGossip {
      authorization: federationAuthForServer server,
      events: batch, hopsRemaining: hops, fromServer: serverHostN})
    case result of
      Err e -> println ("federation: gossip to " ++ server ++ " failed: " ++ show e)
      Ok _ -> yield {})

sendBatchedGossip : [ServerName] -> [GossipEvent] -> Int -> IO {network} {}
sendBatchedGossip = \peerServers allEvents hops ->
  sendToEach peerServers (\server -> sendBatchedGossipToServer server allEvents hops)

broadcastOfflineGossip = \t peerServers expiredLocal ->
  when (federationEnabled && count peerServers > 0 && count expiredLocal > 0) (do
    let cappedExpired = takeRelation maxPresenceEntries expiredLocal
    when (count expiredLocal > maxPresenceEntries)
      (println ("gossip: capped offline broadcast to " ++ show maxPresenceEntries ++ " entries (had " ++ show (count expiredLocal) ++ ")"))
    let gossipEvents = mergeByKey (\a b -> a.pubkey == b.pubkey) (\x -> x.timestamp) [] (offlineGossipEvents cappedExpired)
    sendBatchedGossip peerServers gossipEvents gossipOriginHops)


effectiveGossipEvents = \entries appliedKeys eventType -> do
  e <- entries
  where any appliedKeys (\a -> samePubkeyServer a e)
  yield {eventType: eventType, pubkey: e.pubkey, server: e.server, timestamp: e.timestamp, ttl: e.ttl}

mergeGossipPresence = \presence deduped trustedOffline fromServer t ->
  let trustedDeduped = trustedGossipEntries deduped presence fromServer t in
  let appliedOnline = appliedOnlineKeys trustedDeduped presence in
  let merged = mergeByPubkeyServer presence trustedDeduped in
  let afterOffline = removeOffline merged trustedOffline t in
  let appliedOffline = do p <- diff merged afterOffline; yield (pubkeyServer p) in
  let capResult = capGossipPresence {afterOffline: afterOffline, appliedOnline: appliedOnline, trustedDeduped: trustedDeduped, presence: presence, trustedOffline: trustedOffline, t: t} in
  {finalPresence: capResult.finalPresence,
   appliedKeys: union capResult.appliedOnline appliedOffline,
   gossipPeerServers: collectPeerServers capResult.finalPresence (\p -> p.server),
   withinCapacity: capResult.withinCapacity}


checkFederationRate = \server t -> atomic do
  federationRates <- *federationRates
  let result = checkRateWindow federationRates (\r -> r.server == server)
    (\ts -> {server: server, windowStart: ts, count: 1})
    (\r -> {server: r.server, windowStart: r.windowStart, count: r.count + 1})
    maxFederationRatePerServer federationRateWindowMs maxFederationRateEntries t
  set *federationRates = result.entries
  yield result.limited

checkGlobalRate = \t -> atomic do
  windowStart <- *globalRateWindowStart
  rateCount <- *globalRateCount
  if t - windowStart >= globalRateWindowMs
    then do
      set *globalRateWindowStart = t
      set *globalRateCount = 1
      yield (False {})
    else if rateCount >= maxGlobalRequestRate
      then yield (True {})
      else do
        set *globalRateCount = rateCount + 1
        yield (False {})

-- Auth-tier global rate limiting (shared budget for challenge + verify + revoke)
checkAuthGlobalRate = \t -> atomic do
  windowStart <- *authGlobalRateWindowStart
  rateCount <- *authGlobalRateCount
  if t - windowStart >= authGlobalRateWindowMs
    then do
      set *authGlobalRateWindowStart = t
      set *authGlobalRateCount = 1
      yield (False {})
    else if rateCount >= maxAuthGlobalRate
      then yield (True {})
      else do
        set *authGlobalRateCount = rateCount + 1
        yield (False {})

-- IP-based rate limiting; skips if clientIp header is empty (no reverse proxy)
checkIpRate = \ip t ->
  if ip == "" then yield (False {})
  else atomic do
    ipRates <- *ipRates
    let result = checkRateWindow ipRates (\r -> r.ip == ip)
      (\ts -> {ip: ip, windowStart: ts, count: 1})
      (\r -> {ip: r.ip, windowStart: r.windowStart, count: r.count + 1})
      maxIpRatePerIp ipRateWindowMs maxIpRateEntries t
    set *ipRates = result.entries
    yield result.limited

-- Combined pre-auth gate: drain check, global rate, IP rate. Returns "" if all pass.
checkPreAuth = \clientIp t -> do
  draining <- *draining
  if draining then yield "draining"
  else do
    globalLimited <- checkGlobalRate t
    if globalLimited then yield "global_rate_limited"
    else do
      ipLimited <- checkIpRate clientIp t
      if ipLimited then yield "ip_rate_limited"
      else yield ""

withFederationAuth = \authorization t respond fromServer precondition action ->
  if not (verifyFederationAuthForServer fromServer authorization)
    then yield (respond {ok: False {}, error: "unauthorized"})
    else if not precondition
    then yield (respond {ok: False {}, error: "invalid_request"})
    else do
      globalLimited <- checkGlobalRate t
      if globalLimited
        then do
          println ("federation: global rate limited (" ++ show maxGlobalRequestRate ++ "/s), rejecting for " ++ fromServer)
          yield (respond {ok: False {}, error: "rate_limited"})
        else do
          rateLimited <- checkFederationRate fromServer t
          if rateLimited
            then do
              println ("federation: rate limited (" ++ show maxFederationRatePerServer ++ "/s per server), rejecting for " ++ fromServer)
              yield (respond {ok: False {}, error: "rate_limited"})
            else do
              let hasPeerSecrets = count federationPeerSecrets > 0
              let hasSpecificSecret = any federationPeerSecrets (\p -> normalizeServerName p.server == fromServer)
              when (hasPeerSecrets && not hasSpecificSecret)
                (println ("federation: warning: " ++ fromServer ++ " using global secret (no per-peer secret configured)"))
              clearFailure fromServer
              action

withSessionAuth = \authorization t clientIp onUnauth onAuth -> do
  case extractToken authorization of
    Nothing {} -> onUnauth
    Just {value: token} -> do
      let bucket = tokenBucket token
      sessions <- readSessionBucket bucket
      case authenticateSession sessions token t of
        Unauthorized {} -> onUnauth
        Authorized {pubkey, ip} ->
          if clientIp != "" && ip != "" && clientIp != ip
            then onUnauth
            else onAuth pubkey

removeForward = \mid srv -> atomic do
  forwards <- *forwards
  set *forwards = forwardsExcluding forwards srv [mid]

pow2 : Int -> Int
pow2 = \n -> if n <= 0 then 1 else 2 * pow2 (n - 1)

-- Exponential backoff: base * 2^(failures-1), capped at retryBackoffMax
retryBackoff : Int -> Int<Ms>
retryBackoff = \failures ->
  min retryBackoffMax (retryBackoffBase * pow2 (max 0 (failures - 1)))

shouldRetryServer : Text -> Timestamp -> [ForwardFailure] -> Bool
shouldRetryServer = \server t failures ->
  case headOf (do f <- failures; where f.server == server; yield f) of
    Nothing {} -> True {}
    Just {value: f} -> t - f.firstFailedAt < maxServerDowntime && t - f.failedAt >= retryBackoff f.failures

-- Extended retry check: also skip servers with hung in-flight requests
shouldRetryServerEx : Text -> Timestamp -> [ForwardFailure] -> [FederationInFlightEntry] -> Bool
shouldRetryServerEx = \server t failures inFlight ->
  shouldRetryServer server t failures && not (hasHungFederationRequest server t inFlight)

recordFailure = \server -> do
  t <- now
  atomic do
    failures <- *forwardFailures
    let existing = headOf (do f <- failures; where f.server == server; yield f)
    let updated = case existing of
      Nothing {} -> union failures [{server: server, failedAt: t, failures: 1, firstFailedAt: t}]
      Just {value: f} -> union (do x <- failures; where x.server != server; yield x) [{server: server, failedAt: t, failures: min (f.failures + 1) 10, firstFailedAt: f.firstFailedAt}]
    set *forwardFailures = if count updated > maxForwardFailures then evictOneOldest updated (\x -> x.failedAt) else updated

clearFailure = \server -> do
  t <- now
  atomic do
    failures <- *forwardFailures
    set *forwardFailures = do f <- failures; where f.server != server; yield f
    set *lastFederationSuccessAt = t

retryForwardsForServer : [ForwardEntry] -> Int -> IO {network} {}
retryForwardsForServer = \entries remaining ->
  if remaining <= 0
    then yield {}
    else case headOf entries of
      Nothing {} -> yield {}
      Just {value: f} -> do
        let rest = do x <- entries; where x.messageId != f.messageId; yield x
        result <- fetchFederation f.toServer (ForwardMessage {
          toKey: f.toKey, encryptedBlob: f.encryptedBlob,
          timestamp: f.timestamp, originServer: f.originServer, messageId: f.messageId,
          fromServer: serverHostN, authorization: federationAuthForServer f.toServer})
        case result of
          Err e -> do
            println ("federation: forward to " ++ f.toServer ++ " failed for " ++ f.messageId ++ ": " ++ show e)
            recordFailure f.toServer
            -- Network error: stop retrying, server is unreachable
          Ok response -> do
            if response.ok then do
              removeForward f.messageId f.toServer
              clearFailure f.toServer
            else
              println ("federation: forward to " ++ f.toServer ++ " rejected for " ++ f.messageId ++ ": " ++ response.error)
            retryForwardsForServer rest (remaining - 1)

-- Retry all pending forwards, respecting per-server backoff. Skips servers that failed recently.
retryPendingForwards : [ForwardEntry] -> IO {network} {}
retryPendingForwards = \pending -> do
  let servers = collectPeerServers pending (\x -> x.toServer)
  t <- now
  failures <- *forwardFailures
  inFlight <- *federationInFlight
  let eligibleServers = do s <- servers; where shouldRetryServerEx s t failures inFlight; yield s
  sendToEach eligibleServers (\server ->
    retryForwardsForServer (forwardsForServer pending server) maxForwardRetriesPerServer)
  yield {}

-- When a remote key comes online, create forward entries for queued messages and send them
forwardQueuedMessages = \targets t -> do
  newForwards <- atomic do
    forwards <- *forwards
    presence <- *presence
    let localOnline = localOnlineKeys presence t
    let remoteTargets = remoteOnlyTargets targets localOnline
    -- Read only the message buckets containing target pubkeys (not all 16)
    let neededBuckets = uniqueBucketsFor remoteTargets (\target -> target.pubkey)
    relevantMessages <- readSelectedBuckets neededBuckets
    let candidates = forwardCandidates remoteTargets relevantMessages forwards t
    let capped = takeRelation (maxForwardsEntries - count forwards) candidates
    let updatedForwards = union forwards capped
    set *forwards = updatedForwards
    yield capped
  let servers = collectPeerServers newForwards (\x -> x.toServer)
  failures <- *forwardFailures
  inFlight <- *federationInFlight
  let eligibleServers = do s <- servers; where shouldRetryServerEx s t failures inFlight; yield s
  sendToEach eligibleServers (\server ->
    retryForwardsForServer (forwardsForServer newForwards server) maxForwardRetriesPerServer)

fetchFederationAck = \origin messageIds ->
  fetchFederation origin (FederationAck {
    authorization: federationAuthForServer origin,
    messageIds: messageIds,
    originServer: origin, fromServer: serverHostN})

sendBatchedAcksToServer : [{messageId: MessageIdHex, toKey: PubkeyHex, originServer: ServerName, | a}] -> ServerName -> IO {network} {}
sendBatchedAcksToServer = \serverAcks server ->
  forEachBatch serverAcks maxMessageIds (\batch -> do
    result <- fetchFederationAck server (do a <- batch; yield a.messageId)
    case result of
      Err e -> do
        println ("federation: ack to " ++ server ++ " failed: " ++ show e)
        recordFailure server
      Ok _ -> do
        clearFailure server
        atomic do
          ackedIds <- *ackedIds
          let updatedAckedIds = ackedIdsExcludingBatch ackedIds server batch
          set *ackedIds = updatedAckedIds)

-- Send delivery acknowledgments back to origin servers and remove acked entries on success
sendAcksAndClean : [{messageId: MessageIdHex, toKey: PubkeyHex, originServer: ServerName, | a}] -> IO {network} {}
sendAcksAndClean = \pendingAcks -> do
  let servers = collectPeerServers pendingAcks (\a -> a.originServer)
  t <- now
  failures <- *forwardFailures
  inFlight <- *federationInFlight
  let eligibleServers = do s <- servers; where shouldRetryServerEx s t failures inFlight; yield s
  sendToEach eligibleServers (\server ->
    sendBatchedAcksToServer (acksForServer pendingAcks server) server)

-- Retry sending acks that were evicted from ackedIds due to capacity limits.
-- On failure, re-insert into ackedIds or overflow buffer; overflow entries eventually
-- move to deliveredIds (terminal dedup state) if the buffer is also full.
retryEvictedAcks = \evictedEntries pendingAcks ->
  let evictedToRetry = retriableEvictedAcks evictedEntries pendingAcks
  in do
    let evictedOriginServers = collectPeerServers evictedToRetry (\a -> a.originServer)
    sendToEach evictedOriginServers (\server -> do
      fetchResult <- fetchFederationAck server (do a <- acksForServer evictedToRetry server; yield a.messageId)
      case fetchResult of
        Err e -> do
          println ("federation: evicted ack to " ++ server ++ " failed: " ++ show e)
          overflow <- atomic do
            ackedIds <- *ackedIds
            let reinsert = acksForServer evictedToRetry server
            let combined = union ackedIds reinsert
            let excess = count combined - maxAckedIds
            if excess <= 0
              then do set *ackedIds = combined; yield []
              else do
                let eviction = evictSmallest combined (max 0 excess) (\a -> a.ackedAt)
                set *ackedIds = eviction.kept
                yield eviction.evicted
          when (count overflow > 0) (do
            dropped <- atomic do
              ackOverflow <- *ackOverflow
              let updated = union ackOverflow overflow
              let overflowExcess = count updated - maxAckOverflow
              if overflowExcess <= 0
                then do set *ackOverflow = updated; yield 0
                else do
                  let overflowEviction = evictSmallest updated (max 0 overflowExcess) (\a -> a.ackedAt)
                  set *ackOverflow = overflowEviction.kept
                  deliveredIds <- *deliveredIds
                  let newDelivered = do a <- overflowEviction.evicted; yield {messageId: a.messageId, toKey: a.toKey, deliveredAt: a.ackedAt}
                  let combinedDelivered = union deliveredIds newDelivered
                  let deliveredExcess = count combinedDelivered - maxDeliveredIds
                  set *deliveredIds = if deliveredExcess <= 0 then combinedDelivered
                    else (evictSmallest combinedDelivered (max 0 deliveredExcess) (\d -> d.deliveredAt)).kept
                  when (deliveredExcess > 0)
                    (println ("ackMessages: deliveredIds at capacity (" ++ show maxDeliveredIds ++ "), " ++ show deliveredExcess ++ " oldest dedup entries permanently removed for " ++ server))
                  yield overflowExcess
            when (dropped > 0)
              (println ("ackMessages: overflow at capacity (" ++ show maxAckOverflow ++ "), " ++ show dropped ++ " ack entries moved to delivered set for " ++ server)))
        Ok _ -> yield {})

-- Retry acks sitting in the overflow buffer (last chance before they become deliveredIds)
retryOverflowAcks = \overflow -> do
  let servers = collectPeerServers overflow (\a -> a.originServer)
  t <- now
  failures <- *forwardFailures
  inFlight <- *federationInFlight
  let eligibleServers = do s <- servers; where shouldRetryServerEx s t failures inFlight; yield s
  sendToEach eligibleServers (\server ->
    forEachBatch (acksForServer overflow server) maxMessageIds (\batch -> do
      result <- fetchFederationAck server (do a <- batch; yield a.messageId)
      case result of
        Err e -> do
          println ("federation: overflow ack to " ++ server ++ " failed: " ++ show e)
          recordFailure server
        Ok _ -> do
          clearFailure server
          atomic do
            ackOverflow <- *ackOverflow
            set *ackOverflow = do a <- ackOverflow; where not (a.originServer == server && hasMessage a.messageId a.toKey batch); yield a))

-- Poll federationInFlight until all in-flight requests complete or deadline passes.
-- Used during drain to wait for outstanding federation work before signaling completion.
waitForInFlightDrain = \deadline -> do
  t <- now
  if t >= deadline then println "drain: timed out waiting for in-flight federation tasks"
  else do
    inFlight <- *federationInFlight
    let activeCount = fold (\acc r -> acc + r.count) 0 inFlight
    if activeCount <= 0 then yield {}
    else do
      sleep 1000
      waitForInFlightDrain deadline

-- Full maintenance cycle: prune expired state, retry pending forwards and acks,
-- retry overflow acks, broadcast offline gossip, and refresh presence for local keys
-- nearing expiry. Called by both the background task and the /maintenance/prune endpoint.
pruneAndRetry = \t -> do
  atomic do set *lastPrunedAt = t
  pr <- pruneExpired t
  pendingForwards <- atomic do f <- *forwards; yield f
  ackState <- atomic do
    ackedIds2 <- *ackedIds
    let pendingAcks = do a <- ackedIds2; where not (isLocalServer a.originServer); yield a
    ackOverflow <- *ackOverflow
    let pendingOverflow = do a <- ackOverflow; where not (isLocalServer a.originServer); yield a
    yield {pendingAcks: pendingAcks, pendingOverflow: pendingOverflow}
  refreshResult <- atomic do
    lastRefresh <- *lastPresenceRefresh
    let shouldRefresh = federationEnabled && t - lastRefresh >= presenceRefreshInterval
    presence <- *presence
    allSessions <- readAllSessions
    -- Extend presence for keys with active sessions nearing expiry (sliding window)
    let localNearExpiry = if shouldRefresh then (do p <- presence; where isLocalServer p.server && p.expiresAt > t && p.expiresAt - t < presenceRefreshThreshold; yield p) else []
    let toExtend = do p <- localNearExpiry; where any allSessions (\s -> s.pubkey == p.pubkey && s.expiresAt > t); yield p
    let notExtended = do p <- localNearExpiry; where none allSessions (\s -> s.pubkey == p.pubkey && s.expiresAt > t); yield p
    when (count toExtend > 0) (
      set *presence = do pp <- presence; yield (if any toExtend (\e -> e.pubkey == pp.pubkey && isLocalServer pp.server) then {pubkey: pp.pubkey, server: pp.server, expiresAt: t + sessionExpiry, timestamp: t} else pp))
    let refreshPeers = if shouldRefresh then collectPeerServers presence (\p -> p.server) else []
    when shouldRefresh (set *lastPresenceRefresh = t)
    yield {extendedActive: toExtend, nearExpiryActive: notExtended, refreshPeers: refreshPeers, shouldRefresh: shouldRefresh}
  -- Reset federation latency metrics periodically for windowed averages (prevents
  -- lifetime-cumulative average from masking current conditions)
  atomic do
    resetAt <- *federationLatencyResetAt
    when (t - resetAt >= federationLatencyWindowMs) (do
      set *federationLatencyTotal = 0
      set *federationLatencyCount = 0
      set *federationLatencyMax = 0
      set *federationLatencyResetAt = t)
  let result = {pendingForwards: pendingForwards, pendingAcks: ackState.pendingAcks, pendingOverflow: ackState.pendingOverflow, extendedActive: refreshResult.extendedActive, nearExpiryActive: refreshResult.nearExpiryActive, refreshPeers: refreshResult.refreshPeers, shouldRefresh: refreshResult.shouldRefresh}
  -- Fork federation I/O so hung peers don't block next prune cycle
  fork (do
    broadcastOfflineGossip t pr.peerServers pr.expiredLocal
    when federationEnabled (do
      retryPendingForwards result.pendingForwards
      sendAcksAndClean result.pendingAcks
      retryOverflowAcks result.pendingOverflow))
  -- Only gossip extended sessions; keys nearing expiry without active sessions will naturally
  -- trigger offline gossip when they expire (avoids wasted federation traffic)
  when result.shouldRefresh (do
    let refreshEvents = do p <- result.extendedActive; yield {eventType: GossipOnline {}, pubkey: p.pubkey, server: serverHostN, timestamp: t, ttl: clampTtl (sessionExpiry / 1000)}
    when (count result.refreshPeers > 0 && count refreshEvents > 0)
      (fork (sendBatchedGossip result.refreshPeers refreshEvents gossipOriginHops)))

hexCharIndex : Text -> Int
hexCharIndex = \c ->
  if c == "0" then 0 else if c == "1" then 1 else if c == "2" then 2 else if c == "3" then 3
  else if c == "4" then 4 else if c == "5" then 5 else if c == "6" then 6 else if c == "7" then 7
  else if c == "8" then 8 else if c == "9" then 9 else if c == "a" then 10 else if c == "b" then 11
  else if c == "c" then 12 else if c == "d" then 13 else if c == "e" then 14 else 15

-- Map pubkey to one of 16 signal buckets based on first hex digit.
-- This partitions the signal space so storing a message for one pubkey
-- only wakes polls in the same bucket, not all active polls.
-- Defensive clamp ensures an invalid first char never indexes out of bounds
pubkeyBucket : PubkeyHex -> Int
pubkeyBucket = \pubkey -> clamp 0 15 (hexCharIndex (take 1 pubkey))

-- Update the signal timestamp for a pubkey's bucket, waking any blocked polls in that bucket
signalMessageForKey = \pubkey ts ->
  let b = pubkeyBucket pubkey in
  if b == 0 then set *messageSignal0 = ts
  else if b == 1 then set *messageSignal1 = ts
  else if b == 2 then set *messageSignal2 = ts
  else if b == 3 then set *messageSignal3 = ts
  else if b == 4 then set *messageSignal4 = ts
  else if b == 5 then set *messageSignal5 = ts
  else if b == 6 then set *messageSignal6 = ts
  else if b == 7 then set *messageSignal7 = ts
  else if b == 8 then set *messageSignal8 = ts
  else if b == 9 then set *messageSignal9 = ts
  else if b == 10 then set *messageSignal10 = ts
  else if b == 11 then set *messageSignal11 = ts
  else if b == 12 then set *messageSignal12 = ts
  else if b == 13 then set *messageSignal13 = ts
  else if b == 14 then set *messageSignal14 = ts
  else set *messageSignal15 = ts

readMessageSignal = \pubkey ->
  let b = pubkeyBucket pubkey in
  if b == 0 then do s <- *messageSignal0; yield s
  else if b == 1 then do s <- *messageSignal1; yield s
  else if b == 2 then do s <- *messageSignal2; yield s
  else if b == 3 then do s <- *messageSignal3; yield s
  else if b == 4 then do s <- *messageSignal4; yield s
  else if b == 5 then do s <- *messageSignal5; yield s
  else if b == 6 then do s <- *messageSignal6; yield s
  else if b == 7 then do s <- *messageSignal7; yield s
  else if b == 8 then do s <- *messageSignal8; yield s
  else if b == 9 then do s <- *messageSignal9; yield s
  else if b == 10 then do s <- *messageSignal10; yield s
  else if b == 11 then do s <- *messageSignal11; yield s
  else if b == 12 then do s <- *messageSignal12; yield s
  else if b == 13 then do s <- *messageSignal13; yield s
  else if b == 14 then do s <- *messageSignal14; yield s
  else do s <- *messageSignal15; yield s

-- Acknowledge messages up to the given cursor: remove from messages, cancel pending forwards,
-- and create ack entries for federated messages (to notify origin servers).
-- Returns pending acks and any evicted entries that exceeded ackedIds capacity.
ackPolledMessages = \pubkey cursor t -> do
  let b = pubkeyBucket pubkey
  bucket <- readMessageBucket b
  let toAck = do m <- bucket; where m.toKey == pubkey && m.receivedAt <= cursor; yield m
  let ackCount = count toAck
  if ackCount > 0
    then do
      writeMessageBucket b (diff bucket toAck)
      totalCount <- *totalMessageCount
      set *totalMessageCount = totalCount - ackCount
      recipientCounts <- *recipientMsgCounts
      set *recipientMsgCounts = adjustRecipientCount recipientCounts pubkey (0 - ackCount)
      let ackedMsgIds = do m <- toAck; yield m.messageId
      forwards <- *forwards
      set *forwards = do f <- forwards; where none ackedMsgIds (\mid -> f.messageId == mid && f.toKey == pubkey); yield f
      let ackedFederated = federatedAckEntries toAck t
      ackedIds <- *ackedIds
      let combinedAckedIds = union ackedIds ackedFederated
      let excessCount = max 0 (count combinedAckedIds - maxAckedIds)
      let eviction = evictSmallest combinedAckedIds excessCount (\a -> a.ackedAt)
      set *ackedIds = eviction.kept
      yield {pendingAcks: ackedFederated, evictedEntries: eviction.evicted}
    else yield {pendingAcks: [], evictedEntries: []}

pollNewEvents = \pubkey clampedCursor t -> do
  bucket <- readMessageBucket (pubkeyBucket pubkey)
  let limitedMsgs = takeRelation maxPollEvents (sortBy (\m -> m.receivedAt) (pollableMessages bucket pubkey clampedCursor t))
  let evts = do
    m <- limitedMsgs
    yield {id: m.messageId, eventType: "message",
           payload: {toKey: m.toKey,
                      encryptedBlob: m.encryptedBlob,
                      timestamp: m.timestamp}}
  let lastReceivedAt = fold (\acc m -> max acc m.receivedAt) clampedCursor limitedMsgs
  yield {events: evts, cursor: lastReceivedAt}

-- Execute a single long-poll cycle:
-- 1. Authenticate and ack messages up to cursor (atomic)
-- 2. Acquire a poll slot (limit concurrent polls per key)
-- 3. Check for existing messages; if none, block on signal/heartbeat (retry-based wait)
-- 4. Re-authenticate after waking (session may have expired during wait)
-- 5. Return new events and release the poll slot
pollOnce = \token cursor clientIp -> do
  t <- now
  let bucket = tokenBucket token
  setup <- atomic do
    sessions <- readSessionBucket bucket
    case authenticateSession sessions token t of
      Unauthorized {} -> yield (Nothing {})
      Authorized {pubkey, ip} ->
        if clientIp != "" && ip != "" && clientIp != ip
          then yield (Nothing {})
          else do
        -- Refresh session expiry (sliding window keeps active sessions alive)
        writeSessionBucket bucket (do s <- sessions; yield (if safeCompare s.token token then {token: s.token, pubkey: s.pubkey, expiresAt: t + sessionExpiry, ip: s.ip} else s))
        seqCounter <- *seqCounter
        let clampedCursor = clamp 0 (max seqCounter t) cursor
        ackResult <- if clampedCursor > 0
          then ackPolledMessages pubkey clampedCursor t
          else yield {pendingAcks: [], evictedEntries: []}
        startWakeup <- *pollWakeup
        startSignal <- readMessageSignal pubkey
        yield (Just {value: {pubkey: pubkey, clampedCursor: clampedCursor, startWakeup: startWakeup, startSignal: startSignal, pendingAcks: ackResult.pendingAcks, evictedEntries: ackResult.evictedEntries}})
  case setup of
    Nothing {} -> yield {authorized: False {}, events: [], cursor: 0, pendingAcks: [], evictedEntries: []}
    Just {value: s} -> do
      -- Acquire poll slot (limit concurrent polls per key)
      acquired <- atomic do
        activePolls <- *activePolls
        let pollsForKey = count (do p <- activePolls; where p.pubkey == s.pubkey; yield p)
        if pollsForKey >= maxPollsPerKey
          then yield (False {})
          else do
            set *activePolls = if count activePolls >= maxActivePolls
              then union (evictOneOldest activePolls (\p -> p.startedAt)) [{pubkey: s.pubkey, startedAt: t}]
              else union activePolls [{pubkey: s.pubkey, startedAt: t}]
            yield (True {})
      if not acquired
        then yield {authorized: True {}, events: [], cursor: cursor, pendingAcks: s.pendingAcks, evictedEntries: s.evictedEntries}
        else do
          pollResult <- do
            -- Phase 1: check for existing messages (atomic read)
            initialResult <- atomic do
              bucket <- readMessageBucket (pubkeyBucket s.pubkey)
              if count (pollableMessages bucket s.pubkey s.clampedCursor t) > 0
                then do
                  r <- pollNewEvents s.pubkey s.clampedCursor t
                  yield (Just {value: {events: r.events, cursor: r.cursor}})
                else yield (Nothing {})
            case initialResult of
              Just {value: result} ->
                yield {authorized: True {}, events: result.events, cursor: result.cursor}
              Nothing {} -> do
                -- Phase 2: wait for signal or heartbeat
                atomic do
                  wakeup <- *pollWakeup
                  signal <- readMessageSignal s.pubkey
                  if wakeup > s.startWakeup || signal > s.startSignal
                    then yield {}
                    else retry
                -- Phase 3: re-authenticate and read messages after waking
                t2 <- now
                result <- atomic do
                  sessions2 <- readSessionBucket bucket
                  case authenticateSession sessions2 token t2 of
                    Unauthorized {} -> yield {authorized: False {}, events: [], cursor: s.clampedCursor}
                    Authorized {} -> do
                      r <- pollNewEvents s.pubkey s.clampedCursor t2
                      yield {authorized: True {}, events: r.events, cursor: r.cursor}
                yield {authorized: result.authorized, events: result.events, cursor: result.cursor}
          -- Release poll slot. Safety net: if this is never reached (e.g., panic between
          -- acquire and release), pruneExpired cleans stale entries after pollTimeoutMs * 3.
          atomic do
            activePolls <- *activePolls
            set *activePolls = removeOneForKey activePolls s.pubkey
          yield {authorized: pollResult.authorized, events: pollResult.events, cursor: pollResult.cursor, pendingAcks: s.pendingAcks, evictedEntries: s.evictedEntries}

-- ============================================
-- Derived Relations
-- ============================================
-- Pure query functions over in-memory state. No side effects.

-- All non-expired presence entries for a given pubkey
presenceForKey = \presence pubkey t ->
  do p <- presence; where p.pubkey == pubkey && p.expiresAt > t; yield p

-- Pubkeys that are online on this server
localOnlineKeys = \presence t ->
  do p <- presence; where isLocalServer p.server && p.expiresAt > t; yield p.pubkey

-- Remove the local presence entry for a pubkey (used before re-inserting on auth)
presenceWithoutLocalKey = \presence pubkey ->
  do p <- presence; where p.pubkey != pubkey || not (isLocalServer p.server); yield p

-- Local presence entries that expired during this prune cycle (for offline gossip)
expiredLocalPresence = \before after t ->
  do p <- before; where p.expiresAt <= t && isLocalServer p.server && none after (\q -> q.pubkey == p.pubkey && isLocalServer q.server); yield p

-- Resolve the best server for a pubkey: prefer local, otherwise pick the remote with latest expiry
bestServerForKey = \entries ->
  if any entries (\p -> isLocalServer p.server) then serverHostN
  else case maxBy (do p <- entries; where not (isLocalServer p.server); yield p) (\p -> p.expiresAt) of
    Just {value: p} -> p.server
    Nothing {} -> ""

-- Messages for a pubkey newer than cursor and within messageMaxAge
pollableMessages = \messages pubkey cursor t ->
  do m <- messages; where m.toKey == pubkey && m.receivedAt >= t - messageMaxAge && m.receivedAt > cursor; yield m

-- Build ack entries for messages that came from a remote origin server (need federation ack)
federatedAckEntries = \ackedMessages t ->
  do m <- ackedMessages; where m.originServer != ""; yield {messageId: m.messageId, toKey: m.toKey, ackedAt: t, originServer: m.originServer}

-- Remove forwards for specific message IDs destined to a given server
forwardsExcluding = \forwards server messageIds ->
  do f <- forwards; where not (f.toServer == server && any messageIds (\mid -> f.messageId == mid)); yield f

-- Find messages that haven't been forwarded yet to each target's server.
-- Includes relay: messages received via federation (originServer != "") can be
-- re-forwarded when the recipient moves to a different server. Cascade is bounded
-- by dedup (same messageId won't be forwarded to the same server twice).
forwardCandidates = \targets messages forwards t ->
  fold (\acc target ->
    let serverFwdIds = do f <- forwards; where f.toServer == target.server; yield f.messageId in
    union acc (do
      m <- messages
      where m.toKey == target.pubkey
      where none serverFwdIds (\fid -> fid == m.messageId)
      let origin = if m.originServer == "" then serverHostN else m.originServer
      yield {messageId: m.messageId, toServer: target.server, createdAt: t,
             toKey: m.toKey, encryptedBlob: m.encryptedBlob, timestamp: m.timestamp,
             originServer: origin})) [] targets


challengeMatch = \challenges pubkey challenge ip t ->
  any challenges (\c -> c.pubkey == pubkey && safeCompare c.challenge challenge && c.expiresAt > t && (ip == "" || c.ip == "" || c.ip == ip))

challengesExcluding = \challenges pubkey challenge ->
  do c <- challenges; where c.pubkey != pubkey || c.challenge != challenge; yield c

hasLocalPresence = \entries -> any entries (\p -> isLocalServer p.server)

ackedIdsExcludingBatch = \ackedIds server batch ->
  do a <- ackedIds; where not (a.originServer == server && hasMessage a.messageId a.toKey batch); yield a

retriableEvictedAcks = \evictedEntries pendingAcks ->
  do a <- evictedEntries; where not (hasMessage a.messageId a.toKey pendingAcks); yield a

acksForServer = \acks server -> do a <- acks; where a.originServer == server; yield a

forwardsForServer = \forwards server -> do f <- forwards; where f.toServer == server; yield f

-- Only trust offline events that claim to be from the sending server itself
trustedOfflineEvents = \events fromServer ->
  do e <- events; where e.server == fromServer; yield e

-- Peer servers to re-gossip to, excluding the server that sent us the gossip
gossipTargets = \peerServers fromServer ->
  do s <- peerServers; where s != fromServer; yield s

-- Remote keys that just came online (triggers forwarding of queued messages)
newlyOnlineRemoteKeys = \events appliedKeys ->
  do e <- events; where any appliedKeys (\a -> samePubkeyServer a e); where not (isLocalServer e.server); yield {pubkey: e.pubkey, server: e.server}

-- Trust gossip entries if they're first-party (server == fromServer) or updating
-- an existing (pubkey, server) presence entry. Third-party gossip cannot create
-- new entries for keys we haven't seen — only the key's home server can do that.
trustedGossipEntries = \deduped presence fromServer t ->
  do e <- deduped; where e.server == fromServer || any presence (\p -> samePubkeyServer p e && p.expiresAt > t); yield {expiresAt: e.expiresAt, pubkey: e.pubkey, server: e.server, timestamp: e.timestamp}

-- Keys whose presence was actually updated (new or extended expiry)
appliedOnlineKeys = \entries presence ->
  do e <- entries; where none presence (\p -> samePubkeyServer p e && p.expiresAt >= e.expiresAt); yield (pubkeyServer e)

-- Gossip entries that update existing presence (vs. creating new entries)
existingPresenceUpdates = \entries presence ->
  do e <- entries; where any presence (\p -> samePubkeyServer p e); yield e

-- Gossip entries for keys not yet in the presence table
newPresenceEntries = \entries presence ->
  do e <- entries; where none presence (\p -> samePubkeyServer p e); yield e

-- Generate offline gossip events for locally-expired presence entries
offlineGossipEvents = \expiredLocal -> do
  p <- expiredLocal
  let ttl = clamp offlineGossipMinTtl maxPresenceTtl ((p.expiresAt - p.timestamp) / 1000)
  yield {eventType: GossipOffline {}, pubkey: p.pubkey, server: serverHostN, timestamp: p.expiresAt, ttl: ttl}

-- Filter targets to only those not locally online (avoid forwarding to keys that can poll directly)
remoteOnlyTargets = \targets localOnline ->
  do target <- targets; where none localOnline (\pk -> pk == target.pubkey); yield target

-- ============================================
-- Request Handler
-- ============================================

-- POST /auth/challenge: Generate a random challenge for Ed25519 authentication.
-- Rate-limited per key; globally capped. Challenge expires in 1 minute.
handleChallenge = \pubkey clientIp respond -> do
  t <- now
  preAuth <- checkPreAuth clientIp t
  if preAuth != ""
    then do
      when (preAuth == "ip_rate_limited") (println ("challenge: IP rate limited for " ++ clientIp))
      yield (respond {challenge: "", ok: False {}, expiresAt: 0})
    else do
      authLimited <- checkAuthGlobalRate t
      if authLimited then yield (respond {challenge: "", ok: False {}, expiresAt: 0})
      else do
      rawChallenge <- genToken
      let challenge = serverHostN ++ ":" ++ rawChallenge
      result <- atomic do
        challenges <- *challenges
        let active = do c <- challenges; where c.expiresAt > t; yield c
        let activeForKey = count (do c <- active; where c.pubkey == pubkey; yield c)
        let cappedActive = if activeForKey >= maxChallengesPerKey
          then let forKey = do c <- active; where c.pubkey == pubkey; yield c in
               let others = do c <- active; where c.pubkey != pubkey; yield c in
               union others (evictOneOldest forKey (\c -> c.expiresAt))
          else active
        if count cappedActive >= maxChallenges
          then yield {accepted: False {}, rateLimited: False {}}
          else do
            challengeRates <- *challengeRates
            let rateResult = checkRateWindow challengeRates (\r -> r.pubkey == pubkey)
              (\ts -> {pubkey: pubkey, windowStart: ts, count: 1})
              (\r -> {pubkey: r.pubkey, windowStart: r.windowStart, count: r.count + 1})
              maxChallengeRatePerKey challengeRateWindowMs maxChallengeRateEntries t
            if rateResult.limited
              then yield {accepted: False {}, rateLimited: True {}}
              else do
                set *challengeRates = rateResult.entries
                set *challenges = union cappedActive [{pubkey: pubkey, challenge: challenge, expiresAt: t + challengeExpiry, ip: clientIp}]
                yield {accepted: True {}, rateLimited: False {}}
      when result.rateLimited
        (println ("challenge: rate limited (" ++ show maxChallengeRatePerKey ++ "/s per key), rejecting for " ++ pubkey))
      when (not result.accepted && not result.rateLimited)
        (println ("challenge: at capacity (" ++ show maxChallenges ++ "), rejecting for " ++ pubkey))
      yield (respond {challenge: if result.accepted then challenge else "", ok: result.accepted, expiresAt: if result.accepted then t + challengeExpiry else 0})

-- POST /auth/verify: Verify Ed25519 signature over challenge string.
-- On success: creates a session, registers local presence, and gossips online status.
-- Rate-limited globally and per-key (shares auth rate window with challenge requests).
handleVerifyAuth = \pubkey challenge signature revokeOthers clientIp respond -> do
  t <- now
  preAuth <- checkPreAuth clientIp t
  if preAuth != ""
    then do
      when (preAuth == "ip_rate_limited") (println ("verify: IP rate limited for " ++ clientIp))
      yield (respond {token: "", expiresAt: 0})
    else do
      authRateLimited <- atomic do
        challengeRates <- *challengeRates
        let rateResult = checkRateWindow challengeRates (\r -> r.pubkey == pubkey)
          (\ts -> {pubkey: pubkey, windowStart: ts, count: 1})
          (\r -> {pubkey: r.pubkey, windowStart: r.windowStart, count: r.count + 1})
          maxChallengeRatePerKey challengeRateWindowMs maxChallengeRateEntries t
        set *challengeRates = rateResult.entries
        yield rateResult.limited
      if authRateLimited then do
        println ("verify: rate limited (" ++ show maxChallengeRatePerKey ++ "/s per key), rejecting for " ++ pubkey)
        yield (respond {token: "", expiresAt: 0})
      else do
        authGlobalLimited <- checkAuthGlobalRate t
        if authGlobalLimited then yield (respond {token: "", expiresAt: 0})
        else verifyAuthInner pubkey challenge signature revokeOthers clientIp respond t

verifyAuthInner = \pubkey challenge signature revokeOthers clientIp respond t -> do
  let expiry = t + sessionExpiry
  validation <- atomic do
    challenges <- *challenges
    let hasMatch = challengeMatch challenges pubkey challenge clientIp t
    -- Only consume the challenge on full success (match AND valid signature).
    -- This prevents an attacker who intercepts the challenge string from burning it
    -- by submitting a bad signature from the same IP. Rate limiter still constrains
    -- brute-force attempts; not consuming on IP mismatch prevents remote attackers
    -- from burning challenges.
    -- verify() is inside the atomic block to prevent a TOCTOU gap between challenge
    -- validation and consumption. It's pure (no IO) so safe in STM.
    if not hasMatch
      then yield {valid: False {}}
      else do
        let sigValid = verify (bytesFromHex pubkey) (textToBytes challenge) (bytesFromHex signature)
        if not sigValid
          then yield {valid: False {}}
          else do
            set *challenges = challengesExcluding challenges pubkey challenge
            yield {valid: True {}}
  if validation.valid
    then do
      token <- genToken
      let newBucket = tokenBucket token
      authResult <- atomic do
        isDraining <- *draining
        if isDraining then yield (Nothing {})
        else do
          -- Read all session buckets for per-key enforcement (revokeOthers, capPerKey)
          allSessions <- readAllSessions
          presence <- *presence
          let sessionsForKey = count (do s <- allSessions; where s.pubkey == pubkey; yield s)
          let totalSessions = count allSessions
          let newSession = {token: token, pubkey: pubkey, expiresAt: expiry, ip: clientIp}
          -- Fast path: no revocation, under per-key and global limits — only write one bucket
          if not revokeOthers && sessionsForKey < maxSessionsPerKey && totalSessions < maxSessions
            then do
              let nb = tokenBucket token
              currentBucket <- readSessionBucket nb
              writeSessionBucket nb (union currentBucket [newSession])
              sc <- *totalSessionCount
              set *totalSessionCount = sc + 1
              let presenceWithout = presenceWithoutLocalKey presence pubkey
              let presenceEvicted = capGlobal presenceWithout maxPresenceEntries (\p -> p.expiresAt)
              let updatedPresence = union presenceEvicted [{pubkey: pubkey, server: serverHostN, expiresAt: expiry, timestamp: t}]
              set *presence = updatedPresence
              yield (Just {value: {peerServers: if federationEnabled
                then collectPeerServers updatedPresence (\p -> p.server)
                else [], revokedCount: 0}})
            else do
              -- Slow path: revocation or capacity pressure — redistribute across all buckets
              let revokedCount = if revokeOthers then sessionsForKey else 0
              let afterRevoke = if revokeOthers then do s <- allSessions; where s.pubkey != pubkey; yield s else allSessions
              let capped = capPerKeyAndGlobal afterRevoke (\s -> s.pubkey == pubkey) maxSessionsPerKey (\s -> s.expiresAt) t maxSessions
              let sessionsWithNew = union capped [newSession]
              set *totalSessionCount = count sessionsWithNew
              let bFor = \b -> do s <- sessionsWithNew; where tokenBucket s.token == b; yield s
              writeSessionBucket 0 (bFor 0)
              writeSessionBucket 1 (bFor 1)
              writeSessionBucket 2 (bFor 2)
              writeSessionBucket 3 (bFor 3)
              writeSessionBucket 4 (bFor 4)
              writeSessionBucket 5 (bFor 5)
              writeSessionBucket 6 (bFor 6)
              writeSessionBucket 7 (bFor 7)
              writeSessionBucket 8 (bFor 8)
              writeSessionBucket 9 (bFor 9)
              writeSessionBucket 10 (bFor 10)
              writeSessionBucket 11 (bFor 11)
              writeSessionBucket 12 (bFor 12)
              writeSessionBucket 13 (bFor 13)
              writeSessionBucket 14 (bFor 14)
              writeSessionBucket 15 (bFor 15)
              let presenceWithout = presenceWithoutLocalKey presence pubkey
              let presenceEvicted = capGlobal presenceWithout maxPresenceEntries (\p -> p.expiresAt)
              let updatedPresence = union presenceEvicted [{pubkey: pubkey, server: serverHostN, expiresAt: expiry, timestamp: t}]
              set *presence = updatedPresence
              yield (Just {value: {peerServers: if federationEnabled
                then collectPeerServers updatedPresence (\p -> p.server)
                else [], revokedCount: revokedCount}})
      case authResult of
        Nothing {} -> yield (respond {token: "", expiresAt: 0})
        Just {value: result} -> do
          when (revokeOthers && result.revokedCount > 0)
            (println ("verify: revokeOthers revoked " ++ show result.revokedCount ++ " sessions for " ++ pubkey))
          fork (when federationEnabled
            (sendBatchedGossip result.peerServers [{eventType: GossipOnline {}, pubkey: pubkey, server: serverHostN, timestamp: t, ttl: onlineGossipTtl}] gossipOriginHops))
          yield (respond {token: token, expiresAt: expiry})
    else yield (respond {token: "", expiresAt: 0})

-- POST /poll: Long-poll for new messages. Cursor-based: messages at or before cursor
-- are acked (removed from mailbox). Blocks until new messages arrive or heartbeat fires.
-- Acks for federated messages are sent to origin servers in the background.
handlePoll = \cursor generation watchKeys authorization clientIp respond -> do
  t <- now
  serverGen <- *serverGeneration
  let effectiveCursor = if generation == serverGen then cursor else 0
  let cappedWatchKeys = takeRelation maxWatchKeys watchKeys
  draining <- *draining
  if draining then yield (respond {events: [], cursor: 0, authorized: True {}, rateLimited: False {}, draining: True {}, generation: serverGen, presenceUpdates: []})
  else do
  globalRateLimited <- checkGlobalRate t
  if globalRateLimited then yield (respond {events: [], cursor: 0, authorized: False {}, rateLimited: True {}, draining: False {}, generation: serverGen, presenceUpdates: []})
  else do
    result <- case extractToken authorization of
      Nothing {} -> yield {authorized: False {}, events: [], cursor: 0, pendingAcks: [], evictedEntries: []}
      Just {value: token} -> pollOnce token effectiveCursor clientIp
    -- Check presence for watched keys (piggybacks on poll cycle; max latency = pollTimeoutMs)
    presenceUpdates <- if result.authorized && count cappedWatchKeys > 0 then do
      t2 <- now
      atomic do
        presence <- *presence
        yield (do key <- cappedWatchKeys; yield {pubkey: key, online: count (presenceForKey presence key t2) > 0})
    else yield []
    fork (when federationEnabled (do
      sendAcksAndClean result.pendingAcks
      retryEvictedAcks result.evictedEntries result.pendingAcks))
    yield (respond {events: result.events, cursor: result.cursor, authorized: result.authorized, rateLimited: False {}, draining: False {}, generation: serverGen, presenceUpdates: presenceUpdates})

-- POST /messages: Send an encrypted message to a recipient.
-- Deduplicates by messageId across messages, ackedIds, and deliveredIds.
-- Rate-limited per sender key. If recipient is known on a remote server, forwards via federation.
handleSendMessage = \to encryptedBlob timestamp messageId authorization clientIp respond -> do
  t <- now
  globalRateLimited <- checkGlobalRate t
  if globalRateLimited then yield (respond {status: MsRateLimited {}, messageId: ""})
  else do
    effectiveMsgId <- if messageId != "" then yield messageId else genToken
    if t - timestamp > messageMaxAge
      then yield (respond {status: MsRejected {}, messageId: ""})
      else do
    let clampedTs = clampTimestamp timestamp t
    result <- atomic do
      draining <- *draining
      if draining then yield {send: SendFailed {status: MsDraining {}}, senderRateLimited: False {}, globalCapReached: False {}}
      else withSessionAuth authorization t clientIp
        (yield {send: SendFailed {status: MsUnauthorized {}}, senderRateLimited: False {}, globalCapReached: False {}})
        (\senderKey -> do
          -- Reject self-sends (sender == recipient wastes a mailbox slot)
          if senderKey == to then yield {send: SendFailed {status: MsRejected {}}, senderRateLimited: False {}, globalCapReached: False {}}
          else do
          let msgBucket = pubkeyBucket to
          bucket <- readMessageBucket msgBucket
          ackedIds <- *ackedIds
          deliveredIds <- *deliveredIds
          -- Dedup check (only when messageId is non-empty; scans only the recipient's bucket)
          let isDup = checkMessageDup bucket messageId to || (messageId != "" && (hasMessage messageId to ackedIds || hasMessage messageId to deliveredIds))
          if isDup
            then yield {send: SendDuplicate {}, senderRateLimited: False {}, globalCapReached: False {}}
            else do
              sendRates <- *sendRates
              let rateResult = checkRateWindow sendRates (\r -> r.pubkey == senderKey)
                (\ts -> {pubkey: senderKey, windowStart: ts, count: 1})
                (\r -> {pubkey: r.pubkey, windowStart: r.windowStart, count: r.count + 1})
                maxSendRatePerKey sendRateWindowMs maxSendRateEntries t
              if rateResult.limited
                then yield {send: SendFailed {status: MsRateLimited {}}, senderRateLimited: True {}, globalCapReached: False {}}
                else do
                  set *sendRates = rateResult.entries
                  recvRates <- *recvRates
                  let recvResult = checkRateWindow recvRates (\r -> r.pubkey == to)
                    (\ts -> {pubkey: to, windowStart: ts, count: 1})
                    (\r -> {pubkey: r.pubkey, windowStart: r.windowStart, count: r.count + 1})
                    maxRecvRatePerKey recvRateWindowMs maxRecvRateEntries t
                  if recvResult.limited
                    then yield {send: SendFailed {status: MsRateLimited {}}, senderRateLimited: False {}, globalCapReached: False {}}
                    else do
                      set *recvRates = recvResult.entries
                      totalMsgCount <- *totalMessageCount
                      if totalMsgCount >= maxMessages
                        then yield {send: SendFailed {status: MsRejected {}}, senderRateLimited: False {}, globalCapReached: True {}}
                        else do
                          -- Recipient count from maintained counts (O(unique_recipients) instead of O(all_messages))
                          recipientCounts <- *recipientMsgCounts
                          let recipientCount = getRecipientCount to recipientCounts
                          if recipientCount >= maxMessagesPerRecipient
                            then yield {send: SendFailed {status: MsRejected {}}, senderRateLimited: False {}, globalCapReached: False {}}
                            else do
                              presence <- *presence
                              seqCounter <- *seqCounter
                              let seqTs = nextSeqTs t seqCounter
                              set *seqCounter = seqTs
                              writeMessageBucket msgBucket (union bucket
                                [{messageId: effectiveMsgId, toKey: to,
                                  encryptedBlob: encryptedBlob, timestamp: clampedTs, originServer: "", receivedAt: seqTs}])
                              set *totalMessageCount = totalMsgCount + 1
                              set *recipientMsgCounts = adjustRecipientCount recipientCounts to 1
                              signalMessageForKey to seqTs
                          let toPresence = presenceForKey presence to t
                          let localOnline = hasLocalPresence toPresence
                          let remoteServers = collectPeerServers toPresence (\p -> p.server)
                          let delivery = if localOnline then DsDelivered {}
                            else if federationEnabled && count remoteServers > 0 then DsFederated {}
                            else DsQueued {}
                          -- Create forward entries atomically with message storage (prevents race with ack)
                          when (federationEnabled && count remoteServers > 0) (do
                            forwards <- *forwards
                            let newFwds = do s <- remoteServers; where none forwards (\f -> f.messageId == effectiveMsgId && f.toServer == s); yield {messageId: effectiveMsgId, toServer: s, createdAt: t, toKey: to, encryptedBlob: encryptedBlob, timestamp: clampedTs, originServer: serverHostN}
                            let cappedFwds = takeRelation (maxForwardsEntries - count forwards) newFwds
                            set *forwards = union forwards cappedFwds)
                          yield {send: SendDone {delivery: delivery, remoteServers: remoteServers}, senderRateLimited: False {}, globalCapReached: False {}})
    when result.senderRateLimited
      (println ("sendMessage: rate limited (" ++ show maxSendRatePerKey ++ "/s per key)"))
    when result.globalCapReached
      (println ("sendMessage: global message cap reached (" ++ show maxMessages ++ "), rejecting"))
    case result.send of
      SendDone {delivery, remoteServers} ->
        when (count remoteServers > 0 && federationEnabled) (
          fork (sendToEach remoteServers (\server -> do
            -- Check if forward still exists (recipient may have acked during fork delay)
            stillPending <- atomic do
              forwards <- *forwards
              yield (any forwards (\f -> f.messageId == effectiveMsgId && f.toServer == server))
            when stillPending (do
              fwdResult <- fetchFederation server (ForwardMessage {
                toKey: to, encryptedBlob: encryptedBlob,
                timestamp: clampedTs, originServer: serverHostN, messageId: effectiveMsgId,
                fromServer: serverHostN, authorization: federationAuthForServer server})
              case fwdResult of
                Err e -> do
                  println ("federation: send forward to " ++ server ++ " failed for " ++ effectiveMsgId ++ ": " ++ show e)
                  recordFailure server
                Ok response ->
                  if response.ok then do
                    removeForward effectiveMsgId server
                    clearFailure server
                  else
                    println ("federation: send forward to " ++ server ++ " rejected for " ++ effectiveMsgId ++ ": " ++ response.error)))))
      _ -> yield {}
    yield (case result.send of
      SendFailed {status} -> respond {status: status, messageId: ""}
      SendDuplicate {} -> respond {status: MsDuplicate {}, messageId: effectiveMsgId}
      SendDone {delivery} -> respond {status: deliveryToMessageStatus delivery, messageId: effectiveMsgId})

-- GET /lookup/:pubkey: Look up the best known server for a pubkey.
-- Returns local server if key is online locally, otherwise the remote with latest expiry.
handleLookupPresence = \pubkey authorization clientIp respond -> do
  t <- now
  globalRateLimited <- checkGlobalRate t
  if globalRateLimited then yield (respond {server: "", authorized: False {}})
  else do
    result <- atomic do
      draining <- *draining
      if draining then yield {server: "", authorized: False {}}
      else withSessionAuth authorization t clientIp
        (yield {server: "", authorized: False {}})
        (\senderKey -> do
          lookupRates <- *lookupRates
          let rateResult = checkRateWindow lookupRates (\r -> r.pubkey == senderKey)
            (\ts -> {pubkey: senderKey, windowStart: ts, count: 1})
            (\r -> {pubkey: r.pubkey, windowStart: r.windowStart, count: r.count + 1})
            maxLookupRatePerKey lookupRateWindowMs maxLookupRateEntries t
          set *lookupRates = rateResult.entries
          if rateResult.limited
            then yield {server: "", authorized: True {}}
            else do
              presence <- *presence
              let foundServer = bestServerForKey (presenceForKey presence pubkey t)
              -- Mask remote server names: clients only need to know local/remote/unknown,
              -- not which specific peer server a key is homed on (prevents metadata leakage)
              let maskedServer = if foundServer == "" then "" else if isLocalServer foundServer then foundServer else "remote"
              yield {server: maskedServer, authorized: True {}})
    yield (respond {server: result.server, authorized: result.authorized})

-- POST /messages/status: Check delivery status of a previously sent message.
-- Caller must provide both messageId and recipient pubkey (proves they know the recipient).
-- Returns: "pending" (in mailbox), "forwarding" (federation in progress),
-- "delivered" (acked by recipient), "unknown" (expired or never existed).
handleMessageStatus = \to messageId authorization clientIp respond -> do
  t <- now
  globalRateLimited <- checkGlobalRate t
  if globalRateLimited then yield (respond {status: "", authorized: False {}})
  else
    withSessionAuth authorization t clientIp
      (yield (respond {status: "", authorized: False {}}))
      (\senderKey -> do
        result <- atomic do
          let msgBucket = pubkeyBucket to
          bucket <- readMessageBucket msgBucket
          -- Check if message is still in mailbox (pending delivery)
          let inMailbox = any bucket (\m -> m.messageId == messageId && m.toKey == to)
          if inMailbox then yield "pending"
          else do
            -- Check if being forwarded to a remote server
            forwards <- *forwards
            let inForwards = any forwards (\f -> f.messageId == messageId && f.toKey == to)
            if inForwards then yield "forwarding"
            else do
              -- Check if already delivered (acked or in terminal delivered set)
              ackedIds <- *ackedIds
              deliveredIds <- *deliveredIds
              let inAcked = hasMessage messageId to ackedIds
              let inDelivered = hasMessage messageId to deliveredIds
              if inAcked || inDelivered then yield "delivered"
              else yield "unknown"
        yield (respond {status: result, authorized: True {}}))

-- POST /auth/revoke: Revoke a specific session token.
-- Caller authenticates via Authorization header, then specifies the target token to remove.
-- Only removes the target if it belongs to the same pubkey as the caller (prevents cross-user revocation).
handleRevoke = \targetToken authorization clientIp respond -> do
  t <- now
  globalRateLimited <- checkGlobalRate t
  if globalRateLimited then yield (respond {ok: False {}, authorized: False {}})
  else
    withSessionAuth authorization t clientIp
      (yield (respond {ok: False {}, authorized: False {}}))
      (\callerPubkey -> do
        revokeLimited <- atomic do
          challengeRates <- *challengeRates
          let rateResult = checkRateWindow challengeRates (\r -> r.pubkey == callerPubkey)
            (\ts -> {pubkey: callerPubkey, windowStart: ts, count: 1})
            (\r -> {pubkey: r.pubkey, windowStart: r.windowStart, count: r.count + 1})
            maxChallengeRatePerKey challengeRateWindowMs maxChallengeRateEntries t
          set *challengeRates = rateResult.entries
          yield rateResult.limited
        if revokeLimited then yield (respond {ok: False {}, authorized: True {}})
        else do
        let targetBucket = tokenBucket targetToken
        removed <- atomic do
          sessions <- readSessionBucket targetBucket
          let hasTarget = any sessions (\s -> safeCompare s.token targetToken && s.pubkey == callerPubkey)
          if hasTarget
            then do
              writeSessionBucket targetBucket (do s <- sessions; where not (safeCompare s.token targetToken && s.pubkey == callerPubkey); yield s)
              sc <- *totalSessionCount
              set *totalSessionCount = max 0 (sc - 1)
              yield (True {})
            else yield (False {})
        when removed (println ("revoke: session revoked for " ++ callerPubkey))
        yield (respond {ok: removed, authorized: True {}}))

-- POST /auth/logout: Voluntary disconnect. Removes the caller's session and, if it was
-- the last active session for this pubkey, clears local presence and gossips offline.
-- This gives faster offline detection than waiting for session expiry (1 hour).
handleLogout = \authorization clientIp respond -> do
  t <- now
  globalRateLimited <- checkGlobalRate t
  if globalRateLimited then yield (respond {ok: False {}, authorized: False {}})
  else
    case extractToken authorization of
      Nothing {} -> yield (respond {ok: False {}, authorized: False {}})
      Just {value: token} -> do
        let bucket = tokenBucket token
        result <- atomic do
          sessions <- readSessionBucket bucket
          case authenticateSession sessions token t of
            Unauthorized {} -> yield (Nothing {})
            Authorized {pubkey, ip} ->
              if clientIp != "" && ip != "" && clientIp != ip
                then yield (Nothing {})
                else do
                  -- Remove the caller's session
                  writeSessionBucket bucket (do s <- sessions; where not (safeCompare s.token token); yield s)
                  sc <- *totalSessionCount
                  set *totalSessionCount = max 0 (sc - 1)
                  -- Check if this was the last session for this key
                  allSessions <- readAllSessions
                  let remaining = count (do s <- allSessions; where s.pubkey == pubkey; yield s)
                  if remaining == 0
                    then do
                      -- Remove local presence immediately
                      presence <- *presence
                      set *presence = presenceWithoutLocalKey presence pubkey
                      yield (Just {value: {pubkey: pubkey, gossipOffline: True {}}})
                    else yield (Just {value: {pubkey: pubkey, gossipOffline: False {}}})
        case result of
          Nothing {} -> yield (respond {ok: False {}, authorized: False {}})
          Just {value: r} -> do
            when r.gossipOffline (do
              println ("logout: last session for " ++ r.pubkey ++ ", gossiping offline")
              when federationEnabled (do
                presence <- *presence
                let peerServers = collectPeerServers presence (\p -> p.server)
                when (count peerServers > 0)
                  (fork (sendBatchedGossip peerServers [{eventType: GossipOffline {}, pubkey: r.pubkey, server: serverHostN, timestamp: t, ttl: offlineGossipMinTtl}] gossipOriginHops))))
            yield (respond {ok: True {}, authorized: True {}})

-- POST /federation/gossip: Receive presence gossip from a peer server.
-- Validates events, merges into presence table (last-write-wins), and re-gossips
-- to other known peers with decremented hop count. Triggers message forwarding
-- when a remote key comes online.
handleRecvGossip = \events hopsRemaining fromServer authorization respond -> do
  t <- now
  let cappedHops = clamp 0 maxGossipHops hopsRemaining
  withFederationAuth authorization t respond fromServer (cappedHops >= 1 && not (isLocalServer fromServer) && count events <= maxGossipEvents) (do
    let validated = validGossipEvents events t
    let onlineEntries = validated.online
    let trustedOffline = trustedOfflineEvents validated.offline fromServer
    -- Warn if a peer sends both online and offline for the same key in one batch (suspicious)
    let conflictingKeys = do on <- onlineEntries; off <- trustedOffline; where on.pubkey == off.pubkey && on.server == off.server; yield on.pubkey
    when (count conflictingKeys > 0)
      (println ("gossip: warning: " ++ fromServer ++ " sent conflicting online+offline for same key(s)"))
    let filteredOnline = resolveByTimestamp onlineEntries trustedOffline
    let filteredOffline = resolveByTimestamp trustedOffline onlineEntries
    let deduped = mergeByPubkeyServer [] filteredOnline
    gossipResult <- atomic do
      presence <- *presence
      let gm = mergeGossipPresence presence deduped trustedOffline fromServer t
      set *presence = gm.finalPresence
      yield {gm: gm}
    let effectiveEvents = union (effectiveGossipEvents filteredOnline gossipResult.gm.appliedKeys (GossipOnline {})) (effectiveGossipEvents filteredOffline gossipResult.gm.appliedKeys (GossipOffline {}))
    when (not gossipResult.gm.withinCapacity)
      (println ("gossip: presence at capacity (" ++ show maxPresenceEntries ++ "), limiting new entries from " ++ fromServer))
    -- Suppress re-broadcast of events we've already gossiped recently (prevents amplification)
    freshEvents <- atomic do
      recentGossip <- *recentGossip
      let active = do r <- recentGossip; where t - r.seenAt < gossipDedupWindow; yield r
      -- Pre-filter active entries to only those matching pubkeys in this batch (reduces O(n*m) inner scan)
      let batchPubkeys = fold (\acc e -> if any acc (\a -> a == e.pubkey) then acc else union acc [e.pubkey]) [] effectiveEvents
      let relevantActive = do r <- active; where any batchPubkeys (\pk -> pk == r.pubkey); yield r
      let fresh = do e <- effectiveEvents; where none relevantActive (\r -> r.pubkey == e.pubkey && r.server == e.server && r.timestamp == e.timestamp); yield e
      let newRecent = do e <- fresh; yield {pubkey: e.pubkey, server: e.server, timestamp: e.timestamp, seenAt: t}
      let updated = union active newRecent
      set *recentGossip = if count updated > maxRecentGossip then do r <- updated; where t - r.seenAt < gossipDedupWindow; yield r else updated
      yield fresh
    let newlyOnlineRemote = newlyOnlineRemoteKeys filteredOnline gossipResult.gm.appliedKeys
    fork (do
      when (cappedHops > 1 && federationEnabled && count freshEvents > 0) (
        sendBatchedGossip (gossipTargets gossipResult.gm.gossipPeerServers fromServer) freshEvents (cappedHops - 1))
      when (federationEnabled && count newlyOnlineRemote > 0)
        (forwardQueuedMessages newlyOnlineRemote t))
    yield (respond {ok: True {}, error: ""}))

-- POST /federation/forward: Receive a message forwarded from a peer server.
-- Accepts both direct forwards (fromServer == originServer) and relay forwards
-- (fromServer != originServer) where an intermediate server re-forwards because
-- the recipient moved. Cascade is bounded by dedup (same messageId won't be stored
-- twice) and forwardCandidates (won't re-forward to the same server).
handleForwardMessage = \toKey encryptedBlob timestamp originServer messageId fromServer authorization respond -> do
  t <- now
  withFederationAuth authorization t respond fromServer (not (isLocalServer originServer) && not (isLocalServer fromServer)) (do
    when (fromServer != originServer)
      (println ("forward: relay from " ++ fromServer ++ " (origin: " ++ originServer ++ ") for " ++ toKey))
    -- Replay protection: reject forwards with timestamps older than messageMaxAge.
    -- Legitimate queued messages have timestamps within this window. Replayed captures
    -- become stale once dedup state (messages + ackedIds + deliveredIds) is pruned (~30 days).
    if t - timestamp > messageMaxAge
      then yield (respond {ok: False {}, error: "stale_timestamp"})
      else do
    let clampedTs = clampTimestamp timestamp t
    result <- atomic do
      let msgBucket = pubkeyBucket toKey
      bucket <- readMessageBucket msgBucket
      ackedIds <- *ackedIds
      deliveredIds <- *deliveredIds
      let isDup = checkMessageDup bucket messageId toKey || hasMessage messageId toKey ackedIds || hasMessage messageId toKey deliveredIds
      if isDup
        then yield {forward: ForwardDuplicate {}, globalCapReached: False {}, recvRateLimited: False {}}
        else do
          totalMsgCount <- *totalMessageCount
          if totalMsgCount >= maxMessages
            then yield {forward: ForwardRejected {}, globalCapReached: True {}, recvRateLimited: False {}}
            else do
              recipientCounts <- *recipientMsgCounts
              let recipientCount = getRecipientCount toKey recipientCounts
              if recipientCount >= maxMessagesPerRecipient
                then yield {forward: ForwardRejected {}, globalCapReached: False {}, recvRateLimited: False {}}
                else do
                  recvRates <- *recvRates
                  let recvResult = checkRateWindow recvRates (\r -> r.pubkey == toKey)
                    (\ts -> {pubkey: toKey, windowStart: ts, count: 1})
                    (\r -> {pubkey: r.pubkey, windowStart: r.windowStart, count: r.count + 1})
                    maxRecvRatePerKey recvRateWindowMs maxRecvRateEntries t
                  if recvResult.limited
                    then yield {forward: ForwardRejected {}, globalCapReached: False {}, recvRateLimited: True {}}
                    else do
                      set *recvRates = recvResult.entries
                      seqCounter <- *seqCounter
                      let seqTs = nextSeqTs t seqCounter
                      set *seqCounter = seqTs
                      writeMessageBucket msgBucket (union bucket
                        [{messageId: messageId, toKey: toKey,
                          encryptedBlob: encryptedBlob, timestamp: clampedTs, originServer: originServer, receivedAt: seqTs}])
                      set *totalMessageCount = totalMsgCount + 1
                      set *recipientMsgCounts = adjustRecipientCount recipientCounts toKey 1
                      signalMessageForKey toKey seqTs
                      yield {forward: ForwardStored {}, globalCapReached: False {}, recvRateLimited: False {}}
    case result.forward of
      ForwardRejected {} ->
        if result.globalCapReached
          then println ("forward: global message cap reached (" ++ show maxMessages ++ "), rejecting for " ++ toKey)
          else if result.recvRateLimited
          then println ("forward: recv rate limited (" ++ show maxRecvRatePerKey ++ "/s per key), rejecting for " ++ toKey)
          else println ("forward: rejected for " ++ toKey ++ " (mailbox full, max " ++ show maxMessagesPerRecipient ++ ")")
      _ -> yield {}
    yield (case result.forward of
      ForwardRejected {} -> respond {ok: False {}, error: "mailbox_full"}
      _ -> respond {ok: True {}, error: ""}))

-- POST /federation/ack: Peer server confirms delivery of messages we originated.
-- Removes corresponding forward entries. Also cleans up the original message if the
-- recipient has no local presence and no other pending forwards for that message.
handleFederationAck = \messageIds originServer fromServer authorization respond -> do
  t <- now
  withFederationAuth authorization t respond fromServer (isLocalServer originServer && not (isLocalServer fromServer)) (do
    let dedupedIds = dedupMessageIds messageIds
    -- Only clear forward entries; origin messages are retained until the recipient
    -- polls from this server or they age out via unackedMessageMaxAge. This prevents
    -- a compromised peer from deleting messages by sending unverified acks.
    atomic do
      forwards <- *forwards
      set *forwards = forwardsExcluding forwards fromServer dedupedIds
    yield (respond {ok: True {}, error: ""}))

-- POST /maintenance/drain: Broadcast offline gossip for all local keys (graceful shutdown).
-- Call before stopping the server so peers learn keys went offline immediately.
-- Gossip is sent via fork; allow a few seconds after response before process exit.
handleDrain = \authorization respond -> do
  t <- now
  let authorized = verifyMaintenanceAuth authorization
  if not authorized then yield (respond {ok: False {}, drained: 0})
  else do
    drainResult <- atomic do
      set *draining = True {}
      presence <- *presence
      let localEntries = do p <- presence; where isLocalServer p.server && p.expiresAt > t; yield p
      set *presence = do p <- presence; where not (isLocalServer p.server) || p.expiresAt <= t; yield p
      set *pollWakeup = t
      yield {localEntries: localEntries, peerServers: collectPeerServers presence (\p -> p.server)}
    let drainedCount = count drainResult.localEntries
    forwards <- *forwards
    ackedIds <- *ackedIds
    let pendingAcks = do a <- ackedIds; where not (isLocalServer a.originServer); yield a
    let pendingForwardCount = count forwards
    let pendingAckCount = count pendingAcks
    -- Fork best-effort flush of pending federation ops, then gossip, then wait for in-flight.
    -- Operator polls /stats for drainCompletedAt > 0 to know when safe to stop.
    atomic do set *drainCompletedAt = 0
    fork (do
      -- Best-effort flush of pending forwards and acks before stopping
      when (federationEnabled && pendingForwardCount > 0) (do
        println ("drain: flushing " ++ show pendingForwardCount ++ " pending forwards")
        retryPendingForwards forwards)
      when (federationEnabled && pendingAckCount > 0) (do
        println ("drain: flushing " ++ show pendingAckCount ++ " pending acks")
        sendAcksAndClean pendingAcks)
      when (federationEnabled && drainedCount > 0 && count drainResult.peerServers > 0) (do
        let gossipEvents = do p <- drainResult.localEntries; yield {eventType: GossipOffline {}, pubkey: p.pubkey, server: serverHostN, timestamp: t, ttl: offlineGossipMinTtl}
        sendBatchedGossip drainResult.peerServers gossipEvents gossipOriginHops)
      -- Wait for in-flight federation requests to complete (timeout: 2x fetch timeout)
      when federationEnabled (waitForInFlightDrain (t + federationFetchTimeoutMs * 2))
      t2 <- now
      atomic do set *drainCompletedAt = t2)
    println ("drain: broadcast offline for " ++ show drainedCount ++ " local keys")
    when (pendingForwardCount > 0)
      (println ("drain: flushing " ++ show pendingForwardCount ++ " pending forwards"))
    when (pendingAckCount > 0)
      (println ("drain: flushing " ++ show pendingAckCount ++ " pending acks"))
    yield (respond {ok: True {}, drained: drainedCount})

-- POST /maintenance/undrain: Resume accepting requests after a drain.
-- Background loops (prune, heartbeat) automatically resume on next iteration.
handleUndrain = \authorization respond -> do
  let authorized = verifyMaintenanceAuth authorization
  if not authorized then yield (respond {ok: False {}})
  else do
    wasDraining <- atomic do
      d <- *draining
      set *draining = False {}
      set *drainCompletedAt = 0
      yield d
    when wasDraining (println "undrain: server resumed, accepting new requests")
    when (not wasDraining) (println "undrain: server was not draining")
    yield (respond {ok: True {}})

-- POST /maintenance/prune: Trigger a full maintenance cycle (prune + retry all pending ops).
-- Accepts either federation or maintenance secret.
handlePrune = \authorization respond -> do
  t <- now
  draining <- *draining
  let authorized = verifyMaintenanceAuth authorization && not draining
  when authorized (fork (pruneAndRetry t))
  yield (respond {ok: authorized})

handleHealth = \respond -> do
  t <- now
  -- Health checks exempt from global rate limiting (monitoring traffic shouldn't starve real requests)
  result <- atomic do
    lastPrune <- *lastPrunedAt
    lastHb <- *lastHeartbeatAt
    sa <- *startedAt
    presence <- *presence
    forwards <- *forwards
    sessionCount <- *totalSessionCount
    activePolls <- *activePolls
    tmc <- *totalMessageCount
    lastFedSuccess <- *lastFederationSuccessAt
    forwardFailures <- *forwardFailures
    pruneRun <- *pruneRunning
    let warmup = t - sa < healthPruneMaxAge
    let pruneStuck = pruneRun > 0 && t - pruneRun > backgroundPruneInterval * 2
    -- Capacity pressure: flag when any capped collection exceeds 90% full
    let capacityOk = tmc * 10 <= maxMessages * 9
      && count presence * 10 <= maxPresenceEntries * 9
      && count forwards * 10 <= maxForwardsEntries * 9
      && sessionCount * 10 <= maxSessions * 9
      && count activePolls * 10 <= maxActivePolls * 9
    -- Federation: healthy if disabled, in warmup, no peer issues, or recent success
    let fedOk = not federationEnabled || warmup
      || count forwardFailures == 0
      || (lastFedSuccess > 0 && t - lastFedSuccess < backgroundPruneInterval * 5)
    yield {pruneOk: warmup || (t - lastPrune < healthPruneMaxAge && not pruneStuck),
           heartbeatOk: warmup || t - lastHb < healthHeartbeatMaxAge,
           capacityOk: capacityOk,
           federationOk: fedOk}
  yield (respond {ok: result.pruneOk && result.heartbeatOk && result.capacityOk && result.federationOk,
                  pruneHealthy: result.pruneOk,
                  heartbeatHealthy: result.heartbeatOk,
                  capacityHealthy: result.capacityOk,
                  federationHealthy: result.federationOk})

zeroStats = {sessions: 0, sessionsMax: 0, messages: 0, messagesMax: 0, presence: 0, presenceMax: 0, forwards: 0, forwardsMax: 0, challenges: 0, challengesMax: 0, ackedIds: 0, ackedIdsMax: 0, ackOverflow: 0, ackOverflowMax: 0, deliveredIds: 0, deliveredIdsMax: 0, forwardFailures: 0, activePolls: 0, activePollsMax: 0, sendRates: 0, challengeRates: 0, federationRates: 0, globalRateCount: 0, ipRates: 0, lookupRates: 0, recvRates: 0, pruneCount: 0, pruneRunning: 0, heartbeatCount: 0, uptime: 0, lastPruneAt: 0, lastHeartbeatAt: 0, draining: False {}, federationEnabled: False {}, recentGossip: 0, totalMessageCount: 0, recipientCounts: 0, federationInFlight: 0, messagesPct: 0, presencePct: 0, forwardsPct: 0, sessionsPct: 0, federationAvgLatencyMs: 0, federationMaxLatencyMs: 0, federationCallCount: 0, drainCompletedAt: 0, ok: False {}}

handleStats = \authorization respond -> do
  t <- now
  globalRateLimited <- checkGlobalRate t
  if globalRateLimited then yield (respond zeroStats)
  else do
  let authorized = verifyMaintenanceAuth authorization
  if authorized
    then do
      -- Split into two atomic reads: core capacity state (consistent) and counters/timing
      -- (slight inconsistency acceptable for monitoring). This narrows the lock window.
      core <- atomic do
        sc <- *totalSessionCount
        p <- *presence
        f <- *forwards
        c <- *challenges
        a <- *ackedIds
        ao <- *ackOverflow
        d <- *deliveredIds
        ff <- *forwardFailures
        ap <- *activePolls
        tmc <- *totalMessageCount
        rc <- *recipientMsgCounts
        fi <- *federationInFlight
        rg <- *recentGossip
        yield {sc: sc, p: p, f: f, c: c, a: a, ao: ao, d: d, ff: ff, ap: ap, tmc: tmc, rc: rc, fi: fi, rg: rg}
      counters <- atomic do
        sr <- *sendRates
        cr <- *challengeRates
        fr <- *federationRates
        grc <- *globalRateCount
        ir <- *ipRates
        lr <- *lookupRates
        rr <- *recvRates
        pc <- *pruneCount
        pr <- *pruneRunning
        hc <- *heartbeatCount
        sa <- *startedAt
        lp <- *lastPrunedAt
        lh <- *lastHeartbeatAt
        dr <- *draining
        flt <- *federationLatencyTotal
        flc <- *federationLatencyCount
        flm <- *federationLatencyMax
        dca <- *drainCompletedAt
        yield {sr: sr, cr: cr, fr: fr, grc: grc, ir: ir, lr: lr, rr: rr, pc: pc, pr: pr, hc: hc, sa: sa, lp: lp, lh: lh, dr: dr, flt: flt, flc: flc, flm: flm, dca: dca}
      let result = {sessions: core.sc, messages: core.tmc, presence: count core.p, forwards: count core.f, challenges: count core.c, ackedIds: count core.a, ackOverflow: count core.ao, deliveredIds: count core.d, forwardFailures: count core.ff, activePolls: count core.ap, sendRates: count counters.sr, challengeRates: count counters.cr, federationRates: count counters.fr, globalRateCount: counters.grc, ipRates: count counters.ir, lookupRates: count counters.lr, recvRates: count counters.rr, pruneCount: counters.pc, pruneRunning: counters.pr, heartbeatCount: counters.hc, uptime: t - counters.sa, lastPruneAt: counters.lp, lastHeartbeatAt: counters.lh, draining: counters.dr, recentGossip: count core.rg, totalMessageCount: core.tmc, recipientCounts: count core.rc, federationInFlight: count core.fi, federationLatencyTotal: counters.flt, federationLatencyCount: counters.flc, federationLatencyMax: counters.flm, drainCompletedAt: counters.dca}
      let msgPct = if maxMessages > 0 then result.messages * 100 / maxMessages else 0
      let presPct = if maxPresenceEntries > 0 then result.presence * 100 / maxPresenceEntries else 0
      let fwdPct = if maxForwardsEntries > 0 then result.forwards * 100 / maxForwardsEntries else 0
      let sessPct = if maxSessions > 0 then result.sessions * 100 / maxSessions else 0
      let fedAvg = if result.federationLatencyCount > 0 then result.federationLatencyTotal / result.federationLatencyCount else 0
      yield (respond {sessions: result.sessions, sessionsMax: maxSessions, messages: result.messages, messagesMax: maxMessages, presence: result.presence, presenceMax: maxPresenceEntries, forwards: result.forwards, forwardsMax: maxForwardsEntries, challenges: result.challenges, challengesMax: maxChallenges, ackedIds: result.ackedIds, ackedIdsMax: maxAckedIds, ackOverflow: result.ackOverflow, ackOverflowMax: maxAckOverflow, deliveredIds: result.deliveredIds, deliveredIdsMax: maxDeliveredIds, forwardFailures: result.forwardFailures, activePolls: result.activePolls, activePollsMax: maxActivePolls, sendRates: result.sendRates, challengeRates: result.challengeRates, federationRates: result.federationRates, globalRateCount: result.globalRateCount, ipRates: result.ipRates, lookupRates: result.lookupRates, recvRates: result.recvRates, pruneCount: result.pruneCount, pruneRunning: result.pruneRunning, heartbeatCount: result.heartbeatCount, uptime: result.uptime, lastPruneAt: result.lastPruneAt, lastHeartbeatAt: result.lastHeartbeatAt, draining: result.draining, federationEnabled: federationEnabled, recentGossip: result.recentGossip, totalMessageCount: result.totalMessageCount, recipientCounts: result.recipientCounts, federationInFlight: result.federationInFlight, messagesPct: msgPct, presencePct: presPct, forwardsPct: fwdPct, sessionsPct: sessPct, federationAvgLatencyMs: fedAvg, federationMaxLatencyMs: result.federationLatencyMax, federationCallCount: result.federationLatencyCount, drainCompletedAt: result.drainCompletedAt, ok: True {}})
    else yield (respond zeroStats)

handleStatsPeers = \authorization respond -> do
  t <- now
  globalRateLimited <- checkGlobalRate t
  if globalRateLimited then yield (respond {peers: [], ok: False {}})
  else do
  let authorized = verifyMaintenanceAuth authorization
  if authorized
    then do
      failures <- *forwardFailures
      let peers = do f <- failures; yield {server: f.server, failures: f.failures, lastFailedAt: f.failedAt, firstFailedAt: f.firstFailedAt, backoffMs: retryBackoff f.failures, retriable: shouldRetryServer f.server t failures}
      yield (respond {peers: peers, ok: True {}})
    else yield (respond {peers: [], ok: False {}})

handleStatsKey = \pubkey authorization respond -> do
  t <- now
  globalRateLimited <- checkGlobalRate t
  if globalRateLimited then yield (respond {messages: 0, presence: [], sessions: 0, forwards: 0, activePolls: 0, ok: False {}})
  else do
  let authorized = verifyMaintenanceAuth authorization
  if authorized
    then do
      result <- atomic do
        keyBucket <- readMessageBucket (pubkeyBucket pubkey)
        presence <- *presence
        allSessions <- readAllSessions
        forwards <- *forwards
        activePolls <- *activePolls
        let keyMessages = count (do m <- keyBucket; where m.toKey == pubkey; yield m)
        let keyPresence = do p <- presence; where p.pubkey == pubkey && p.expiresAt > t; yield {server: p.server, expiresAt: p.expiresAt}
        let keySessions = count (do s <- allSessions; where s.pubkey == pubkey; yield s)
        let keyForwards = count (do f <- forwards; where f.toKey == pubkey; yield f)
        let keyPolls = count (do p <- activePolls; where p.pubkey == pubkey; yield p)
        yield {messages: keyMessages, presence: keyPresence, sessions: keySessions, forwards: keyForwards, activePolls: keyPolls}
      yield (respond {messages: result.messages, presence: result.presence, sessions: result.sessions, forwards: result.forwards, activePolls: result.activePolls, ok: True {}})
    else yield (respond {messages: 0, presence: [], sessions: 0, forwards: 0, activePolls: 0, ok: False {}})

serve = \req -> case req of
  ReqChallenge {pubkey, clientIp, respond} -> handleChallenge pubkey clientIp respond
  VerifyAuth {pubkey, challenge, signature, revokeOthers, clientIp, respond} -> handleVerifyAuth pubkey challenge signature revokeOthers clientIp respond
  RevokeSession {targetToken, authorization, clientIp, respond} -> handleRevoke targetToken authorization clientIp respond
  Logout {authorization, clientIp, respond} -> handleLogout authorization clientIp respond
  Poll {cursor, generation, watchKeys, authorization, clientIp, respond} -> handlePoll cursor generation watchKeys authorization clientIp respond
  SendMessage {to, encryptedBlob, timestamp, messageId, authorization, clientIp, respond} -> handleSendMessage to encryptedBlob timestamp messageId authorization clientIp respond
  MessageStatus {to, messageId, authorization, clientIp, respond} -> handleMessageStatus to messageId authorization clientIp respond
  LookupPresence {pubkey, authorization, clientIp, respond} -> handleLookupPresence pubkey authorization clientIp respond
  RecvGossip {events, hopsRemaining, fromServer, authorization, respond} -> handleRecvGossip events hopsRemaining fromServer authorization respond
  ForwardMessage {toKey, encryptedBlob, timestamp, originServer, messageId, fromServer, authorization, respond} -> handleForwardMessage toKey encryptedBlob timestamp originServer messageId fromServer authorization respond
  FederationAck {messageIds, originServer, fromServer, authorization, respond} -> handleFederationAck messageIds originServer fromServer authorization respond
  Prune {authorization, respond} -> handlePrune authorization respond
  Drain {authorization, respond} -> handleDrain authorization respond
  Undrain {authorization, respond} -> handleUndrain authorization respond
  Health {respond} -> handleHealth respond
  Stats {authorization, respond} -> handleStats authorization respond
  StatsPeers {authorization, respond} -> handleStatsPeers authorization respond
  StatsKey {pubkey, authorization, respond} -> handleStatsKey pubkey authorization respond

-- ============================================
-- Entry Point
-- ============================================

-- Background loop: periodically prunes expired state and retries pending federation ops.
-- Jitter prevents thundering herd when multiple servers restart simultaneously.
backgroundPrune = do
  jitter <- randomInt 5000
  sleep (backgroundPruneInterval + jitter)
  draining <- *draining
  if draining then do
    sleep backgroundPruneInterval
    backgroundPrune
  else do
  t <- now
  -- Heartbeat watchdog: bump pollWakeup if heartbeat loop appears dead
  sa <- *startedAt
  lastHb <- *lastHeartbeatAt
  when (t - sa > healthHeartbeatMaxAge && t - lastHb > healthHeartbeatMaxAge) (do
    println "backgroundPrune: heartbeat appears dead, bumping pollWakeup"
    atomic do
      set *pollWakeup = t
      set *lastHeartbeatAt = t)
  status <- atomic do
    running <- *pruneRunning
    if running > 0 && t - running < backgroundPruneInterval * 2
      then yield {canRun: False {}, recovered: False {}, gen: 0, stuckSince: 0}
      else do
        set *pruneRunning = t
        gen <- *pruneGeneration
        let newGen = gen + 1
        set *pruneGeneration = newGen
        pc <- *pruneCount
        set *pruneCount = pc + 1
        yield {canRun: True {}, recovered: running > 0, gen: newGen, stuckSince: running}
  when status.recovered
    (println ("backgroundPrune: previous cycle stuck for " ++ show (t - status.stuckSince) ++ "ms, forcing recovery"))
  if status.canRun
    then do
      -- Guard against unbounded concurrent prune forks from repeated stuck recovery
      forks <- *activePruneForks
      if forks >= 2
        then println "backgroundPrune: skipping (max concurrent prune forks reached)"
        else do
          atomic do
            af <- *activePruneForks
            set *activePruneForks = af + 1
          fork (do
            pruneAndRetry t
            -- Only clear running flag if this is still the latest generation
            -- (prevents a stuck old fork from clearing the flag after a recovery cycle started)
            atomic do
              currentGen <- *pruneGeneration
              when (currentGen == status.gen) (set *pruneRunning = 0)
              af <- *activePruneForks
              set *activePruneForks = max 0 (af - 1))
    else println "backgroundPrune: skipping (previous cycle still running)"
  backgroundPrune

-- Background loop: periodically bumps pollWakeup to unblock long-polls that have been
-- waiting too long (heartbeat). Ensures polls return within pollTimeoutMs even if no messages arrive.
pollHeartbeat = do
  jitter <- randomInt 2000
  sleep (pollTimeoutMs + jitter)
  draining <- *draining
  if draining then do
    t <- now
    atomic do set *pollWakeup = t
    -- Don't exit; sleep and retry so undrain can resume the loop
    sleep pollTimeoutMs
    pollHeartbeat
  else do
    t <- now
    atomic do
      set *pollWakeup = t
      set *lastHeartbeatAt = t
      hc <- *heartbeatCount
      set *heartbeatCount = hc + 1
    pollHeartbeat

main = do
  let configOk = maxMessages > 0 && maxMessagesPerRecipient > 0 && maxPresenceEntries > 0
        && maxSessions > 0 && maxChallenges > 0 && backgroundPruneInterval > 0
        && pollTimeoutMs > 0 && challengeExpiry > 0 && sessionExpiry > 0
        && maxPresenceTtl > 0 && maxForwardsEntries > 0 && maxAckedIds > 0
  let peerSecretsOk = none federationPeerSecrets (\p -> isBadServerName (normalizeServerName p.server) || p.secret == "")
  if not configOk
    then println "FATAL: invalid configuration — capacity limits and intervals must be > 0, server not started"
    else if not peerSecretsOk
    then println "FATAL: invalid federationPeerSecrets — server names must pass validation and secrets must be non-empty"
    else do
      t <- now
      atomic do
        set *startedAt = t
        set *serverGeneration = t
      println "Skrepka relay server starting on port 8080..."
      println ("  federation: " ++ if federationEnabled then "enabled" else "disabled")
      println ("  prune interval: " ++ show backgroundPruneInterval ++ "ms")
      println ("  poll timeout: " ++ show pollTimeoutMs ++ "ms")
      println ("  max messages: " ++ show maxMessages ++ " (per recipient: " ++ show maxMessagesPerRecipient ++ ")")
      println ("  max sessions: " ++ show maxSessions ++ " (per key: " ++ show maxSessionsPerKey ++ ")")
      println ("  max presence: " ++ show maxPresenceEntries)
      println ("  max forwards: " ++ show maxForwardsEntries)
      println ("  session expiry: " ++ show sessionExpiry ++ "ms")
      println ("  message max age: " ++ show messageMaxAge ++ "ms")
      println ("  global rate limit: " ++ show maxGlobalRequestRate ++ "/" ++ show globalRateWindowMs ++ "ms")
      println ("  auth rate limit: " ++ show maxAuthGlobalRate ++ "/" ++ show authGlobalRateWindowMs ++ "ms")
      when (count federationPeerSecrets > 0)
        (println ("  per-peer secrets: " ++ show (count federationPeerSecrets) ++ " configured"))
      fork backgroundPrune
      fork pollHeartbeat
      listen 8080 serve
