-- Round-robin presence refresh: tracks which bucket group (0-3) to scan next.
-- Each refresh cycle scans 4 buckets (0-3, 4-7, 8-11, 12-15), cycling through
-- all 16 over 4 refresh intervals. Spreads gossip traffic across prune cycles.
-- NOTE: group only advances when shouldRefresh is true (enough time passed since
-- lastPresenceRefresh), so skipped/delayed prune cycles don't cause bucket gaps.
*presenceRefreshGroup : Int

-- Round-robin nonce pruning: tracks which bucket group (0-3) to scan next.
-- Each prune cycle scans 4 of 16 nonce buckets, cycling through all 16 over 4 cycles.
-- Nonces have 60-day retention so 30-second pruning granularity is unnecessary.
*noncePruneGroup : Int

*challengeRates : [ChallengeRateEntry]

-- Separate revoke rate limiter (prevents challenge floods from exhausting revoke budget)
*revokeRates : [ChallengeRateEntry]

-- Heartbeat signal: incremented periodically to wake all blocking long-polls
*pollWakeup : Timestamp

-- Per-bucket message signals (16 buckets, keyed by first hex digit of pubkey).
