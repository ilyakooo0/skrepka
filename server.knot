-- ============================================
-- Types
-- ============================================
-- Wire/state shapes plus refinement aliases for hex/server-name validation.
-- Hex types are bounded length + lowercase-hex; server names are lowercased
-- and stripped of trailing dots, with a deny-list filter (`isBadServerName`)
-- applied where SSRF is a concern.

type PollEvent = {id: MessageIdHex, eventType: Text, payload: {encryptedBlob: BlobHex, timestamp: Timestamp, toKey: PubkeyHex, expiresAt: Timestamp}}

data GossipEventType = GossipOnline {} | GossipOffline {} | GossipUnknown {}

impl ToJSON GossipEventType where
  toJson et = toJson (case et of
    GossipOnline {} -> "online"
    GossipOffline {} -> "offline"
    GossipUnknown {} -> "unknown")

impl FromJSON GossipEventType where
  parseJson t =
    let s : Text = parseJson t in
    if s == "online" then GossipOnline {}
    else if s == "offline" then GossipOffline {}
    else GossipUnknown {}

type GossipEvent = {eventType: GossipEventType, pubkey: PubkeyHex, server: ServerName, timestamp: Timestamp, ttl: Int<Ms>, seenBy: [Text]}

data MessageStatus = MsDelivered {} | MsFederated {} | MsQueued {} | MsUnauthorized {} | MsRejected {} | MsRateLimited {} | MsDuplicate {} | MsDraining {}

impl ToJSON MessageStatus where
  toJson ms = toJson (case ms of
    MsDelivered {} -> "delivered"
    MsFederated {} -> "federated"
    MsQueued {} -> "queued"
    MsUnauthorized {} -> "unauthorized"
    MsRejected {} -> "rejected"
    MsRateLimited {} -> "rate_limited"
    MsDuplicate {} -> "duplicate"
    MsDraining {} -> "draining")

isValidBoundedHex : Int -> Text -> Bool
isValidBoundedHex = \maxLen s -> not (tooLong s maxLen) && isValidHex s
type PubkeyHex = Text where isValidBoundedHex maxPubkeyLen
type BlobHex = Text where isValidBoundedHex maxBlobLen
type SignatureHex = Text where isValidBoundedHex maxSignatureLen
isValidMessageId : Text -> Bool
isValidMessageId = isValidBoundedHex maxMessageIdLen
type MessageIdHex = Text where isValidMessageId
type OptionalMessageId = Text where \s -> s == "" || isValidMessageId s
isAnyServerName : Text -> Bool
isAnyServerName = \s -> not (tooLong s maxServerNameLen) && s == normalizeServerName s
isValidServerName : Text -> Bool
isValidServerName = \s -> isAnyServerName s && not (isBadServerName s)
type ServerName = Text where isValidServerName
type AnyServerName = Text where isAnyServerName

type Timestamp = Int<Ms>

type Challenge = {pubkey: PubkeyHex, challenge: Text, expiresAt: Timestamp, ip: Text}
type Session = {token: Text, pubkey: PubkeyHex, expiresAt: Timestamp, ip: Text, createdAt: Timestamp}
type Message = {messageId: MessageIdHex, toKey: PubkeyHex, encryptedBlob: BlobHex, timestamp: Timestamp, originServer: Text, receivedAt: Timestamp, expiresAt: Timestamp, senderKey: Text, priority: Int}
type PresenceEntry = {pubkey: PubkeyHex, server: AnyServerName, expiresAt: Timestamp, timestamp: Timestamp}
type ForwardEntry = {messageId: MessageIdHex, toServer: ServerName, createdAt: Timestamp, toKey: PubkeyHex, encryptedBlob: BlobHex, timestamp: Timestamp, originServer: Text, retries: Int, expiresAt: Timestamp, priority: Int, senderKey: Text}
type AckedEntry = {messageId: MessageIdHex, toKey: PubkeyHex, ackedAt: Timestamp, originServer: ServerName, retries: Int}
type DeliveredEntry = {messageId: MessageIdHex, toKey: PubkeyHex, deliveredAt: Timestamp}
type ForwardFailure = {server: Text, failedAt: Timestamp, failures: Int, firstFailedAt: Timestamp}
type RateEntry = {key: Text, windowStart: Timestamp, count: Int}
type ActivePoll = {pubkey: PubkeyHex, startedAt: Timestamp}

type SenderExpiration = {senderKey: Text, messageId: MessageIdHex, toKey: PubkeyHex, expiredAt: Timestamp}
type SenderDelivery = {senderKey: Text, messageId: MessageIdHex, toKey: PubkeyHex, deliveredAt: Timestamp}
type CancelNotification = {toKey: PubkeyHex, messageId: MessageIdHex, cancelledAt: Timestamp}
type PendingFederationCancel = {messageId: MessageIdHex, toKey: PubkeyHex, toServer: ServerName, createdAt: Timestamp, retries: Int}

type BatchMessage = {to: PubkeyHex, encryptedBlob: BlobHex, timestamp: Timestamp, messageId: OptionalMessageId, expiresInMs: Int, priority: Int}
type BatchResult = {messageId: OptionalMessageId, status: MessageStatus}

type BatchCancelEntry = {messageId: MessageIdHex, to: PubkeyHex}
type BatchCancelResult = {messageId: MessageIdHex, cancelled: Bool}

-- ============================================
-- Persisted State (all flat lists, no sharding)
-- ============================================
-- Mutable refs (`*x`) holding the entire server state in memory. Every list
-- scan is O(n); scaling is the first thing the production version replaces.
-- Grouped here: auth (challenges/sessions), mailbox (messages/forwards/acks),
-- presence, rate-limit windows, drain phase, and bookkeeping counters.

*challenges : [Challenge]
*sessions : [Session]
*messages : [Message]
*presence : [PresenceEntry]
*forwards : [ForwardEntry]
*ackedIds : [AckedEntry]
*deliveredIds : [DeliveredEntry]
*forwardFailures : [ForwardFailure]
*activePolls : [ActivePoll]

*sendRates : [RateEntry]
*recvRates : [RateEntry]
*pairRates : [RateEntry]
*challengeRates : [RateEntry]
*lookupRates : [RateEntry]
*clientWriteRates : [RateEntry]
*federationRates : [RateEntry]
*ipRates : [RateEntry]

*globalRateCount : Int
*globalRateWindowStart : Timestamp
*authGlobalRateCount : Int
*authGlobalRateWindowStart : Timestamp

*seqCounter : Timestamp
*pollWakeup : Timestamp
*lastPrunedAt : Timestamp
*lastHeartbeatAt : Timestamp
*lastPresenceRefresh : Timestamp
*startedAt : Timestamp
*serverGeneration : Int

*drainPhase : Int
*drainCompletedAt : Timestamp

*pendingVerifications : [{token: Text, createdAt: Timestamp, scope: Text}]

*senderExpirations : [SenderExpiration]
*senderDeliveries : [SenderDelivery]
*cancelNotifications : [CancelNotification]
*pendingFederationCancels : [PendingFederationCancel]

*runtimeMaintenanceSecret : Text

*blockedPeers : [Text]
*allowedPeers : [Text]

*pruneCount : Int
*heartbeatCount : Int

-- ============================================
-- Routes (response shapes preserved; removed metric fields are zero-filled)
-- ============================================
-- Public HTTP surface, grouped by audience:
--   AuthApi          -- challenge/verify/revoke/logout (client identity)
--   ClientApi        -- /poll, send/batch/list/ack/delete/cancel, presence lookup
--   FederationApi    -- inter-server gossip, forward, ack, cancel, delivery receipts
--   FederationVerify -- callback used by peers to verify Bearer tokens this server issued
--   FederationPubkey -- exposes this server's federation Ed25519 public key
--   MaintenanceApi   -- operator endpoints (drain, prune, peer allow/block, admin)
--   HealthApi/StatsApi/MetricsApi/ReadyApi -- observability
-- Response field shapes are kept stable for backwards compatibility even when
-- the underlying value is no longer computed (zero-filled).

route AuthApi where
  /auth
    POST {pubkey: PubkeyHex} /challenge headers {clientIp: Text}
      -> {challenge: Text, ok: Bool, expiresAt: Timestamp, retryAfterMs: Int, error: Text}
      = ReqChallenge
    POST {pubkey: PubkeyHex, challenge: Text, signature: SignatureHex, revokeOthers: Bool} /verify headers {clientIp: Text}
      -> {token: Text, expiresAt: Timestamp, error: Text}
      = VerifyAuth
    POST {targetToken: Text} /revoke headers {authorization: Text, clientIp: Text}
      -> {ok: Bool, authorized: Bool}
      = RevokeSession
    POST {} /logout headers {authorization: Text, clientIp: Text}
      -> {ok: Bool, authorized: Bool}
      = Logout

route ClientApi where
  POST {cursor: Timestamp, generation: Int, watchKeys: [PubkeyHex]} /poll headers {authorization: Text, clientIp: Text}
    -> {events: [PollEvent], cursor: Timestamp, authorized: Bool, rateLimited: Bool, draining: Bool, generation: Int, presenceUpdates: [{pubkey: PubkeyHex, online: Bool}], heartbeat: Bool, retryAfterMs: Int, cursorReset: Bool, hasMore: Bool, cursorStale: Bool, messageExpirations: [{messageId: MessageIdHex, toKey: PubkeyHex, expiredAt: Timestamp}], messageDeliveries: [{messageId: MessageIdHex, toKey: PubkeyHex, deliveredAt: Timestamp}], droppedDeliveryReceipts: Int, droppedExpirationNotifs: Int, loadPct: Int, messageCancellations: [{messageId: MessageIdHex, cancelledAt: Timestamp}]}
    = Poll
  /messages
    POST {to: PubkeyHex, encryptedBlob: BlobHex, timestamp: Timestamp, messageId: OptionalMessageId, expiresInMs: Int, priority: Int} / headers {authorization: Text, clientIp: Text}
      -> {status: MessageStatus, messageId: OptionalMessageId, retryAfterMs: Int, error: Text, loadPct: Int}
      = SendMessage
    POST {to: PubkeyHex, messageId: MessageIdHex} /status headers {authorization: Text, clientIp: Text}
      -> {status: Text, authorized: Bool}
      = MessageStatus
    POST {messageIds: [MessageIdHex]} /ack headers {authorization: Text, clientIp: Text}
      -> {ok: Bool, authorized: Bool, ackedCount: Int, error: Text}
      = AckMessages
    POST {messages: [BatchMessage]} /batch headers {authorization: Text, clientIp: Text}
      -> {results: [BatchResult], authorized: Bool, retryAfterMs: Int}
      = SendBatch
    POST {offset: Int} /list headers {authorization: Text, clientIp: Text}
      -> {messages: [{messageId: MessageIdHex, timestamp: Timestamp, receivedAt: Timestamp}], authorized: Bool, count: Int, error: Text}
      = ListMessages
    POST {messageIds: [MessageIdHex]} /delete headers {authorization: Text, clientIp: Text}
      -> {ok: Bool, authorized: Bool, deletedCount: Int, error: Text}
      = DeleteMessages
    POST {messageId: MessageIdHex, to: PubkeyHex} /cancel headers {authorization: Text, clientIp: Text}
      -> {ok: Bool, authorized: Bool, cancelled: Bool, error: Text}
      = CancelMessage
    POST {cancels: [BatchCancelEntry]} /cancel-batch headers {authorization: Text, clientIp: Text}
      -> {results: [BatchCancelResult], authorized: Bool, error: Text}
      = CancelBatch
  GET /lookup/{pubkey: PubkeyHex} headers {authorization: Text, clientIp: Text}
    -> {server: AnyServerName, authorized: Bool, error: Text}
    = LookupPresence
  POST {pubkeys: [PubkeyHex]} /lookup/batch headers {authorization: Text, clientIp: Text}
    -> {results: [{pubkey: PubkeyHex, server: AnyServerName}], authorized: Bool, error: Text}
    = BatchLookupPresence

route FederationApi where
  /federation
    POST {events: [GossipEvent], hopsRemaining: Int, fromServer: ServerName, requestTimestamp: Timestamp, correlationId: Text, protocolVersion: Int} /gossip headers {authorization: Text}
      -> {ok: Bool, error: Text, retryAfterMs: Int}
      = RecvGossip
    POST {toKey: PubkeyHex, encryptedBlob: BlobHex, timestamp: Timestamp, originServer: ServerName, messageId: MessageIdHex, fromServer: ServerName, requestTimestamp: Timestamp, correlationId: Text, expiresAt: Timestamp, priority: Int, protocolVersion: Int} /forward headers {authorization: Text}
      -> {ok: Bool, error: Text, retryAfterMs: Int}
      = ForwardMessage
    POST {messageIds: [MessageIdHex], originServer: ServerName, fromServer: ServerName, requestTimestamp: Timestamp, correlationId: Text, protocolVersion: Int} /ack headers {authorization: Text}
      -> {ok: Bool, error: Text, ackedCount: Int, results: [{messageId: MessageIdHex, found: Bool}], retryAfterMs: Int}
      = FederationAck
    POST {messageId: MessageIdHex, toKey: PubkeyHex, fromServer: ServerName, requestTimestamp: Timestamp, correlationId: Text, protocolVersion: Int} /cancel headers {authorization: Text}
      -> {ok: Bool, error: Text, cancelled: Bool, retryAfterMs: Int}
      = FederationCancel
    POST {cancels: [{messageId: MessageIdHex, toKey: PubkeyHex}], fromServer: ServerName, requestTimestamp: Timestamp, correlationId: Text, protocolVersion: Int} /cancel-batch headers {authorization: Text}
      -> {ok: Bool, error: Text, results: [BatchCancelResult], retryAfterMs: Int}
      = FederationBatchCancel
    POST {forwards: [{toKey: PubkeyHex, encryptedBlob: BlobHex, timestamp: Timestamp, originServer: ServerName, messageId: MessageIdHex, expiresAt: Timestamp, priority: Int}], fromServer: ServerName, requestTimestamp: Timestamp, correlationId: Text, protocolVersion: Int} /forward-batch headers {authorization: Text}
      -> {ok: Bool, error: Text, results: [{messageId: MessageIdHex, ok: Bool}], retryAfterMs: Int}
      = FederationBatchForward
    POST {messageIds: [MessageIdHex], toKeys: [PubkeyHex], fromServer: ServerName, requestTimestamp: Timestamp, correlationId: Text, protocolVersion: Int} /delivery-receipt headers {authorization: Text}
      -> {ok: Bool, error: Text, receivedCount: Int, retryAfterMs: Int}
      = FederationDeliveryReceipt

route FederationVerifyApi where
  POST {token: Text, scope: Text} /federation/verify headers {clientIp: Text} -> {ok: Bool} = VerifyToken

route FederationPubkeyApi where
  GET /federation/pubkey -> {pubkey: Text, ok: Bool} = FederationPubkey

route MaintenanceApi where
  POST {} /maintenance/prune headers {authorization: Text}
    -> {ok: Bool}
    = Prune
  POST {phase: Int} /maintenance/drain headers {authorization: Text}
    -> {ok: Bool, drained: Int, phase: Int}
    = Drain
  POST {} /maintenance/undrain headers {authorization: Text}
    -> {ok: Bool}
    = Undrain
  POST {} /maintenance/shutdown headers {authorization: Text}
    -> {ok: Bool, drained: Int}
    = Shutdown
  POST {server: ServerName} /maintenance/block headers {authorization: Text}
    -> {ok: Bool, blocked: Int}
    = BlockPeer
  POST {server: ServerName} /maintenance/unblock headers {authorization: Text}
    -> {ok: Bool, unblocked: Bool}
    = UnblockPeer
  GET /maintenance/blocked headers {authorization: Text}
    -> {peers: [Text], ok: Bool}
    = ListBlocked
  POST {server: ServerName} /maintenance/ping headers {authorization: Text}
    -> {ok: Bool, latencyMs: Int, error: Text}
    = PingPeer
  GET /maintenance/sessions/{pubkey: PubkeyHex} headers {authorization: Text}
    -> {sessions: [{token: Text, expiresAt: Timestamp, ip: Text, createdAt: Timestamp}], count: Int, ok: Bool}
    = AdminListSessions
  POST {pubkey: PubkeyHex} /maintenance/sessions/revoke-all headers {authorization: Text}
    -> {ok: Bool, revokedCount: Int}
    = AdminRevokeSessions
  POST {pubkey: PubkeyHex} /maintenance/messages/purge headers {authorization: Text}
    -> {ok: Bool, purgedCount: Int}
    = AdminPurgeMessages
  POST {ip: Text} /maintenance/sessions/revoke-ip headers {authorization: Text}
    -> {ok: Bool, revokedCount: Int, affectedKeys: Int}
    = AdminRevokeIp
  POST {limit: Int} /maintenance/sessions/list headers {authorization: Text}
    -> {sessions: [{pubkey: PubkeyHex, count: Int, ips: [Text], latestExpiry: Timestamp}], ok: Bool, total: Int}
    = AdminListAllSessions
  GET /maintenance/rate-limits headers {authorization: Text}
    -> {ok: Bool, globalRequest: Int, ipRate: Int, sendRate: Int, federationRate: Int, authGlobal: Int, recvRate: Int, challengeRate: Int, pairRate: Int, lookupRate: Int, clientWriteRate: Int}
    = GetRateLimits
  POST {globalRequest: Int, ipRate: Int, sendRate: Int, federationRate: Int, authGlobal: Int, recvRate: Int, challengeRate: Int, pairRate: Int, lookupRate: Int, clientWriteRate: Int} /maintenance/rate-limits headers {authorization: Text}
    -> {ok: Bool}
    = SetRateLimits
  POST {} /maintenance/nonces/flush headers {authorization: Text}
    -> {ok: Bool, flushedCount: Int}
    = FlushNonces
  POST {server: ServerName} /maintenance/allow headers {authorization: Text}
    -> {ok: Bool, allowed: Int}
    = AllowPeer
  POST {server: ServerName} /maintenance/unallow headers {authorization: Text}
    -> {ok: Bool, removed: Bool}
    = UnallowPeer
  GET /maintenance/allowed headers {authorization: Text}
    -> {peers: [Text], ok: Bool}
    = ListAllowed
  POST {} /maintenance/reconcile headers {authorization: Text}
    -> {ok: Bool, messageDrift: Int, presenceDrift: Int, sessionDrift: Int}
    = Reconcile
  POST {newSecret: Text} /maintenance/rotate-secret headers {authorization: Text}
    -> {ok: Bool, error: Text}
    = RotateSecret
  GET /maintenance/config headers {authorization: Text}
    -> {ok: Bool, maxMessagesPerRecipient: Int, maxGossipHops: Int, pollTimeoutMs: Int, ackGracePeriod: Int}
    = GetConfig

route HealthApi where
  GET /health headers {authorization: Text} -> {ok: Bool, version: Text, pruneHealthy: Bool, heartbeatHealthy: Bool, capacityHealthy: Bool, capacityWarning: Bool, federationHealthy: Bool, watchdogHealthy: Bool, nonceHealthy: Bool, forwardQueueHealthy: Bool, requestPressureHealthy: Bool, draining: Bool, degradedPeers: Int} = Health

type PeerStatus = {server: Text, failures: Int, lastFailedAt: Timestamp, firstFailedAt: Timestamp, backoffMs: Int, retriable: Bool, pendingForwards: Int, avgLatencyMs: Int, maxLatencyMs: Int, latencySamples: Int, gossipEventsPerMin: Int}
type KeyPresenceEntry = {server: Text, expiresAt: Timestamp}
type RecipientCount = {pubkey: PubkeyHex, count: Int}

route StatsApi where
  GET /stats headers {authorization: Text}
    -> {ok: Bool, version: Text, capacity: {sessions: Int, sessionsMax: Int, sessionsPct: Int, messages: Int, messagesMax: Int, messagesPct: Int, totalMessageCount: Int, presence: Int, presenceMax: Int, presencePct: Int, forwards: Int, forwardsMax: Int, forwardsPct: Int, challenges: Int, challengesMax: Int, ackedIds: Int, ackedIdsMax: Int, ackOverflow: Int, ackOverflowMax: Int, deliveredIds: Int, deliveredIdsMax: Int, forwardNonces: Int, forwardNoncesMax: Int, nonceEvictions: Int, activePolls: Int, activePollsMax: Int, recipientCounts: Int, messageBucketMax: Int, messageBucketMin: Int}, federation: {enabled: Bool, inFlight: Int, hungSlots: Int, avgLatencyMs: Int, maxLatencyMs: Int, callCount: Int, slowVerifies: Int, verifyFailures: Int, forwardFailures: Int, oldestForwardAge: Int, oldestAckAge: Int, recentGossip: Int, blockedPeers: Int, drainCompletedAt: Timestamp, forwardServers: Int, maxForwardQueueDepth: Int, topFailingPeers: [{server: Text, failures: Int}], pendingCancels: Int, gossipSuccess: Int, gossipFail: Int, latencyBuckets: {lt100: Int, lt500: Int, lt2000: Int, gte2000: Int}}, rates: {send: Int, challenge: Int, federation: Int, federationPair: Int, global: Int, ip: Int, lookup: Int, recv: Int, pair: Int, gossipEvent: Int, verifyIp: Int, uniqueKeyIp: Int, pendingAckCleanups: Int, senderExpirations: Int, senderDeliveries: Int, rejectedGlobal: Int, rejectedIp: Int, rejectedAuth: Int, rejectedPerKey: Int, rejectedFederation: Int, clientCancels: Int, federationCancels: Int}, timing: {pruneCount: Int, pruneRunning: Timestamp, heartbeatCount: Int, uptime: Int, lastPruneAt: Timestamp, lastHeartbeatAt: Timestamp, draining: Bool, drainPhase: Int, totalEntries: Int, activeRequests: Int, peakActiveRequests: Int, pollAvgMs: Int, pollMaxMs: Int, pollCount: Int, pollLatencyBuckets: {lt50: Int, lt200: Int, lt1000: Int, gte1000: Int}, sendAvgMs: Int, sendMaxMs: Int, sendCount: Int, sendLatencyBuckets: {lt50: Int, lt200: Int, lt1000: Int, gte1000: Int}, authAvgMs: Int, authMaxMs: Int, authCount: Int}}
    = Stats
  GET /stats/peers headers {authorization: Text}
    -> {peers: [PeerStatus], ok: Bool}
    = StatsPeers
  GET /stats/key/{pubkey: PubkeyHex} headers {authorization: Text}
    -> {messages: Int, presence: [KeyPresenceEntry], sessions: Int, forwards: Int, forwardDetails: [{server: Text, retries: Int, createdAt: Timestamp}], activePolls: Int, ok: Bool}
    = StatsKey
  POST {limit: Int} /stats/top-recipients headers {authorization: Text}
    -> {recipients: [RecipientCount], ok: Bool, total: Int}
    = TopRecipients
  GET /stats/forwards headers {authorization: Text}
    -> {servers: [{server: Text, count: Int, oldestAge: Int, totalRetries: Int}], ok: Bool, total: Int}
    = StatsForwards
  GET /stats/rates headers {authorization: Text}
    -> {ok: Bool, scalePct: Int, globalRequest: Int, ipRate: Int, sendRate: Int, federationRate: Int, authGlobal: Int, recvRate: Int, challengeRate: Int, pairRate: Int, lookupRate: Int, clientWriteRate: Int}
    = StatsRates

route MetricsApi where
  GET /metrics headers {authorization: Text} -> {metrics: Text, ok: Bool} = Metrics

route ReadyApi where
  GET /ready -> {ready: Bool} = Ready

route Api = AuthApi | ClientApi | FederationApi | FederationVerifyApi | FederationPubkeyApi | MaintenanceApi | HealthApi | StatsApi | MetricsApi | ReadyApi

-- ============================================
-- Generic helpers
-- ============================================
-- List/predicate combinators (filter/any/none/findFirst/...), token generation,
-- and small text/server-name utilities used throughout the rest of the file.
-- Everything is intentionally O(n) over flat lists; performance is sacrificed
-- for clarity per the file header.

filter : (a b) -> (b -> Bool) -> (a b)
filter = \xs pred -> do x <- xs; where pred x; yield x
removeWhere : (a b) -> (b -> Bool) -> (a b)
removeWhere = \xs pred -> filter xs (\x -> not (pred x))
pluck : (a b) -> (b -> c) -> (a c)
pluck = \xs f -> do x <- xs; yield (f x)
mapWhere : (a b) -> (b -> Bool) -> (b -> c) -> (a c)
mapWhere = \xs pred -> pluck (filter xs pred)
countWhere : (a b) -> (b -> Bool) -> Int
countWhere = \xs pred -> count (filter xs pred)
any : [a] -> (a -> Bool) -> Bool
any = \xs pred -> countWhere xs pred > 0
none : [a] -> (a -> Bool) -> Bool
none = \xs pred -> not (any xs pred)
all : [a] -> (a -> Bool) -> Bool
all = \xs pred -> none xs (\x -> not (pred x))
elem : [a] -> a -> Bool
elem = \xs x -> any xs (\y -> y == x)
findFirst : [a] -> (a -> Bool) -> Maybe a
findFirst = \xs pred -> headOf (filter xs pred)
when : Bool -> IO {} {} -> IO {} {}
when = \cond action -> if cond then action else yield {}
min : a -> a -> a
min = \a b -> if a < b then a else b
max : a -> a -> a
max = \a b -> if a > b then a else b
clamp : a -> a -> a -> a
clamp = \lo hi x -> max lo (min hi x)
abs : Int -> Int
abs = \x -> if x < 0 then 0 - x else x

-- Dedup: keeps first occurrence (O(n^2)).
unique : [a] -> [a]
unique = fold (\acc x -> if elem acc x then acc else union acc [x]) []

-- Pair each element with its 0-based index.
withIndex : [a] -> [{i: Int, v: a}]
withIndex = fold (\acc x -> union acc [{i: count acc, v: x}]) []

headOf : [a] -> Maybe a
headOf = \items -> fold (\_ x -> Just {value: x}) Nothing {} (takeRelation 1 items)

-- Cap to maxN by dropping the smallest-key entries (LRU-style). Always sorts.
capList : [a] -> Int -> (a -> b) -> [a]
capList = \items maxN getKey -> dropRelation (max 0 (count items - maxN)) (sortBy getKey items)

-- Integer percentage with zero-denominator guard.
pct : Int -> Int -> Int
pct = \cur maxN -> if maxN > 0 then cur * 100 / maxN else 0

-- Common ack/delete tail: pull matching messages, drop them and their forwards.
removeForKey : (forall a. {toKey: PubkeyHex, messageId: MessageIdHex | a} -> Bool) -> IO {} [Message]
removeForKey = \pred -> do
  msgs <- *messages
  fwds <- *forwards
  set *messages = removeWhere msgs pred
  set *forwards = removeWhere fwds pred
  yield (filter msgs pred)

-- Cap pred-matching entries to maxN-1 (caller adds one more).
capPerKey : [a] -> (a -> Bool) -> Int -> (a -> b) -> [a]
capPerKey = \items pred maxN getKey ->
  union (removeWhere items pred) (capList (filter items pred) (maxN - 1) getKey)

-- Shared empty/error shape for /poll. Only a few fields ever vary.
emptyPollResp : Timestamp -> Bool -> Bool -> Bool -> Int -> Int -> Bool -> {events: [PollEvent], cursor: Timestamp, authorized: Bool, rateLimited: Bool, draining: Bool, generation: Int, presenceUpdates: [{pubkey: PubkeyHex, online: Bool}], heartbeat: Bool, retryAfterMs: Int, cursorReset: Bool, hasMore: Bool, cursorStale: Bool, messageExpirations: [{messageId: MessageIdHex, toKey: PubkeyHex, expiredAt: Timestamp}], messageDeliveries: [{messageId: MessageIdHex, toKey: PubkeyHex, deliveredAt: Timestamp}], droppedDeliveryReceipts: Int, droppedExpirationNotifs: Int, loadPct: Int, messageCancellations: [{messageId: MessageIdHex, cancelledAt: Timestamp}]}
emptyPollResp = \cursor authorized rateLimited draining gen retryAfterMs cursorWasReset ->
  {events: [], cursor: cursor, authorized: authorized, rateLimited: rateLimited, draining: draining, generation: gen, presenceUpdates: [], heartbeat: False {}, retryAfterMs: retryAfterMs, cursorReset: cursorWasReset, hasMore: False {}, cursorStale: False {}, messageExpirations: [], messageDeliveries: [], droppedDeliveryReceipts: 0, droppedExpirationNotifs: 0, loadPct: 0, messageCancellations: []}

-- Shared error shape for /messages send.
sendErrResp : MessageStatus -> Text -> {status: MessageStatus, messageId: OptionalMessageId, retryAfterMs: Int, error: Text, loadPct: Int}
sendErrResp = \status err -> {status: status, messageId: "", retryAfterMs: 0, error: err, loadPct: 0}

-- True when a send produced (or matched) a deliverable message.
isSendSuccess : MessageStatus -> Bool
isSendSuccess = \s -> case s of
  MsDelivered {} -> True {}
  MsFederated {} -> True {}
  MsQueued {} -> True {}
  MsDuplicate {} -> True {}
  _ -> False {}

-- Sequence an IO action over each item, in order.
forEach : [a] -> (a -> IO {} {}) -> IO {} {}
forEach = \items action -> case single (takeRelation 1 items) of
  Nothing {} -> yield {}
  Just {value: x} -> do action x; forEach (dropRelation 1 items) action

-- Like forEach, but collects each action's result into a list.
mapEach : [a] -> (a -> IO {} b) -> IO {} [b]
mapEach = \items action -> case headOf items of
  Nothing {} -> yield []
  Just {value: x} -> do
    r <- action x
    rest <- mapEach (dropRelation 1 items) action
    yield (union [r] rest)

-- Hex tokens: one random hex char per recursive call.
genTokenN : Int -> IO {} Text
genTokenN = \n -> if n <= 0 then yield "" else do
  d <- randomInt 16
  rest <- genTokenN (n - 1)
  yield (take 1 (drop d "0123456789abcdef") ++ rest)

genToken : IO {} Text
genToken = genTokenN 48

-- Use the supplied message id when non-empty, otherwise generate a fresh one.
resolveMessageId : OptionalMessageId -> IO {} OptionalMessageId
resolveMessageId = \mid -> if mid != "" then yield mid else genToken

tooLong : Text -> Int -> Bool
tooLong = \s maxLen -> count (chars s) > maxLen

isValidHex : Text -> Bool
isValidHex = \s ->
  let cs = chars s in
  let n = count cs in
  n > 0 && n / 2 * 2 == n && all cs (\c -> contains c "0123456789abcdef")

stripTrailingDot : Text -> Text
stripTrailingDot = \s -> if containsSuffix "." s then stripTrailingDot (take (count (chars s) - 1) s) else s

normalizeServerName : Text -> Text
normalizeServerName = \s -> toLower (stripTrailingDot s)

serverHostN : Text
serverHostN = normalizeServerName serverHost
isLocalServer : Text -> Bool
isLocalServer = \s -> s == serverHostN
isRemote : Text -> Bool
isRemote = \s -> not (isLocalServer s)

hasPrefix : Text -> Text -> Bool
hasPrefix = \pre s -> take (count (chars pre)) s == pre

containsSuffix : Text -> Text -> Bool
containsSuffix = \suffix s -> drop (max 0 (count (chars s) - count (chars suffix))) s == suffix

-- Block private/reserved/internal hostnames (SSRF defense). Skips obscure encoding
-- tricks (octal, hex, percent-encoding) but covers the high-value cases.
isBadServerName : Text -> Bool
isBadServerName = \sn ->
  sn == "" || sn == "localhost"
  || not (all (chars sn) (\c -> contains c "0123456789abcdefghijklmnopqrstuvwxyz-.:"))
  || any [".", ":", "[", "127.", "10.", "192.168.", "169.254.", "0.", "::"] (\p -> hasPrefix p sn)
  || any [".localhost", ".local", ".internal", ".arpa", ".onion"] (\s -> containsSuffix s sn)

-- ============================================
-- Auth helpers
-- ============================================
-- Bearer token extraction, session lookup, maintenance secret check, and the
-- `gateAuth`/`gateClientWrite`/`gateLookup` combinators that every client
-- handler funnels through (drain → global rate → per-key rate → session).
-- Federation requests use a separate path (`withFederationAuth`) supporting
-- both Ed25519-signed and callback-Bearer auth.

-- Plain ip match (sessions with empty ip skip the check).
matchIp : Text -> Text -> Bool
matchIp = \clientIp sessionIp -> sessionIp == "" || clientIp == sessionIp

extractToken : Text -> Maybe Text
extractToken = \h ->
  if hasPrefix "Bearer " h && drop 7 h != "" then Just {value: drop 7 h} else Nothing {}

verifyMaintenanceAuth : Text -> IO {} Bool
verifyMaintenanceAuth = \authorization -> do
  secret <- *runtimeMaintenanceSecret
  yield (secret != "" && extractToken authorization == Just {value: secret})

withMaintAuth : Text -> IO {} a -> IO {} a -> IO {} a
withMaintAuth = \authorization onUnauth onAuth -> do
  authorized <- verifyMaintenanceAuth authorization
  if authorized then onAuth else onUnauth

-- Common gate for handlers: optional drain check, global rate, session auth.
-- mkErr is called with one of: "draining", "rate_limited", "unauthorized".
gateAuth : Bool -> Text -> Text -> Timestamp -> (resp -> ret) -> (Text -> resp) -> (PubkeyHex -> IO {} ret) -> IO {} ret
gateAuth = \checkDrain auth ip t respond mkErr onAuth -> do
  dp <- *drainPhase
  g <- checkGlobalRate t
  let err = \e -> yield (respond (mkErr e))
  if checkDrain && dp >= 2 then err "draining"
  else if g then err "rate_limited"
  else withSessionAuth auth t ip (err "unauthorized") onAuth

-- gateAuth + per-key rate gate. `rateResp` is the response value when the per-key gate trips.
gateClientWrite : Text -> Text -> Timestamp -> (resp -> ret) -> (Text -> resp) -> resp -> (PubkeyHex -> IO {} ret) -> IO {} ret
gateClientWrite = \auth ip t respond mkErr rateResp onAuth ->
  gateAuth (True {}) auth ip t respond mkErr (\pk -> do
    lim <- atomic do
      rates <- *clientWriteRates
      let r = checkRate rates pk maxClientWriteRatePerKey clientWriteRateWindowMs t
      set *clientWriteRates = r.entries
      yield r.limited
    if lim then yield (respond rateResp) else onAuth pk)

gateLookup : Text -> Text -> Timestamp -> (resp -> ret) -> (Text -> resp) -> resp -> (PubkeyHex -> IO {} ret) -> IO {} ret
gateLookup = \auth ip t respond mkErr rateResp onAuth ->
  gateAuth (False {}) auth ip t respond mkErr (\pk -> do
    lim <- atomic do
      rates <- *lookupRates
      let r = checkRate rates pk maxLookupRatePerKey lookupRateWindowMs t
      set *lookupRates = r.entries
      yield r.limited
    if lim then yield (respond rateResp) else onAuth pk)

withSessionAuth : Text -> Int<Ms> -> Text -> a -> (PubkeyHex -> a) -> a
withSessionAuth = \authorization t clientIp onUnauth onAuth ->
  case extractToken authorization of
    Nothing {} -> onUnauth
    Just {value: token} -> do
      ses <- *sessions
      case findFirst ses (\s -> s.expiresAt > t && s.token == token && matchIp clientIp s.ip) of
        Just {value: s} -> onAuth s.pubkey
        _ -> onUnauth

generateFederationAuth : Text -> Timestamp -> IO {network} Text
generateFederationAuth = \scope requestTimestamp ->
  if serverFederationPrivateKeyHex != ""
    then do
      nonce <- genTokenN 48
      yield ("Signed " ++ bytesToHex (sign (bytesFromHex serverFederationPrivateKeyHex) (textToBytes (scope ++ "|" ++ show requestTimestamp ++ "|" ++ serverHostN ++ "|" ++ nonce))) ++ ":" ++ nonce)
    else do
      token <- genToken
      t <- now
      atomic do
        cur <- *pendingVerifications
        set *pendingVerifications = capList (union cur [{token: token, createdAt: t, scope: scope}]) maxPendingVerifications (\p -> p.createdAt)
      yield ("Bearer " ++ token)

-- Verify a federation request: signed (Ed25519 over scope|ts|fromServer|nonce) or callback Bearer token.
verifyFederationAuth : Text -> Text -> Text -> a -> IO {network} {} Bool
verifyFederationAuth = \authorization fromServer scope requestTimestamp -> do
  if hasPrefix "Signed " authorization then do
    let payload = drop 7 authorization
    if payload == "" || tooLong payload (maxSignatureLen + 25) then yield False {}
    else do
      -- Split payload on first ':' into {sig, nonce}.
      let cs = chars payload
      let sepIdx = case findFirst (withIndex cs) (\p -> p.v == ":") of
            Just {value: p} -> p.i
            _ -> count cs
      let sig = take sepIdx payload
      let nonce = drop (sepIdx + 1) payload
      result <- fetch (federationUrl fromServer) (FederationPubkey {})
      case result of
        Ok {value: r} -> yield (r.ok && r.pubkey != "" && verify (bytesFromHex r.pubkey) (textToBytes (scope ++ "|" ++ show requestTimestamp ++ "|" ++ fromServer ++ (if nonce == "" then "" else "|" ++ nonce))) (bytesFromHex sig))
        _ -> yield False {}
  else case extractToken authorization of
    Just {value: token} -> do
      result <- fetch (federationUrl fromServer) (VerifyToken {token: token, scope: scope, clientIp: ""})
      case result of Ok {value: r} -> yield r.ok; _ -> yield False {}
    _ -> yield False {}

withFederationAuth : Text -> Timestamp -> ({ok: Bool, error: Text, retryAfterMs: Int} -> ret) -> Text -> Text -> Timestamp -> Bool -> IO {network} ret -> IO {network} ret
withFederationAuth = \authorization t respond fromServer scope requestTimestamp precondition action -> do
  blocked <- *blockedPeers
  allowed <- *allowedPeers
  let err = \e r -> yield (respond {ok: False {}, error: e, retryAfterMs: r})
  let preErr =
        if elem blocked fromServer then "blocked"
        else if count allowed > 0 && not (elem allowed fromServer) then "not_allowed"
        else if not precondition then "invalid_request"
        else if requestTimestamp > 0 && abs (requestTimestamp - t) > clockSkewTolerance then "clock_skew"
        else ""
  if preErr != "" then err preErr 0
  else do
    verified <- verifyFederationAuth authorization fromServer scope requestTimestamp
    if not verified then err "unauthorized" 0
    else do
      limited <- checkServerRateGate fromServer t
      if limited then err "rate_limited" federationRateWindowMs
      else action

-- ============================================
-- Rate limiting (plain count-per-window, no sliding interpolation)
-- ============================================
-- Two flavors of fixed-window counters:
--   * Per-key (`checkRate`) — keyed by pubkey, ip, server, or pair string;
--     entries live in a `RateEntry` list ref capped at 5000 with LRU eviction.
--   * Global (`checkGlobalRate`/`checkAuthGlobalRate`) — single counter+windowStart
--     pair, used for the request-wide and auth-wide ceilings.
-- `authPreCheck` composes drain + global + ip + auth-global into a one-shot
-- gate for unauthenticated handlers (challenge/verify).

-- Returns {limited, entries}. Increments count when the key fits within the window.
checkRate : [RateEntry] -> Text -> Int -> Int<Ms> -> Timestamp -> {limited: Bool, entries: [RateEntry]}
checkRate = \entries key maxRate windowMs t ->
  let cur = case findFirst entries (\r -> r.key == key && t - r.windowStart < windowMs) of
        Just {value: r} -> {windowStart: r.windowStart, count: r.count + 1}
        _ -> {windowStart: t, count: 1} in
  if cur.count > maxRate
    then {limited: True {}, entries: entries}
    else {limited: False {}, entries: capList (union (removeWhere entries (\x -> x.key == key)) [{key: key, windowStart: cur.windowStart, count: cur.count}]) 5000 (\r -> r.windowStart)}

checkGlobalRate : Int<Ms> -> IO {} Bool
checkGlobalRate = \t -> atomic do
  ws <- *globalRateWindowStart
  c <- *globalRateCount
  if t - ws >= globalRateWindowMs then do
    set *globalRateWindowStart = t
    set *globalRateCount = 1
    yield False {}
  else if c >= maxGlobalRequestRate then yield True {}
  else do
    set *globalRateCount = c + 1
    yield False {}

checkAuthGlobalRate : Int<Ms> -> IO {} Bool
checkAuthGlobalRate = \t -> atomic do
  ws <- *authGlobalRateWindowStart
  c <- *authGlobalRateCount
  if t - ws >= authGlobalRateWindowMs then do
    set *authGlobalRateWindowStart = t
    set *authGlobalRateCount = 1
    yield False {}
  else if c >= maxAuthGlobalRate then yield True {}
  else do
    set *authGlobalRateCount = c + 1
    yield False {}

checkIpRateGate : Text -> Timestamp -> IO {} Bool
checkIpRateGate = \ip t ->
  if ip == "" then yield False {}
  else atomic do
    rates <- *ipRates
    let r = checkRate rates ip maxIpRatePerIp ipRateWindowMs t
    set *ipRates = r.entries
    yield r.limited

checkServerRateGate : Text -> Int -> IO {} Bool
checkServerRateGate = \server t -> atomic do
  rates <- *federationRates
  let r = checkRate rates server maxFederationRatePerServer federationRateWindowMs t
  set *federationRates = r.entries
  yield r.limited

-- Pre-auth gate: drain + global + ip + auth-global. Returns "" when ok, else an error code.
authPreCheck : Text -> Timestamp -> IO {} Text
authPreCheck = \clientIp t -> do
  dp <- *drainPhase
  g <- checkGlobalRate t
  i <- checkIpRateGate clientIp t
  a <- checkAuthGlobalRate t
  yield (if dp >= 1 then "draining"
    else if g then "global_rate_limited"
    else if i then "ip_rate_limited"
    else if a then "auth_rate_limited"
    else "")

-- ============================================
-- Federation failure tracking (simple, no circuit breaker)
-- ============================================
-- Linear backoff per peer: each consecutive failure multiplies the delay by
-- `retryBackoffBase` (capped at `retryBackoffMax`). `shouldRetryServer` is the
-- single read-side gate; `recordFailure`/`clearFailure` are the write side.
-- There is no half-open state — a single success clears all accumulated failures.

retryBackoff : Int -> Int<Ms>
retryBackoff = \failures -> min retryBackoffMax (retryBackoffBase * max 1 failures)

shouldRetryServer : Text -> Timestamp -> [ForwardFailure] -> Bool
shouldRetryServer = \server t failures ->
  none failures (\f -> f.server == server && t - f.failedAt < retryBackoff f.failures)

recordFailure : Text -> IO {} {}
recordFailure = \server -> do
  t <- now
  atomic do
    failures <- *forwardFailures
    let same = \f -> f.server == server
    let prev = case findFirst failures same of
          Just {value: f} -> {failures: f.failures + 1, firstFailedAt: f.firstFailedAt}
          _ -> {failures: 1, firstFailedAt: t}
    set *forwardFailures = union (removeWhere failures same)
      [{server: server, failedAt: t, failures: prev.failures, firstFailedAt: prev.firstFailedAt}]

clearFailure : Text -> IO {} {}
clearFailure = \server -> atomic do
  forwardFailures <- *forwardFailures
  set *forwardFailures = filter forwardFailures (\f -> f.server != server)

-- ============================================
-- Common utility queries
-- ============================================
-- Pure helpers shared by send/poll/federation paths: TTL/timestamp clamping,
-- monotonic sequence generation, presence lookup, duplicate detection across
-- (messages, ackedIds, deliveredIds), and last-write-wins presence merge.

clampTtl : Int<Ms> -> Int<Ms>
clampTtl = clamp 1 maxPresenceTtl

clampTimestamp : Timestamp -> Timestamp -> Timestamp
clampTimestamp = \timestamp t -> clamp (t - messageMaxAge) t timestamp

effectiveMessageTtl : Int<Ms> -> Int<Ms>
effectiveMessageTtl = \e -> if e <= 0 then unackedMessageMaxAge else clamp minMessageTtl unackedMessageMaxAge e

nextSeqTs : Timestamp -> Timestamp -> Timestamp
nextSeqTs = \t seqCounter -> max t (seqCounter + 1)

dedupMessageIds : [MessageIdHex] -> [MessageIdHex]
dedupMessageIds = \ids -> takeRelation maxMessageIds (unique ids)

presenceForKey : [PresenceEntry] -> PubkeyHex -> Timestamp -> [PresenceEntry]
presenceForKey = \presence pubkey t ->
  filter presence (\p -> p.pubkey == pubkey && p.expiresAt > t)

-- Resolve a key's server for client lookup, masking remote identities behind "remote".
maskedServer : [PresenceEntry] -> PubkeyHex -> Timestamp -> Text
maskedServer = \pres pubkey t ->
  let here = presenceForKey pres pubkey t in
  if any here (\p -> isLocalServer p.server) then serverHostN
  else if count here > 0 then "remote"
  else ""

hasMessage : MessageIdHex -> PubkeyHex -> [{messageId: MessageIdHex, toKey: PubkeyHex | a}] -> Bool
hasMessage = \mid toKey items -> any items (\x -> x.messageId == mid && x.toKey == toKey)

isDuplicateMessage : MessageIdHex -> PubkeyHex -> [{messageId: MessageIdHex, toKey: PubkeyHex | a}] -> [{messageId: MessageIdHex, toKey: PubkeyHex | b}] -> [{messageId: MessageIdHex, toKey: PubkeyHex | c}] -> Bool
isDuplicateMessage = \mid toKey msgs aids dids ->
  hasMessage mid toKey msgs || hasMessage mid toKey aids || hasMessage mid toKey dids

collectPeers : [a] -> (a -> Text) -> [Text]
collectPeers = \items getServer ->
  unique (filter (pluck items getServer) isRemote)

knownPeerServersFromPresence : [PresenceEntry] -> [Text]
knownPeerServersFromPresence = \presence -> collectPeers presence (\p -> p.server)

-- Last-write-wins merge by (pubkey, server), keeping the entry with the larger expiresAt.
mergePresence : [PresenceEntry] -> [PresenceEntry] -> [PresenceEntry]
mergePresence = \existing incoming ->
  fold (\acc e ->
    let same = \x -> x.pubkey == e.pubkey && x.server == e.server in
    if any acc (\x -> same x && x.expiresAt >= e.expiresAt) then acc
    else union (removeWhere acc same) [e]) existing incoming

-- ============================================
-- Pruning
-- ============================================
-- Single sweep that drops expired entries from every state ref in one atomic
-- block. Returns the locally-expired presence rows whose pubkey has no other
-- live local session, so the caller can broadcast offline gossip for them.

pruneExpired : Timestamp -> IO {} [PresenceEntry]
pruneExpired = \t -> atomic do
  ch <- *challenges
  set *challenges = filter ch (\x -> x.expiresAt > t)
  ses <- *sessions
  set *sessions = filter ses (\x -> x.expiresAt > t)
  msgs <- *messages
  set *messages = filter msgs (\m -> m.expiresAt > t)
  fwds <- *forwards
  set *forwards = filter fwds (\f -> f.expiresAt > t)
  aids <- *ackedIds
  set *ackedIds = filter aids (\a -> t - a.ackedAt < messageMaxAge)
  dids <- *deliveredIds
  set *deliveredIds = filter dids (\d -> t - d.deliveredAt < messageMaxAge)
  ff <- *forwardFailures
  set *forwardFailures = filter ff (\f -> t - f.failedAt < 86400000)
  aps <- *activePolls
  set *activePolls = filter aps (\p -> t - p.startedAt < pollTimeoutMs * 3)
  pv <- *pendingVerifications
  set *pendingVerifications = filter pv (\p -> t - p.createdAt < verificationTokenExpiry)
  se <- *senderExpirations
  set *senderExpirations = filter se (\x -> t - x.expiredAt < unackedMessageMaxAge)
  sd <- *senderDeliveries
  set *senderDeliveries = filter sd (\x -> t - x.deliveredAt < unackedMessageMaxAge)
  cn <- *cancelNotifications
  set *cancelNotifications = filter cn (\x -> t - x.cancelledAt < unackedMessageMaxAge)
  pfc <- *pendingFederationCancels
  set *pendingFederationCancels = filter pfc (\x -> t - x.createdAt < messageMaxAge)
  -- presence: remember locally-expired keys for offline gossip
  pres <- *presence
  set *presence = filter pres (\p -> p.expiresAt > t)
  let stillLive = \pk -> any pres (\k -> isLocalServer k.server && k.pubkey == pk && k.expiresAt > t)
  yield (filter pres (\p -> p.expiresAt <= t && isLocalServer p.server && not (stillLive p.pubkey)))

-- ============================================
-- Federation gossip
-- ============================================
-- Construction and outbound dispatch of presence gossip events. Each event
-- carries a `seenBy` list to short-circuit loops on the receiver. Failures
-- from a peer record into `forwardFailures` (shared with forward retries) so
-- both subsystems back off together.

-- Build a gossip event with this server's identity.
mkGossip : GossipEventType -> PubkeyHex -> Timestamp -> Int<Ms> -> GossipEvent
mkGossip = \etype pk t ttl ->
  {eventType: etype, pubkey: pk, server: serverHostN, timestamp: t, ttl: ttl, seenBy: [serverHostN]}

-- Build an acked entry for a federated message.
mkAckedEntry : {messageId: MessageIdHex, toKey: PubkeyHex, originServer: Text | a} -> Timestamp -> AckedEntry
mkAckedEntry = \m t -> {messageId: m.messageId, toKey: m.toKey, ackedAt: t, originServer: m.originServer, retries: 0}

-- Record federation acks and sender deliveries for a batch of just-removed messages.
-- Returns the federated-ack entries (the caller flushes them remotely later).
recordAcksAndDeliveries : [Message] -> Timestamp -> IO {} [AckedEntry]
recordAcksAndDeliveries = \toAck t -> do
  let ackedFed = mapWhere toAck (\m -> m.originServer != "") (\m -> mkAckedEntry m t)
  let myDel = mapWhere toAck (\m -> m.senderKey != "" && m.originServer == "")
                (\m -> {senderKey: m.senderKey, messageId: m.messageId, toKey: m.toKey, deliveredAt: t})
  aids <- *ackedIds
  set *ackedIds = capList (union aids ackedFed) maxAckedIds (\a -> a.ackedAt)
  sds <- *senderDeliveries
  set *senderDeliveries = capList (union sds myDel) 10000 (\d -> d.deliveredAt)
  yield ackedFed

-- Common cancel block: drop matching messages + forwards, record cancel notification.
-- Returns the federated forward servers that had the message (for caller follow-up).
applyCancel : [a] -> (forall r. {messageId: MessageIdHex, toKey: Text | r} -> Bool) -> Text -> MessageIdHex -> Timestamp ->  IO {} [Text]
applyCancel = \msgs matches to mid t -> do
  set *messages = removeWhere msgs matches
  fwds <- *forwards
  set *forwards = removeWhere fwds matches
  cn <- *cancelNotifications
  set *cancelNotifications = capList (union cn [{toKey: to, messageId: mid, cancelledAt: t}]) 10000 (\c -> c.cancelledAt)
  yield (collectPeers (filter fwds matches) (\f -> f.toServer))

-- Cancel one message if `ownerPred` holds for it; returns whether a cancel happened.
cancelOne : MessageIdHex -> PubkeyHex -> (Message -> Bool) -> Timestamp -> IO {} Bool
cancelOne = \mid to ownerPred t -> atomic do
  msgs <- *messages
  let matches = \x -> x.messageId == mid && x.toKey == to
  let owns = any msgs (\m -> matches m && ownerPred m)
  when owns (do applyCancel msgs matches to mid t; yield {})
  yield owns

sendBatchedGossip : [Text] -> [GossipEvent] -> IO {network} {}
sendBatchedGossip = \peers events -> forEach peers (\server -> do
  t <- now
  failures <- *forwardFailures
  when (shouldRetryServer server t failures) (do
    auth <- generateFederationAuth "gossip" t
    result <- fetch (federationUrl server) (RecvGossip {
      authorization: auth,
      events: events, hopsRemaining: gossipOriginHops, fromServer: serverHostN,
      requestTimestamp: t, correlationId: "", protocolVersion: federationProtocolVersion})
    case result of
      Err _ -> recordFailure server
      Ok _ -> clearFailure server))

broadcastOfflineGossip : Timestamp -> [PresenceEntry] -> IO {network} {}
broadcastOfflineGossip = \t expiredLocal -> do
  presence <- *presence
  when (federationEnabled && count expiredLocal > 0)
    (sendBatchedGossip (knownPeerServersFromPresence presence) (pluck expiredLocal (\p -> mkGossip (GossipOffline {}) p.pubkey t offlineGossipMinTtl)))

-- ============================================
-- Forward retries and acks
-- ============================================
-- `retryPendingForwards` walks queued cross-server forwards in batches per
-- destination, increments retry counts, and gives up after `maxForwardRetries`.
-- `sendAcksAndClean` flushes federated acks back to origin servers and prunes
-- the local `ackedIds` rows once the remote confirms.
-- `forwardQueuedToServer` is the catch-up path triggered when a remote key
-- comes online: any messages already buffered for that pubkey are enqueued
-- as forwards to the newly-known server.

retryPendingForwards : IO {network} {}
retryPendingForwards = do
  t <- now
  fwds <- *forwards
  failures <- *forwardFailures
  blocked <- *blockedPeers
  forEach (filter (collectPeers fwds (\f -> f.toServer)) (\s -> shouldRetryServer s t failures && not (elem blocked s))) (\server ->
    forEach (takeRelation maxBatchSize (filter fwds (\f -> f.toServer == server))) (\f -> do
      t2 <- now
      auth <- generateFederationAuth ("forward:" ++ f.messageId) t2
      result <- fetch (federationUrl server) (ForwardMessage {
        toKey: f.toKey, encryptedBlob: f.encryptedBlob,
        timestamp: f.timestamp, originServer: f.originServer, messageId: f.messageId,
        fromServer: serverHostN, requestTimestamp: t2,
        authorization: auth, correlationId: "",
        expiresAt: f.expiresAt, priority: f.priority, protocolVersion: federationProtocolVersion})
      success <- case result of
        Err _ -> do recordFailure server; yield False {}
        Ok {value: r} -> do when r.ok (clearFailure server); yield r.ok
      let isMatch = \x -> x.messageId == f.messageId && x.toServer == server
      let isDone = \x -> isMatch x && (success || x.retries + 1 >= maxForwardRetries)
      atomic do
        cur <- *forwards
        set *forwards = pluck (removeWhere cur isDone) (\x ->
          if isMatch x
            then {messageId: x.messageId, toServer: x.toServer, createdAt: x.createdAt, toKey: x.toKey, encryptedBlob: x.encryptedBlob, timestamp: x.timestamp, originServer: x.originServer, retries: x.retries + 1, expiresAt: x.expiresAt, priority: x.priority, senderKey: x.senderKey}
            else x)))

sendAcksAndClean : [AckedEntry] -> IO {network} {}
sendAcksAndClean = \pendingAcks ->
  forEach (collectPeers pendingAcks (\a -> a.originServer)) (\server -> do
    let mids = mapWhere pendingAcks (\a -> a.originServer == server) (\a -> a.messageId)
    t <- now
    auth <- generateFederationAuth "ack" t
    result <- fetch (federationUrl server) (FederationAck {
      authorization: auth,
      messageIds: mids, originServer: server, fromServer: serverHostN,
      requestTimestamp: t, correlationId: "", protocolVersion: federationProtocolVersion})
    case result of
      Err _ -> recordFailure server
      Ok _ -> do
        clearFailure server
        atomic do
          aids <- *ackedIds
          set *ackedIds = filter aids (\a -> not (a.originServer == server && elem mids a.messageId)))

-- Forward queued messages to a server when a remote key comes online.
forwardQueuedToServer : PubkeyHex -> Text -> Timestamp -> IO {} {}
forwardQueuedToServer = \pubkey server t -> atomic do
  msgs <- *messages
  fwds <- *forwards
  let candidates = filter msgs (\m -> m.toKey == pubkey && none fwds (\f -> f.messageId == m.messageId && f.toServer == server))
  let newFwds = pluck (takeRelation maxForwardsPerServer candidates) (\m ->
    {messageId: m.messageId, toServer: server, createdAt: t, toKey: m.toKey, encryptedBlob: m.encryptedBlob, timestamp: m.timestamp, originServer: (if m.originServer == "" then serverHostN else m.originServer), retries: 0, expiresAt: m.expiresAt, priority: m.priority, senderKey: m.senderKey})
  set *forwards = capList (union fwds newFwds) maxForwardsEntries (\f -> f.createdAt)

-- ============================================
-- Background loops
-- ============================================
-- Composite tick run from `backgroundPrune` (and on demand via /maintenance/prune):
-- expire stale rows, then opportunistically retry pending forwards and refresh
-- local presence so peers don't see us go offline mid-session.

pruneAndRetry : Timestamp -> IO {network} {}
pruneAndRetry = \t -> do
  atomic do set *lastPrunedAt = t
  expiredLocal <- pruneExpired t
  fork (broadcastOfflineGossip t expiredLocal)
  when federationEnabled (do
    fork retryPendingForwards
    aids <- *ackedIds
    fork (sendAcksAndClean (filter aids (\a -> isRemote a.originServer)))
    lastRefresh <- *lastPresenceRefresh
    when (t - lastRefresh >= presenceRefreshInterval) (do
      atomic do set *lastPresenceRefresh = t
      refreshLocalPresence t))

refreshLocalPresence : Timestamp -> IO {network} {}
refreshLocalPresence = \t -> do
  refreshState <- atomic do
    sessions <- *sessions
    presence <- *presence
    let sessionKeys = pluck sessions (\s -> s.pubkey)
    let needsRefresh = \p -> isLocalServer p.server && elem sessionKeys p.pubkey && p.expiresAt - t < sessionExpiry / 2
    let refreshed = mapWhere presence needsRefresh (\p -> {pubkey: p.pubkey, server: p.server, expiresAt: t + sessionExpiry, timestamp: t})
    let updated = union (removeWhere presence needsRefresh) refreshed
    set *presence = updated
    yield {refreshed: refreshed, peers: knownPeerServersFromPresence updated}
  when (count refreshState.refreshed > 0)
    (fork (sendBatchedGossip refreshState.peers (pluck refreshState.refreshed (\p -> mkGossip (GossipOnline {}) p.pubkey t (clampTtl (sessionExpiry / 1000))))))

-- ============================================
-- Handler: challenge / verify / revoke / logout
-- ============================================
-- Identity is a public key; there are no accounts. The flow is:
--   1. Client requests a fresh nonce (`handleChallenge`).
--   2. Client signs the nonce with its private key and submits the signature
--      together with the original challenge (`handleVerifyAuth`).
--   3. Server returns a Bearer token bound to (pubkey, ip, expiry); the new
--      session also installs a local presence row and gossips an `online`
--      event to known peers.
-- `handleRevoke` lets a session revoke its peers (same pubkey, different
-- token); `handleLogout` invalidates the caller's own token and, if no
-- sibling sessions remain, gossips an `offline` event.

-- POST /auth/challenge: issue a fresh signed-nonce challenge for `pubkey`.
-- Capped per-key (maxChallengesPerKey) and rate-limited; the IP is recorded
-- so /auth/verify can require the same client.
handleChallenge : PubkeyHex -> Text -> ({challenge: Text, ok: Bool, expiresAt: Timestamp, retryAfterMs: Int, error: Text} -> ret) -> IO {} ret
handleChallenge = \pubkey clientIp respond -> do
  t <- now
  preErr <- if requireClientIp && clientIp == "" then yield "client_ip_required" else authPreCheck clientIp t
  if preErr != "" then yield (respond {challenge: "", ok: False {}, expiresAt: 0, retryAfterMs: 0, error: preErr})
  else do
    challenge <- genToken
    result <- atomic do
      ch <- *challenges
      let cappedActive = capPerKey (filter ch (\c -> c.expiresAt > t)) (\c -> c.pubkey == pubkey) maxChallengesPerKey (\c -> c.expiresAt)
      if count cappedActive >= maxChallenges then yield {ok: False {}, error: "capacity"}
      else do
        chRates <- *challengeRates
        let chR = checkRate chRates pubkey maxChallengeRatePerKey challengeRateWindowMs t
        set *challengeRates = chR.entries
        if chR.limited then yield {ok: False {}, error: "rate_limited"}
        else do
          set *challenges = union cappedActive [{pubkey: pubkey, challenge: challenge, expiresAt: t + challengeExpiry, ip: clientIp}]
          yield {ok: True {}, error: ""}
    yield (respond {challenge: if result.ok then challenge else "", ok: result.ok, expiresAt: if result.ok then t + challengeExpiry else 0, retryAfterMs: 0, error: result.error})

-- POST /auth/verify: validate `signature` over `challenge` for `pubkey`.
-- On success, mints a session token, records local presence (`pubkey` is now
-- live on this server), and gossips an `online` event to known peers. If
-- `revokeOthers` is set, all other sessions for the same pubkey are dropped.
handleVerifyAuth : PubkeyHex -> Text -> SignatureHex -> Bool -> Text -> ({token: Text, expiresAt: Timestamp, error: Text} -> ret) -> IO {network} ret
handleVerifyAuth = \pubkey challenge signature revokeOthers clientIp respond -> do
  t <- now
  preErr <- authPreCheck clientIp t
  if preErr != "" then yield (respond {token: "", expiresAt: 0, error: preErr})
  else do
    let expiry = t + sessionExpiry
    token <- genToken
    result <- atomic do
      ch <- *challenges
      dp <- *drainPhase
      let same = \c -> c.pubkey == pubkey && c.challenge == challenge
      let valid = dp < 1
            && any ch (\c -> same c && c.expiresAt > t && matchIp clientIp c.ip)
            && verify (bytesFromHex pubkey) (textToBytes challenge) (bytesFromHex signature)
      if not valid then yield {valid: False {}, peers: []}
      else do
        set *challenges = removeWhere ch same
        ses <- *sessions
        let mine = \s -> s.pubkey == pubkey
        let pruned = if revokeOthers then removeWhere ses mine else capPerKey ses mine maxSessionsPerKey (\s -> s.expiresAt)
        let newSession = {token: token, pubkey: pubkey, expiresAt: expiry, ip: clientIp, createdAt: t}
        set *sessions = capList (union pruned [newSession]) maxSessions (\s -> s.expiresAt)
        pres <- *presence
        let prunedPres = removeWhere pres (\p -> p.pubkey == pubkey && isLocalServer p.server)
        let newPres = capList (union prunedPres [{pubkey: pubkey, server: serverHostN, expiresAt: expiry, timestamp: t}]) maxPresenceEntries (\p -> p.expiresAt)
        set *presence = newPres
        yield {valid: True {}, peers: knownPeerServersFromPresence newPres}
    if not result.valid then yield (respond {token: "", expiresAt: 0, error: "invalid"})
    else do
      when federationEnabled
        (fork (sendBatchedGossip result.peers [mkGossip (GossipOnline {}) pubkey t onlineGossipTtl]))
      yield (respond {token: token, expiresAt: expiry, error: ""})

-- POST /auth/revoke: caller (any session for the pubkey) revokes a sibling
-- session by token. Returns ok=False if no such sibling existed.
handleRevoke : Text -> Text -> Text -> ({ok: Bool, authorized: Bool} -> ret) -> IO {} ret
handleRevoke = \targetToken authorization clientIp respond -> do
  t <- now
  gateAuth (False {}) authorization clientIp t respond (\_ -> {ok: False {}, authorized: False {}}) (\caller -> do
    result <- atomic do
      ses <- *sessions
      let pred = \s -> s.pubkey == caller && s.token == targetToken
      set *sessions = removeWhere ses pred
      yield (any ses pred)
    yield (respond {ok: result, authorized: True {}}))

-- POST /auth/logout: drop the caller's own session. If this was the last
-- session for the pubkey, also clear local presence and gossip offline.
handleLogout : Text -> Text -> ({ok: Bool, authorized: Bool} -> ret) -> IO {network} ret
handleLogout = \authorization clientIp respond -> do
  t <- now
  let myToken = case extractToken authorization of Just {value: tk} -> tk; _ -> ""
  removed <- atomic (withSessionAuth authorization t clientIp
    (yield {ok: False {}, pubkey: "", peers: []})
    (\pubkey -> do
      ses <- *sessions
      set *sessions = removeWhere ses (\s -> s.token == myToken)
      after <- *sessions
      peers <- if any after (\s -> s.pubkey == pubkey) then yield []
        else do
          pres <- *presence
          set *presence = removeWhere pres (\p -> p.pubkey == pubkey && isLocalServer p.server)
          yield (knownPeerServersFromPresence pres)
      yield {ok: True {}, pubkey: pubkey, peers: peers}))
  when (removed.ok && federationEnabled)
    (fork (sendBatchedGossip removed.peers [mkGossip (GossipOffline {}) removed.pubkey t offlineGossipMinTtl]))
  yield (respond {ok: removed.ok, authorized: removed.ok})

-- ============================================
-- Handler: poll
-- ============================================
-- Long-poll. The client supplies a cursor (last-seen `receivedAt`) and the
-- server's last-known `generation` (server identity for cursor validity). We:
--   * If the generation mismatches, reset the cursor and signal `cursorReset`.
--   * Ack-and-drop everything <= the cursor (treating poll progress as ack).
--   * Wait on `pollWakeup` (bumped by send/heartbeat) and return new events
--     plus piggybacked metadata (presence updates for `watchKeys`, sender-side
--     expirations/deliveries/cancellations).
-- Per-pubkey concurrency is capped via `activePolls` to bound long-poll holds.

-- POST /poll: top-level dispatch. Validates drain/global gates, detects a
-- generation mismatch (server restart) to force a cursor reset, then hands
-- off to `pollOnce` for the actual long-poll body.
handlePoll : Timestamp -> Int -> [PubkeyHex] -> Text -> Text -> ({events: [PollEvent], cursor: Timestamp, authorized: Bool, rateLimited: Bool, draining: Bool, generation: Int, presenceUpdates: [{pubkey: PubkeyHex, online: Bool}], heartbeat: Bool, retryAfterMs: Int, cursorReset: Bool, hasMore: Bool, cursorStale: Bool, messageExpirations: [{messageId: MessageIdHex, toKey: PubkeyHex, expiredAt: Timestamp}], messageDeliveries: [{messageId: MessageIdHex, toKey: PubkeyHex, deliveredAt: Timestamp}], droppedDeliveryReceipts: Int, droppedExpirationNotifs: Int, loadPct: Int, messageCancellations: [{messageId: MessageIdHex, cancelledAt: Timestamp}]} -> ret) -> IO {network} ret
handlePoll = \cursor generation watchKeys authorization clientIp respond -> do
  t <- now
  serverGen <- *serverGeneration
  dp <- *drainPhase
  g <- checkGlobalRate t
  let cursorWasReset = generation != serverGen && cursor > 0
  let er = \auth rate drain retryRate -> yield (respond (emptyPollResp 0 auth rate drain serverGen retryRate cursorWasReset))
  if dp >= 2 then er (True {}) (False {}) (True {}) 0
  else if g then er (False {}) (True {}) (False {}) globalRateWindowMs
  else pollOnce authorization (if cursorWasReset then 0 else cursor) cursorWasReset (takeRelation maxWatchKeys watchKeys) clientIp serverGen respond t

-- Body of a single poll. Treats the cursor advance as an implicit ack
-- (`ackPolledMessages`), acquires a per-pubkey poll slot, runs `doPoll` to
-- collect events (or block until wakeup), then assembles the response with
-- piggybacked presence/expiration/delivery/cancellation metadata.
pollOnce : Text -> Timestamp -> Bool -> [PubkeyHex] -> Text -> Int -> ({events: [PollEvent], cursor: Timestamp, authorized: Bool, rateLimited: Bool, draining: Bool, generation: Int, presenceUpdates: [{pubkey: PubkeyHex, online: Bool}], heartbeat: Bool, retryAfterMs: Int, cursorReset: Bool, hasMore: Bool, cursorStale: Bool, messageExpirations: [{messageId: MessageIdHex, toKey: PubkeyHex, expiredAt: Timestamp}], messageDeliveries: [{messageId: MessageIdHex, toKey: PubkeyHex, deliveredAt: Timestamp}], droppedDeliveryReceipts: Int, droppedExpirationNotifs: Int, loadPct: Int, messageCancellations: [{messageId: MessageIdHex, cancelledAt: Timestamp}]} -> ret) -> Timestamp -> IO {network} ret
pollOnce = \authorization cursor cursorWasReset watchKeys clientIp serverGen respond t -> do
  setup <- atomic (withSessionAuth authorization t clientIp
    (yield Nothing {})
    (\pubkey -> do
      let clampedCursor = clamp 0 t cursor
      pendingAcks <- if clampedCursor > 0 then ackPolledMessages pubkey clampedCursor t else yield []
      startWakeup <- *pollWakeup
      yield (Just {value: {pubkey: pubkey, clampedCursor: clampedCursor, startWakeup: startWakeup, pendingAcks: pendingAcks}})))
  case setup of
    Nothing {} -> yield (respond (emptyPollResp 0 (False {}) (False {}) (False {}) serverGen 0 cursorWasReset))
    Just {value: s} -> do
      acquired <- atomic do
        aps <- *activePolls
        if countWhere aps (\p -> p.pubkey == s.pubkey) >= maxPollsPerKey then yield False {}
        else do
          set *activePolls = capList (union aps [{pubkey: s.pubkey, startedAt: t}]) maxActivePolls (\p -> p.startedAt)
          yield True {}
      if not acquired
        then yield (respond (emptyPollResp cursor (True {}) (True {}) (False {}) serverGen pollTimeoutMs cursorWasReset))
        else do
          pollResult <- doPoll s t
          atomic do
            aps <- *activePolls
            set *activePolls = filter aps (\p -> p.pubkey != s.pubkey)
          when federationEnabled (fork (sendAcksAndClean s.pendingAcks))
          t2 <- now
          extras <- atomic do
            pres <- *presence
            let mine = \x -> x.senderKey == s.pubkey
            seItems <- *senderExpirations
            set *senderExpirations = removeWhere seItems mine
            let myExp = mapWhere seItems mine (\x -> {messageId: x.messageId, toKey: x.toKey, expiredAt: x.expiredAt})
            sdItems <- *senderDeliveries
            set *senderDeliveries = removeWhere sdItems mine
            let myDel = mapWhere sdItems mine (\x -> {messageId: x.messageId, toKey: x.toKey, deliveredAt: x.deliveredAt})
            cnItems <- *cancelNotifications
            let isMine = \x -> x.toKey == s.pubkey
            set *cancelNotifications = removeWhere cnItems isMine
            let myCancels = mapWhere cnItems isMine (\x -> {messageId: x.messageId, cancelledAt: x.cancelledAt})
            yield {presenceUpdates: pluck watchKeys (\k -> {pubkey: k, online: count (presenceForKey pres k t2) > 0}), expirations: myExp, deliveries: myDel, cancellations: myCancels}
          yield (respond {events: pollResult.events, cursor: pollResult.cursor, authorized: True {}, rateLimited: False {}, draining: False {}, generation: serverGen, presenceUpdates: extras.presenceUpdates, heartbeat: count pollResult.events == 0, retryAfterMs: 0, cursorReset: cursorWasReset, hasMore: pollResult.hasMore, cursorStale: False {}, messageExpirations: extras.expirations, messageDeliveries: extras.deliveries, droppedDeliveryReceipts: 0, droppedExpirationNotifs: 0, loadPct: 0, messageCancellations: extras.cancellations})

-- One pass: collect events at `t`. If empty, retry-wait on `pollWakeup`
-- (bumped by send/heartbeat) and re-collect once at the new wall time.
doPoll : {pubkey: PubkeyHex, clampedCursor: Timestamp, startWakeup: Timestamp, pendingAcks: [AckedEntry]} -> Timestamp -> IO {} {events: [PollEvent], cursor: Timestamp, hasMore: Bool}
doPoll = \s t -> do
  let collectAt = \tnow -> atomic do
    msgs <- *messages
    yield (collectPollEvents msgs s.pubkey s.clampedCursor tnow)
  initial <- collectAt t
  if count initial.events > 0 then yield initial
  else do
    atomic do
      wakeup <- *pollWakeup
      if wakeup > s.startWakeup then yield {} else retry
    t2 <- now
    collectAt t2

-- Pull this pubkey's unexpired messages newer than `cursor`, sort by
-- receivedAt, take up to `maxPollEvents`, and report `hasMore` if truncated.
collectPollEvents : [Message] -> PubkeyHex -> Timestamp -> Timestamp -> {events: [PollEvent], cursor: Timestamp, hasMore: Bool}
collectPollEvents = \messages pubkey cursor t ->
  let myMsgs = filter messages (\m -> m.toKey == pubkey && m.expiresAt > t && m.receivedAt > cursor) in
  let limited = takeRelation maxPollEvents (sortBy (\m -> m.receivedAt) myMsgs) in
  {events: pluck limited (\m -> {id: m.messageId, eventType: "message", payload: {toKey: m.toKey, encryptedBlob: m.encryptedBlob, timestamp: m.timestamp, expiresAt: m.expiresAt}}),
   cursor: fold (\acc m -> max acc m.receivedAt) cursor limited,
   hasMore: count myMsgs > count limited}

-- Treat the supplied cursor as an ack: drop all messages with
-- receivedAt <= cursor, plus their pending forwards, and record federated
-- acks/sender deliveries via `recordAcksAndDeliveries`.
ackPolledMessages : PubkeyHex -> Timestamp -> Timestamp -> IO {} [AckedEntry]
ackPolledMessages = \pubkey cursor t -> do
  msgs <- *messages
  let matches = \m -> m.toKey == pubkey && m.receivedAt <= cursor
  let toAck = filter msgs matches
  let mids = pluck toAck (\m -> m.messageId)
  set *messages = removeWhere msgs matches
  fwds <- *forwards
  set *forwards = filter fwds (\f -> not (f.toKey == pubkey && elem mids f.messageId))
  recordAcksAndDeliveries toAck t

-- ============================================
-- Handler: send
-- ============================================
-- Accept a message for a recipient pubkey and decide its placement:
--   * `MsDelivered`  -- recipient has a live local session
--   * `MsFederated`  -- recipient lives on a remote peer; queued as a forward
--   * `MsQueued`     -- no presence yet; held until presence appears
--   * `MsRejected` / `MsRateLimited` / `MsDuplicate` / `MsDraining` -- refused
-- Send is gated by drain phase, global rate, and the per-sender / per-pair /
-- per-recipient rate limits charged together inside `sendMessageCore`.
-- Federated forwards are kicked off in a background fork after the atomic.

-- POST /messages: send one ciphertext to `to`. Rejects on draining/rate
-- limit/stale timestamp; otherwise calls `sendMessageCore` inside an atomic
-- block and forks the federation forward (if any) once the local commit lands.
handleSendMessage : PubkeyHex -> BlobHex -> Timestamp -> OptionalMessageId -> Int -> Int -> Text -> Text -> ({status: MessageStatus, messageId: OptionalMessageId, retryAfterMs: Int, error: Text, loadPct: Int} -> ret) -> IO {network} ret
handleSendMessage = \to encryptedBlob timestamp messageId expiresInMs priority authorization clientIp respond -> do
  t <- now
  dp <- *drainPhase
  g <- checkGlobalRate t
  effMsgId <- resolveMessageId messageId
  let err = \s e -> yield (respond (sendErrResp s e))
  if dp >= 2 then err (MsDraining {}) "draining"
  else if g then err (MsRateLimited {}) "rate_limited"
  else if t - timestamp > messageMaxAge then err (MsRejected {}) "stale_timestamp"
  else do
    let clampedTs = clampTimestamp timestamp t
    result <- atomic do
      withSessionAuth authorization t clientIp
        (yield {status: MsUnauthorized {}, remoteServers: []})
        (\senderKey -> sendMessageCore senderKey to encryptedBlob clampedTs effMsgId expiresInMs (clamp 0 maxMessagePriority priority) t)
    when federationEnabled
      (fork (forkForwardsTo effMsgId to encryptedBlob clampedTs result.remoteServers))
    let ok = isSendSuccess result.status
    yield (respond {status: result.status, messageId: if ok then effMsgId else "", retryAfterMs: 0, error: if ok then "" else "rejected", loadPct: 0})

-- Atomic core of /messages and /messages/batch. Charges send/pair/recv rate
-- counters together (so any limit denies the message), enforces caps and
-- self-send/duplicate rejections, allocates a monotonic receivedAt via
-- `seqCounter`, appends the message, and pre-stages forwards for any remote
-- presence rows that already exist for `to`. Returns the chosen status and
-- the list of remote servers the caller should kick forwards to.
sendMessageCore : PubkeyHex -> PubkeyHex -> BlobHex -> Timestamp -> OptionalMessageId -> Int -> Int -> Timestamp -> IO {} {status: MessageStatus, remoteServers: [Text]}
sendMessageCore = \senderKey to encryptedBlob clampedTs effMsgId expiresInMs msgPriority t -> do
  msgs <- *messages
  aids <- *ackedIds
  dids <- *deliveredIds
  sRates <- *sendRates
  let sR = checkRate sRates senderKey maxSendRatePerKey sendRateWindowMs t
  set *sendRates = sR.entries
  let srLim = sR.limited
  pRates <- *pairRates
  let pR = checkRate pRates (senderKey ++ "|" ++ to) maxPairRatePerPair pairRateWindowMs t
  set *pairRates = pR.entries
  let prLim = pR.limited
  rRates <- *recvRates
  let rR = checkRate rRates to maxRecvRatePerKey recvRateWindowMs t
  set *recvRates = rR.entries
  let rrLim = rR.limited
  let reject = \s -> yield {status: s, remoteServers: []}
  if senderKey == to then reject (MsRejected {})
  else if isDuplicateMessage effMsgId to msgs aids dids then reject (MsDuplicate {})
  else if srLim || prLim || rrLim then reject (MsRateLimited {})
  else if count msgs >= maxMessages then reject (MsRejected {})
  else if countWhere msgs (\m -> m.toKey == to) >= maxMessagesPerRecipient then reject (MsQueued {})
  else do
    pres <- *presence
    seq <- *seqCounter
    let seqTs = nextSeqTs t seq
    set *seqCounter = seqTs
    let expiresAt = seqTs + effectiveMessageTtl expiresInMs
    set *messages = union msgs [{messageId: effMsgId, toKey: to, encryptedBlob: encryptedBlob, timestamp: clampedTs, originServer: "", receivedAt: seqTs, expiresAt: expiresAt, senderKey: senderKey, priority: msgPriority}]
    set *pollWakeup = seqTs
    let toPresence = presenceForKey pres to t
    let remoteServers = collectPeers toPresence (\p -> p.server)
    forwardsEnqueued <- if federationEnabled then do
        fwds <- *forwards
        let newFwds = mapWhere remoteServers (\s -> none fwds (\f -> f.messageId == effMsgId && f.toServer == s)) (\s -> {messageId: effMsgId, toServer: s, createdAt: t, toKey: to, encryptedBlob: encryptedBlob, timestamp: clampedTs, originServer: serverHostN, retries: 0, expiresAt: expiresAt, priority: msgPriority, senderKey: senderKey})
        set *forwards = capList (union fwds newFwds) maxForwardsEntries (\f -> f.createdAt)
        yield (count newFwds > 0)
      else yield False {}
    yield {status: if any toPresence (\p -> isLocalServer p.server) then MsDelivered {} else if forwardsEnqueued then MsFederated {} else MsQueued {}, remoteServers: remoteServers}

-- Fire one /federation/forward call per pre-staged server. On success the
-- corresponding row in `forwards` is pruned (no retry needed); on failure
-- it stays so `retryPendingForwards` can re-attempt with backoff.
forkForwardsTo : OptionalMessageId -> PubkeyHex -> BlobHex -> Timestamp -> [Text] -> IO {network} {}
forkForwardsTo = \effMsgId to encryptedBlob clampedTs servers ->
  forEach servers (\server -> do
    fwds <- *forwards
    let same = \x -> x.messageId == effMsgId && x.toServer == server
    case findFirst fwds same of
      Nothing {} -> yield {}
      Just {value: f} -> do
        t <- now
        auth <- generateFederationAuth ("forward:" ++ effMsgId) t
        result <- fetch (federationUrl server) (ForwardMessage {
          toKey: to, encryptedBlob: encryptedBlob,
          timestamp: clampedTs, originServer: serverHostN, messageId: effMsgId,
          fromServer: serverHostN, requestTimestamp: t,
          authorization: auth, correlationId: "",
          expiresAt: f.expiresAt, priority: f.priority, protocolVersion: federationProtocolVersion})
        case result of
          Err _ -> recordFailure server
          Ok {value: r} -> when r.ok (do
            clearFailure server
            atomic do
              fwds2 <- *forwards
              set *forwards = filter fwds2 (\x -> not (same x))))

-- ============================================
-- Handler: lookup
-- ============================================
-- Presence resolution for clients deciding where to send. Remote presence is
-- masked to the literal string "remote" rather than leaking the peer hostname
-- (the routing decision is the server's, not the sender's).

-- GET /lookup/{pubkey}: return our local server name if the key is here,
-- "remote" if known on a peer, "" otherwise. Peer hostnames are deliberately
-- masked (see section header).
handleLookupPresence : PubkeyHex -> Text -> Text -> ({server: AnyServerName, authorized: Bool, error: Text} -> ret) -> IO {} ret
handleLookupPresence = \pubkey authorization clientIp respond -> do
  t <- now
  let mkErr = \e -> {server: "", authorized: False {}, error: if e == "rate_limited" then e else ""}
  gateLookup authorization clientIp t respond mkErr
    {server: "", authorized: True {}, error: "rate_limited"} (\_ -> do
      pres <- *presence
      yield (respond {server: maskedServer pres pubkey t, authorized: True {}, error: ""}))

-- POST /lookup/batch: same masking as `handleLookupPresence`, but for up to
-- 50 pubkeys in one round-trip.
handleBatchLookupPresence : [PubkeyHex] -> Text -> Text -> ({results: [{pubkey: PubkeyHex, server: AnyServerName}], authorized: Bool, error: Text} -> ret) -> IO {} ret
handleBatchLookupPresence = \pubkeys authorization clientIp respond -> do
  t <- now
  let mkErr = \e -> {results: [], authorized: False {}, error: if e == "rate_limited" then e else ""}
  gateLookup authorization clientIp t respond mkErr
    {results: [], authorized: True {}, error: "rate_limited"} (\_ -> do
      pres <- *presence
      let results = pluck (takeRelation 50 pubkeys) (\k -> {pubkey: k, server: maskedServer pres k t})
      yield (respond {results: results, authorized: True {}, error: ""}))

-- POST /messages/status: classify a message as
-- pending (in mailbox), forwarding (en-route to a peer),
-- delivered (acked or terminal), or unknown.
handleMessageStatus : PubkeyHex -> MessageIdHex -> Text -> Text -> ({status: Text, authorized: Bool} -> ret) -> IO {} ret
handleMessageStatus = \to messageId authorization clientIp respond -> do
  t <- now
  let mkErr = \_ -> {status: "", authorized: False {}}
  gateAuth (False {}) authorization clientIp t respond mkErr (\_ -> do
    msgs <- *messages
    fwds <- *forwards
    aids <- *ackedIds
    dids <- *deliveredIds
    let matches = \x -> x.messageId == messageId && x.toKey == to
    let s = if any msgs matches then "pending"
          else if any fwds matches then "forwarding"
          else if any aids matches || any dids matches then "delivered"
          else "unknown"
    yield (respond {status: s, authorized: True {}}))

-- ============================================
-- Handler: ack / list / delete / cancel
-- ============================================
-- Mailbox mutation by the recipient (ack, list, delete) and by the original
-- sender (cancel, cancel-batch). Cancel propagates over federation when the
-- message has already been forwarded to peers; if the remote rejects, we
-- queue a `pendingFederationCancels` retry.

-- POST /messages/ack: explicit ack by message id (alternative to the implicit
-- cursor-based ack in /poll). Drops mailbox+forward rows and forks federation
-- ack flush for any messages that originated remotely.
handleAckMessages : [MessageIdHex] -> Text -> Text -> ({ok: Bool, authorized: Bool, ackedCount: Int, error: Text} -> ret) -> IO {network} ret
handleAckMessages = \messageIds authorization clientIp respond -> do
  t <- now
  let mkErr = \e -> {ok: False {}, authorized: False {}, ackedCount: 0, error: e}
  gateClientWrite authorization clientIp t respond mkErr
    {ok: False {}, authorized: True {}, ackedCount: 0, error: "rate_limited"} (\pubkey -> do
      result <- atomic do
        toAck <- removeForKey (\x -> x.toKey == pubkey && elem (dedupMessageIds messageIds) x.messageId)
        ackedFed <- recordAcksAndDeliveries toAck t
        yield {ackedCount: count toAck, pendingAcks: ackedFed}
      when federationEnabled (fork (sendAcksAndClean result.pendingAcks))
      yield (respond {ok: True {}, authorized: True {}, ackedCount: result.ackedCount, error: ""}))

-- POST /messages/list: paginated peek at the caller's mailbox without acking.
-- Returns metadata only (no ciphertext) plus the total count.
handleListMessages : Int -> Text -> Text -> ({messages: [{messageId: MessageIdHex, timestamp: Timestamp, receivedAt: Timestamp}], authorized: Bool, count: Int, error: Text} -> ret) -> IO {} ret
handleListMessages = \offset authorization clientIp respond -> do
  t <- now
  let mkErr = \e -> {messages: [], authorized: False {}, count: 0, error: if e == "rate_limited" then e else ""}
  gateAuth (True {}) authorization clientIp t respond mkErr (\pubkey -> do
    lim <- atomic do
      rates <- *lookupRates
      let r = checkRate rates pubkey maxLookupRatePerKey lookupRateWindowMs t
      set *lookupRates = r.entries
      yield r.limited
    if lim then yield (respond {messages: [], authorized: True {}, count: 0, error: "rate_limited"})
    else do
      msgs <- *messages
      let myMsgs = sortBy (\m -> m.receivedAt) (filter msgs (\m -> m.toKey == pubkey && m.expiresAt > t))
      let total = count myMsgs
      let page = pluck (takeRelation maxPollEvents (dropRelation (clamp 0 total offset) myMsgs)) (\m -> {messageId: m.messageId, timestamp: m.timestamp, receivedAt: m.receivedAt})
      yield (respond {messages: page, authorized: True {}, count: total, error: ""}))

-- POST /messages/delete: same effect as ack from the recipient's side, with
-- a "delete" semantic for the response.
handleDeleteMessages : [MessageIdHex] -> Text -> Text -> ({ok: Bool, authorized: Bool, deletedCount: Int, error: Text} -> ret) -> IO {network} ret
handleDeleteMessages = \messageIds authorization clientIp respond -> do
  t <- now
  let mkErr = \e -> {ok: False {}, authorized: False {}, deletedCount: 0, error: if e == "draining" then "" else e}
  gateClientWrite authorization clientIp t respond mkErr
    {ok: False {}, authorized: True {}, deletedCount: 0, error: "rate_limited"} (\pubkey -> do
      result <- atomic do
        toDel <- removeForKey (\x -> x.toKey == pubkey && elem (dedupMessageIds messageIds) x.messageId)
        let ackedFed = mapWhere toDel (\m -> m.originServer != "") (\m -> mkAckedEntry m t)
        aids <- *ackedIds
        set *ackedIds = capList (union aids ackedFed) maxAckedIds (\a -> a.ackedAt)
        yield {deletedCount: count toDel, pendingAcks: ackedFed}
      when federationEnabled (fork (sendAcksAndClean result.pendingAcks))
      yield (respond {ok: True {}, authorized: True {}, deletedCount: result.deletedCount, error: ""}))

-- POST /messages/cancel: sender-side recall. Only succeeds while the message
-- is still locally undelivered AND was sent by this caller; if it had already
-- been forwarded to peers, federation cancels are dispatched in a fork.
handleCancelMessage : MessageIdHex -> PubkeyHex -> Text -> Text -> ({ok: Bool, authorized: Bool, cancelled: Bool, error: Text} -> ret) -> IO {network} ret
handleCancelMessage = \messageId to authorization clientIp respond -> do
  t <- now
  let mkErr = \e -> {ok: False {}, authorized: False {}, cancelled: False {}, error: if e == "draining" then "" else e}
  gateClientWrite authorization clientIp t respond mkErr
    {ok: False {}, authorized: True {}, cancelled: False {}, error: "rate_limited"} (\senderKey -> do
      let matches = \x -> x.messageId == messageId && x.toKey == to
      result <- atomic do
        msgs <- *messages
        if any msgs (\m -> matches m && m.originServer == "" && m.senderKey == senderKey) then do
          fwdServers <- applyCancel msgs matches to messageId t
          pres <- *presence
          yield {cancelled: True {}, cancelServers: unique (union (collectPeers (presenceForKey pres to t) (\p -> p.server)) fwdServers)}
        else yield {cancelled: False {}, cancelServers: []}
      when (result.cancelled && federationEnabled)
        (fork (sendCancelToEach messageId to result.cancelServers))
      yield (respond {ok: True {}, authorized: True {}, cancelled: result.cancelled, error: ""}))

-- Best-effort federation cancel; on failure the cancel is queued in
-- `pendingFederationCancels` so a later background pass can retry it.
sendCancelToEach : MessageIdHex -> PubkeyHex -> [Text] -> IO {network} {}
sendCancelToEach = \messageId to servers ->
  forEach servers (\server -> do
    t <- now
    auth <- generateFederationAuth ("cancel:" ++ messageId) t
    result <- fetch (federationUrl server) (FederationCancel {
      messageId: messageId, toKey: to, fromServer: serverHostN,
      requestTimestamp: t, correlationId: "", authorization: auth,
      protocolVersion: federationProtocolVersion})
    when (case result of Err _ -> True {}; Ok {value: r} -> not r.ok) (atomic do
      cur <- *pendingFederationCancels
      set *pendingFederationCancels = capList (union cur [{messageId: messageId, toKey: to, toServer: server, createdAt: t, retries: 0}]) 10000 (\c -> c.createdAt)))

-- POST /messages/cancel-batch: multi-id sender-side cancel. Same ownership
-- check as `handleCancelMessage`, applied independently per entry.
handleCancelBatch : [BatchCancelEntry] -> Text -> Text -> ({results: [BatchCancelResult], authorized: Bool, error: Text} -> ret) -> IO {} ret
handleCancelBatch = \cancels authorization clientIp respond -> do
  t <- now
  let mkErr = \e -> {results: [], authorized: False {}, error: if e == "draining" then "" else e}
  gateClientWrite authorization clientIp t respond mkErr
    {results: [], authorized: True {}, error: "rate_limited"} (\senderKey -> do
      results <- mapEach (takeRelation maxBatchSize cancels) (\e -> do
        r <- cancelOne e.messageId e.to (\m -> m.originServer == "" && m.senderKey == senderKey) t
        yield {messageId: e.messageId, cancelled: r})
      yield (respond {results: results, authorized: True {}, error: ""}))

-- POST /messages/batch: multi-recipient send in one call. Each entry runs
-- through `sendMessageCore` separately so per-entry rate limits/errors don't
-- abort the rest; federated forwards are forked per entry.
handleSendBatch : [BatchMessage] -> Text -> Text -> ({results: [BatchResult], authorized: Bool, retryAfterMs: Int} -> ret) -> IO {network} ret
handleSendBatch = \messages authorization clientIp respond -> do
  t <- now
  let mkErr = \_ -> {results: [], authorized: False {}, retryAfterMs: 0}
  gateAuth (True {}) authorization clientIp t respond mkErr (\senderKey -> do
    results <- mapEach (takeRelation maxBatchSize messages) (\m -> do
      effMsgId <- resolveMessageId m.messageId
      let clampedTs = clampTimestamp m.timestamp t
      r <- if t - m.timestamp > messageMaxAge
        then yield {status: MsRejected {}, remoteServers: []}
        else atomic do sendMessageCore senderKey m.to m.encryptedBlob clampedTs effMsgId m.expiresInMs (clamp 0 maxMessagePriority m.priority) t
      when federationEnabled
        (fork (forkForwardsTo effMsgId m.to m.encryptedBlob clampedTs r.remoteServers))
      yield {messageId: effMsgId, status: r.status})
    yield (respond {results: results, authorized: True {}, retryAfterMs: 0}))

-- ============================================
-- Handler: federation receive
-- ============================================
-- Inbound endpoints called peer-to-peer. Every handler funnels through
-- `withFederationAuth` which checks: peer block/allow lists, request
-- precondition (e.g. expected origin/server constraints), clock skew vs the
-- request timestamp, signature/Bearer auth, and per-peer rate limit.
-- Receive paths never trust `originServer` for routing; they only use it for
-- ack bookkeeping and SSRF-style filtering.

-- POST /federation/verify: callback endpoint a peer invokes to validate a
-- Bearer token we issued in `generateFederationAuth`. Single-use: a
-- successful match removes the token from `pendingVerifications`.
handleVerifyToken : Text -> Text -> Text -> ({ok: Bool} -> ret) -> IO {} ret
handleVerifyToken = \token scope clientIp respond -> do
  t <- now
  g <- checkGlobalRate t
  ipLim <- checkIpRateGate clientIp t
  if scope == "" || g || ipLim then yield (respond {ok: False {}})
  else do
    found <- atomic do
      pending <- *pendingVerifications
      let same = \p -> p.scope == scope && p.token == token
      let match = any pending (\p -> same p && t - p.createdAt < verificationTokenExpiry)
      when match (set *pendingVerifications = removeWhere pending same)
      yield match
    yield (respond {ok: found})

-- GET /federation/pubkey: publish the Ed25519 public key peers should use to
-- verify our `Signed ...` federation auth headers. Returns ok=False when the
-- server has no configured federation key (peers fall back to Bearer mode).
handleFederationPubkey : ({pubkey: Text, ok: Bool} -> ret) -> IO {} ret
handleFederationPubkey = \respond -> do
  yield (respond {pubkey: serverFederationPublicKeyHex, ok: serverFederationPublicKeyHex != ""})

-- POST /federation/gossip: ingest peer presence events. Filters out events
-- whose origin is local (loops) or whose timestamp is in the future beyond
-- skew tolerance, applies last-write-wins merge per (pubkey, server), and
-- — for keys that became newly online — flushes any locally-buffered messages
-- for them via `forwardQueuedToServer` (the catch-up path).
handleRecvGossip : [GossipEvent] -> Int -> ServerName -> Timestamp -> Text -> ({ok: Bool, error: Text, retryAfterMs: Int} -> ret) -> IO {network} ret
handleRecvGossip = \events hopsRemaining fromServer requestTimestamp authorization respond -> do
  t <- now
  withFederationAuth authorization t respond fromServer "gossip" requestTimestamp (clamp 0 maxGossipHops hopsRemaining >= 1 && isRemote fromServer && count events <= maxGossipEvents) (do
    newlyOnline <- atomic do
      pres <- *presence
      let validEvents = do
        e <- events
        where isRemote e.server && e.timestamp <= t + clockSkewTolerance
        let expiresAt = min e.timestamp t + clampTtl e.ttl * 1000
        where expiresAt > t
        yield {pubkey: e.pubkey, server: e.server, expiresAt: expiresAt, timestamp: e.timestamp, eventType: e.eventType}
      let isOnline = \v -> case v.eventType of GossipOnline {} -> True {}; _ -> False {}
      let isOffline = \v -> case v.eventType of GossipOffline {} -> True {}; _ -> False {}
      let online = mapWhere validEvents isOnline (\v -> {pubkey: v.pubkey, server: v.server, expiresAt: v.expiresAt, timestamp: v.timestamp})
      let offline = mapWhere validEvents isOffline (\v -> {pubkey: v.pubkey, server: v.server, timestamp: v.timestamp})
      set *presence = capList (mergePresence (filter pres (\p -> none offline (\o -> o.pubkey == p.pubkey && o.server == p.server && o.timestamp > p.timestamp))) online) maxPresenceEntries (\p -> p.expiresAt)
      yield (mapWhere online (\e -> none pres (\p -> p.pubkey == e.pubkey && p.server == e.server && p.expiresAt >= e.expiresAt)) (\e -> {pubkey: e.pubkey, server: e.server}))
    fork (forEach newlyOnline (\tgt -> forwardQueuedToServer tgt.pubkey tgt.server t))
    yield (respond {ok: True {}, error: "", retryAfterMs: 0}))

-- Store a federated/forwarded message into the local mailbox. Caller wraps in `atomic`.
-- Returns "" on success (including duplicates), otherwise an error code:
-- "no_presence" | "global_full" | "mailbox_full" | "rate_limited" (only when checkRecvRate).
storeFederated : PubkeyHex -> BlobHex -> Timestamp -> ServerName -> MessageIdHex -> Timestamp -> Int -> Bool -> Timestamp -> IO {} Text
storeFederated = \toKey encryptedBlob timestamp originServer messageId expiresAt priority checkRecvRate t -> do
  pres <- *presence
  msgs <- *messages
  aids <- *ackedIds
  dids <- *deliveredIds
  if not (any pres (\p -> p.pubkey == toKey && p.expiresAt > t)) then yield "no_presence"
  else if isDuplicateMessage messageId toKey msgs aids dids then yield ""
  else if count msgs >= maxMessages then yield "global_full"
  else if countWhere msgs (\m -> m.toKey == toKey) >= maxMessagesPerRecipient then yield "mailbox_full"
  else do
    limited <- if checkRecvRate then do
        rRates <- *recvRates
        let r = checkRate rRates toKey maxRecvRatePerKey recvRateWindowMs t
        set *recvRates = r.entries
        yield r.limited
      else yield False {}
    if limited then yield "rate_limited"
    else do
      seq <- *seqCounter
      let seqTs = nextSeqTs t seq
      let cappedExpiry = if expiresAt > t then min expiresAt (seqTs + unackedMessageMaxAge) else seqTs + unackedMessageMaxAge
      set *seqCounter = seqTs
      set *messages = union msgs [{messageId: messageId, toKey: toKey, encryptedBlob: encryptedBlob, timestamp: clampTimestamp timestamp t, originServer: originServer, receivedAt: seqTs, expiresAt: cappedExpiry, senderKey: "", priority: clamp 0 maxMessagePriority priority}]
      set *pollWakeup = seqTs
      yield ""

-- POST /federation/forward: receive a single federated message destined for
-- a local key. Delegates the actual store decision to `storeFederated`,
-- which returns "" on success (including the duplicate case).
handleForwardMessage : PubkeyHex -> BlobHex -> Timestamp -> ServerName -> MessageIdHex -> ServerName -> Timestamp -> Timestamp -> Int -> Text -> ({ok: Bool, error: Text, retryAfterMs: Int} -> ret) -> IO {network} ret
handleForwardMessage = \toKey encryptedBlob timestamp originServer messageId fromServer requestTimestamp expiresAt priority authorization respond -> do
  t <- now
  withFederationAuth authorization t respond fromServer ("forward:" ++ messageId) requestTimestamp (isRemote originServer && isRemote fromServer) (do
    if t - timestamp > messageMaxAge
      then yield (respond {ok: False {}, error: "stale_timestamp", retryAfterMs: 0})
      else do
        result <- atomic (storeFederated toKey encryptedBlob timestamp originServer messageId expiresAt priority (True {}) t)
        yield (respond {ok: result == "", error: result, retryAfterMs: 0}))

-- POST /federation/ack: peer reports it has acked messages we forwarded to it.
-- We drop the matching `forwards` rows; if the recipient is no longer locally
-- live and no other forward is still pending for the same id, also reap the
-- backing `messages` row (after `ackGracePeriod` to dampen race with /poll).
handleFederationAck : [MessageIdHex] -> ServerName -> ServerName -> Timestamp -> Text -> ({ok: Bool, error: Text, ackedCount: Int, results: [{messageId: MessageIdHex, found: Bool}], retryAfterMs: Int} -> ret) -> IO {network} ret
handleFederationAck = \messageIds originServer fromServer requestTimestamp authorization respond -> do
  t <- now
  let ackRespond = \r -> respond {ok: r.ok, error: r.error, ackedCount: 0, results: [], retryAfterMs: r.retryAfterMs}
  withFederationAuth authorization t ackRespond fromServer "ack" requestTimestamp (isLocalServer originServer && isRemote fromServer) (do
    let dedupedIds = dedupMessageIds messageIds
    result <- atomic do
      fwds <- *forwards
      let isAcked = \f -> f.toServer == fromServer && elem dedupedIds f.messageId
      let removed = filter fwds isAcked
      let remainingFwds = removeWhere fwds isAcked
      set *forwards = remainingFwds
      msgs <- *messages
      let removedIds = pluck removed (\f -> f.messageId)
      pres <- *presence
      let toReap = filter msgs (\m ->
        elem removedIds m.messageId
        && t - m.receivedAt >= ackGracePeriod
        && none pres (\p -> p.pubkey == m.toKey && isLocalServer p.server && p.expiresAt > t)
        && none remainingFwds (\f -> f.messageId == m.messageId && f.toKey == m.toKey))
      set *messages = removeWhere msgs (\m -> hasMessage m.messageId m.toKey toReap)
      yield {ackedCount: count removed, results: pluck dedupedIds (\mid -> {messageId: mid, found: any removed (\f -> f.messageId == mid)})}
    yield (respond {ok: True {}, error: "", ackedCount: result.ackedCount, results: result.results, retryAfterMs: 0}))

-- POST /federation/cancel: peer asks us to cancel a message it originated
-- here. The owner predicate requires `originServer == fromServer` so peers
-- can only cancel their own messages.
handleFederationCancel : MessageIdHex -> PubkeyHex -> ServerName -> Timestamp -> Text -> ({ok: Bool, error: Text, cancelled: Bool, retryAfterMs: Int} -> ret) -> IO {network} ret
handleFederationCancel = \messageId toKey fromServer requestTimestamp authorization respond -> do
  t <- now
  let cancelRespond = \r -> respond {ok: r.ok, error: r.error, cancelled: False {}, retryAfterMs: r.retryAfterMs}
  withFederationAuth authorization t cancelRespond fromServer ("cancel:" ++ messageId) requestTimestamp (isRemote fromServer) (do
    cancelled <- cancelOne messageId toKey (\m -> m.originServer == fromServer) t
    yield (respond {ok: True {}, error: "", cancelled: cancelled, retryAfterMs: 0}))

-- POST /federation/cancel-batch: same ownership constraint as
-- `handleFederationCancel`, applied independently per entry.
handleFederationBatchCancel : [{messageId: MessageIdHex, toKey: PubkeyHex}] -> ServerName -> Timestamp -> Text -> ({ok: Bool, error: Text, results: [BatchCancelResult], retryAfterMs: Int} -> ret) -> IO {network} ret
handleFederationBatchCancel = \cancels fromServer requestTimestamp authorization respond -> do
  t <- now
  let batchRespond = \r -> respond {ok: r.ok, error: r.error, results: [], retryAfterMs: r.retryAfterMs}
  withFederationAuth authorization t batchRespond fromServer "cancel-batch" requestTimestamp (isRemote fromServer && count cancels <= maxBatchSize) (do
    results <- mapEach (takeRelation maxBatchSize cancels) (\e -> do
      cancelled <- cancelOne e.messageId e.toKey (\m -> m.originServer == fromServer) t
      yield {messageId: e.messageId, cancelled: cancelled})
    yield (respond {ok: True {}, error: "", results: results, retryAfterMs: 0}))

-- POST /federation/forward-batch: bulk variant of `handleForwardMessage`.
-- Skips per-entry recv-rate charging (the per-server federation rate limit
-- already gates the call as a whole).
handleFederationBatchForward : [{toKey: PubkeyHex, encryptedBlob: BlobHex, timestamp: Timestamp, originServer: ServerName, messageId: MessageIdHex, expiresAt: Timestamp, priority: Int}] -> ServerName -> Timestamp -> Text -> ({ok: Bool, error: Text, results: [{messageId: MessageIdHex, ok: Bool}], retryAfterMs: Int} -> ret) -> IO {network} ret
handleFederationBatchForward = \forwards fromServer requestTimestamp authorization respond -> do
  t <- now
  let batchRespond = \r -> respond {ok: r.ok, error: r.error, results: [], retryAfterMs: r.retryAfterMs}
  withFederationAuth authorization t batchRespond fromServer "forward-batch" requestTimestamp (isRemote fromServer && count forwards <= maxBatchSize) (do
    results <- mapEach (takeRelation maxBatchSize forwards) (\e -> do
      ok <- if isLocalServer e.originServer || t - e.timestamp > messageMaxAge then yield False {}
        else do
          result <- atomic (storeFederated e.toKey e.encryptedBlob e.timestamp e.originServer e.messageId e.expiresAt e.priority (False {}) t)
          yield (result == "")
      yield {messageId: e.messageId, ok: ok})
    yield (respond {ok: True {}, error: "", results: results, retryAfterMs: 0}))

-- POST /federation/delivery-receipt: peer confirms delivery of messages whose
-- sender is local to us; we record per-sender delivery rows so that sender's
-- next /poll can include the deliveredAt timestamp.
handleFederationDeliveryReceipt : [MessageIdHex] -> [PubkeyHex] -> ServerName -> Timestamp -> Text -> ({ok: Bool, error: Text, receivedCount: Int, retryAfterMs: Int} -> ret) -> IO {network} ret
handleFederationDeliveryReceipt = \messageIds toKeys fromServer requestTimestamp authorization respond -> do
  t <- now
  let receiptRespond = \r -> respond {ok: r.ok, error: r.error, receivedCount: 0, retryAfterMs: r.retryAfterMs}
  withFederationAuth authorization t receiptRespond fromServer "delivery-receipt" requestTimestamp (isRemote fromServer && count messageIds <= maxMessageIds) (do
    if count messageIds != count toKeys
      then yield (respond {ok: False {}, error: "mismatched_lengths", receivedCount: 0, retryAfterMs: 0})
      else do
        let pairs = do
          mp <- withIndex messageIds
          kp <- withIndex toKeys
          where mp.i == kp.i
          yield {messageId: mp.v, toKey: kp.v}
        atomic do
          msgs <- *messages
          sds <- *senderDeliveries
          let newDels = do
                p <- pairs
                m <- msgs
                where m.messageId == p.messageId && m.toKey == p.toKey && m.senderKey != "" && m.originServer == ""
                yield {senderKey: m.senderKey, messageId: p.messageId, toKey: p.toKey, deliveredAt: t}
          set *senderDeliveries = capList (union sds newDels) 10000 (\d -> d.deliveredAt)
        yield (respond {ok: True {}, error: "", receivedCount: count pairs, retryAfterMs: 0}))

-- ============================================
-- Maintenance handlers
-- ============================================
-- Operator endpoints, all gated by `runtimeMaintenanceSecret` (Bearer header).
-- Drain is two-phase: phase 1 stops accepting new auth, phase 2 also clears
-- local presence and gossips offline. Admin endpoints can revoke sessions by
-- pubkey or IP, purge a recipient's mailbox, list aggregated session activity,
-- block/allow peers, rotate the maintenance secret, and read live config.

-- POST /maintenance/drain: phase 1 stops accepting new auth (challenges,
-- verify); phase 2 additionally clears local presence and broadcasts offline
-- gossip for every locally-live key so peers can reroute. Idempotent.
handleDrain : Int -> Text -> ({ok: Bool, drained: Int, phase: Int} -> ret) -> IO {network} ret
handleDrain = \phase authorization respond -> withMaintAuth authorization
  (yield (respond {ok: False {}, drained: 0, phase: 0}))
  (do
    let effectivePhase = if phase == 1 then 1 else 2
    t <- now
    drainResult <- atomic do
      set *drainPhase = effectivePhase
      set *drainCompletedAt = t
      if effectivePhase == 1 then yield {peers: [], localKeys: []}
      else do
        pres <- *presence
        let isLocalLive = \p -> isLocalServer p.server && p.expiresAt > t
        set *presence = removeWhere pres isLocalLive
        set *pollWakeup = t
        yield {peers: knownPeerServersFromPresence pres, localKeys: filter pres isLocalLive}
    when (effectivePhase == 2 && count drainResult.localKeys > 0 && federationEnabled)
      (fork (sendBatchedGossip drainResult.peers (pluck drainResult.localKeys (\p -> mkGossip (GossipOffline {}) p.pubkey t offlineGossipMinTtl))))
    yield (respond {ok: True {}, drained: count drainResult.localKeys, phase: effectivePhase}))

-- POST /maintenance/undrain: clear drain state and resume normal operation.
-- Does not restore presence — clients must re-authenticate to repopulate.
handleUndrain : Text -> ({ok: Bool} -> ret) -> IO {} ret
handleUndrain = \authorization respond -> withMaintAuth authorization
  (yield (respond {ok: False {}}))
  (do
    atomic do
      set *drainPhase = 0
      set *drainCompletedAt = 0
    yield (respond {ok: True {}}))

-- POST /maintenance/shutdown: convenience wrapper that performs a phase-2
-- drain and reports the count of presence rows cleared.
handleShutdown : Text -> ({ok: Bool, drained: Int} -> ret) -> IO {network} ret
handleShutdown = \authorization respond ->
  handleDrain 2 authorization (\r -> respond {ok: r.ok, drained: r.drained})

-- POST /maintenance/prune: trigger an out-of-band `pruneAndRetry` tick.
-- Useful when the operator wants to force expiry/forward retries without
-- waiting for the next `backgroundPrune` interval.
handlePrune : Text -> ({ok: Bool} -> ret) -> IO {network} ret
handlePrune = \authorization respond -> do
  t <- now
  authorized <- verifyMaintenanceAuth authorization
  when authorized (fork (pruneAndRetry t))
  yield (respond {ok: authorized})

-- POST /maintenance/reconcile: stub. Production builds run a state
-- reconciliation pass here; this simplified server reports zero drift.
handleReconcile : Text -> ({ok: Bool, messageDrift: Int, presenceDrift: Int, sessionDrift: Int} -> ret) -> IO {} ret
handleReconcile = \authorization respond -> do
  authorized <- verifyMaintenanceAuth authorization
  yield (respond {ok: authorized, messageDrift: 0, presenceDrift: 0, sessionDrift: 0})

-- GET /health: aggregate readiness flags. During an initial warmup window
-- (3 prune intervals after startup) prune/heartbeat checks always pass to
-- avoid false negatives before the background loops have ticked.
handleHealth : Text -> ({ok: Bool, version: Text, pruneHealthy: Bool, heartbeatHealthy: Bool, capacityHealthy: Bool, capacityWarning: Bool, federationHealthy: Bool, watchdogHealthy: Bool, nonceHealthy: Bool, forwardQueueHealthy: Bool, requestPressureHealthy: Bool, draining: Bool, degradedPeers: Int} -> ret) -> IO {} ret
handleHealth = \authorization respond -> do
  t <- now
  lastPrune <- *lastPrunedAt
  lastHb <- *lastHeartbeatAt
  sa <- *startedAt
  dp <- *drainPhase
  let warmup = t - sa < backgroundPruneInterval * 3
  let pruneOk = warmup || t - lastPrune < backgroundPruneInterval * 3
  let heartbeatOk = warmup || t - lastHb < pollTimeoutMs * 3
  yield (respond {ok: dp == 0 && pruneOk && heartbeatOk, version: serverBuildVersion, pruneHealthy: pruneOk, heartbeatHealthy: heartbeatOk, capacityHealthy: True {}, capacityWarning: False {}, federationHealthy: True {}, watchdogHealthy: True {}, nonceHealthy: True {}, forwardQueueHealthy: True {}, requestPressureHealthy: True {}, draining: dp > 0, degradedPeers: 0})

-- GET /ready: signals readiness once the first background prune has run
-- (load-balancer / orchestrator probe).
handleReady : ({ready: Bool} -> ret) -> IO {} ret
handleReady = \respond -> do
  sa <- *startedAt
  lastPrune <- *lastPrunedAt
  yield (respond {ready: lastPrune > 0 && lastPrune >= sa})

-- POST /maintenance/block: deny-list a peer. Outbound retries skip blocked
-- peers; inbound federation calls from blocked peers fail in `withFederationAuth`.
handleBlockPeer : ServerName -> Text -> ({ok: Bool, blocked: Int} -> ret) -> IO {} ret
handleBlockPeer = \server authorization respond -> withMaintAuth authorization
  (yield (respond {ok: False {}, blocked: 0}))
  (do
    n <- atomic do
      current <- *blockedPeers
      let updated = unique (union current [server])
      set *blockedPeers = updated
      yield (count updated)
    yield (respond {ok: True {}, blocked: n}))

-- POST /maintenance/unblock: remove a peer from the deny-list.
handleUnblockPeer : ServerName -> Text -> ({ok: Bool, unblocked: Bool} -> ret) -> IO {} ret
handleUnblockPeer = \server authorization respond -> withMaintAuth authorization
  (yield (respond {ok: False {}, unblocked: False {}}))
  (do
    removed <- atomic do
      current <- *blockedPeers
      set *blockedPeers = removeWhere current (\x -> x == server)
      yield (elem current server)
    yield (respond {ok: True {}, unblocked: removed}))

handleListBlocked : Text -> ({peers: [Text], ok: Bool} -> ret) -> IO {} ret
handleListBlocked = \authorization respond -> do
  ok <- verifyMaintenanceAuth authorization
  list <- *blockedPeers
  yield (respond {peers: if ok then list else [], ok: ok})

-- POST /maintenance/allow: when the allowed-peers list is non-empty, only
-- federation calls from listed peers are accepted (whitelist mode). An empty
-- list disables the whitelist.
handleAllowPeer : ServerName -> Text -> ({ok: Bool, allowed: Int} -> ret) -> IO {} ret
handleAllowPeer = \server authorization respond -> withMaintAuth authorization
  (yield (respond {ok: False {}, allowed: 0}))
  (do
    n <- atomic do
      current <- *allowedPeers
      let updated = unique (union current [server])
      set *allowedPeers = updated
      yield (count updated)
    yield (respond {ok: True {}, allowed: n}))

-- POST /maintenance/unallow: remove an entry from the allow-list. If the
-- list becomes empty, the whitelist gate disengages.
handleUnallowPeer : ServerName -> Text -> ({ok: Bool, removed: Bool} -> ret) -> IO {} ret
handleUnallowPeer = \server authorization respond -> withMaintAuth authorization
  (yield (respond {ok: False {}, removed: False {}}))
  (do
    removed <- atomic do
      current <- *allowedPeers
      set *allowedPeers = removeWhere current (\x -> x == server)
      yield (elem current server)
    yield (respond {ok: True {}, removed: removed}))

handleListAllowed : Text -> ({peers: [Text], ok: Bool} -> ret) -> IO {} ret
handleListAllowed = \authorization respond -> do
  ok <- verifyMaintenanceAuth authorization
  list <- *allowedPeers
  yield (respond {peers: if ok then list else [], ok: ok})

-- POST /maintenance/ping: send a zero-event gossip to a peer and return the
-- round-trip latency. Useful for diagnosing federation reachability without
-- waiting for organic traffic.
handlePingPeer : ServerName -> Text -> ({ok: Bool, latencyMs: Int, error: Text} -> ret) -> IO {network} ret
handlePingPeer = \server authorization respond -> withMaintAuth authorization
  (yield (respond {ok: False {}, latencyMs: 0, error: "unauthorized"}))
  (do
    startTime <- now
    auth <- generateFederationAuth "gossip" startTime
    result <- fetch (federationUrl server) (RecvGossip {
      authorization: auth,
      events: [], hopsRemaining: 1, fromServer: serverHostN,
      requestTimestamp: startTime, correlationId: "", protocolVersion: federationProtocolVersion})
    endTime <- now
    case result of
      Err e -> yield (respond {ok: False {}, latencyMs: endTime - startTime, error: show e})
      Ok {value: r} -> yield (respond {ok: r.ok, latencyMs: endTime - startTime, error: r.error}))

-- GET /maintenance/sessions/{pubkey}: list a single user's active sessions.
-- Token values are masked ("***") — operators see expiry, ip, createdAt only.
handleAdminListSessions : PubkeyHex -> Text -> ({sessions: [{token: Text, expiresAt: Timestamp, ip: Text, createdAt: Timestamp}], count: Int, ok: Bool} -> ret) -> IO {} ret
handleAdminListSessions = \pubkey authorization respond -> do
  ok <- verifyMaintenanceAuth authorization
  ses <- *sessions
  let mine = if ok then mapWhere ses (\s -> s.pubkey == pubkey) (\s -> {token: "***", expiresAt: s.expiresAt, ip: s.ip, createdAt: s.createdAt}) else []
  yield (respond {sessions: mine, count: count mine, ok: ok})

-- POST /maintenance/sessions/revoke-all: drop every session and local presence
-- row for `pubkey`. Operator-side kick for a compromised key.
handleAdminRevokeSessions : PubkeyHex -> Text -> ({ok: Bool, revokedCount: Int} -> ret) -> IO {} ret
handleAdminRevokeSessions = \pubkey authorization respond -> withMaintAuth authorization
  (yield (respond {ok: False {}, revokedCount: 0}))
  (do
    revoked <- atomic do
      ses <- *sessions
      let same = \s -> s.pubkey == pubkey
      set *sessions = removeWhere ses same
      pres <- *presence
      set *presence = filter pres (\p -> p.pubkey != pubkey || isRemote p.server)
      yield (countWhere ses same)
    yield (respond {ok: True {}, revokedCount: revoked}))

-- POST /maintenance/messages/purge: drop all queued/forwarding messages
-- destined for `pubkey`, recording federation acks for any that originated
-- elsewhere so peers learn we have nothing for the key.
handleAdminPurgeMessages : PubkeyHex -> Text -> ({ok: Bool, purgedCount: Int} -> ret) -> IO {} ret
handleAdminPurgeMessages = \pubkey authorization respond -> withMaintAuth authorization
  (yield (respond {ok: False {}, purgedCount: 0}))
  (do
    t <- now
    purged <- atomic do
      msgs <- *messages
      let mine = \m -> m.toKey == pubkey
      let purgedMsgs = filter msgs mine
      set *messages = removeWhere msgs mine
      fwds <- *forwards
      set *forwards = filter fwds (\f -> f.toKey != pubkey)
      aids <- *ackedIds
      set *ackedIds = capList (union aids (mapWhere purgedMsgs (\m -> m.originServer != "") (\m -> mkAckedEntry m t))) maxAckedIds (\a -> a.ackedAt)
      yield (count purgedMsgs)
    yield (respond {ok: True {}, purgedCount: purged}))

-- POST /maintenance/sessions/revoke-ip: kill every session bound to a given
-- client IP, regardless of pubkey. Reports total revoked + distinct keys.
handleAdminRevokeIp : Text -> Text -> ({ok: Bool, revokedCount: Int, affectedKeys: Int} -> ret) -> IO {} ret
handleAdminRevokeIp = \ip authorization respond -> withMaintAuth authorization
  (yield (respond {ok: False {}, revokedCount: 0, affectedKeys: 0}))
  (do
    keys <- if ip == "" then yield [] else atomic do
      ses <- *sessions
      let same = \s -> s.ip == ip
      set *sessions = removeWhere ses same
      yield (mapWhere ses same (\s -> s.pubkey))
    yield (respond {ok: ip != "", revokedCount: count keys, affectedKeys: count (unique keys)}))

-- POST /maintenance/sessions/list: paged session inventory aggregated by
-- pubkey (count, distinct ips, latest expiry). Sorted by descending count.
handleAdminListAllSessions : Int -> Text -> ({sessions: [{pubkey: PubkeyHex, count: Int, ips: [Text], latestExpiry: Timestamp}], ok: Bool, total: Int} -> ret) -> IO {} ret
handleAdminListAllSessions = \limit authorization respond -> withMaintAuth authorization
  (yield (respond {sessions: [], ok: False {}, total: 0}))
  (do
    t <- now
    ses <- *sessions
    let active = filter ses (\s -> s.expiresAt > t)
    let grouped = pluck (unique (pluck active (\s -> s.pubkey))) (\pk ->
      let mine = filter active (\s -> s.pubkey == pk) in
      {pubkey: pk,
       count: count mine,
       ips: unique (mapWhere mine (\s -> s.ip != "") (\s -> s.ip)),
       latestExpiry: fold (\acc s -> max acc s.expiresAt) 0 mine})
    let cap = clamp 1 500 (if limit <= 0 then 100 else limit)
    let top = takeRelation cap (sortBy (\g -> 0 - g.count) grouped)
    yield (respond {sessions: top, ok: True {}, total: count grouped}))

-- GET /maintenance/rate-limits: expose the configured rate ceilings. Returns
-- zeros for unauthenticated callers (response shape stays stable).
handleGetRateLimits : Text -> ({ok: Bool, globalRequest: Int, ipRate: Int, sendRate: Int, federationRate: Int, authGlobal: Int, recvRate: Int, challengeRate: Int, pairRate: Int, lookupRate: Int, clientWriteRate: Int} -> ret) -> IO {} ret
handleGetRateLimits = \authorization respond -> do
  ok <- verifyMaintenanceAuth authorization
  let v = \x -> if ok then x else 0
  yield (respond {ok: ok, globalRequest: v maxGlobalRequestRate, ipRate: v maxIpRatePerIp, sendRate: v maxSendRatePerKey, federationRate: v maxFederationRatePerServer, authGlobal: v maxAuthGlobalRate, recvRate: v maxRecvRatePerKey, challengeRate: v maxChallengeRatePerKey, pairRate: v maxPairRatePerPair, lookupRate: v maxLookupRatePerKey, clientWriteRate: v maxClientWriteRatePerKey})

-- POST /maintenance/rate-limits: stub. Rate ceilings are compile-time constants
-- in this simplified server, so this just authorizes and returns ok=true.
handleSetRateLimits : Int -> Int -> Int -> Int -> Int -> Int -> Int -> Int -> Int -> Int -> Text -> ({ok: Bool} -> ret) -> IO {} ret
handleSetRateLimits = \globalRequest ipRate sendRate federationRate authGlobal recvRate challengeRate pairRate lookupRate clientWriteRate authorization respond -> do
  authorized <- verifyMaintenanceAuth authorization
  yield (respond {ok: authorized})

-- POST /maintenance/nonces/flush: stub. Nonce caches were removed; the
-- endpoint is preserved so older operator tooling keeps working.
handleFlushNonces : Text -> ({ok: Bool, flushedCount: Int} -> ret) -> IO {} ret
handleFlushNonces = \authorization respond -> do
  authorized <- verifyMaintenanceAuth authorization
  yield (respond {ok: authorized, flushedCount: 0})

-- POST /maintenance/rotate-secret: replace the maintenance Bearer secret.
-- The old secret authenticates the rotation; subsequent calls must use the
-- new value.
handleRotateSecret : Text -> Text -> ({ok: Bool, error: Text} -> ret) -> IO {} ret
handleRotateSecret = \newSecret authorization respond -> withMaintAuth authorization
  (yield (respond {ok: False {}, error: "unauthorized"}))
  (do
    atomic do set *runtimeMaintenanceSecret = newSecret
    yield (respond {ok: True {}, error: ""}))

-- GET /maintenance/config: expose a small set of operationally-relevant
-- compile-time constants (mailbox cap, gossip hops, poll timeout, ack grace).
handleGetConfig : Text -> ({ok: Bool, maxMessagesPerRecipient: Int, maxGossipHops: Int, pollTimeoutMs: Int, ackGracePeriod: Int} -> ret) -> IO {} ret
handleGetConfig = \authorization respond -> do
  ok <- verifyMaintenanceAuth authorization
  let v = \x -> if ok then x else 0
  yield (respond {ok: ok, maxMessagesPerRecipient: v maxMessagesPerRecipient, maxGossipHops: v maxGossipHops, pollTimeoutMs: v pollTimeoutMs, ackGracePeriod: v ackGracePeriod})

-- GET /stats: capacity gauges + minimal federation/timing snapshot. Most of
-- the historical metric fields are zero-filled (see `zeroStats`) — only the
-- counts that come straight from the state refs are populated.
handleStats : Text -> ({ok: Bool, version: Text, capacity: {sessions: Int, sessionsMax: Int, sessionsPct: Int, messages: Int, messagesMax: Int, messagesPct: Int, totalMessageCount: Int, presence: Int, presenceMax: Int, presencePct: Int, forwards: Int, forwardsMax: Int, forwardsPct: Int, challenges: Int, challengesMax: Int, ackedIds: Int, ackedIdsMax: Int, ackOverflow: Int, ackOverflowMax: Int, deliveredIds: Int, deliveredIdsMax: Int, forwardNonces: Int, forwardNoncesMax: Int, nonceEvictions: Int, activePolls: Int, activePollsMax: Int, recipientCounts: Int, messageBucketMax: Int, messageBucketMin: Int}, federation: {enabled: Bool, inFlight: Int, hungSlots: Int, avgLatencyMs: Int, maxLatencyMs: Int, callCount: Int, slowVerifies: Int, verifyFailures: Int, forwardFailures: Int, oldestForwardAge: Int, oldestAckAge: Int, recentGossip: Int, blockedPeers: Int, drainCompletedAt: Timestamp, forwardServers: Int, maxForwardQueueDepth: Int, topFailingPeers: [{server: Text, failures: Int}], pendingCancels: Int, gossipSuccess: Int, gossipFail: Int, latencyBuckets: {lt100: Int, lt500: Int, lt2000: Int, gte2000: Int}}, rates: {send: Int, challenge: Int, federation: Int, federationPair: Int, global: Int, ip: Int, lookup: Int, recv: Int, pair: Int, gossipEvent: Int, verifyIp: Int, uniqueKeyIp: Int, pendingAckCleanups: Int, senderExpirations: Int, senderDeliveries: Int, rejectedGlobal: Int, rejectedIp: Int, rejectedAuth: Int, rejectedPerKey: Int, rejectedFederation: Int, clientCancels: Int, federationCancels: Int}, timing: {pruneCount: Int, pruneRunning: Timestamp, heartbeatCount: Int, uptime: Int, lastPruneAt: Timestamp, lastHeartbeatAt: Timestamp, draining: Bool, drainPhase: Int, totalEntries: Int, activeRequests: Int, peakActiveRequests: Int, pollAvgMs: Int, pollMaxMs: Int, pollCount: Int, pollLatencyBuckets: {lt50: Int, lt200: Int, lt1000: Int, gte1000: Int}, sendAvgMs: Int, sendMaxMs: Int, sendCount: Int, sendLatencyBuckets: {lt50: Int, lt200: Int, lt1000: Int, gte1000: Int}, authAvgMs: Int, authMaxMs: Int, authCount: Int}} -> ret) -> IO {} ret
handleStats = \authorization respond -> withMaintAuth authorization
  (yield (respond zeroStats))
  (do
    t <- now
    sa <- *startedAt
    sessions <- *sessions
    msgs <- *messages
    pres <- *presence
    fwds <- *forwards
    aids <- *ackedIds
    dids <- *deliveredIds
    aps <- *activePolls
    chs <- *challenges
    bp <- *blockedPeers
    pc <- *pruneCount
    hc <- *heartbeatCount
    lp <- *lastPrunedAt
    lh <- *lastHeartbeatAt
    dp <- *drainPhase
    pfc <- *pendingFederationCancels
    let sCount = count sessions
    let mCount = count msgs
    let pCount = count pres
    let fCount = count fwds
    yield (respond {ok: True {}, version: serverBuildVersion,
      capacity: {sessions: sCount, sessionsMax: maxSessions, sessionsPct: pct sCount maxSessions, messages: mCount, messagesMax: maxMessages, messagesPct: pct mCount maxMessages, totalMessageCount: mCount, presence: pCount, presenceMax: maxPresenceEntries, presencePct: pct pCount maxPresenceEntries, forwards: fCount, forwardsMax: maxForwardsEntries, forwardsPct: pct fCount maxForwardsEntries, challenges: count chs, challengesMax: maxChallenges, ackedIds: count aids, ackedIdsMax: maxAckedIds, ackOverflow: 0, ackOverflowMax: 0, deliveredIds: count dids, deliveredIdsMax: maxDeliveredIds, forwardNonces: 0, forwardNoncesMax: 0, nonceEvictions: 0, activePolls: count aps, activePollsMax: maxActivePolls, recipientCounts: 0, messageBucketMax: 0, messageBucketMin: 0},
      federation: {enabled: federationEnabled, inFlight: 0, hungSlots: 0, avgLatencyMs: 0, maxLatencyMs: 0, callCount: 0, slowVerifies: 0, verifyFailures: 0, forwardFailures: 0, oldestForwardAge: 0, oldestAckAge: 0, recentGossip: 0, blockedPeers: count bp, drainCompletedAt: 0, forwardServers: 0, maxForwardQueueDepth: 0, topFailingPeers: [], pendingCancels: count pfc, gossipSuccess: 0, gossipFail: 0, latencyBuckets: {lt100: 0, lt500: 0, lt2000: 0, gte2000: 0}},
      rates: {send: 0, challenge: 0, federation: 0, federationPair: 0, global: 0, ip: 0, lookup: 0, recv: 0, pair: 0, gossipEvent: 0, verifyIp: 0, uniqueKeyIp: 0, pendingAckCleanups: 0, senderExpirations: 0, senderDeliveries: 0, rejectedGlobal: 0, rejectedIp: 0, rejectedAuth: 0, rejectedPerKey: 0, rejectedFederation: 0, clientCancels: 0, federationCancels: 0},
      timing: {pruneCount: pc, pruneRunning: 0, heartbeatCount: hc, uptime: t - sa, lastPruneAt: lp, lastHeartbeatAt: lh, draining: dp > 0, drainPhase: dp, totalEntries: sCount + mCount + pCount + fCount, activeRequests: 0, peakActiveRequests: 0, pollAvgMs: 0, pollMaxMs: 0, pollCount: 0, pollLatencyBuckets: {lt50: 0, lt200: 0, lt1000: 0, gte1000: 0}, sendAvgMs: 0, sendMaxMs: 0, sendCount: 0, sendLatencyBuckets: {lt50: 0, lt200: 0, lt1000: 0, gte1000: 0}, authAvgMs: 0, authMaxMs: 0, authCount: 0}}))

zeroStats : {ok: Bool, version: Text, capacity: {sessions: Int, sessionsMax: Int, sessionsPct: Int, messages: Int, messagesMax: Int, messagesPct: Int, totalMessageCount: Int, presence: Int, presenceMax: Int, presencePct: Int, forwards: Int, forwardsMax: Int, forwardsPct: Int, challenges: Int, challengesMax: Int, ackedIds: Int, ackedIdsMax: Int, ackOverflow: Int, ackOverflowMax: Int, deliveredIds: Int, deliveredIdsMax: Int, forwardNonces: Int, forwardNoncesMax: Int, nonceEvictions: Int, activePolls: Int, activePollsMax: Int, recipientCounts: Int, messageBucketMax: Int, messageBucketMin: Int}, federation: {enabled: Bool, inFlight: Int, hungSlots: Int, avgLatencyMs: Int, maxLatencyMs: Int, callCount: Int, slowVerifies: Int, verifyFailures: Int, forwardFailures: Int, oldestForwardAge: Int, oldestAckAge: Int, recentGossip: Int, blockedPeers: Int, drainCompletedAt: Timestamp, forwardServers: Int, maxForwardQueueDepth: Int, topFailingPeers: [{server: Text, failures: Int}], pendingCancels: Int, gossipSuccess: Int, gossipFail: Int, latencyBuckets: {lt100: Int, lt500: Int, lt2000: Int, gte2000: Int}}, rates: {send: Int, challenge: Int, federation: Int, federationPair: Int, global: Int, ip: Int, lookup: Int, recv: Int, pair: Int, gossipEvent: Int, verifyIp: Int, uniqueKeyIp: Int, pendingAckCleanups: Int, senderExpirations: Int, senderDeliveries: Int, rejectedGlobal: Int, rejectedIp: Int, rejectedAuth: Int, rejectedPerKey: Int, rejectedFederation: Int, clientCancels: Int, federationCancels: Int}, timing: {pruneCount: Int, pruneRunning: Timestamp, heartbeatCount: Int, uptime: Int, lastPruneAt: Timestamp, lastHeartbeatAt: Timestamp, draining: Bool, drainPhase: Int, totalEntries: Int, activeRequests: Int, peakActiveRequests: Int, pollAvgMs: Int, pollMaxMs: Int, pollCount: Int, pollLatencyBuckets: {lt50: Int, lt200: Int, lt1000: Int, gte1000: Int}, sendAvgMs: Int, sendMaxMs: Int, sendCount: Int, sendLatencyBuckets: {lt50: Int, lt200: Int, lt1000: Int, gte1000: Int}, authAvgMs: Int, authMaxMs: Int, authCount: Int}}
zeroStats = {ok: False {}, version: serverBuildVersion, capacity: {sessions: 0, sessionsMax: 0, sessionsPct: 0, messages: 0, messagesMax: 0, messagesPct: 0, totalMessageCount: 0, presence: 0, presenceMax: 0, presencePct: 0, forwards: 0, forwardsMax: 0, forwardsPct: 0, challenges: 0, challengesMax: 0, ackedIds: 0, ackedIdsMax: 0, ackOverflow: 0, ackOverflowMax: 0, deliveredIds: 0, deliveredIdsMax: 0, forwardNonces: 0, forwardNoncesMax: 0, nonceEvictions: 0, activePolls: 0, activePollsMax: 0, recipientCounts: 0, messageBucketMax: 0, messageBucketMin: 0}, federation: {enabled: False {}, inFlight: 0, hungSlots: 0, avgLatencyMs: 0, maxLatencyMs: 0, callCount: 0, slowVerifies: 0, verifyFailures: 0, forwardFailures: 0, oldestForwardAge: 0, oldestAckAge: 0, recentGossip: 0, blockedPeers: 0, drainCompletedAt: 0, forwardServers: 0, maxForwardQueueDepth: 0, topFailingPeers: [], pendingCancels: 0, gossipSuccess: 0, gossipFail: 0, latencyBuckets: {lt100: 0, lt500: 0, lt2000: 0, gte2000: 0}}, rates: {send: 0, challenge: 0, federation: 0, federationPair: 0, global: 0, ip: 0, lookup: 0, recv: 0, pair: 0, gossipEvent: 0, verifyIp: 0, uniqueKeyIp: 0, pendingAckCleanups: 0, senderExpirations: 0, senderDeliveries: 0, rejectedGlobal: 0, rejectedIp: 0, rejectedAuth: 0, rejectedPerKey: 0, rejectedFederation: 0, clientCancels: 0, federationCancels: 0}, timing: {pruneCount: 0, pruneRunning: 0, heartbeatCount: 0, uptime: 0, lastPruneAt: 0, lastHeartbeatAt: 0, draining: False {}, drainPhase: 0, totalEntries: 0, activeRequests: 0, peakActiveRequests: 0, pollAvgMs: 0, pollMaxMs: 0, pollCount: 0, pollLatencyBuckets: {lt50: 0, lt200: 0, lt1000: 0, gte1000: 0}, sendAvgMs: 0, sendMaxMs: 0, sendCount: 0, sendLatencyBuckets: {lt50: 0, lt200: 0, lt1000: 0, gte1000: 0}, authAvgMs: 0, authMaxMs: 0, authCount: 0}}

-- GET /stats/peers: per-peer failure summary derived from `forwardFailures`,
-- including current backoff and pending forward queue depth.
handleStatsPeers : Text -> ({peers: [PeerStatus], ok: Bool} -> ret) -> IO {} ret
handleStatsPeers = \authorization respond -> withMaintAuth authorization
  (yield (respond {peers: [], ok: False {}}))
  (do
    t <- now
    failures <- *forwardFailures
    fwds <- *forwards
    yield (respond {peers: pluck failures (\f ->
      {server: f.server, failures: f.failures, lastFailedAt: f.failedAt, firstFailedAt: f.firstFailedAt, backoffMs: retryBackoff f.failures, retriable: shouldRetryServer f.server t failures, pendingForwards: countWhere fwds (\x -> x.toServer == f.server), avgLatencyMs: 0, maxLatencyMs: 0, latencySamples: 0, gossipEventsPerMin: 0}), ok: True {}}))

-- GET /stats/key/{pubkey}: per-key footprint — message count, presence rows,
-- session count, queued forwards (with details), and active long-poll count.
handleStatsKey : PubkeyHex -> Text -> ({messages: Int, presence: [KeyPresenceEntry], sessions: Int, forwards: Int, forwardDetails: [{server: Text, retries: Int, createdAt: Timestamp}], activePolls: Int, ok: Bool} -> ret) -> IO {} ret
handleStatsKey = \pubkey authorization respond -> withMaintAuth authorization
  (yield (respond {messages: 0, presence: [], sessions: 0, forwards: 0, forwardDetails: [], activePolls: 0, ok: False {}}))
  (do
    t <- now
    msgs <- *messages
    pres <- *presence
    ses <- *sessions
    fwds <- *forwards
    aps <- *activePolls
    let myFwds = filter fwds (\x -> x.toKey == pubkey)
    yield (respond {
      messages: countWhere msgs (\x -> x.toKey == pubkey),
      presence: mapWhere pres (\x -> x.pubkey == pubkey && x.expiresAt > t) (\x -> {server: x.server, expiresAt: x.expiresAt}),
      sessions: countWhere ses (\x -> x.pubkey == pubkey),
      forwards: count myFwds,
      forwardDetails: pluck myFwds (\x -> {server: x.toServer, retries: x.retries, createdAt: x.createdAt}),
      activePolls: countWhere aps (\x -> x.pubkey == pubkey),
      ok: True {}}))

-- POST /stats/top-recipients: ranked list of pubkeys by mailbox depth.
-- `limit` defaults to 20, capped at 100, used to spot hot-spots / abuse.
handleTopRecipients : Int -> Text -> ({recipients: [RecipientCount], ok: Bool, total: Int} -> ret) -> IO {} ret
handleTopRecipients = \limit authorization respond -> withMaintAuth authorization
  (yield (respond {recipients: [], ok: False {}, total: 0}))
  (do
    msgs <- *messages
    let counts = pluck (unique (pluck msgs (\m -> m.toKey))) (\pk -> {pubkey: pk, count: countWhere msgs (\m -> m.toKey == pk)})
    let cap = clamp 1 100 (if limit <= 0 then 20 else limit)
    let top = takeRelation cap (sortBy (\c -> 0 - c.count) counts)
    yield (respond {recipients: top, ok: True {}, total: count counts}))

-- GET /stats/forwards: per-destination forward queue summary — count, age of
-- oldest pending entry, and total accumulated retries.
handleStatsForwards : Text -> ({servers: [{server: Text, count: Int, oldestAge: Int, totalRetries: Int}], ok: Bool, total: Int} -> ret) -> IO {} ret
handleStatsForwards = \authorization respond -> withMaintAuth authorization
  (yield (respond {servers: [], ok: False {}, total: 0}))
  (do
    t <- now
    fwds <- *forwards
    yield (respond {
      servers: pluck (collectPeers fwds (\f -> f.toServer)) (\s ->
        let svFwds = filter fwds (\f -> f.toServer == s) in
        {server: s, count: count svFwds, oldestAge: t - fold (\acc f -> min acc f.createdAt) t svFwds, totalRetries: fold (\acc f -> acc + f.retries) 0 svFwds}),
      ok: True {},
      total: count fwds}))

-- GET /stats/rates: same shape as /maintenance/rate-limits with an extra
-- scalePct field. Kept separate for backwards compatibility with older clients.
handleStatsRates : Text -> ({ok: Bool, scalePct: Int, globalRequest: Int, ipRate: Int, sendRate: Int, federationRate: Int, authGlobal: Int, recvRate: Int, challengeRate: Int, pairRate: Int, lookupRate: Int, clientWriteRate: Int} -> ret) -> IO {} ret
handleStatsRates = \authorization respond -> do
  ok <- verifyMaintenanceAuth authorization
  let v = \x -> if ok then x else 0
  yield (respond {ok: ok, scalePct: v 100, globalRequest: v maxGlobalRequestRate, ipRate: v maxIpRatePerIp, sendRate: v maxSendRatePerKey, federationRate: v maxFederationRatePerServer, authGlobal: v maxAuthGlobalRate, recvRate: v maxRecvRatePerKey, challengeRate: v maxChallengeRatePerKey, pairRate: v maxPairRatePerPair, lookupRate: v maxLookupRatePerKey, clientWriteRate: v maxClientWriteRatePerKey})

-- GET /metrics: Prometheus-style text exposition of the most useful gauges.
-- The `authorization` header is accepted but not validated here — operators
-- relying on auth must front this endpoint with a reverse proxy that enforces it.
handleMetrics : Text -> ({metrics: Text, ok: Bool} -> ret) -> IO {} ret
handleMetrics = \authorization respond -> do
  t <- now
  msgs <- *messages
  ses <- *sessions
  pres <- *presence
  fwds <- *forwards
  aps <- *activePolls
  sa <- *startedAt
  dp <- *drainPhase
  yield (respond {metrics: fold (\acc r -> acc ++ r.k ++ " " ++ show r.v ++ "\n") "" [
    {k: "skrepka_messages_total", v: count msgs},
    {k: "skrepka_sessions_total", v: count ses},
    {k: "skrepka_presence_total", v: count pres},
    {k: "skrepka_forwards_total", v: count fwds},
    {k: "skrepka_active_polls", v: count aps},
    {k: "skrepka_uptime_seconds", v: (t - sa) / 1000},
    {k: "skrepka_draining", v: if dp > 0 then 1 else 0}], ok: True {}})

-- ============================================
-- Dispatch
-- ============================================
-- Single match from generated request constructor (one per route entry above)
-- to the corresponding `handleXxx` function. Adding a new route means adding
-- a `route ... = NewReq` line, a `handleNewReq` definition, and a clause here.

serve : Api -> IO {network} Response
serve = \req -> case req of
  ReqChallenge {pubkey, clientIp, respond} -> handleChallenge pubkey clientIp respond
  VerifyAuth {pubkey, challenge, signature, revokeOthers, clientIp, respond} -> handleVerifyAuth pubkey challenge signature revokeOthers clientIp respond
  RevokeSession {targetToken, authorization, clientIp, respond} -> handleRevoke targetToken authorization clientIp respond
  Logout {authorization, clientIp, respond} -> handleLogout authorization clientIp respond
  Poll {cursor, generation, watchKeys, authorization, clientIp, respond} -> handlePoll cursor generation watchKeys authorization clientIp respond
  SendMessage {to, encryptedBlob, timestamp, messageId, expiresInMs, priority, authorization, clientIp, respond} -> handleSendMessage to encryptedBlob timestamp messageId expiresInMs priority authorization clientIp respond
  MessageStatus {to, messageId, authorization, clientIp, respond} -> handleMessageStatus to messageId authorization clientIp respond
  AckMessages {messageIds, authorization, clientIp, respond} -> handleAckMessages messageIds authorization clientIp respond
  SendBatch {messages, authorization, clientIp, respond} -> handleSendBatch messages authorization clientIp respond
  ListMessages {offset, authorization, clientIp, respond} -> handleListMessages offset authorization clientIp respond
  DeleteMessages {messageIds, authorization, clientIp, respond} -> handleDeleteMessages messageIds authorization clientIp respond
  CancelMessage {messageId, to, authorization, clientIp, respond} -> handleCancelMessage messageId to authorization clientIp respond
  CancelBatch {cancels, authorization, clientIp, respond} -> handleCancelBatch cancels authorization clientIp respond
  LookupPresence {pubkey, authorization, clientIp, respond} -> handleLookupPresence pubkey authorization clientIp respond
  BatchLookupPresence {pubkeys, authorization, clientIp, respond} -> handleBatchLookupPresence pubkeys authorization clientIp respond
  RecvGossip {events, hopsRemaining, fromServer, requestTimestamp, authorization, respond} -> handleRecvGossip events hopsRemaining fromServer requestTimestamp authorization respond
  ForwardMessage {toKey, encryptedBlob, timestamp, originServer, messageId, fromServer, requestTimestamp, expiresAt, priority, authorization, respond} -> handleForwardMessage toKey encryptedBlob timestamp originServer messageId fromServer requestTimestamp expiresAt priority authorization respond
  FederationAck {messageIds, originServer, fromServer, requestTimestamp, authorization, respond} -> handleFederationAck messageIds originServer fromServer requestTimestamp authorization respond
  FederationCancel {messageId, toKey, fromServer, requestTimestamp, authorization, respond} -> handleFederationCancel messageId toKey fromServer requestTimestamp authorization respond
  FederationBatchCancel {cancels, fromServer, requestTimestamp, authorization, respond} -> handleFederationBatchCancel cancels fromServer requestTimestamp authorization respond
  FederationBatchForward {forwards, fromServer, requestTimestamp, authorization, respond} -> handleFederationBatchForward forwards fromServer requestTimestamp authorization respond
  FederationDeliveryReceipt {messageIds, toKeys, fromServer, requestTimestamp, authorization, respond} -> handleFederationDeliveryReceipt messageIds toKeys fromServer requestTimestamp authorization respond
  VerifyToken {token, scope, clientIp, respond} -> handleVerifyToken token scope clientIp respond
  FederationPubkey {respond} -> handleFederationPubkey respond
  Prune {authorization, respond} -> handlePrune authorization respond
  Drain {phase, authorization, respond} -> handleDrain phase authorization respond
  Shutdown {authorization, respond} -> handleShutdown authorization respond
  Undrain {authorization, respond} -> handleUndrain authorization respond
  BlockPeer {server, authorization, respond} -> handleBlockPeer server authorization respond
  UnblockPeer {server, authorization, respond} -> handleUnblockPeer server authorization respond
  ListBlocked {authorization, respond} -> handleListBlocked authorization respond
  PingPeer {server, authorization, respond} -> handlePingPeer server authorization respond
  AdminListSessions {pubkey, authorization, respond} -> handleAdminListSessions pubkey authorization respond
  AdminRevokeSessions {pubkey, authorization, respond} -> handleAdminRevokeSessions pubkey authorization respond
  AdminListAllSessions {limit, authorization, respond} -> handleAdminListAllSessions limit authorization respond
  AdminPurgeMessages {pubkey, authorization, respond} -> handleAdminPurgeMessages pubkey authorization respond
  AdminRevokeIp {ip, authorization, respond} -> handleAdminRevokeIp ip authorization respond
  GetRateLimits {authorization, respond} -> handleGetRateLimits authorization respond
  SetRateLimits {globalRequest, ipRate, sendRate, federationRate, authGlobal, recvRate, challengeRate, pairRate, lookupRate, clientWriteRate, authorization, respond} -> handleSetRateLimits globalRequest ipRate sendRate federationRate authGlobal recvRate challengeRate pairRate lookupRate clientWriteRate authorization respond
  FlushNonces {authorization, respond} -> handleFlushNonces authorization respond
  AllowPeer {server, authorization, respond} -> handleAllowPeer server authorization respond
  UnallowPeer {server, authorization, respond} -> handleUnallowPeer server authorization respond
  ListAllowed {authorization, respond} -> handleListAllowed authorization respond
  Reconcile {authorization, respond} -> handleReconcile authorization respond
  RotateSecret {newSecret, authorization, respond} -> handleRotateSecret newSecret authorization respond
  GetConfig {authorization, respond} -> handleGetConfig authorization respond
  Health {authorization, respond} -> handleHealth authorization respond
  Stats {authorization, respond} -> handleStats authorization respond
  StatsPeers {authorization, respond} -> handleStatsPeers authorization respond
  StatsKey {pubkey, authorization, respond} -> handleStatsKey pubkey authorization respond
  TopRecipients {limit, authorization, respond} -> handleTopRecipients limit authorization respond
  StatsForwards {authorization, respond} -> handleStatsForwards authorization respond
  StatsRates {authorization, respond} -> handleStatsRates authorization respond
  Metrics {authorization, respond} -> handleMetrics authorization respond
  Ready {respond} -> handleReady respond

-- ============================================
-- Background loops
-- ============================================
-- `backgroundPrune` runs `pruneAndRetry` every `backgroundPruneInterval` ms
-- (skipped while drain phase >= 2). `pollHeartbeat` bumps `pollWakeup` every
-- `pollTimeoutMs` so long-poll holders unblock and return an empty heartbeat
-- response, keeping connections fresh.

backgroundPrune : IO {network} {}
backgroundPrune = do
  sleep backgroundPruneInterval
  dp <- *drainPhase
  when (dp < 2) (do
    t <- now
    atomic do
      pc <- *pruneCount
      set *pruneCount = pc + 1
    pruneAndRetry t)
  backgroundPrune

pollHeartbeat : IO {} {}
pollHeartbeat = do
  sleep pollTimeoutMs
  t <- now
  atomic do
    set *pollWakeup = t
    set *lastHeartbeatAt = t
    hc <- *heartbeatCount
    set *heartbeatCount = hc + 1
  pollHeartbeat

-- ============================================
-- Entry Point
-- ============================================
-- Stamp `startedAt` and a fresh `serverGeneration` (used by clients to detect
-- server restarts and reset their poll cursor), spawn the two background
-- loops, and start the listener.

main : IO {network} {}
main = do
  t <- now
  genJitter <- randomInt 1000000
  atomic do
    set *startedAt = t
    set *serverGeneration = t * 1000 + genJitter
  logInfo ("Skrepka relay server starting on port " ++ show listenPort ++ "...")
  logInfo ("  federation: " ++ if federationEnabled then "enabled" else "disabled")
  fork backgroundPrune
  fork pollHeartbeat
  listen listenPort serve
