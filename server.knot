-- Skrepka Relay Server
-- Single-server implementation of the Skrepka protocol (v0.1)
-- Binary data (keys, signatures, blobs) uses hex encoding (bytesToHex/bytesFromHex)
--
-- Architecture:
--   Clients authenticate via Ed25519 challenge-response, then poll for messages via long-polling.
--   Messages are E2E encrypted blobs routed by recipient pubkey.
--   Federation: servers gossip presence info and forward messages for keys homed elsewhere.
--   Presence tracks which server a pubkey was last seen on (online/offline via gossip).
--   All state is in-memory; background tasks handle pruning and retry of failed federation ops.

-- ============================================
-- Configuration
-- ============================================

-- Server identity and federation credentials
serverHost = "localhost:8080"
maintenanceSecret = "" -- set to enable /maintenance/* and /stats endpoints
federationScheme = "https://" -- scheme for federation HTTP calls
-- NOTE: Outbound federation HTTP calls have no runtime-level timeout. The fetchFederation
-- wrapper tracks in-flight requests per server and skips servers with outstanding requests
-- older than federationFetchTimeoutMs (see shouldRetryServerEx). This prevents a single
-- slow peer from consuming all concurrency slots, though truly hung connections still hold
-- one slot until the forked task terminates.
-- Message and data size limits
messageMaxAge : Int<Ms>
messageMaxAge = 2592000000 -- 30 days
maxPresenceTtl : Int<S>
maxPresenceTtl = 3600 -- max presence TTL from gossip
maxPubkeyLen = 256
maxBlobLen = 65536
maxSignatureLen = 256
maxMessageIds = 100
maxGossipEvents = 100
maxPollEvents = 50
maxPresenceEntries = 10000
maxMessagesPerRecipient = 500
maxMessages = 100000 -- global cap on total stored messages across all recipients
-- Global capacity limits for in-memory collections
clockSkewTolerance : Int<Ms>
clockSkewTolerance = 5000 -- 5 seconds tolerance for clock skew between federated servers
maxForwardsEntries = 10000
maxServerNameLen = 128
maxMessageIdLen = 128
maxTokenLen = 256
maxChallenges = 10000
maxSessions = 10000
maxAckedIds = 10000
maxAckOverflow = 200 -- overflow buffer for acks that couldn't be sent yet
maxDeliveredIds = 10000
-- Per-key limits and rate limiting
maxChallengesPerKey = 5
maxSessionsPerKey = 10
challengeExpiry : Int<Ms>
challengeExpiry = 60000 -- 1 minute
maxChallengeRatePerKey = 5 -- max challenge requests per key per window
maxChallengeRateEntries = 1000
challengeRateWindowMs : Int<Ms>
challengeRateWindowMs = 1000
maxSendRatePerKey = 20 -- max messages sent per key per window
sendRateWindowMs : Int<Ms>
sendRateWindowMs = 1000
maxSendRateEntries = 1000
-- Per-recipient receive rate limiting
maxRecvRatePerKey = 10 -- max messages received by a key per window (across all senders)
recvRateWindowMs : Int<Ms>
recvRateWindowMs = 1000
maxRecvRateEntries = 1000
-- Per-sender-per-recipient rate limiting (prevents one sender from filling a recipient's mailbox)
maxPairRatePerPair = 30 -- max messages per sender-recipient pair per window
pairRateWindowMs : Int<Ms>
pairRateWindowMs = 60000 -- 1 minute
maxPairRateEntries = 5000
-- Federation rate limiting (per-server)
maxFederationRatePerServer = 50 -- max federation requests per server per window
federationRateWindowMs : Int<Ms>
federationRateWindowMs = 1000
maxFederationRateEntries = 100
-- Per-server-per-recipient rate limiting for federation forwards
maxFederationPairRatePerPair = 10 -- max forwards per fromServer-recipient pair per window
federationPairRateWindowMs : Int<Ms>
federationPairRateWindowMs = 60000 -- 1 minute
maxFederationPairRateEntries = 5000
-- Global request rate limiting
maxGlobalRequestRate = 1000 -- max total requests per window
globalRateWindowMs : Int<Ms>
globalRateWindowMs = 1000
-- Auth-tier global rate limiting (prevents auth flooding from starving client operations)
maxAuthGlobalRate = 200 -- max auth requests (challenge + verify + revoke) per window
authGlobalRateWindowMs : Int<Ms>
authGlobalRateWindowMs = 1000
-- Session and gossip timing
sessionExpiry : Int<Ms>
sessionExpiry = 3600000 -- 1 hour
maxSessionLifetime : Int<Ms>
maxSessionLifetime = 86400000 -- 24 hours; absolute session lifetime (forces re-auth even if sliding window keeps refreshing)
onlineGossipTtl : Int<S>
onlineGossipTtl = 3600 -- 1 hour; TTL announced when a key authenticates
offlineGossipMinTtl : Int<S>
offlineGossipMinTtl = 60 -- minimum TTL for offline gossip events
maxFederationConcurrency = 10 -- max concurrent outbound federation requests per cycle
maxForwardRetriesPerServer = 100
maxForwardRetries = 10 -- max retries per individual forward entry before dropping
maxAckRetries = 10 -- max retries per ack entry before dropping to deliveredIds
maxGossipHops = 5 -- max hops a gossip event can propagate across servers
maxThirdPartyGossipHops = 2 -- max re-broadcast hops for relayed (third-party) gossip events
gossipOriginHops = 2 -- hops set when this server originates a gossip event
gossipDedupWindow : Int<Ms>
gossipDedupWindow = 60000 -- suppress re-broadcast of identical gossip events within this window
maxRecentGossip = 1000
-- Exponential backoff for failed federation forwards
retryBackoffBase : Int<Ms>
retryBackoffBase = 30000 -- 30 seconds
retryBackoffMax : Int<Ms>
retryBackoffMax = 480000 -- 8 minutes
maxForwardFailures = 1000 -- max tracked server failure records
maxServerDowntime : Int<Ms>
maxServerDowntime = 86400000 -- 24 hours; stop retrying a server after this duration of consecutive failures
-- Federation in-flight tracking: skip servers with outstanding requests older than this threshold
federationFetchTimeoutMs : Int<Ms>
federationFetchTimeoutMs = 30000 -- 30 seconds; consider server unresponsive if fetch hasn't returned
maxFederationInFlight = 100
-- Federation circuit breaker: pause all outbound federation when this many unique peer
-- servers have active (non-expired) failure records. Prevents wasted retries and log spam
-- when the local network is down. Set to 0 to disable.
federationCircuitBreakerThreshold = 3
-- Federation replay dedup: track recent (server, timestamp) pairs to reject exact replays
maxRecentFederationRequests = 1000
-- Forward nonce dedup: tracks (messageId, toKey) pairs to catch replays
-- beyond the lifetime of messages/ackedIds/deliveredIds
maxForwardNonces = 100000
forwardNonceRetention : Int<Ms>
forwardNonceRetention = messageMaxAge * 2 -- 60 days; extends 30 days beyond message dedup
-- Counter reconciliation: every N prune cycles, recount from truth to self-heal drift
reconciliationFrequency = 10

-- Federation latency metric window
federationLatencyWindowMs : Int<Ms>
federationLatencyWindowMs = 300000 -- 5 minutes; reset latency metrics after this interval

-- Snapshot format version (increment on schema changes to prevent corrupt restores)
snapshotVersion = 3

-- Per-peer gossip event volume limiting (prevents flooding via large batches of unique pubkeys)
maxGossipEventsPerServer = 500 -- max total gossip events per server per window
gossipEventRateWindowMs : Int<Ms>
gossipEventRateWindowMs = 60000 -- 1 minute
maxGossipEventRateEntries = 100
-- Global federation connection cap (bounds total concurrent outbound connections across all paths)
maxGlobalFederationConcurrency = 30
-- Peer blocklist: max blocked servers tracked at runtime (managed via /maintenance/block, /maintenance/unblock)
maxBlockedPeers = 100

-- Background task intervals
backgroundPruneInterval : Int<Ms>
backgroundPruneInterval = 30000 -- 30 seconds; also retries failed forwards/acks
autoSnapshotInterval : Int<Ms>
autoSnapshotInterval = 300000 -- 5 minutes; periodic state summary to stdout (0 to disable)
snapshotStalenessWarning : Int<Ms>
snapshotStalenessWarning = 3600000 -- 1 hour; warn if no snapshot exported via /maintenance/snapshot
pollTimeoutMs : Int<Ms>
pollTimeoutMs = 25000 -- long-poll heartbeat interval (how long a poll blocks before returning empty)
maxPollsPerKey = 3 -- max concurrent long-poll connections per pubkey
maxActivePolls = 5000
maxWatchKeys = 50
presenceRefreshInterval : Int<Ms>
presenceRefreshInterval = 300000 -- 5 minutes
presenceRefreshThreshold : Int<Ms>
presenceRefreshThreshold = presenceRefreshInterval * 2 -- refresh entries expiring within this window
federationEnabled = True {}
-- WARNING: DNS rebinding risk — federationUrl resolves DNS at fetch time, not at
-- ServerName validation time. A hostname passing isBadServerName could rebind to a
-- private IP between validation and fetch. Mitigate at the network layer (e.g.,
-- firewall rules blocking outbound connections to RFC1918 ranges from the server process).
-- TODO: If Knot adds a resolved-IP introspection API (e.g., fetchWithResolvedIp),
-- validate the resolved IP against isBadServerName before completing the request.
federationUrl = \server -> federationScheme ++ server
-- Callback verification: outbound federation requests include a random single-use token;
-- the receiver calls back to /federation/verify to confirm the sender actually issued it.
maxPendingVerifications = 10000
verificationTokenExpiry : Int<Ms>
verificationTokenExpiry = 30000 -- 30 seconds
-- IP-based rate limiting (reverse proxy sets ClientIp header)
maxIpRatePerIp = 10 -- max auth requests per IP per window
ipRateWindowMs : Int<Ms>
ipRateWindowMs = 1000
maxIpRateEntries = 5000
-- Lookup rate limiting (per-key, on presence lookups)
maxLookupRatePerKey = 5 -- max lookups per key per window
lookupRateWindowMs : Int<Ms>
lookupRateWindowMs = 1000
maxLookupRateEntries = 1000
-- Federation verify rate limiting (per-IP, tighter than general IP rate)
maxVerifyRatePerIp = 5 -- max verify requests per IP per window
verifyRateWindowMs : Int<Ms>
verifyRateWindowMs = 1000
maxVerifyRateEntries = 1000
-- Unacked message aging (messages pruned after this regardless of ack status)
unackedMessageMaxAge : Int<Ms>
unackedMessageMaxAge = 604800000 -- 7 days
-- Grace period before federation ack can delete the original message (allows local client to poll)
ackGracePeriod : Int<Ms>
ackGracePeriod = 30000 -- 30 seconds
-- Deferred ack cleanup capacity
maxPendingAckCleanups = 10000
-- Per-key deferred ack cleanup cap (prevents one noisy key from dominating the queue)
maxPendingAckCleanupsPerKey = 100

-- Health check thresholds (background task freshness)
healthPruneMaxAge : Int<Ms>
healthPruneMaxAge = backgroundPruneInterval * 3
healthHeartbeatMaxAge : Int<Ms>
healthHeartbeatMaxAge = pollTimeoutMs * 3
healthWatchdogMaxAge : Int<Ms>
healthWatchdogMaxAge = backgroundPruneInterval * 15 -- watchdog runs every ~5 prune intervals

-- ============================================
-- Types
-- ============================================

-- Event delivered to a polling client: an encrypted message blob
type PollEvent = {id: MessageIdHex, eventType: Text, payload: {encryptedBlob: BlobHex, timestamp: Timestamp, toKey: PubkeyHex}}

-- Gossip events propagate presence changes between federated servers
data GossipEventType = GossipOnline {} | GossipOffline {} | GossipUnknown {}

impl ToJSON GossipEventType where
  toJson et = toJson (case et of
    GossipOnline {} -> "online"
    GossipOffline {} -> "offline"
    GossipUnknown {} -> "unknown")

impl FromJSON GossipEventType where
  parseJson t =
    let s : Text = parseJson t in
    if s == "online" then GossipOnline {}
    else if s == "offline" then GossipOffline {}
    else GossipUnknown {}

-- Wire format for gossip events sent between servers
type GossipEvent = {eventType: GossipEventType, pubkey: PubkeyHex, server: ServerName, timestamp: Timestamp, ttl: Int<S>}

-- A gossip event that passed validation (timestamp not in future, TTL > 0, not expired)
type ValidGossipEntry = {pubkey: PubkeyHex, server: ServerName, expiresAt: Timestamp, timestamp: Timestamp, ttl: Int<S>}

-- Status returned to the sender after SendMessage
-- Delivered: recipient is online locally; Federated: forwarded to remote server;
-- Queued: stored but recipient location unknown; Unauthorized/Rejected: not accepted
data MessageStatus = MsDelivered {} | MsFederated {} | MsQueued {} | MsUnauthorized {} | MsRejected {} | MsRateLimited {} | MsDuplicate {} | MsDraining {}

impl ToJSON MessageStatus where
  toJson ms = toJson (case ms of
    MsDelivered {} -> "delivered"
    MsFederated {} -> "federated"
    MsQueued {} -> "queued"
    MsUnauthorized {} -> "unauthorized"
    MsRejected {} -> "rejected"
    MsRateLimited {} -> "rate_limited"
    MsDuplicate {} -> "duplicate"
    MsDraining {} -> "draining")

-- Validated hex-encoded types with maximum length constraints
isValidBoundedHex : Int -> Text -> Bool
isValidBoundedHex = \maxLen s -> not (tooLong s maxLen) && isValidHex s && s == normalizeHex s
type PubkeyHex = Text where isValidBoundedHex maxPubkeyLen
type BlobHex = Text where isValidBoundedHex maxBlobLen
type SignatureHex = Text where isValidBoundedHex maxSignatureLen
isValidMessageId : Text -> Bool
isValidMessageId = isValidBoundedHex maxMessageIdLen
type MessageIdHex = Text where isValidMessageId
type OptionalMessageId = Text where \s -> s == "" || isValidMessageId s
-- ServerName: validated server hostname (rejects private IPs, localhost, etc.)
-- AnyServerName: normalized server name without the security checks (used in presence lookups)
isValidServerName : Text -> Bool
isValidServerName = \s -> not (tooLong s maxServerNameLen) && s == normalizeServerName s && not (isBadServerName s)
type ServerName = Text where isValidServerName
type AnyServerName = Text where \s -> not (tooLong s maxServerNameLen) && s == normalizeServerName s

type Timestamp = Int<Ms>

-- Pending challenge for Ed25519 challenge-response auth
type Challenge = {pubkey: PubkeyHex, challenge: Text, expiresAt: Timestamp, ip: Text}
-- Authenticated session; token is a random hex string
type Session = {token: Text, pubkey: PubkeyHex, expiresAt: Timestamp, ip: Text, createdAt: Timestamp}
-- Stored message; originServer is "" for locally-originated messages, set to sender server for federated forwards
type Message = {messageId: MessageIdHex, toKey: PubkeyHex, encryptedBlob: BlobHex, timestamp: Timestamp, originServer: Text, receivedAt: Timestamp}
-- Presence: tracks that a pubkey is online at a given server, with expiry
type PresenceEntry = {pubkey: PubkeyHex, server: AnyServerName, expiresAt: Timestamp, timestamp: Timestamp}
-- Queued federation forward: message waiting to be delivered to a remote server
type ForwardEntry = {messageId: MessageIdHex, toServer: ServerName, createdAt: Timestamp, toKey: PubkeyHex, encryptedBlob: BlobHex, timestamp: Timestamp, originServer: Text, retries: Int}
-- Tracks message IDs that were acked by a polling client, pending federation ack back to origin
type AckedEntry = {messageId: MessageIdHex, toKey: PubkeyHex, ackedAt: Timestamp, originServer: ServerName, retries: Int}
-- Terminal state: message delivered and ack confirmed (used for dedup after ack overflow)
type DeliveredEntry = {messageId: MessageIdHex, toKey: PubkeyHex, deliveredAt: Timestamp}
-- Tracks consecutive failures per federation peer for exponential backoff
type ForwardFailure = {server: Text, failedAt: Timestamp, failures: Int, firstFailedAt: Timestamp}
-- Sliding-window rate limit state per pubkey
type SendRateEntry = {pubkey: PubkeyHex, windowStart: Timestamp, count: Int}
type RecvRateEntry = {pubkey: PubkeyHex, windowStart: Timestamp, count: Int}
type PairRateEntry = {sender: PubkeyHex, recipient: PubkeyHex, windowStart: Timestamp, count: Int}
type ChallengeRateEntry = {pubkey: PubkeyHex, windowStart: Timestamp, count: Int}
-- Sliding-window rate limit state per federation peer server
type FederationRateEntry = {server: Text, windowStart: Timestamp, count: Int}
type FederationPairRateEntry = {server: Text, recipient: PubkeyHex, windowStart: Timestamp, count: Int}
-- Tracks active long-poll connections to enforce per-key concurrency limits
type ActivePoll = {pubkey: PubkeyHex, startedAt: Timestamp}
data AuthResult = Authorized {pubkey: PubkeyHex, ip: Text} | Unauthorized {}
data ForwardResult = ForwardDuplicate {} | ForwardRejected {} | ForwardStored {}

type IpRateEntry = {ip: Text, windowStart: Timestamp, count: Int}
type LookupRateEntry = {pubkey: PubkeyHex, windowStart: Timestamp, count: Int}
-- Tracks recently re-broadcast gossip events to suppress amplification from duplicate cycles
type RecentGossipEntry = {pubkey: PubkeyHex, server: Text, timestamp: Timestamp, seenAt: Timestamp}
type PeerStatus = {server: Text, failures: Int, lastFailedAt: Timestamp, firstFailedAt: Timestamp, backoffMs: Int, retriable: Bool}
type KeyPresenceEntry = {server: Text, expiresAt: Timestamp}
type RecipientCount = {pubkey: PubkeyHex, count: Int}
type FederationInFlightEntry = {server: Text, count: Int, firstStartedAt: Timestamp}
-- Tracks recent federation request (server, timestamp) pairs for replay detection
type RecentFederationRequest = {server: Text, timestamp: Timestamp, seenAt: Timestamp}
type GossipEventRateEntry = {server: Text, windowStart: Timestamp, count: Int}

-- Forward nonce for extended replay protection (persisted in snapshots)
type ForwardNonce = {messageId: MessageIdHex, toKey: PubkeyHex, originServer: Text, seenAt: Timestamp}

-- Batch send types
type BatchMessage = {to: PubkeyHex, encryptedBlob: BlobHex, timestamp: Timestamp, messageId: OptionalMessageId}
type BatchResult = {messageId: OptionalMessageId, status: MessageStatus}

-- ============================================
-- Persisted State
-- ============================================
-- All state is in-memory (no disk persistence). Prefixed with * (mutable refs).
-- Atomic blocks provide transactional consistency for reads + writes.

*challenges : [Challenge]

-- Sessions sharded into 16 buckets by first hex char of token.
-- Hot-path auth scans only one bucket (~1/16 of sessions).
-- TODO: If Knot adds indexed arrays or maps, replace the 16 manual bucket
-- refs and their if-else dispatch chains with a single indexed collection.
-- This would eliminate ~800 lines of mechanical boilerplate across sessions,
-- messages, presence, and signal buckets.
*sessionBucket0 : [Session]
*sessionBucket1 : [Session]
*sessionBucket2 : [Session]
*sessionBucket3 : [Session]
*sessionBucket4 : [Session]
*sessionBucket5 : [Session]
*sessionBucket6 : [Session]
*sessionBucket7 : [Session]
*sessionBucket8 : [Session]
*sessionBucket9 : [Session]
*sessionBucket10 : [Session]
*sessionBucket11 : [Session]
*sessionBucket12 : [Session]
*sessionBucket13 : [Session]
*sessionBucket14 : [Session]
*sessionBucket15 : [Session]

-- Messages sharded into 16 buckets by first hex char of recipient pubkey (toKey).
-- Hot-path operations (poll, send, ack) scan only one bucket (~1/16 of messages).
*messageBucket0 : [Message]
*messageBucket1 : [Message]
*messageBucket2 : [Message]
*messageBucket3 : [Message]
*messageBucket4 : [Message]
*messageBucket5 : [Message]
*messageBucket6 : [Message]
*messageBucket7 : [Message]
*messageBucket8 : [Message]
*messageBucket9 : [Message]
*messageBucket10 : [Message]
*messageBucket11 : [Message]
*messageBucket12 : [Message]
*messageBucket13 : [Message]
*messageBucket14 : [Message]
*messageBucket15 : [Message]

*totalMessageCount : Int

-- Presence sharded into 16 buckets by first hex char of pubkey.
-- Hot-path operations (send, lookup, poll) scan only one bucket (~1/16 of entries).
*presenceBucket0 : [PresenceEntry]
*presenceBucket1 : [PresenceEntry]
*presenceBucket2 : [PresenceEntry]
*presenceBucket3 : [PresenceEntry]
*presenceBucket4 : [PresenceEntry]
*presenceBucket5 : [PresenceEntry]
*presenceBucket6 : [PresenceEntry]
*presenceBucket7 : [PresenceEntry]
*presenceBucket8 : [PresenceEntry]
*presenceBucket9 : [PresenceEntry]
*presenceBucket10 : [PresenceEntry]
*presenceBucket11 : [PresenceEntry]
*presenceBucket12 : [PresenceEntry]
*presenceBucket13 : [PresenceEntry]
*presenceBucket14 : [PresenceEntry]
*presenceBucket15 : [PresenceEntry]

*totalPresenceCount : Int

-- Cached set of known peer server names (updated on prune and gossip, avoids full presence scans)
*knownPeerServers : [Text]

-- Monotonic counter ensuring unique receivedAt ordering even within the same millisecond
*seqCounter : Timestamp

*forwards : [ForwardEntry]

-- Messages acked by local recipients, pending federation ack to origin server
*ackedIds : [AckedEntry]

*lastPrunedAt : Timestamp

*forwardFailures : [ForwardFailure]

*sendRates : [SendRateEntry]

*lastPresenceRefresh : Timestamp

*challengeRates : [ChallengeRateEntry]

-- Heartbeat signal: incremented periodically to wake all blocking long-polls
*pollWakeup : Timestamp

-- Per-bucket message signals (16 buckets, keyed by first hex digit of pubkey).
-- Updated when a message is stored for a recipient; polls for that pubkey's
-- bucket watch for changes to avoid waking unrelated polls.
*messageSignal0 : Timestamp
*messageSignal1 : Timestamp
*messageSignal2 : Timestamp
*messageSignal3 : Timestamp
*messageSignal4 : Timestamp
*messageSignal5 : Timestamp
*messageSignal6 : Timestamp
*messageSignal7 : Timestamp
*messageSignal8 : Timestamp
*messageSignal9 : Timestamp
*messageSignal10 : Timestamp
*messageSignal11 : Timestamp
*messageSignal12 : Timestamp
*messageSignal13 : Timestamp
*messageSignal14 : Timestamp
*messageSignal15 : Timestamp

*activePolls : [ActivePoll]

-- Overflow buffer: acks evicted from ackedIds before they could be sent to origin
*ackOverflow : [AckedEntry]

-- Final dedup set: messages confirmed delivered (ack sent or overflow drained)
*deliveredIds : [DeliveredEntry]

*federationRates : [FederationRateEntry]

*federationPairRates : [FederationPairRateEntry]

*globalRateCount : Int

*globalRateWindowStart : Timestamp

-- Background task cycle counters (exposed via /stats for health monitoring)
*pruneCount : Int

*heartbeatCount : Int

*startedAt : Timestamp

*lastHeartbeatAt : Timestamp

*draining : Bool

*pruneRunning : Timestamp

*pruneGeneration : Int

*ipRates : [IpRateEntry]

*lookupRates : [LookupRateEntry]

*recvRates : [RecvRateEntry]

*pairRates : [PairRateEntry]

*recentGossip : [RecentGossipEntry]

*lastFederationSuccessAt : Timestamp

-- Per-recipient message counts (avoids O(n) scan of all messages on send/forward)
*recipientMsgCounts : [RecipientCount]

-- Tracks outstanding federation fetches per server (detects hung connections)
*federationInFlight : [FederationInFlightEntry]

-- Federation latency tracking (for /stats)
*federationLatencyTotal : Int<Ms>
*federationLatencyCount : Int
*federationLatencyMax : Int<Ms>

-- Server instance generation (epoch timestamp, for cursor staleness detection)
*serverGeneration : Int

-- Timestamp when drain federation ops completed (0 if in progress or not draining)
*drainCompletedAt : Timestamp

-- Last time federation latency metrics were reset (for windowed averages)
*federationLatencyResetAt : Timestamp

-- Total session count across all buckets (avoids O(16) recount on monitoring paths)
*totalSessionCount : Int

-- Auth-tier global rate limiting state
*authGlobalRateCount : Int
*authGlobalRateWindowStart : Timestamp

-- Max concurrent background prune forks (prevents resource exhaustion from stuck recovery)
*activePruneForks : Int

-- Signal for drain timeout (set by forked timer, watched by STM retry in waitForInFlightDrain)
*drainTimedOut : Bool

-- Recent federation requests for replay detection (dedup by server+timestamp)
*recentFederationRequests : [RecentFederationRequest]

-- Pending verification tokens for federation callback auth (single-use, short-lived)
-- scope binds the token to a specific request type (gossip/forward/ack) to prevent cross-use
*pendingVerifications : [{token: Text, createdAt: Timestamp, scope: Text}]

-- Forward nonce dedup: (messageId, toKey, originServer, seenAt) for replay protection beyond message lifetime
*forwardNonces : [ForwardNonce]

-- Federation verify per-IP rate limiting (tighter than general IP rate)
*verifyIpRates : [IpRateEntry]

-- Tracks when /maintenance/snapshot was last exported (for staleness warnings)
*lastSnapshotExportAt : Timestamp

-- Per-peer gossip event volume rate limiting
*gossipEventRates : [GossipEventRateEntry]

-- Global federation connection counter (tracks total concurrent outbound connections)
*federationActiveConnections : Int

-- Blocked federation peers (managed at runtime via /maintenance/block and /maintenance/unblock)
*blockedPeers : [Text]

-- Deferred ack cleanups: origin message reclamation queued by federation ack handlers,
-- processed by the prune cycle after ackGracePeriod elapses (replaces fork+sleep pattern).
*pendingAckCleanups : [{messageId: MessageIdHex, toKey: PubkeyHex, cleanupAfter: Timestamp}]

-- Monotonic counter bumped on any presence change (gossip, auth, logout, prune, restore, drain)
-- Polls compare against this to skip expensive presence lookups when nothing changed.
*presenceVersion : Timestamp

-- Last time the background watchdog loop ran (for health check liveness detection)
*lastWatchdogAt : Timestamp

-- ============================================
-- Routes
-- ============================================

-- Authentication: Ed25519 challenge-response flow
-- 1. Client POSTs pubkey to /auth/challenge, gets a random challenge string
-- 2. Client signs the challenge with their private key and POSTs to /auth/verify
-- 3. Server verifies signature, returns a session token
route AuthApi where
  /auth
    POST {pubkey: PubkeyHex} /challenge headers {clientIp: Text}
      -> {challenge: Text, ok: Bool, expiresAt: Timestamp, retryAfterMs: Int}
      = ReqChallenge
    POST {pubkey: PubkeyHex, challenge: Text, signature: SignatureHex, revokeOthers: Bool} /verify headers {clientIp: Text}
      -> {token: Text, expiresAt: Timestamp}
      = VerifyAuth
    POST {targetToken: Text} /revoke headers {authorization: Text, clientIp: Text}
      -> {ok: Bool, authorized: Bool}
      = RevokeSession
    -- Voluntary disconnect: removes session and gossips offline if last session for this key
    POST {} /logout headers {authorization: Text, clientIp: Text}
      -> {ok: Bool, authorized: Bool}
      = Logout

-- Client-facing API (requires session token in Authorization header)
route ClientApi where
  -- Long-poll for new messages; cursor tracks last-seen receivedAt timestamp
  POST {cursor: Timestamp, generation: Int, watchKeys: [PubkeyHex]} /poll headers {authorization: Text, clientIp: Text}
    -> {events: [PollEvent], cursor: Timestamp, authorized: Bool, rateLimited: Bool, draining: Bool, generation: Int, presenceUpdates: [{pubkey: PubkeyHex, online: Bool}], heartbeat: Bool, retryAfterMs: Int}
    = Poll
  /messages
    -- Send an E2E encrypted message to a recipient pubkey
    POST {to: PubkeyHex, encryptedBlob: BlobHex, timestamp: Timestamp, messageId: OptionalMessageId} / headers {authorization: Text, clientIp: Text}
      -> {status: MessageStatus, messageId: OptionalMessageId, retryAfterMs: Int}
      = SendMessage
    -- Check delivery status of a sent message (caller must know recipient to prove ownership)
    POST {to: PubkeyHex, messageId: MessageIdHex} /status headers {authorization: Text, clientIp: Text}
      -> {status: Text, authorized: Bool}
      = MessageStatus
    -- Explicitly acknowledge received messages by ID (alternative to cursor-based ack in poll)
    POST {messageIds: [MessageIdHex]} /ack headers {authorization: Text, clientIp: Text}
      -> {ok: Bool, authorized: Bool, ackedCount: Int}
      = AckMessages
    -- Send multiple messages in one request (auth checked once; each message rate-limited independently)
    POST {messages: [BatchMessage]} /batch headers {authorization: Text, clientIp: Text}
      -> {results: [BatchResult], authorized: Bool, retryAfterMs: Int}
      = SendBatch
    -- List pending messages without acking (useful after cursor loss or device migration)
    GET /messages/list headers {authorization: Text, clientIp: Text}
      -> {messages: [{messageId: MessageIdHex, timestamp: Timestamp, receivedAt: Timestamp}], authorized: Bool, count: Int}
      = ListMessages
  -- Look up which server a pubkey is present on (for federation routing)
  GET /lookup/{pubkey: PubkeyHex} headers {authorization: Text, clientIp: Text}
    -> {server: AnyServerName, authorized: Bool}
    = LookupPresence

-- Server-to-server federation API (authenticated via domain callback verification)
route FederationApi where
  /federation
    -- Receive presence gossip events from a peer server
    POST {events: [GossipEvent], hopsRemaining: Int, fromServer: ServerName, requestTimestamp: Timestamp} /gossip headers {authorization: Text}
      -> {ok: Bool, error: Text}
      = RecvGossip
    -- Receive a forwarded message from a peer server on behalf of a sender
    POST {toKey: PubkeyHex, encryptedBlob: BlobHex, timestamp: Timestamp, originServer: ServerName, messageId: MessageIdHex, fromServer: ServerName, requestTimestamp: Timestamp} /forward headers {authorization: Text}
      -> {ok: Bool, error: Text}
      = ForwardMessage
    -- Acknowledge delivery of messages back to the origin server
    POST {messageIds: [MessageIdHex], originServer: ServerName, fromServer: ServerName, requestTimestamp: Timestamp} /ack headers {authorization: Text}
      -> {ok: Bool, error: Text, ackedCount: Int}
      = FederationAck

-- Federation callback verification: the receiving server calls back to the sender
-- to confirm a request token is genuine. No shared secret needed.
route FederationVerifyApi where
  POST {token: Text, scope: Text} /federation/verify headers {clientIp: Text} -> {ok: Bool} = VerifyToken

-- Triggers pruning of expired state and retry of pending federation ops
route MaintenanceApi where
  POST {} /maintenance/prune headers {authorization: Text}
    -> {ok: Bool}
    = Prune
  POST {} /maintenance/drain headers {authorization: Text}
    -> {ok: Bool, drained: Int}
    = Drain
  POST {} /maintenance/undrain headers {authorization: Text}
    -> {ok: Bool}
    = Undrain
  -- Snapshot: export federation metadata for persistence across restarts.
  -- Messages are excluded (ephemeral by design; clients handle re-delivery).
  -- Includes presence, acked/delivered IDs (dedup state), and peer failure records.
  GET /maintenance/snapshot headers {authorization: Text}
    -> {ok: Bool, version: Int, presence: [PresenceEntry], ackedIds: [AckedEntry], ackOverflow: [AckedEntry], deliveredIds: [DeliveredEntry], forwardFailures: [ForwardFailure], forwards: [ForwardEntry], forwardNonces: [ForwardNonce], blockedPeers: [Text]}
    = Snapshot
  -- Restore: import a previously-exported snapshot. Server must be in drain mode
  -- to prevent conflicts with live state. Run /maintenance/undrain after restore.
  POST {version: Int, presence: [PresenceEntry], ackedIds: [AckedEntry], ackOverflow: [AckedEntry], deliveredIds: [DeliveredEntry], forwardFailures: [ForwardFailure], forwards: [ForwardEntry], forwardNonces: [ForwardNonce], blockedPeers: [Text]} /maintenance/restore headers {authorization: Text}
    -> {ok: Bool, error: Text, presenceCount: Int, ackedIdsCount: Int, deliveredIdsCount: Int}
    = Restore
  -- Block a federation peer (rejects all inbound/outbound federation with this server)
  POST {server: ServerName} /maintenance/block headers {authorization: Text}
    -> {ok: Bool, blocked: Int}
    = BlockPeer
  -- Unblock a previously blocked peer
  POST {server: ServerName} /maintenance/unblock headers {authorization: Text}
    -> {ok: Bool, unblocked: Bool}
    = UnblockPeer
  -- List currently blocked peers
  GET /maintenance/blocked headers {authorization: Text}
    -> {peers: [Text], ok: Bool}
    = ListBlocked
  -- Test federation connectivity to a specific peer via verify callback round-trip
  POST {server: ServerName} /maintenance/ping headers {authorization: Text}
    -> {ok: Bool, latencyMs: Int, error: Text}
    = PingPeer
  -- List sessions for a specific pubkey (admin debugging)
  GET /maintenance/sessions/{pubkey: PubkeyHex} headers {authorization: Text}
    -> {sessions: [{token: Text, expiresAt: Timestamp, ip: Text, createdAt: Timestamp}], count: Int, ok: Bool}
    = AdminListSessions
  -- Revoke all sessions for a specific pubkey (abuse response)
  POST {pubkey: PubkeyHex} /maintenance/sessions/revoke-all headers {authorization: Text}
    -> {ok: Bool, revokedCount: Int}
    = AdminRevokeSessions

route HealthApi where
  GET /health headers {authorization: Text} -> {ok: Bool, pruneHealthy: Bool, heartbeatHealthy: Bool, capacityHealthy: Bool, federationHealthy: Bool, snapshotHealthy: Bool, watchdogHealthy: Bool} = Health

-- Returns counts of in-memory collections (requires maintenance secret)
-- TODO: If Knot adds raw text response support, add a /metrics endpoint
-- returning Prometheus exposition format for direct integration with standard
-- monitoring stacks. Currently /stats returns JSON which requires a custom scraper.
route StatsApi where
  GET /stats headers {authorization: Text}
    -> {sessions: Int, sessionsMax: Int, messages: Int, messagesMax: Int, presence: Int, presenceMax: Int, forwards: Int, forwardsMax: Int, challenges: Int, challengesMax: Int, ackedIds: Int, ackedIdsMax: Int, ackOverflow: Int, ackOverflowMax: Int, deliveredIds: Int, deliveredIdsMax: Int, forwardFailures: Int, activePolls: Int, activePollsMax: Int, sendRates: Int, challengeRates: Int, federationRates: Int, globalRateCount: Int, ipRates: Int, lookupRates: Int, recvRates: Int, pairRates: Int, federationPairRates: Int, pruneCount: Int, pruneRunning: Timestamp, heartbeatCount: Int, uptime: Int, lastPruneAt: Timestamp, lastHeartbeatAt: Timestamp, draining: Bool, federationEnabled: Bool, recentGossip: Int, totalMessageCount: Int, recipientCounts: Int, federationInFlight: Int, hungFederationSlots: Int, messagesPct: Int, presencePct: Int, forwardsPct: Int, sessionsPct: Int, federationAvgLatencyMs: Int, federationMaxLatencyMs: Int, federationCallCount: Int, drainCompletedAt: Timestamp, oldestForwardAge: Int, oldestAckAge: Int, forwardNonces: Int, forwardNoncesMax: Int, pendingAckCleanups: Int, blockedPeers: Int, gossipEventRates: Int, verifyIpRates: Int, ok: Bool}
    = Stats
  GET /stats/peers headers {authorization: Text}
    -> {peers: [PeerStatus], ok: Bool}
    = StatsPeers
  GET /stats/key/{pubkey: PubkeyHex} headers {authorization: Text}
    -> {messages: Int, presence: [KeyPresenceEntry], sessions: Int, forwards: Int, activePolls: Int, ok: Bool}
    = StatsKey

route Api = AuthApi | ClientApi | FederationApi | FederationVerifyApi | MaintenanceApi | HealthApi | StatsApi

-- ============================================
-- Helpers
-- ============================================

-- Structured log helpers (severity-prefixed for operator filtering)
logInfo = \msg -> println ("[INFO] " ++ msg)
logWarn = \msg -> println ("[WARN] " ++ msg)
logError = \msg -> println ("[ERROR] " ++ msg)

any : [a] -> (a -> Bool) -> Bool
any = \xs pred -> fold (\acc x -> if acc then acc else pred x) (False {}) xs
none : [a] -> (a -> Bool) -> Bool
none = \xs pred -> not (any xs pred)
when = \cond action -> if cond then action else yield {}
whenOk = \result action -> case result of
  Ok _ -> action
  Err _ -> yield {}
clamp = \lo hi x -> if x < lo then lo else if x > hi then hi else x
min = \a b -> if a < b then a else b
max = \a b -> if a > b then a else b
headOf = \items -> fold (\acc x -> case acc of
  Nothing {} -> Just {value: x}
  _ -> acc) Nothing {} items

maxBy = \items getKey -> fold (\acc x -> case acc of
  Nothing {} -> Just {value: x}
  Just {value: v} -> if getKey x > getKey v then Just {value: x} else acc) Nothing {} items

minBy = \items getKey -> fold (\acc x -> case acc of
  Nothing {} -> Just {value: x}
  Just {value: v} -> if getKey x < getKey v then Just {value: x} else acc) Nothing {} items

-- Hex encoding utilities for token generation
hexDigit : Int -> Text
hexDigit = \n -> take 1 (drop (clamp 0 15 n) "0123456789abcdef")

byteToHex : Int -> Text
byteToHex = \n -> hexDigit (n / 16) ++ hexDigit (n - (n / 16) * 16)

-- Encode a 24-bit integer as 6 hex characters (3 bytes)
intTo3Hex : Int -> Text
intTo3Hex = \n ->
  let b0 = n / 65536 in
  let r0 = n - b0 * 65536 in
  let b1 = r0 / 256 in
  let b2 = r0 - b1 * 256 in
  byteToHex b0 ++ byteToHex b1 ++ byteToHex b2

-- Generate a random hex token (n chunks of 3 bytes each = 6n hex chars)
genTokenN = \n -> if n <= 0 then yield "" else do
  chunk <- randomInt 16777216
  rest <- genTokenN (n - 1)
  yield (intTo3Hex chunk ++ rest)

-- Default token: 8 chunks = 48 hex chars = 24 bytes of randomness
genToken = genTokenN 8

tooLong : Text -> Int -> Bool
tooLong = \s maxLen -> drop maxLen s != ""

isHexChar : Text -> Bool
isHexChar = \c -> contains c "0123456789abcdef"

isValidHexPairs : Text -> Bool
isValidHexPairs = \s ->
  if s == "" then True {}
  else if drop 1 s == "" then False {}
  else if isHexChar (take 1 s) && isHexChar (take 1 (drop 1 s)) then isValidHexPairs (drop 2 s)
  else False {}

isValidHex : Text -> Bool
isValidHex = \s -> s != "" && isValidHexPairs s

normalizeHex : Text -> Text
normalizeHex = \s -> bytesToHex (bytesFromHex s)

isDigitChar : Text -> Bool
isDigitChar = \c -> contains c "0123456789"

isAllowedServerChar : Text -> Bool
isAllowedServerChar = \c -> contains c "0123456789abcdefghijklmnopqrstuvwxyz-.:"

containsBadUrlChar : Text -> Bool
containsBadUrlChar = \s -> any (chars s) (\c -> not (isAllowedServerChar c))

-- Carrier-grade NAT range: 100.64.0.0/10 (RFC 6598)
isCgnatRange : Text -> Bool
isCgnatRange = \s ->
  take 4 s == "100."
  && let d4 = take 1 (drop 4 s) in
  let d5 = take 1 (drop 5 s) in
  let d6 = take 1 (drop 6 s) in
  let d7 = take 1 (drop 7 s) in
  let twoDigitOctet = d6 == "." && isAllDigitsOrDotsUntilColonOrEnd (drop 7 s) in
  let threeDigitOctet = d7 == "." && isAllDigitsOrDotsUntilColonOrEnd (drop 8 s) in
  ((contains d4 "789" && isDigitChar d5 && twoDigitOctet)
  || (d4 == "6" && contains d5 "456789" && twoDigitOctet)
  || (d4 == "1" && contains d5 "01" && isDigitChar d6 && threeDigitOctet)
  || (d4 == "1" && d5 == "2" && contains d6 "01234567" && threeDigitOctet))

containsMultipleColons : Text -> Bool
containsMultipleColons = \s -> count (do c <- chars s; where c == ":"; yield c) > 1

hasPatternAfterDot : (Text -> Bool) -> Text -> Bool
hasPatternAfterDot = \pred s ->
  if s == "" then False {}
  else if take 1 s == "." && pred (drop 1 s) then True {}
  else hasPatternAfterDot pred (drop 1 s)

isOctalStart : Text -> Bool
isOctalStart = \s -> take 1 s == "0" && isDigitChar (take 1 (drop 1 s)) && isAllDigitsOrDotsUntilColonOrEnd (drop 2 s)
hasOctalOctet : Text -> Bool
hasOctalOctet = \s -> isOctalStart s || hasPatternAfterDot isOctalStart s

isHexStart : Text -> Bool
isHexStart = \s -> take 2 s == "0x" || take 2 s == "0X"
hasHexPrefix : Text -> Bool
hasHexPrefix = \s -> isHexStart s || hasPatternAfterDot isHexStart s

isAllDigitsOrDotsUntilColonOrEnd : Text -> Bool
isAllDigitsOrDotsUntilColonOrEnd = \s ->
  if s == "" then True {}
  else if take 1 s == ":" then True {}
  else if isDigitChar (take 1 s) || take 1 s == "." then isAllDigitsOrDotsUntilColonOrEnd (drop 1 s)
  else False {}

isTrailingDots : Text -> Bool
isTrailingDots = \s ->
  if s == "" then True {}
  else if take 1 s == ":" then True {}
  else if take 1 s == "." then isTrailingDots (drop 1 s)
  else False {}

stripTrailingDot : Text -> Text
stripTrailingDot = \s ->
  if s == "" then ""
  else if take 1 s == "." && isTrailingDots (drop 1 s) then stripTrailingDot (drop 1 s)
  else take 1 s ++ stripTrailingDot (drop 1 s)

normalizeServerName : Text -> Text
normalizeServerName = \s -> toLower (stripTrailingDot s)

serverHostN : Text
serverHostN = normalizeServerName serverHost
isLocalServer : Text -> Bool
isLocalServer = \s -> s == serverHostN

containsSuffixN : Text -> Int -> Text -> Bool
containsSuffixN = \suffix suffixLen s ->
  if s == "" then False {}
  else if take suffixLen s == suffix && (drop suffixLen s == "" || take 1 (drop suffixLen s) == ":") then True {}
  else containsSuffixN suffix suffixLen (drop 1 s)

containsSuffix : Text -> Text -> Bool
containsSuffix = \suffix s -> containsSuffixN suffix (count (chars suffix)) s

is172Private : Text -> Bool
is172Private = \sn ->
  take 4 sn == "172."
  && let d1 = take 1 (drop 4 sn) in
  let d2 = take 1 (drop 5 sn) in
  take 1 (drop 6 sn) == "."
  && isDigitChar (take 1 (drop 7 sn))
  && ((d1 == "1" && contains d2 "6789")
    || (d1 == "2" && isDigitChar d2)
    || (d1 == "3" && contains d2 "01"))

isHighOctetPrefix : Text -> Bool
isHighOctetPrefix = \sn ->
  take 1 sn == "2"
  && let d2 = take 1 (drop 1 sn) in
  let d3 = take 1 (drop 2 sn) in
  take 1 (drop 3 sn) == "."
  && isDigitChar (take 1 (drop 4 sn))
  && ((d2 == "2" && contains d3 "456789")
    || (contains d2 "34" && isDigitChar d3)
    || (d2 == "5" && contains d3 "012345"))

matchesHostname : Text -> Text -> Bool
matchesHostname = \sn name ->
  let nameLen = count (chars name) in
  take nameLen sn == name && (drop nameLen sn == "" || take 1 (drop nameLen sn) == ":")

matchesHostnameOrSubdomain : Text -> Text -> Bool
matchesHostnameOrSubdomain = \sn name ->
  matchesHostname sn name || containsSuffix ("." ++ name) sn

hasDotBeforePort : Text -> Bool
hasDotBeforePort = \s ->
  if s == "" then False {}
  else if take 1 s == ":" then False {}
  else if take 1 s == "." then True {}
  else hasDotBeforePort (drop 1 s)

-- DNS rebinding / SSRF protection: reject server names that resolve to private/reserved addresses.
-- Blocks localhost, private RFC1918 ranges, link-local, loopback, CGNAT, documentation ranges,
-- IPv6 shorthand, octal/hex IP tricks, bare IPs without dots, and .arpa domains.
isBadServerName : Text -> Bool
isBadServerName = \sn ->
  let fc = take 1 sn in
  fc == ""
  || fc == "."
  || fc == ":"
  || containsBadUrlChar sn
  || not (hasDotBeforePort sn)
  || matchesHostnameOrSubdomain sn "localhost"
  || matchesHostname sn "localhost.localdomain"
  || matchesHostnameOrSubdomain sn "local"
  || matchesHostnameOrSubdomain sn "internal"
  || matchesHostnameOrSubdomain sn "metadata"
  || take 4 sn == "127." || take 3 sn == "10."
  || take 8 sn == "192.168." || take 8 sn == "169.254."
  || take 2 sn == "0." || fc == "["
  || is172Private sn
  || take 7 sn == "198.18." || take 7 sn == "198.19."
  || take 8 sn == "192.0.0."
  || take 8 sn == "192.0.2."
  || take 10 sn == "192.88.99."
  || take 11 sn == "198.51.100."
  || take 10 sn == "203.0.113."
  || take 2 sn == "::"
  || isCgnatRange sn
  || containsMultipleColons sn
  || hasOctalOctet sn
  || hasHexPrefix sn
  || (isDigitChar fc && isAllDigitsOrDotsUntilColonOrEnd sn)
  || isHighOctetPrefix sn
  || containsSuffix ".arpa" sn
  || containsSuffix ".onion" sn
  || containsSuffix ".i2p" sn
  || containsSuffix ".corp" sn
  || containsSuffix ".home" sn
  || containsSuffix ".lan" sn
  || containsSuffix ".intranet" sn
  || containsSuffix ".test" sn
  || containsSuffix ".example" sn
  || containsSuffix ".invalid" sn

-- Look up a non-expired session matching the given token (constant-time comparison).
-- Caller passes the appropriate session bucket (sharded by token prefix).
authenticateSession : [Session] -> Text -> Timestamp -> AuthResult
authenticateSession = \sessions token t ->
  case headOf (do s <- sessions; where s.expiresAt > t && t - s.createdAt < maxSessionLifetime && safeCompare s.token token; yield s) of
    Nothing {} -> Unauthorized {}
    Just {value: s} -> Authorized {pubkey: s.pubkey, ip: s.ip}

-- Fast re-authentication for poll Phase 3: pre-filters by known pubkey before
-- running safeCompare. Reduces safeCompare calls from O(bucket_size) to
-- O(sessions_for_key_in_bucket) (~1-2 vs ~600). Safe in this context because
-- the pubkey was already verified in Phase 1.
reauthenticateSession : [Session] -> Text -> PubkeyHex -> Timestamp -> Bool
reauthenticateSession = \sessions token pubkey t ->
  any sessions (\s -> s.pubkey == pubkey && s.expiresAt > t && t - s.createdAt < maxSessionLifetime && safeCompare s.token token)

-- Extract bearer token from "Authorization: Bearer <token>" header.
-- Rejects empty tokens early to avoid unnecessary session bucket scans.
extractToken = \authHeader ->
  let token = drop 7 authHeader in
  if toLower (take 7 authHeader) == "bearer " && token != "" && not (tooLong token maxTokenLen)
    then Just {value: token}
    else Nothing {}

-- Constant-time secret comparison (prevents timing attacks on maintenance secret)
verifySecret : Text -> Text -> Bool
verifySecret = \token secret ->
  secret != "" && safeCompare token secret

verifyAuthWith : (Text -> Bool) -> Text -> Bool
verifyAuthWith = \check authorization ->
  case extractToken authorization of
    Nothing {} -> False {}
    Just {value: token} -> check token

verifyMaintenanceAuth : Text -> Bool
verifyMaintenanceAuth = verifyAuthWith (\token -> verifySecret token maintenanceSecret)

-- Check if a server is on the blocklist
isBlockedPeer : Text -> [Text] -> Bool
isBlockedPeer = \server blocked -> any blocked (\b -> b == server)

-- Generate a single-use token for outbound federation auth.
-- The receiving server calls back to /federation/verify to confirm we issued it.
-- scope binds the token to a request type ("gossip", "forward", "ack") so a token
-- issued for one operation cannot authorize a different one.
generateFederationAuth : Text -> IO {network} Text
generateFederationAuth = \scope -> do
  token <- genToken
  t <- now
  atomic do
    pending <- *pendingVerifications
    let updated = union pending [{token: token, createdAt: t, scope: scope}]
    set *pendingVerifications = if count updated > maxPendingVerifications
      then evictOneOldest updated (\p -> p.createdAt)
      else updated
  yield ("Bearer " ++ token)

-- Verify an inbound federation token by callback to the sender's /federation/verify endpoint.
-- Single-use: the sender consumes the token on verification.
-- scope must match the scope the token was generated with; empty scope accepts any (backward compat).
-- No retry: a failed verify rejects the request. The peer's federation rate limit + circuit breaker
-- handle unreliable peers; retrying here doubles verify traffic and blocks with a 1s sleep per op,
-- which a malicious peer can exploit for amplification.
verifyFederationCallback : Text -> Text -> Text -> IO {network} Bool
verifyFederationCallback = \fromServer authorization scope ->
  case extractToken authorization of
    Nothing {} -> yield (False {})
    Just {value: token} -> do
      result <- fetch (federationUrl fromServer) (VerifyToken {token: token, scope: scope})
      case result of
        Err e -> do
          logWarn ("federation: verify callback to " ++ fromServer ++ " failed: " ++ show e)
          yield (False {})
        Ok r -> yield r.ok

-- ============================================
-- Session Bucket Helpers
-- ============================================
-- Sessions are sharded into 16 buckets by the first hex char of the token.
-- This reduces auth scan from O(n) to O(n/16) on the hot path.

tokenBucket : Text -> Int
tokenBucket = \token -> clamp 0 15 (hexCharIndex (take 1 token))

readSessionBucket : Int -> IO [Session]
readSessionBucket = \b ->
  if b == 0 then do s <- *sessionBucket0; yield s
  else if b == 1 then do s <- *sessionBucket1; yield s
  else if b == 2 then do s <- *sessionBucket2; yield s
  else if b == 3 then do s <- *sessionBucket3; yield s
  else if b == 4 then do s <- *sessionBucket4; yield s
  else if b == 5 then do s <- *sessionBucket5; yield s
  else if b == 6 then do s <- *sessionBucket6; yield s
  else if b == 7 then do s <- *sessionBucket7; yield s
  else if b == 8 then do s <- *sessionBucket8; yield s
  else if b == 9 then do s <- *sessionBucket9; yield s
  else if b == 10 then do s <- *sessionBucket10; yield s
  else if b == 11 then do s <- *sessionBucket11; yield s
  else if b == 12 then do s <- *sessionBucket12; yield s
  else if b == 13 then do s <- *sessionBucket13; yield s
  else if b == 14 then do s <- *sessionBucket14; yield s
  else do s <- *sessionBucket15; yield s

writeSessionBucket : Int -> [Session] -> IO ()
writeSessionBucket = \b sessions ->
  if b == 0 then set *sessionBucket0 = sessions
  else if b == 1 then set *sessionBucket1 = sessions
  else if b == 2 then set *sessionBucket2 = sessions
  else if b == 3 then set *sessionBucket3 = sessions
  else if b == 4 then set *sessionBucket4 = sessions
  else if b == 5 then set *sessionBucket5 = sessions
  else if b == 6 then set *sessionBucket6 = sessions
  else if b == 7 then set *sessionBucket7 = sessions
  else if b == 8 then set *sessionBucket8 = sessions
  else if b == 9 then set *sessionBucket9 = sessions
  else if b == 10 then set *sessionBucket10 = sessions
  else if b == 11 then set *sessionBucket11 = sessions
  else if b == 12 then set *sessionBucket12 = sessions
  else if b == 13 then set *sessionBucket13 = sessions
  else if b == 14 then set *sessionBucket14 = sessions
  else set *sessionBucket15 = sessions

-- Read all 16 session buckets (for per-key operations, prune, stats)
readAllSessions : IO [Session]
readAllSessions = do
  s0 <- *sessionBucket0
  s1 <- *sessionBucket1
  s2 <- *sessionBucket2
  s3 <- *sessionBucket3
  s4 <- *sessionBucket4
  s5 <- *sessionBucket5
  s6 <- *sessionBucket6
  s7 <- *sessionBucket7
  s8 <- *sessionBucket8
  s9 <- *sessionBucket9
  s10 <- *sessionBucket10
  s11 <- *sessionBucket11
  s12 <- *sessionBucket12
  s13 <- *sessionBucket13
  s14 <- *sessionBucket14
  s15 <- *sessionBucket15
  yield (union s0 (union s1 (union s2 (union s3 (union s4 (union s5 (union s6 (union s7 (union s8 (union s9 (union s10 (union s11 (union s12 (union s13 (union s14 s15)))))))))))))))

-- Count sessions across all 16 buckets without materializing the full list
countAllSessions : IO Int
countAllSessions = do
  s0 <- *sessionBucket0
  s1 <- *sessionBucket1
  s2 <- *sessionBucket2
  s3 <- *sessionBucket3
  s4 <- *sessionBucket4
  s5 <- *sessionBucket5
  s6 <- *sessionBucket6
  s7 <- *sessionBucket7
  s8 <- *sessionBucket8
  s9 <- *sessionBucket9
  s10 <- *sessionBucket10
  s11 <- *sessionBucket11
  s12 <- *sessionBucket12
  s13 <- *sessionBucket13
  s14 <- *sessionBucket14
  s15 <- *sessionBucket15
  yield (count s0 + count s1 + count s2 + count s3 + count s4 + count s5 + count s6 + count s7 + count s8 + count s9 + count s10 + count s11 + count s12 + count s13 + count s14 + count s15)

-- Short-circuit scan: check if any session bucket contains a session for the given pubkey.
-- Stops reading buckets as soon as one matching session is found (O(n/16) best case
-- vs O(n) for readAllSessions when the user has sessions in early buckets).
hasSessionForKey : PubkeyHex -> Int -> IO Bool
hasSessionForKey = \pubkey b ->
  if b > 15 then yield (False {})
  else do
    bucket <- readSessionBucket b
    if any bucket (\s -> s.pubkey == pubkey) then yield (True {})
    else hasSessionForKey pubkey (b + 1)

-- Count sessions for a specific pubkey across all buckets (avoids materializing full session list).
-- Used in verify fast path to skip readAllSessions.
countSessionsForKey : PubkeyHex -> IO Int
countSessionsForKey = \pubkey -> countSessionsInBucket pubkey 0

countSessionsInBucket : PubkeyHex -> Int -> IO Int
countSessionsInBucket = \pubkey b ->
  if b > 15 then yield 0
  else do
    bucket <- readSessionBucket b
    let n = count (do s <- bucket; where s.pubkey == pubkey; yield s)
    rest <- countSessionsInBucket pubkey (b + 1)
    yield (n + rest)

-- Apply a filter/transform to every session bucket
transformAllSessionBuckets : ([Session] -> [Session]) -> IO ()
transformAllSessionBuckets = \f -> do
  b0 <- *sessionBucket0; set *sessionBucket0 = f b0
  b1 <- *sessionBucket1; set *sessionBucket1 = f b1
  b2 <- *sessionBucket2; set *sessionBucket2 = f b2
  b3 <- *sessionBucket3; set *sessionBucket3 = f b3
  b4 <- *sessionBucket4; set *sessionBucket4 = f b4
  b5 <- *sessionBucket5; set *sessionBucket5 = f b5
  b6 <- *sessionBucket6; set *sessionBucket6 = f b6
  b7 <- *sessionBucket7; set *sessionBucket7 = f b7
  b8 <- *sessionBucket8; set *sessionBucket8 = f b8
  b9 <- *sessionBucket9; set *sessionBucket9 = f b9
  b10 <- *sessionBucket10; set *sessionBucket10 = f b10
  b11 <- *sessionBucket11; set *sessionBucket11 = f b11
  b12 <- *sessionBucket12; set *sessionBucket12 = f b12
  b13 <- *sessionBucket13; set *sessionBucket13 = f b13
  b14 <- *sessionBucket14; set *sessionBucket14 = f b14
  b15 <- *sessionBucket15; set *sessionBucket15 = f b15

-- Single-pass partition of sessions by token bucket and write to all 16 buckets.
-- Mirrors writeAllPresence for the session sharding scheme.
writeAllSessions : [Session] -> IO ()
writeAllSessions = \sessions -> do
  let partitioned = fold (\acc s ->
    let b = tokenBucket s.token in
    {b0: if b == 0 then union [s] acc.b0 else acc.b0,
     b1: if b == 1 then union [s] acc.b1 else acc.b1,
     b2: if b == 2 then union [s] acc.b2 else acc.b2,
     b3: if b == 3 then union [s] acc.b3 else acc.b3,
     b4: if b == 4 then union [s] acc.b4 else acc.b4,
     b5: if b == 5 then union [s] acc.b5 else acc.b5,
     b6: if b == 6 then union [s] acc.b6 else acc.b6,
     b7: if b == 7 then union [s] acc.b7 else acc.b7,
     b8: if b == 8 then union [s] acc.b8 else acc.b8,
     b9: if b == 9 then union [s] acc.b9 else acc.b9,
     b10: if b == 10 then union [s] acc.b10 else acc.b10,
     b11: if b == 11 then union [s] acc.b11 else acc.b11,
     b12: if b == 12 then union [s] acc.b12 else acc.b12,
     b13: if b == 13 then union [s] acc.b13 else acc.b13,
     b14: if b == 14 then union [s] acc.b14 else acc.b14,
     b15: if b == 15 then union [s] acc.b15 else acc.b15})
    {b0: [], b1: [], b2: [], b3: [], b4: [], b5: [], b6: [], b7: [], b8: [], b9: [], b10: [], b11: [], b12: [], b13: [], b14: [], b15: []} sessions
  writeSessionBucket 0 partitioned.b0
  writeSessionBucket 1 partitioned.b1
  writeSessionBucket 2 partitioned.b2
  writeSessionBucket 3 partitioned.b3
  writeSessionBucket 4 partitioned.b4
  writeSessionBucket 5 partitioned.b5
  writeSessionBucket 6 partitioned.b6
  writeSessionBucket 7 partitioned.b7
  writeSessionBucket 8 partitioned.b8
  writeSessionBucket 9 partitioned.b9
  writeSessionBucket 10 partitioned.b10
  writeSessionBucket 11 partitioned.b11
  writeSessionBucket 12 partitioned.b12
  writeSessionBucket 13 partitioned.b13
  writeSessionBucket 14 partitioned.b14
  writeSessionBucket 15 partitioned.b15

-- ============================================
-- Presence Bucket Helpers
-- ============================================
-- Presence is sharded into 16 buckets by the first hex char of the pubkey.
-- Hot-path operations (send, lookup, poll) scan only one bucket (~1/16 of entries).

readPresenceBucket : Int -> IO [PresenceEntry]
readPresenceBucket = \b ->
  if b == 0 then do s <- *presenceBucket0; yield s
  else if b == 1 then do s <- *presenceBucket1; yield s
  else if b == 2 then do s <- *presenceBucket2; yield s
  else if b == 3 then do s <- *presenceBucket3; yield s
  else if b == 4 then do s <- *presenceBucket4; yield s
  else if b == 5 then do s <- *presenceBucket5; yield s
  else if b == 6 then do s <- *presenceBucket6; yield s
  else if b == 7 then do s <- *presenceBucket7; yield s
  else if b == 8 then do s <- *presenceBucket8; yield s
  else if b == 9 then do s <- *presenceBucket9; yield s
  else if b == 10 then do s <- *presenceBucket10; yield s
  else if b == 11 then do s <- *presenceBucket11; yield s
  else if b == 12 then do s <- *presenceBucket12; yield s
  else if b == 13 then do s <- *presenceBucket13; yield s
  else if b == 14 then do s <- *presenceBucket14; yield s
  else do s <- *presenceBucket15; yield s

writePresenceBucket : Int -> [PresenceEntry] -> IO ()
writePresenceBucket = \b entries ->
  if b == 0 then set *presenceBucket0 = entries
  else if b == 1 then set *presenceBucket1 = entries
  else if b == 2 then set *presenceBucket2 = entries
  else if b == 3 then set *presenceBucket3 = entries
  else if b == 4 then set *presenceBucket4 = entries
  else if b == 5 then set *presenceBucket5 = entries
  else if b == 6 then set *presenceBucket6 = entries
  else if b == 7 then set *presenceBucket7 = entries
  else if b == 8 then set *presenceBucket8 = entries
  else if b == 9 then set *presenceBucket9 = entries
  else if b == 10 then set *presenceBucket10 = entries
  else if b == 11 then set *presenceBucket11 = entries
  else if b == 12 then set *presenceBucket12 = entries
  else if b == 13 then set *presenceBucket13 = entries
  else if b == 14 then set *presenceBucket14 = entries
  else set *presenceBucket15 = entries

readAllPresence : IO [PresenceEntry]
readAllPresence = do
  p0 <- *presenceBucket0
  p1 <- *presenceBucket1
  p2 <- *presenceBucket2
  p3 <- *presenceBucket3
  p4 <- *presenceBucket4
  p5 <- *presenceBucket5
  p6 <- *presenceBucket6
  p7 <- *presenceBucket7
  p8 <- *presenceBucket8
  p9 <- *presenceBucket9
  p10 <- *presenceBucket10
  p11 <- *presenceBucket11
  p12 <- *presenceBucket12
  p13 <- *presenceBucket13
  p14 <- *presenceBucket14
  p15 <- *presenceBucket15
  yield (union p0 (union p1 (union p2 (union p3 (union p4 (union p5 (union p6 (union p7 (union p8 (union p9 (union p10 (union p11 (union p12 (union p13 (union p14 p15)))))))))))))))

countAllPresence : IO Int
countAllPresence = do
  p0 <- *presenceBucket0
  p1 <- *presenceBucket1
  p2 <- *presenceBucket2
  p3 <- *presenceBucket3
  p4 <- *presenceBucket4
  p5 <- *presenceBucket5
  p6 <- *presenceBucket6
  p7 <- *presenceBucket7
  p8 <- *presenceBucket8
  p9 <- *presenceBucket9
  p10 <- *presenceBucket10
  p11 <- *presenceBucket11
  p12 <- *presenceBucket12
  p13 <- *presenceBucket13
  p14 <- *presenceBucket14
  p15 <- *presenceBucket15
  yield (count p0 + count p1 + count p2 + count p3 + count p4 + count p5 + count p6 + count p7 + count p8 + count p9 + count p10 + count p11 + count p12 + count p13 + count p14 + count p15)

-- Read only the presence buckets at the given indices (avoids reading all 16)
readSelectedPresenceBuckets : [Int] -> IO [PresenceEntry]
readSelectedPresenceBuckets = \buckets ->
  case headOf buckets of
    Nothing {} -> yield []
    Just {value: b} -> do
      let rest = do x <- buckets; where x != b; yield x
      entries <- readPresenceBucket b
      remaining <- readSelectedPresenceBuckets rest
      yield (union entries remaining)

-- Single-pass partitioning: each entry's bucket is computed once (vs 16x in the list-comprehension approach)
writeAllPresence : [PresenceEntry] -> IO ()
writeAllPresence = \entries -> do
  let partitioned = fold (\acc p ->
    let b = pubkeyBucket p.pubkey in
    {b0: if b == 0 then union [p] acc.b0 else acc.b0,
     b1: if b == 1 then union [p] acc.b1 else acc.b1,
     b2: if b == 2 then union [p] acc.b2 else acc.b2,
     b3: if b == 3 then union [p] acc.b3 else acc.b3,
     b4: if b == 4 then union [p] acc.b4 else acc.b4,
     b5: if b == 5 then union [p] acc.b5 else acc.b5,
     b6: if b == 6 then union [p] acc.b6 else acc.b6,
     b7: if b == 7 then union [p] acc.b7 else acc.b7,
     b8: if b == 8 then union [p] acc.b8 else acc.b8,
     b9: if b == 9 then union [p] acc.b9 else acc.b9,
     b10: if b == 10 then union [p] acc.b10 else acc.b10,
     b11: if b == 11 then union [p] acc.b11 else acc.b11,
     b12: if b == 12 then union [p] acc.b12 else acc.b12,
     b13: if b == 13 then union [p] acc.b13 else acc.b13,
     b14: if b == 14 then union [p] acc.b14 else acc.b14,
     b15: if b == 15 then union [p] acc.b15 else acc.b15})
    {b0: [], b1: [], b2: [], b3: [], b4: [], b5: [], b6: [], b7: [], b8: [], b9: [], b10: [], b11: [], b12: [], b13: [], b14: [], b15: []} entries
  writePresenceBucket 0 partitioned.b0
  writePresenceBucket 1 partitioned.b1
  writePresenceBucket 2 partitioned.b2
  writePresenceBucket 3 partitioned.b3
  writePresenceBucket 4 partitioned.b4
  writePresenceBucket 5 partitioned.b5
  writePresenceBucket 6 partitioned.b6
  writePresenceBucket 7 partitioned.b7
  writePresenceBucket 8 partitioned.b8
  writePresenceBucket 9 partitioned.b9
  writePresenceBucket 10 partitioned.b10
  writePresenceBucket 11 partitioned.b11
  writePresenceBucket 12 partitioned.b12
  writePresenceBucket 13 partitioned.b13
  writePresenceBucket 14 partitioned.b14
  writePresenceBucket 15 partitioned.b15

transformAllPresenceBuckets : ([PresenceEntry] -> [PresenceEntry]) -> IO ()
transformAllPresenceBuckets = \f -> do
  b0 <- *presenceBucket0; set *presenceBucket0 = f b0
  b1 <- *presenceBucket1; set *presenceBucket1 = f b1
  b2 <- *presenceBucket2; set *presenceBucket2 = f b2
  b3 <- *presenceBucket3; set *presenceBucket3 = f b3
  b4 <- *presenceBucket4; set *presenceBucket4 = f b4
  b5 <- *presenceBucket5; set *presenceBucket5 = f b5
  b6 <- *presenceBucket6; set *presenceBucket6 = f b6
  b7 <- *presenceBucket7; set *presenceBucket7 = f b7
  b8 <- *presenceBucket8; set *presenceBucket8 = f b8
  b9 <- *presenceBucket9; set *presenceBucket9 = f b9
  b10 <- *presenceBucket10; set *presenceBucket10 = f b10
  b11 <- *presenceBucket11; set *presenceBucket11 = f b11
  b12 <- *presenceBucket12; set *presenceBucket12 = f b12
  b13 <- *presenceBucket13; set *presenceBucket13 = f b13
  b14 <- *presenceBucket14; set *presenceBucket14 = f b14
  b15 <- *presenceBucket15; set *presenceBucket15 = f b15

-- ============================================
-- Message Bucket Helpers
-- ============================================
-- Messages are sharded into 16 buckets by the first hex char of the recipient pubkey.
-- This reduces poll/send/ack scans from O(n) to O(n/16) on the hot path.

readMessageBucket : Int -> IO [Message]
readMessageBucket = \b ->
  if b == 0 then do s <- *messageBucket0; yield s
  else if b == 1 then do s <- *messageBucket1; yield s
  else if b == 2 then do s <- *messageBucket2; yield s
  else if b == 3 then do s <- *messageBucket3; yield s
  else if b == 4 then do s <- *messageBucket4; yield s
  else if b == 5 then do s <- *messageBucket5; yield s
  else if b == 6 then do s <- *messageBucket6; yield s
  else if b == 7 then do s <- *messageBucket7; yield s
  else if b == 8 then do s <- *messageBucket8; yield s
  else if b == 9 then do s <- *messageBucket9; yield s
  else if b == 10 then do s <- *messageBucket10; yield s
  else if b == 11 then do s <- *messageBucket11; yield s
  else if b == 12 then do s <- *messageBucket12; yield s
  else if b == 13 then do s <- *messageBucket13; yield s
  else if b == 14 then do s <- *messageBucket14; yield s
  else do s <- *messageBucket15; yield s

writeMessageBucket : Int -> [Message] -> IO ()
writeMessageBucket = \b msgs ->
  if b == 0 then set *messageBucket0 = msgs
  else if b == 1 then set *messageBucket1 = msgs
  else if b == 2 then set *messageBucket2 = msgs
  else if b == 3 then set *messageBucket3 = msgs
  else if b == 4 then set *messageBucket4 = msgs
  else if b == 5 then set *messageBucket5 = msgs
  else if b == 6 then set *messageBucket6 = msgs
  else if b == 7 then set *messageBucket7 = msgs
  else if b == 8 then set *messageBucket8 = msgs
  else if b == 9 then set *messageBucket9 = msgs
  else if b == 10 then set *messageBucket10 = msgs
  else if b == 11 then set *messageBucket11 = msgs
  else if b == 12 then set *messageBucket12 = msgs
  else if b == 13 then set *messageBucket13 = msgs
  else if b == 14 then set *messageBucket14 = msgs
  else set *messageBucket15 = msgs

-- Read all 16 message buckets (for cold-path operations: federation ack, forward candidates, stats)
readAllMessages : IO [Message]
readAllMessages = do
  m0 <- *messageBucket0
  m1 <- *messageBucket1
  m2 <- *messageBucket2
  m3 <- *messageBucket3
  m4 <- *messageBucket4
  m5 <- *messageBucket5
  m6 <- *messageBucket6
  m7 <- *messageBucket7
  m8 <- *messageBucket8
  m9 <- *messageBucket9
  m10 <- *messageBucket10
  m11 <- *messageBucket11
  m12 <- *messageBucket12
  m13 <- *messageBucket13
  m14 <- *messageBucket14
  m15 <- *messageBucket15
  yield (union m0 (union m1 (union m2 (union m3 (union m4 (union m5 (union m6 (union m7 (union m8 (union m9 (union m10 (union m11 (union m12 (union m13 (union m14 m15)))))))))))))))

-- Apply a filter/transform to every message bucket
transformAllMessageBuckets : ([Message] -> [Message]) -> IO ()
transformAllMessageBuckets = \f -> do
  b0 <- *messageBucket0; set *messageBucket0 = f b0
  b1 <- *messageBucket1; set *messageBucket1 = f b1
  b2 <- *messageBucket2; set *messageBucket2 = f b2
  b3 <- *messageBucket3; set *messageBucket3 = f b3
  b4 <- *messageBucket4; set *messageBucket4 = f b4
  b5 <- *messageBucket5; set *messageBucket5 = f b5
  b6 <- *messageBucket6; set *messageBucket6 = f b6
  b7 <- *messageBucket7; set *messageBucket7 = f b7
  b8 <- *messageBucket8; set *messageBucket8 = f b8
  b9 <- *messageBucket9; set *messageBucket9 = f b9
  b10 <- *messageBucket10; set *messageBucket10 = f b10
  b11 <- *messageBucket11; set *messageBucket11 = f b11
  b12 <- *messageBucket12; set *messageBucket12 = f b12
  b13 <- *messageBucket13; set *messageBucket13 = f b13
  b14 <- *messageBucket14; set *messageBucket14 = f b14
  b15 <- *messageBucket15; set *messageBucket15 = f b15

-- Read only the message buckets at the given indices (avoids reading all 16)
readSelectedBuckets : [Int] -> IO [Message]
readSelectedBuckets = \buckets ->
  case headOf buckets of
    Nothing {} -> yield []
    Just {value: b} -> do
      let rest = do x <- buckets; where x != b; yield x
      msgs <- readMessageBucket b
      remaining <- readSelectedBuckets rest
      yield (union msgs remaining)

-- Transform only the message buckets at the given indices
transformSelectedBuckets : [Int] -> ([Message] -> [Message]) -> IO ()
transformSelectedBuckets = \buckets f ->
  case headOf buckets of
    Nothing {} -> yield {}
    Just {value: b} -> do
      let rest = do x <- buckets; where x != b; yield x
      msgs <- readMessageBucket b
      writeMessageBucket b (f msgs)
      transformSelectedBuckets rest f

-- Collect unique bucket indices for a set of pubkeys
uniqueBucketsFor = \items getKey ->
  fold (\acc x ->
    let b = pubkeyBucket (getKey x) in
    if any acc (\i -> i == b) then acc else union acc [b]) [] items

-- Prune a single message bucket and atomically adjust shared counters.
-- Each bucket prune decrements totalMessageCount and recipientMsgCounts by exactly
-- what was removed, preserving concurrent modifications from poll-ack or send.
pruneMessageBucket = \b messageCutoff -> atomic do
  bucket <- readMessageBucket b
  let kept = do m <- bucket; where m.receivedAt > messageCutoff; yield m
  let removedCount = count bucket - count kept
  writeMessageBucket b kept
  if removedCount > 0 then do
    tc <- *totalMessageCount
    set *totalMessageCount = max 0 (tc - removedCount)
    rc <- *recipientMsgCounts
    let removed = do m <- bucket; where m.receivedAt <= messageCutoff; yield m
    set *recipientMsgCounts = batchDecrementRecipientCounts rc (countByRecipient removed)
  else yield {}

-- Per-bucket message reconciliation: reads one bucket per atomic block instead of all 16
-- at once, reducing lock contention during reconciliation. Each pubkey maps to exactly one
-- bucket, so per-bucket recipient counts are disjoint and can be merged without overlap.
reconcileMessageCounts = \b acc ->
  if b > 15 then do
    atomic do
      let total = fold (\a c -> a + c.count) 0 acc
      stored <- *totalMessageCount
      set *totalMessageCount = total
      set *recipientMsgCounts = acc
      yield (total - stored)
  else do
    bucketCounts <- atomic do
      bucket <- readMessageBucket b
      yield (countByRecipient bucket)
    reconcileMessageCounts (b + 1) (union acc bucketCounts)

-- ============================================
-- Recipient Count Helpers
-- ============================================
-- Per-recipient message counts avoid O(n) scan of all messages on send/forward.
-- TODO: If Knot adds a map/dictionary type, replace [RecipientCount] with a
-- Map<PubkeyHex, Int> for O(1) lookups. Currently getRecipientCount and
-- adjustRecipientCount are O(unique_recipients) per call.

getRecipientCount : PubkeyHex -> [RecipientCount] -> Int
getRecipientCount = \pubkey counts ->
  fold (\acc c -> if c.pubkey == pubkey then c.count else acc) 0 counts

-- Single-pass recipient count adjustment: fold once instead of any + list comprehension (O(n) vs O(2n))
adjustRecipientCount : [RecipientCount] -> PubkeyHex -> Int -> [RecipientCount]
adjustRecipientCount = \counts pubkey delta ->
  if delta == 0 then counts
  else let result = fold (\acc c ->
    if c.pubkey == pubkey
      then if c.count + delta > 0
        then {items: union acc.items [{pubkey: c.pubkey, count: c.count + delta}], found: True {}}
        else {items: acc.items, found: True {}}
      else {items: union acc.items [c], found: acc.found})
    {items: [], found: False {}} counts
  in if result.found then result.items
    else if delta > 0 then union counts [{pubkey: pubkey, count: delta}]
    else counts

-- Count items per toKey in a single pass: fold accumulates {pubkey, count} pairs,
-- incrementing existing entries or inserting new ones.
-- NOTE: O(n*k) where k = unique recipients due to `any acc` check inside fold.
-- Acceptable for per-bucket data (n ≤ maxMessages/16). A map type would make this O(n).
countByRecipient = \items ->
  fold (\acc x ->
    if any acc (\c -> c.pubkey == x.toKey)
      then do c <- acc; yield (if c.pubkey == x.toKey then {pubkey: c.pubkey, count: c.count + 1} else c)
      else union acc [{pubkey: x.toKey, count: 1}]) [] items

-- Batch-decrement recipient counts: subtract per-key removal counts in a single pass
-- instead of calling adjustRecipientCount in a loop.
batchDecrementRecipientCounts : [RecipientCount] -> [RecipientCount] -> [RecipientCount]
batchDecrementRecipientCounts = \counts removedCounts ->
  do c <- counts; let adj = c.count - getRecipientCount c.pubkey removedCounts; where adj > 0; yield {pubkey: c.pubkey, count: adj}

-- Check message dedup only (without counting — count comes from recipientMsgCounts)
checkMessageDup : [Message] -> Text -> PubkeyHex -> Bool
checkMessageDup = \messages messageId toKey ->
  messageId != "" && any messages (\m -> m.messageId == messageId && m.toKey == toKey)

-- ============================================
-- Federation In-Flight Tracking
-- ============================================
-- Tracks outstanding federation fetches per server. Servers with hung requests
-- (older than federationFetchTimeoutMs) are skipped to prevent slot exhaustion.

markFederationInFlight = \server -> do
  t <- now
  atomic do
    inFlight <- *federationInFlight
    let existing = headOf (do r <- inFlight; where r.server == server; yield r)
    case existing of
      Nothing {} -> set *federationInFlight =
        let updated = union inFlight [{server: server, count: 1, firstStartedAt: t}] in
        if count updated > maxFederationInFlight then evictOneOldest updated (\r -> r.firstStartedAt) else updated
      Just {} -> set *federationInFlight = do r <- inFlight; yield (if r.server == server then {server: r.server, count: r.count + 1, firstStartedAt: r.firstStartedAt} else r)

clearFederationInFlight = \server -> atomic do
  inFlight <- *federationInFlight
  set *federationInFlight = do r <- inFlight; yield (if r.server == server then {server: r.server, count: max 0 (r.count - 1), firstStartedAt: if r.count <= 1 then 0 else r.firstStartedAt} else r)

hasHungFederationRequest : Text -> Timestamp -> [FederationInFlightEntry] -> Bool
hasHungFederationRequest = \server t inFlight ->
  any inFlight (\r -> r.server == server && r.count > 0 && r.firstStartedAt > 0 && t - r.firstStartedAt >= federationFetchTimeoutMs)

-- Wrapper around fetch for federation calls: tracks in-flight state, global connection count,
-- logs slow responses, and records latency metrics.
-- NOTE: If fetch panics (runtime error), in-flight and connection counters leak until
-- pruneExpired reclaims them (stale threshold: 1.5x federationFetchTimeoutMs). Knot
-- lacks try-finally, so this safety net in pruneExpired is the cleanup mechanism.
fetchFederation = \server request -> do
  -- Acquire global federation connection slot
  atomic do
    ac <- *federationActiveConnections
    set *federationActiveConnections = ac + 1
  markFederationInFlight server
  startTime <- now
  result <- fetch (federationUrl server) request
  clearFederationInFlight server
  -- Release global federation connection slot
  atomic do
    ac <- *federationActiveConnections
    set *federationActiveConnections = max 0 (ac - 1)
  endTime <- now
  let latency = endTime - startTime
  when (latency > federationFetchTimeoutMs)
    (logWarn ("federation: slow response from " ++ server ++ " (" ++ show latency ++ "ms)"))
  atomic do
    total <- *federationLatencyTotal
    cnt <- *federationLatencyCount
    mx <- *federationLatencyMax
    set *federationLatencyTotal = total + latency
    set *federationLatencyCount = cnt + 1
    set *federationLatencyMax = if latency > mx then latency else mx
  yield result

clampTtl : Int<S> -> Int<S>
clampTtl = clamp 1 maxPresenceTtl

clampTimestamp : Timestamp -> Timestamp -> Timestamp
clampTimestamp = \timestamp t -> clamp (t - messageMaxAge) t timestamp

-- Ensure strictly monotonic timestamps for message ordering
nextSeqTs : Timestamp -> Timestamp -> Timestamp
nextSeqTs = \t seqCounter -> if t > seqCounter then t else seqCounter + 1

-- Deduplicate message IDs, preserving order, capped at maxMessageIds
dedupMessageIds : [MessageIdHex] -> [MessageIdHex]
dedupMessageIds = \messageIds ->
  let capped = takeRelation maxMessageIds messageIds in
  fold (\acc mid ->
    if any acc (\a -> a == mid) then acc
    else union acc [mid]) [] capped


-- Constant-time string comparison to prevent timing side-channels.
-- Always iterates maxTokenLen characters regardless of input length;
-- rejects empty strings. Tracks both character mismatches and length
-- mismatch (one string ended before the other) within the loop itself,
-- avoiding variable-time count(chars) calls that would leak string length.
safeCompareLoop : Text -> Text -> Int -> Int -> Int -> Int
safeCompareLoop = \s1 s2 n diff lenDiff ->
  if n <= 0
    then diff + lenDiff
    else
      let c1 = take 1 s1 in
      let c2 = take 1 s2 in
      let newDiff = diff + (if c1 == c2 then 0 else 1) in
      let endMismatch = if c1 == "" then (if c2 == "" then 0 else 1) else (if c2 == "" then 1 else 0) in
      safeCompareLoop (drop 1 s1) (drop 1 s2) (n - 1) newDiff (lenDiff + endMismatch)

safeCompare : Text -> Text -> Bool
safeCompare = \a b ->
  if take 1 a == "" || take 1 b == "" then False {}
  else safeCompareLoop a b maxTokenLen 0 0 == 0

-- Constant-time IP binding check: returns True if IPs match or no binding is configured.
-- When a session was created with an IP (behind a proxy), requests without an IP header
-- are rejected — prevents bypass if the proxy is removed mid-session.
-- Uses safeCompareLoop to prevent timing side-channels on IP comparison.
matchIp : Text -> Text -> Bool
matchIp = \clientIp sessionIp ->
  if sessionIp == "" then True {} -- no binding configured for this session
  else if clientIp == "" then False {} -- session has IP but request doesn't — proxy disappeared
  else safeCompareLoop clientIp sessionIp maxServerNameLen 0 0 == 0

-- Generic sliding-window rate limiter. Returns whether the request is rate-limited,
-- the updated entries list, and retryAfterMs (time until the current window resets, 0 if not limited).
-- Callers provide match/create/update functions for their entry type.
checkRateWindow = \entries matchKey makeNew updateCount maxRate windowMs maxEntries t ->
  let entry = headOf (do r <- entries; where matchKey r; yield r) in
  let isNewWindow = case entry of Nothing {} -> True {}; Just {value: r} -> t - r.windowStart >= windowMs in
  let rateCount = case entry of Nothing {} -> 0; Just {value: r} -> if isNewWindow then 0 else r.count in
  if rateCount >= maxRate
    then let retryMs = case entry of Nothing {} -> windowMs; Just {value: r} -> max 0 (windowMs - (t - r.windowStart))
      in {limited: True {}, entries: entries, retryAfterMs: retryMs}
    else
      let newEntries = if isNewWindow
        then union (do r <- entries; where not (matchKey r); yield r) [makeNew t]
        else do r <- entries; yield (if matchKey r then updateCount r else r)
      in {limited: False {}, entries: if count newEntries > maxEntries then (do r <- newEntries; where t - r.windowStart < windowMs; yield r) else newEntries, retryAfterMs: 0}

-- Rate limiter helpers: wrap common checkRateWindow patterns to reduce boilerplate.
-- Each returns {limited, entries, retryAfterMs} — caller reads/writes the mutable ref.
checkPubkeyRate = \rates pubkey maxRate windowMs maxEntries t ->
  checkRateWindow rates (\r -> r.pubkey == pubkey)
    (\ts -> {pubkey: pubkey, windowStart: ts, count: 1})
    (\r -> {pubkey: r.pubkey, windowStart: r.windowStart, count: r.count + 1})
    maxRate windowMs maxEntries t

checkIpRate = \rates ip maxRate windowMs maxEntries t ->
  checkRateWindow rates (\r -> r.ip == ip)
    (\ts -> {ip: ip, windowStart: ts, count: 1})
    (\r -> {ip: r.ip, windowStart: r.windowStart, count: r.count + 1})
    maxRate windowMs maxEntries t

checkServerRate = \rates server maxRate windowMs maxEntries t ->
  checkRateWindow rates (\r -> r.server == server)
    (\ts -> {server: server, windowStart: ts, count: 1})
    (\r -> {server: r.server, windowStart: r.windowStart, count: r.count + 1})
    maxRate windowMs maxEntries t

checkPairRate = \rates sender recipient maxRate windowMs maxEntries t ->
  checkRateWindow rates (\r -> r.sender == sender && r.recipient == recipient)
    (\ts -> {sender: sender, recipient: recipient, windowStart: ts, count: 1})
    (\r -> {sender: r.sender, recipient: r.recipient, windowStart: r.windowStart, count: r.count + 1})
    maxRate windowMs maxEntries t

checkServerRecipientRate = \rates server recipient maxRate windowMs maxEntries t ->
  checkRateWindow rates (\r -> r.server == server && r.recipient == recipient)
    (\ts -> {server: server, recipient: recipient, windowStart: ts, count: 1})
    (\r -> {server: r.server, recipient: r.recipient, windowStart: r.windowStart, count: r.count + 1})
    maxRate windowMs maxEntries t

-- Extract the item with the smallest key and return both the item and remaining list
extractOldest = \items getKey ->
  fold (\acc x ->
    case acc.candidate of
      Nothing {} -> {candidate: Just {value: x}, items: acc.items}
      Just {value: c} ->
        if getKey x < getKey c
          then {candidate: Just {value: x}, items: union acc.items [c]}
          else {candidate: acc.candidate, items: union acc.items [x]}
    ) {candidate: Nothing {}, items: []} items

-- Remove the single item with the smallest key value (LRU-style eviction)
evictOneOldest = \items getKey ->
  let r = extractOldest items getKey in
  case r.candidate of
    Nothing {} -> items
    Just {} -> r.items

-- Remove the N items with the smallest key value. O(n*k) — efficient when k is small.
evictSmallest = \items n getKey ->
  if n <= 0 then {kept: items, evicted: []}
  else let r = extractOldest items getKey in
    case r.candidate of
      Nothing {} -> {kept: items, evicted: []}
      Just {value: c} ->
        let rest = evictSmallest r.items (n - 1) getKey in
        {kept: rest.kept, evicted: union [c] rest.evicted}

-- Enforce per-key capacity: if a key has >= maxPerKey items, evict the oldest for that key.
-- Also prunes expired items.
capPerKey = \items matchKey maxPerKey getExpiry t ->
  let active = do x <- items; where getExpiry x > t; yield x in
  let forKey = do x <- active; where matchKey x; yield x in
  if count forKey >= maxPerKey
    then let others = diff active forKey in
         union others (evictOneOldest forKey getExpiry)
    else active

-- Enforce global capacity: if at maxCount, evict the single oldest item
capGlobal = \items maxCount getKey ->
  if count items >= maxCount
    then evictOneOldest items getKey
    else items

-- Two-tier capacity enforcement: per-key first, then global
capPerKeyAndGlobal = \items matchKey maxPerKey getExpiry t maxGlobal ->
  capGlobal (capPerKey items matchKey maxPerKey getExpiry t) maxGlobal getExpiry

removeOneForKey = \items pubkey ->
  let forKey = do x <- items; where x.pubkey == pubkey; yield x in
  let others = do x <- items; where x.pubkey != pubkey; yield x in
  union others (evictOneOldest forKey (\x -> x.startedAt))

-- Extract unique remote (non-local) server names from a list of items.
-- O(n*k) where k = unique servers; acceptable since k is typically small (<20).
collectPeerServers : [a] -> (a -> Text) -> [Text]
collectPeerServers = \items getServer ->
  fold (\acc item ->
    let s = getServer item in
    if isLocalServer s then acc
    else if any acc (\a -> a == s) then acc
    else union acc [s]) [] items

samePubkeyServer = \a b -> a.pubkey == b.pubkey && a.server == b.server
pubkeyServer = \e -> {pubkey: e.pubkey, server: e.server}

-- Upsert items by key, keeping the fresher entry on conflict (last-write-wins by freshness)
mergeByKey = \sameKey getFreshness initial items ->
  fold (\acc e ->
    if any acc (\a -> sameKey a e && getFreshness a >= getFreshness e)
      then acc
      else union
        (do a <- acc; where not (sameKey a e); yield a)
        [e]) initial items

-- Merge presence entries by (pubkey, server), keeping the one with the latest expiresAt
mergeByPubkeyServer = mergeByKey samePubkeyServer (\x -> x.expiresAt)

-- Keep entries from setA that are not superseded by a newer-timestamped entry in setB
resolveByTimestamp = \setA setB ->
  do e <- setA; where none setB (\o -> samePubkeyServer o e && o.timestamp > e.timestamp); yield e

-- Remove presence entries that have a corresponding offline event with a newer timestamp
removeOffline = \presenceSet trustedOffline t ->
  diff presenceSet (do
    p <- presenceSet
    o <- trustedOffline
    where samePubkeyServer p o && min o.timestamp t > p.timestamp
    yield p)

-- Cap presence table after gossip merge. If over capacity, only allow updates to
-- existing entries and reclaim slots from expired ones for new entries.
capGossipPresence = \args ->
  if count args.afterOffline <= maxPresenceEntries
    then {finalPresence: args.afterOffline, appliedOnline: args.appliedOnline, withinCapacity: True {}}
    else
      let updatesOnly = existingPresenceUpdates args.trustedDeduped args.presence in
      let updatesOnlyMerged = mergeByPubkeyServer args.presence updatesOnly in
      let updatesOnlyAfterOffline = removeOffline updatesOnlyMerged args.trustedOffline args.t in
      let reclaimSlots = maxPresenceEntries - count updatesOnlyAfterOffline in
      let newEntries = newPresenceEntries args.trustedDeduped args.presence in
      let reclaimedEntries = takeRelation reclaimSlots newEntries in
      {finalPresence: union updatesOnlyAfterOffline reclaimedEntries,
       appliedOnline: union
        (appliedOnlineKeys updatesOnly args.presence)
        (do e <- reclaimedEntries; yield (pubkeyServer e)),
       withinCapacity: False {}}

hasMessage : MessageIdHex -> PubkeyHex -> [{messageId: MessageIdHex, toKey: PubkeyHex | a}] -> Bool
hasMessage = \mid toKey items -> any items (\x -> x.messageId == mid && x.toKey == toKey)

-- Validate incoming gossip events: reject local-server events, future timestamps,
-- and already-expired entries. Clamp TTLs and split into online/offline buckets.
validGossipEvents : [GossipEvent] -> Timestamp -> {online: [ValidGossipEntry], offline: [ValidGossipEntry]}
validGossipEvents = \events t ->
  let validate = \e ->
    if not (isLocalServer e.server) && e.timestamp <= t + clockSkewTolerance
      then let ttl = clampTtl e.ttl in
           let expiresAt = e.timestamp + ttl * 1000 in
           if expiresAt > t
             then [{pubkey: e.pubkey, server: e.server, expiresAt: expiresAt, timestamp: e.timestamp, ttl: ttl}]
             else []
      else []
  in fold (\acc e ->
    case e.eventType of
      GossipOnline {} -> {online: union acc.online (validate e), offline: acc.offline}
      GossipOffline {} -> {online: acc.online, offline: union acc.offline (validate e)}
      _ -> acc) {online: [], offline: []} events

-- Execute an action for each server, forking up to maxFederationConcurrency
-- and processing the remainder sequentially to bound resource usage.
sendToEach : [ServerName] -> (ServerName -> (a {})) -> a {}
sendToEach = \servers action -> sendToEachN servers action maxFederationConcurrency

sendToEachN = \servers action remaining ->
  case headOf servers of
    Nothing {} -> yield {}
    Just {value: server} -> do
      let rest = do s <- servers; where s != server; yield s
      -- Check global federation connection cap: fall back to sequential when at limit
      globalActive <- *federationActiveConnections
      let effectiveRemaining = if globalActive >= maxGlobalFederationConcurrency then 0 else remaining
      if effectiveRemaining > 0
        then do
          fork (action server)
          sendToEachN rest action (effectiveRemaining - 1)
        else do
          action server
          sendToEachN rest action 0

-- Per-bucket presence pruning: prune a single presence bucket atomically.
-- Returns expired local entries (for offline gossip), peer servers in kept entries,
-- all peer servers (before pruning), and count of removed entries.
prunePresenceBucketN = \b t -> atomic do
  bucket <- readPresenceBucket b
  let kept = do x <- bucket; where x.expiresAt > t; yield x
  let expired = do x <- bucket; where x.expiresAt <= t; yield x
  -- Expired local entries: only those without a surviving local presence entry for the same key
  -- (all entries for a pubkey live in the same bucket, so this per-bucket check is complete)
  let expiredLocal = do x <- expired; where isLocalServer x.server && none kept (\k -> k.pubkey == x.pubkey && isLocalServer k.server); yield x
  writePresenceBucket b kept
  yield {expiredLocal: expiredLocal, keptPeerServers: collectPeerServers kept (\p -> p.server), allPeerServers: collectPeerServers bucket (\p -> p.server), removedCount: count expired}

-- Recursively prune all 16 presence buckets and aggregate results.
prunePresenceBuckets = \b t ->
  if b > 15 then yield {expiredLocal: [], keptPeerServers: [], allPeerServers: [], totalRemoved: 0}
  else do
    r <- prunePresenceBucketN b t
    rest <- prunePresenceBuckets (b + 1) t
    let mergePeers = \a ps -> fold (\acc s -> if any acc (\x -> x == s) then acc else union acc [s]) a ps
    yield {expiredLocal: union r.expiredLocal rest.expiredLocal,
           keptPeerServers: mergePeers r.keptPeerServers rest.keptPeerServers,
           allPeerServers: mergePeers r.allPeerServers rest.allPeerServers,
           totalRemoved: r.removedCount + rest.totalRemoved}

-- Remove all expired entries from every collection. Returns expired local presence
-- entries (for broadcasting offline gossip) and the set of peer servers known before pruning.
pruneExpired = \t -> do
  -- Prune presence per-bucket (16 smaller atomic blocks instead of one large one).
  -- Each bucket is independent: all entries for a pubkey hash to the same bucket,
  -- so per-bucket before/after comparison is equivalent to the global check.
  presenceResults <- prunePresenceBuckets 0 t
  atomic do
    tpc <- *totalPresenceCount
    set *totalPresenceCount = max 0 (tpc - presenceResults.totalRemoved)
    set *knownPeerServers = presenceResults.keptPeerServers
    when (presenceResults.totalRemoved > 0) (set *presenceVersion = t)
  let presenceResult = {expiredLocal: presenceResults.expiredLocal, peerServers: presenceResults.allPeerServers}
  -- Prune auth state
  atomic do
    challenges <- *challenges
    set *challenges = do x <- challenges; where x.expiresAt > t; yield x
    transformAllSessionBuckets (\bucket -> do x <- bucket; where x.expiresAt > t && t - x.createdAt < maxSessionLifetime; yield x)
    sessionCount <- countAllSessions
    set *totalSessionCount = sessionCount
  -- Prune messages across all 16 buckets. Each bucket prune is atomic and adjusts
  -- shared counters (totalMessageCount, recipientMsgCounts) by delta, preserving
  -- concurrent modifications from poll-ack or send-message operations.
  let messageCutoff = t - unackedMessageMaxAge
  pruneMessageBucket 0 messageCutoff
  pruneMessageBucket 1 messageCutoff
  pruneMessageBucket 2 messageCutoff
  pruneMessageBucket 3 messageCutoff
  pruneMessageBucket 4 messageCutoff
  pruneMessageBucket 5 messageCutoff
  pruneMessageBucket 6 messageCutoff
  pruneMessageBucket 7 messageCutoff
  pruneMessageBucket 8 messageCutoff
  pruneMessageBucket 9 messageCutoff
  pruneMessageBucket 10 messageCutoff
  pruneMessageBucket 11 messageCutoff
  pruneMessageBucket 12 messageCutoff
  pruneMessageBucket 13 messageCutoff
  pruneMessageBucket 14 messageCutoff
  pruneMessageBucket 15 messageCutoff
  -- Prune federation state
  atomic do
    let retainCutoff = t - messageMaxAge
    forwards <- *forwards
    -- Clear all forwards when federation is disabled (they can never be retried)
    set *forwards = if not federationEnabled then []
      else do f <- forwards; where f.createdAt > retainCutoff; yield f
    ackedIds <- *ackedIds
    set *ackedIds = do a <- ackedIds; where a.ackedAt > retainCutoff; yield a
    forwardFailures <- *forwardFailures
    set *forwardFailures = do f <- forwardFailures; where t - f.failedAt < maxServerDowntime; yield f
    ackOverflow <- *ackOverflow
    set *ackOverflow = do a <- ackOverflow; where a.ackedAt > retainCutoff; yield a
    deliveredIds <- *deliveredIds
    set *deliveredIds = do d <- deliveredIds; where d.deliveredAt > retainCutoff; yield d
  -- Prune rate limiters (split into smaller atomic blocks to reduce lock contention)
  atomic do
    sendRates <- *sendRates
    set *sendRates = do r <- sendRates; where t - r.windowStart < sendRateWindowMs; yield r
    challengeRates <- *challengeRates
    set *challengeRates = do r <- challengeRates; where t - r.windowStart < challengeRateWindowMs; yield r
    recvRates <- *recvRates
    set *recvRates = do r <- recvRates; where t - r.windowStart < recvRateWindowMs; yield r
    pairRates <- *pairRates
    set *pairRates = do r <- pairRates; where t - r.windowStart < pairRateWindowMs; yield r
    -- Reset auth-tier global rate window
    authWS <- *authGlobalRateWindowStart
    when (t - authWS >= authGlobalRateWindowMs) (do
      set *authGlobalRateWindowStart = t
      set *authGlobalRateCount = 0)
  atomic do
    federationRates <- *federationRates
    set *federationRates = do r <- federationRates; where t - r.windowStart < federationRateWindowMs; yield r
    federationPairRates <- *federationPairRates
    set *federationPairRates = do r <- federationPairRates; where t - r.windowStart < federationPairRateWindowMs; yield r
    ipRates <- *ipRates
    set *ipRates = do r <- ipRates; where t - r.windowStart < ipRateWindowMs; yield r
    lookupRates <- *lookupRates
    set *lookupRates = do r <- lookupRates; where t - r.windowStart < lookupRateWindowMs; yield r
    verifyIpRates <- *verifyIpRates
    set *verifyIpRates = do r <- verifyIpRates; where t - r.windowStart < verifyRateWindowMs; yield r
  atomic do
    activePolls <- *activePolls
    set *activePolls = do p <- activePolls; where t - p.startedAt < pollTimeoutMs * 3; yield p
    recentGossip <- *recentGossip
    set *recentGossip = do r <- recentGossip; where t - r.seenAt < gossipDedupWindow; yield r
    -- Clean up stale in-flight entries: remove zeroed entries and reset leaked slots
    -- where the forked task died without calling clearFederationInFlight.
    -- Uses 1.25x timeout threshold so leaked slots are reclaimed promptly
    -- after the skip-hung-server logic (at 1x) has already taken effect.
    -- Tighter than the original 1.5x to reduce the window where panicked
    -- fetches hold federation slots hostage.
    inFlight <- *federationInFlight
    let staleThreshold = federationFetchTimeoutMs * 5 / 4
    let staleInFlight = do r <- inFlight; where r.count > 0 && r.firstStartedAt > 0 && t - r.firstStartedAt >= staleThreshold; yield r
    when (count staleInFlight > 0)
      (logWarn ("pruneExpired: cleaning " ++ show (count staleInFlight) ++ " stale in-flight entries (leaked slots)"))
    set *federationInFlight = do r <- inFlight; where r.count > 0 && (r.firstStartedAt == 0 || t - r.firstStartedAt < staleThreshold); yield r
    -- Prune stale federation replay dedup entries
    recentFedReqs <- *recentFederationRequests
    set *recentFederationRequests = do r <- recentFedReqs; where t - r.seenAt < clockSkewTolerance * 2; yield r
    -- Prune expired federation verification tokens
    pending <- *pendingVerifications
    set *pendingVerifications = do p <- pending; where t - p.createdAt < verificationTokenExpiry; yield p
    -- Prune expired forward nonces (extended replay protection)
    forwardNonces <- *forwardNonces
    set *forwardNonces = do n <- forwardNonces; where t - n.seenAt < forwardNonceRetention; yield n
    -- Prune gossip event rate entries
    gossipEventRates <- *gossipEventRates
    set *gossipEventRates = do r <- gossipEventRates; where t - r.windowStart < gossipEventRateWindowMs; yield r
    -- Prune stale deferred ack cleanups (older than messageMaxAge are never useful)
    pendingCleanups <- *pendingAckCleanups
    set *pendingAckCleanups = do c <- pendingCleanups; where t - c.cleanupAfter < messageMaxAge; yield c
    -- Reconcile global federation connection counter with actual in-flight state
    -- (self-heals drift from leaked slots where a forked task died without decrementing)
    inFlightRec <- *federationInFlight
    set *federationActiveConnections = fold (\acc r -> acc + r.count) 0 inFlightRec
  yield presenceResult


splitAtN = \items n ->
  fold (\acc e ->
    if acc.n < n then {n: acc.n + 1, batch: union acc.batch [e], rest: acc.rest}
    else {n: acc.n, batch: acc.batch, rest: union acc.rest [e]})
    {n: 0, batch: [], rest: []} items

forEachBatch = \items batchSize process ->
  if count items == 0 then yield {}
  else do
    let split = splitAtN items batchSize
    process split.batch
    forEachBatch split.rest batchSize process

sendBatchedGossipToServer : ServerName -> [GossipEvent] -> Int -> IO {network} {}
sendBatchedGossipToServer = \server allEvents hops ->
  forEachBatch allEvents maxGossipEvents (\batch -> do
    t <- now
    auth <- generateFederationAuth "gossip"
    result <- fetchFederation server (RecvGossip {
      authorization: auth,
      events: batch, hopsRemaining: hops, fromServer: serverHostN,
      requestTimestamp: t})
    case result of
      Err e -> logWarn ("federation: gossip to " ++ server ++ " failed: " ++ show e)
      Ok _ -> yield {})

sendBatchedGossip : [ServerName] -> [GossipEvent] -> Int -> IO {network} {}
sendBatchedGossip = \peerServers allEvents hops ->
  sendToEach peerServers (\server -> sendBatchedGossipToServer server allEvents hops)

broadcastOfflineGossip = \t peerServers expiredLocal ->
  when (federationEnabled && count peerServers > 0 && count expiredLocal > 0) (do
    failures <- *forwardFailures
    if isFederationCircuitOpen failures t
      then logWarn ("federation: circuit breaker open, skipping offline gossip broadcast")
      else do
    let cappedExpired = takeRelation maxPresenceEntries expiredLocal
    when (count expiredLocal > maxPresenceEntries)
      (logWarn ("gossip: capped offline broadcast to " ++ show maxPresenceEntries ++ " entries (had " ++ show (count expiredLocal) ++ ")"))
    let gossipEvents = mergeByKey (\a b -> a.pubkey == b.pubkey) (\x -> x.timestamp) [] (offlineGossipEvents cappedExpired)
    sendBatchedGossip peerServers gossipEvents gossipOriginHops)


effectiveGossipEvents = \entries appliedKeys eventType -> do
  e <- entries
  where any appliedKeys (\a -> samePubkeyServer a e)
  yield {eventType: eventType, pubkey: e.pubkey, server: e.server, timestamp: e.timestamp, ttl: e.ttl}

mergeGossipPresence = \presence deduped trustedOffline fromServer t ->
  let trustedDeduped = trustedGossipEntries deduped presence fromServer t in
  let appliedOnline = appliedOnlineKeys trustedDeduped presence in
  let merged = mergeByPubkeyServer presence trustedDeduped in
  let afterOffline = removeOffline merged trustedOffline t in
  let appliedOffline = do p <- diff merged afterOffline; yield (pubkeyServer p) in
  let capResult = capGossipPresence {afterOffline: afterOffline, appliedOnline: appliedOnline, trustedDeduped: trustedDeduped, presence: presence, trustedOffline: trustedOffline, t: t} in
  {finalPresence: capResult.finalPresence,
   appliedKeys: union capResult.appliedOnline appliedOffline,
   gossipPeerServers: collectPeerServers capResult.finalPresence (\p -> p.server),
   withinCapacity: capResult.withinCapacity}


checkFederationRate = \server t -> atomic do
  federationRates <- *federationRates
  let result = checkServerRate federationRates server maxFederationRatePerServer federationRateWindowMs maxFederationRateEntries t
  set *federationRates = result.entries
  yield result.limited

checkGlobalRate = \t -> atomic do
  windowStart <- *globalRateWindowStart
  rateCount <- *globalRateCount
  if t - windowStart >= globalRateWindowMs
    then do
      set *globalRateWindowStart = t
      set *globalRateCount = 1
      yield (False {})
    else if rateCount >= maxGlobalRequestRate
      then yield (True {})
      else do
        set *globalRateCount = rateCount + 1
        yield (False {})

-- Auth-tier global rate limiting (shared budget for challenge + verify + revoke)
checkAuthGlobalRate = \t -> atomic do
  windowStart <- *authGlobalRateWindowStart
  rateCount <- *authGlobalRateCount
  if t - windowStart >= authGlobalRateWindowMs
    then do
      set *authGlobalRateWindowStart = t
      set *authGlobalRateCount = 1
      yield (False {})
    else if rateCount >= maxAuthGlobalRate
      then yield (True {})
      else do
        set *authGlobalRateCount = rateCount + 1
        yield (False {})

-- IP-based rate limiting; skips if clientIp header is empty (no reverse proxy)
checkClientIpRate = \ip t ->
  if ip == "" then yield (False {})
  else atomic do
    ipRates <- *ipRates
    let result = checkIpRate ipRates ip maxIpRatePerIp ipRateWindowMs maxIpRateEntries t
    set *ipRates = result.entries
    yield result.limited

-- Combined pre-auth gate: drain check, global rate, IP rate. Returns "" if all pass.
checkPreAuth = \clientIp t -> do
  draining <- *draining
  if draining then yield "draining"
  else do
    globalLimited <- checkGlobalRate t
    if globalLimited then yield "global_rate_limited"
    else do
      ipLimited <- checkClientIpRate clientIp t
      if ipLimited then yield "ip_rate_limited"
      else yield ""

withFederationAuth = \authorization t respond fromServer scope requestTimestamp precondition action -> do
  -- Check blocklist before spending resources on verification callback
  blocked <- *blockedPeers
  if isBlockedPeer fromServer blocked
    then do
      logWarn ("federation: blocked peer " ++ fromServer ++ " rejected")
      yield (respond {ok: False {}, error: "blocked"})
    else do
  verified <- verifyFederationCallback fromServer authorization scope
  if not verified
    then yield (respond {ok: False {}, error: "unauthorized"})
    -- Replay protection: reject requests with timestamps too far from local clock.
    -- requestTimestamp == 0 means the peer doesn't support this field yet (accept).
    else if requestTimestamp > 0 && (requestTimestamp > t + clockSkewTolerance || requestTimestamp < t - clockSkewTolerance)
    then do
      logWarn ("federation: clock skew " ++ show (t - requestTimestamp) ++ "ms from " ++ fromServer ++ ", rejecting (tolerance: " ++ show clockSkewTolerance ++ "ms)")
      yield (respond {ok: False {}, error: "clock_skew"})
    else if not precondition
    then yield (respond {ok: False {}, error: "invalid_request"})
    else do
      -- Replay detection: reject duplicate (server, timestamp) pairs within the skew window
      replayDetected <- if requestTimestamp > 0
        then atomic do
          recent <- *recentFederationRequests
          let isDup = any recent (\r -> r.server == fromServer && r.timestamp == requestTimestamp)
          if isDup then yield (True {})
          else do
            let cleaned = do r <- recent; where t - r.seenAt < clockSkewTolerance * 2; yield r
            let updated = union cleaned [{server: fromServer, timestamp: requestTimestamp, seenAt: t}]
            set *recentFederationRequests = if count updated > maxRecentFederationRequests then evictOneOldest updated (\r -> r.seenAt) else updated
            yield (False {})
        else yield (False {})
      if replayDetected
        then do
          logWarn ("federation: replay detected from " ++ fromServer ++ " (timestamp: " ++ show requestTimestamp ++ ")")
          yield (respond {ok: False {}, error: "replay_detected"})
        else do
      globalLimited <- checkGlobalRate t
      if globalLimited
        then do
          logWarn ("federation: global rate limited (" ++ show maxGlobalRequestRate ++ "/s), rejecting for " ++ fromServer)
          yield (respond {ok: False {}, error: "rate_limited"})
        else do
          rateLimited <- checkFederationRate fromServer t
          if rateLimited
            then do
              logWarn ("federation: rate limited (" ++ show maxFederationRatePerServer ++ "/s per server), rejecting for " ++ fromServer)
              yield (respond {ok: False {}, error: "rate_limited"})
            else do
              clearFailure fromServer
              action

withSessionAuth = \authorization t clientIp onUnauth onAuth -> do
  case extractToken authorization of
    Nothing {} -> onUnauth
    Just {value: token} -> do
      let bucket = tokenBucket token
      sessions <- readSessionBucket bucket
      case authenticateSession sessions token t of
        Unauthorized {} -> onUnauth
        Authorized {pubkey, ip} ->
          if not (matchIp clientIp ip)
            then onUnauth
            else onAuth pubkey

removeForward = \mid srv -> atomic do
  forwards <- *forwards
  set *forwards = forwardsExcluding forwards srv [mid]

-- Reclaim origin messages after federation ack confirms delivery.
-- Batched by message bucket: all entries for the same bucket are processed in one
-- atomic block (reduces transaction overhead compared to one-per-entry).
ackCleanupForwards = \entries t ->
  let bucketIds = uniqueBucketsFor entries (\e -> e.toKey) in
  ackCleanupByBucket bucketIds entries t

ackCleanupByBucket = \bucketIds entries t -> case headOf bucketIds of
  Nothing {} -> yield {}
  Just {value: b} -> do
    let remainingBuckets = do x <- bucketIds; where x != b; yield x
    let bucketEntries = do e <- entries; where pubkeyBucket e.toKey == b; yield e
    atomic do
      -- All entries in this batch share pubkeyBucket == b, so only that presence bucket is needed
      bucketPresence <- readPresenceBucket b
      forwards <- *forwards
      msgs <- readMessageBucket b
      tc <- *totalMessageCount
      rc <- *recipientMsgCounts
      let cleanup = fold (\acc rf ->
        let hasLocal = any bucketPresence (\p -> p.pubkey == rf.toKey && isLocalServer p.server && p.expiresAt > t) in
        let hasOtherFwds = any forwards (\f -> f.messageId == rf.messageId && f.toKey == rf.toKey) in
        if hasLocal || hasOtherFwds then acc
        else case headOf (do m <- acc.msgs; where m.messageId == rf.messageId && m.toKey == rf.toKey && t - m.receivedAt >= ackGracePeriod; yield m) of
          Nothing {} -> acc
          Just {} -> {msgs: (do m <- acc.msgs; where not (m.messageId == rf.messageId && m.toKey == rf.toKey); yield m), removed: acc.removed + 1, rc: adjustRecipientCount acc.rc rf.toKey (0 - 1)}
        ) {msgs: msgs, removed: 0, rc: rc} bucketEntries
      writeMessageBucket b cleanup.msgs
      set *totalMessageCount = max 0 (tc - cleanup.removed)
      set *recipientMsgCounts = cleanup.rc
    ackCleanupByBucket remainingBuckets entries t

pow2 : Int -> Int
pow2 = \n -> if n <= 0 then 1 else 2 * pow2 (n - 1)

-- Exponential backoff: base * 2^(failures-1), capped at retryBackoffMax
retryBackoff : Int -> Int<Ms>
retryBackoff = \failures ->
  min retryBackoffMax (retryBackoffBase * pow2 (max 0 (failures - 1)))

shouldRetryServer : Text -> Timestamp -> [ForwardFailure] -> Bool
shouldRetryServer = \server t failures ->
  case headOf (do f <- failures; where f.server == server; yield f) of
    Nothing {} -> True {}
    Just {value: f} -> t - f.firstFailedAt < maxServerDowntime && t - f.failedAt >= retryBackoff f.failures

-- Extended retry check: also skip servers with hung in-flight requests or on the blocklist
shouldRetryServerEx : Text -> Timestamp -> [ForwardFailure] -> [FederationInFlightEntry] -> [Text] -> Bool
shouldRetryServerEx = \server t failures inFlight blocked ->
  not (isBlockedPeer server blocked) && shouldRetryServer server t failures && not (hasHungFederationRequest server t inFlight)

-- Global circuit breaker: returns True when too many peers are failing simultaneously,
-- indicating a likely local network issue rather than individual peer problems.
-- When tripped, all outbound federation is paused until the next prune cycle.
isFederationCircuitOpen : [ForwardFailure] -> Timestamp -> Bool
isFederationCircuitOpen = \failures t ->
  federationCircuitBreakerThreshold > 0
  && count (do f <- failures; where t - f.firstFailedAt < maxServerDowntime; yield f) >= federationCircuitBreakerThreshold

recordFailure = \server -> do
  t <- now
  atomic do
    failures <- *forwardFailures
    let existing = headOf (do f <- failures; where f.server == server; yield f)
    let updated = case existing of
      Nothing {} -> union failures [{server: server, failedAt: t, failures: 1, firstFailedAt: t}]
      Just {value: f} -> union (do x <- failures; where x.server != server; yield x) [{server: server, failedAt: t, failures: min (f.failures + 1) 10, firstFailedAt: f.firstFailedAt}]
    set *forwardFailures = if count updated > maxForwardFailures then evictOneOldest updated (\x -> x.failedAt) else updated

clearFailure = \server -> do
  t <- now
  atomic do
    failures <- *forwardFailures
    set *forwardFailures = do f <- failures; where f.server != server; yield f
    set *lastFederationSuccessAt = t

-- Atomically increment a forward entry's retry count; drop if maxForwardRetries exceeded
incrementForwardRetries = \messageId toServer -> atomic do
  forwards <- *forwards
  let shouldDrop = any forwards (\f -> f.messageId == messageId && f.toServer == toServer && f.retries + 1 >= maxForwardRetries)
  if shouldDrop
    then do
      set *forwards = do f <- forwards; where not (f.messageId == messageId && f.toServer == toServer); yield f
      logWarn ("federation: dropping forward " ++ messageId ++ " to " ++ toServer ++ " after " ++ show maxForwardRetries ++ " retries")
    else set *forwards = do f <- forwards; yield (if f.messageId == messageId && f.toServer == toServer then {messageId: f.messageId, toServer: f.toServer, createdAt: f.createdAt, toKey: f.toKey, encryptedBlob: f.encryptedBlob, timestamp: f.timestamp, originServer: f.originServer, retries: f.retries + 1} else f)

retryForwardsForServer : [ForwardEntry] -> Int -> IO {network} {}
retryForwardsForServer = \entries remaining ->
  if remaining <= 0
    then yield {}
    else case headOf entries of
      Nothing {} -> yield {}
      Just {value: f} -> do
        let rest = do x <- entries; where x.messageId != f.messageId; yield x
        t <- now
        auth <- generateFederationAuth "forward"
        result <- fetchFederation f.toServer (ForwardMessage {
          toKey: f.toKey, encryptedBlob: f.encryptedBlob,
          timestamp: f.timestamp, originServer: f.originServer, messageId: f.messageId,
          fromServer: serverHostN, requestTimestamp: t,
          authorization: auth})
        case result of
          Err e -> do
            logWarn ("federation: forward to " ++ f.toServer ++ " failed for " ++ f.messageId ++ ": " ++ show e)
            recordFailure f.toServer
            incrementForwardRetries f.messageId f.toServer
            -- Network error: stop retrying this server
          Ok response -> do
            if response.ok then do
              removeForward f.messageId f.toServer
              clearFailure f.toServer
            else do
              logWarn ("federation: forward to " ++ f.toServer ++ " rejected for " ++ f.messageId ++ ": " ++ response.error)
              incrementForwardRetries f.messageId f.toServer
            retryForwardsForServer rest (remaining - 1)

-- Retry all pending forwards, respecting per-server backoff. Skips servers that failed recently.
-- Circuit breaker: skips entirely when too many peers are failing (likely local network issue).
retryPendingForwards : [ForwardEntry] -> IO {network} {}
retryPendingForwards = \pending -> do
  let servers = collectPeerServers pending (\x -> x.toServer)
  t <- now
  failures <- *forwardFailures
  if isFederationCircuitOpen failures t
    then logWarn ("federation: circuit breaker open (" ++ show (count failures) ++ " peers failing), skipping forward retries")
    else do
  inFlight <- *federationInFlight
  blocked <- *blockedPeers
  let eligibleServers = do s <- servers; where shouldRetryServerEx s t failures inFlight blocked; yield s
  sendToEach eligibleServers (\server ->
    retryForwardsForServer (forwardsForServer pending server) maxForwardRetriesPerServer)
  yield {}

-- When a remote key comes online, create forward entries for queued messages and send them
forwardQueuedMessages = \targets t -> do
  newForwards <- atomic do
    forwards <- *forwards
    -- Read only the presence buckets needed for target pubkeys (not all 16)
    let targetPresenceBuckets = uniqueBucketsFor targets (\target -> target.pubkey)
    relevantPresence <- readSelectedPresenceBuckets targetPresenceBuckets
    let localOnline = localOnlineKeys relevantPresence t
    let remoteTargets = remoteOnlyTargets targets localOnline
    -- Read only the message buckets containing target pubkeys (not all 16)
    let neededBuckets = uniqueBucketsFor remoteTargets (\target -> target.pubkey)
    relevantMessages <- readSelectedBuckets neededBuckets
    let candidates = forwardCandidates remoteTargets relevantMessages forwards t
    let capped = takeRelation (maxForwardsEntries - count forwards) candidates
    let updatedForwards = union forwards capped
    set *forwards = updatedForwards
    yield capped
  let servers = collectPeerServers newForwards (\x -> x.toServer)
  failures <- *forwardFailures
  if isFederationCircuitOpen failures t
    then logWarn ("federation: circuit breaker open, skipping queued message forwarding")
    else do
  inFlight <- *federationInFlight
  blocked <- *blockedPeers
  let eligibleServers = do s <- servers; where shouldRetryServerEx s t failures inFlight blocked; yield s
  sendToEach eligibleServers (\server ->
    retryForwardsForServer (forwardsForServer newForwards server) maxForwardRetriesPerServer)

fetchFederationAck = \origin messageIds -> do
  t <- now
  auth <- generateFederationAuth "ack"
  fetchFederation origin (FederationAck {
    authorization: auth,
    messageIds: messageIds,
    originServer: origin, fromServer: serverHostN,
    requestTimestamp: t})

sendBatchedAcksToServer : [{messageId: MessageIdHex, toKey: PubkeyHex, originServer: ServerName, | a}] -> ServerName -> IO {network} {}
sendBatchedAcksToServer = \serverAcks server ->
  forEachBatch serverAcks maxMessageIds (\batch -> do
    result <- fetchFederationAck server (do a <- batch; yield a.messageId)
    case result of
      Err e -> do
        logWarn ("federation: ack to " ++ server ++ " failed: " ++ show e)
        recordFailure server
        -- Increment retry counters; drop entries exceeding maxAckRetries to deliveredIds
        dropped <- atomic do
          ackedIds <- *ackedIds
          let isTarget = \a -> a.originServer == server && hasMessage a.messageId a.toKey batch
          let toDrop = do a <- ackedIds; where isTarget a && a.retries + 1 >= maxAckRetries; yield a
          let dropCount = count toDrop
          set *ackedIds = do a <- ackedIds
            where not (isTarget a && a.retries + 1 >= maxAckRetries)
            yield (if isTarget a then {messageId: a.messageId, toKey: a.toKey, ackedAt: a.ackedAt, originServer: a.originServer, retries: a.retries + 1} else a)
          when (dropCount > 0) (do
            deliveredIds <- *deliveredIds
            let newDelivered = do d <- toDrop; yield {messageId: d.messageId, toKey: d.toKey, deliveredAt: d.ackedAt}
            let combined = union deliveredIds newDelivered
            set *deliveredIds = if count combined > maxDeliveredIds then (evictSmallest combined (count combined - maxDeliveredIds) (\d -> d.deliveredAt)).kept else combined)
          yield dropCount
        when (dropped > 0)
          (logWarn ("federation: dropped " ++ show dropped ++ " ack entries to " ++ server ++ " after " ++ show maxAckRetries ++ " retries"))
      Ok _ -> do
        clearFailure server
        atomic do
          ackedIds <- *ackedIds
          let updatedAckedIds = ackedIdsExcludingBatch ackedIds server batch
          set *ackedIds = updatedAckedIds)

-- Send delivery acknowledgments back to origin servers and remove acked entries on success
sendAcksAndClean : [{messageId: MessageIdHex, toKey: PubkeyHex, originServer: ServerName, | a}] -> IO {network} {}
sendAcksAndClean = \pendingAcks -> do
  let servers = collectPeerServers pendingAcks (\a -> a.originServer)
  t <- now
  failures <- *forwardFailures
  if isFederationCircuitOpen failures t
    then logWarn ("federation: circuit breaker open, skipping ack retries")
    else do
  inFlight <- *federationInFlight
  blocked <- *blockedPeers
  let eligibleServers = do s <- servers; where shouldRetryServerEx s t failures inFlight blocked; yield s
  sendToEach eligibleServers (\server ->
    sendBatchedAcksToServer (acksForServer pendingAcks server) server)

-- Retry sending acks that were evicted from ackedIds due to capacity limits.
-- On failure, re-insert into ackedIds or overflow buffer; overflow entries eventually
-- move to deliveredIds (terminal dedup state) if the buffer is also full.
retryEvictedAcks = \evictedEntries pendingAcks ->
  let evictedToRetry = retriableEvictedAcks evictedEntries pendingAcks
  in do
    let evictedOriginServers = collectPeerServers evictedToRetry (\a -> a.originServer)
    sendToEach evictedOriginServers (\server -> do
      fetchResult <- fetchFederationAck server (do a <- acksForServer evictedToRetry server; yield a.messageId)
      case fetchResult of
        Err e -> do
          logWarn ("federation: evicted ack to " ++ server ++ " failed: " ++ show e)
          overflow <- atomic do
            ackedIds <- *ackedIds
            let reinsert = do a <- acksForServer evictedToRetry server; yield {messageId: a.messageId, toKey: a.toKey, ackedAt: a.ackedAt, originServer: a.originServer, retries: a.retries + 1}
            let combined = union ackedIds reinsert
            let excess = count combined - maxAckedIds
            if excess <= 0
              then do set *ackedIds = combined; yield []
              else do
                let eviction = evictSmallest combined (max 0 excess) (\a -> a.ackedAt)
                set *ackedIds = eviction.kept
                yield eviction.evicted
          when (count overflow > 0) (do
            dropped <- atomic do
              ackOverflow <- *ackOverflow
              let updated = union ackOverflow overflow
              let overflowExcess = count updated - maxAckOverflow
              if overflowExcess <= 0
                then do set *ackOverflow = updated; yield 0
                else do
                  let overflowEviction = evictSmallest updated (max 0 overflowExcess) (\a -> a.ackedAt)
                  set *ackOverflow = overflowEviction.kept
                  deliveredIds <- *deliveredIds
                  let newDelivered = do a <- overflowEviction.evicted; yield {messageId: a.messageId, toKey: a.toKey, deliveredAt: a.ackedAt}
                  let combinedDelivered = union deliveredIds newDelivered
                  let deliveredExcess = count combinedDelivered - maxDeliveredIds
                  set *deliveredIds = if deliveredExcess <= 0 then combinedDelivered
                    else (evictSmallest combinedDelivered (max 0 deliveredExcess) (\d -> d.deliveredAt)).kept
                  when (deliveredExcess > 0)
                    (logWarn ("ackMessages: deliveredIds at capacity (" ++ show maxDeliveredIds ++ "), " ++ show deliveredExcess ++ " oldest dedup entries permanently removed for " ++ server))
                  yield overflowExcess
            when (dropped > 0)
              (logWarn ("ackMessages: overflow at capacity (" ++ show maxAckOverflow ++ "), " ++ show dropped ++ " ack entries moved to delivered set for " ++ server)))
        Ok _ -> yield {})

-- Retry acks sitting in the overflow buffer (last chance before they become deliveredIds)
retryOverflowAcks = \overflow -> do
  let servers = collectPeerServers overflow (\a -> a.originServer)
  t <- now
  failures <- *forwardFailures
  if isFederationCircuitOpen failures t
    then logWarn ("federation: circuit breaker open, skipping overflow ack retries")
    else do
  inFlight <- *federationInFlight
  blocked <- *blockedPeers
  let eligibleServers = do s <- servers; where shouldRetryServerEx s t failures inFlight blocked; yield s
  sendToEach eligibleServers (\server ->
    forEachBatch (acksForServer overflow server) maxMessageIds (\batch -> do
      result <- fetchFederationAck server (do a <- batch; yield a.messageId)
      case result of
        Err e -> do
          logWarn ("federation: overflow ack to " ++ server ++ " failed: " ++ show e)
          recordFailure server
          -- Increment retry counters in overflow; drop entries exceeding maxAckRetries to deliveredIds
          dropped <- atomic do
            ackOverflow <- *ackOverflow
            let isTarget = \a -> a.originServer == server && hasMessage a.messageId a.toKey batch
            let toDrop = do a <- ackOverflow; where isTarget a && a.retries + 1 >= maxAckRetries; yield a
            let dropCount = count toDrop
            set *ackOverflow = do a <- ackOverflow
              where not (isTarget a && a.retries + 1 >= maxAckRetries)
              yield (if isTarget a then {messageId: a.messageId, toKey: a.toKey, ackedAt: a.ackedAt, originServer: a.originServer, retries: a.retries + 1} else a)
            when (dropCount > 0) (do
              deliveredIds <- *deliveredIds
              let newDelivered = do d <- toDrop; yield {messageId: d.messageId, toKey: d.toKey, deliveredAt: d.ackedAt}
              let combined = union deliveredIds newDelivered
              set *deliveredIds = if count combined > maxDeliveredIds then (evictSmallest combined (count combined - maxDeliveredIds) (\d -> d.deliveredAt)).kept else combined)
            yield dropCount
          when (dropped > 0)
            (logWarn ("federation: dropped " ++ show dropped ++ " overflow ack entries to " ++ server ++ " after " ++ show maxAckRetries ++ " retries"))
        Ok _ -> do
          clearFailure server
          atomic do
            ackOverflow <- *ackOverflow
            set *ackOverflow = do a <- ackOverflow; where not (a.originServer == server && hasMessage a.messageId a.toKey batch); yield a))

-- Wait for all in-flight federation requests to complete or timeout.
-- Uses STM retry instead of busy-wait: blocks until *federationInFlight changes
-- (when clearFederationInFlight writes) or *drainTimedOut is set by the timeout fork.
-- This avoids the 1-second polling loop and wakes immediately when work completes.
waitForInFlightDrain = \deadline -> do
  t <- now
  let remaining = deadline - t
  atomic do set *drainTimedOut = False {}
  -- Fork a timer that sets the timeout signal after the deadline
  fork (do
    when (remaining > 0) (sleep remaining)
    atomic do set *drainTimedOut = True {})
  -- Block until either all in-flight complete or timeout fires
  atomic do
    timedOut <- *drainTimedOut
    if timedOut then yield {}
    else do
      inFlight <- *federationInFlight
      let activeCount = fold (\acc r -> acc + r.count) 0 inFlight
      if activeCount <= 0 then yield {}
      else retry
  timedOut <- *drainTimedOut
  when timedOut (logWarn "drain: timed out waiting for in-flight federation tasks")

-- Full maintenance cycle: prune expired state, retry pending forwards and acks,
-- retry overflow acks, broadcast offline gossip, and refresh presence for local keys
-- nearing expiry. Called by both the background task and the /maintenance/prune endpoint.
pruneAndRetry = \t -> do
  atomic do set *lastPrunedAt = t
  pr <- pruneExpired t
  -- Counter reconciliation: always reconcile presence and session counters (cheap: just
  -- counting list lengths across buckets). Message reconciliation stays periodic because
  -- it requires reading all messages and rebuilding per-recipient counts.
  presDrift <- atomic do
    actual <- countAllPresence
    stored <- *totalPresenceCount
    set *totalPresenceCount = actual
    yield (actual - stored)
  sessDrift <- atomic do
    actual <- countAllSessions
    stored <- *totalSessionCount
    set *totalSessionCount = actual
    yield (actual - stored)
  when (presDrift != 0 || sessDrift != 0)
    (logInfo ("reconciliation: corrected drift — presence: " ++ show presDrift ++ ", sessions: " ++ show sessDrift))
  -- Message reconciliation: per-bucket reads reduce lock contention vs reading all 16 at once
  pc <- *pruneCount
  when (pc > 0 && pc - (pc / reconciliationFrequency) * reconciliationFrequency == 0) (do
    msgDrift <- reconcileMessageCounts 0 []
    when (msgDrift != 0)
      (logInfo ("reconciliation: corrected message drift: " ++ show msgDrift)))
  pendingForwards <- atomic do f <- *forwards; yield f
  ackState <- atomic do
    ackedIds2 <- *ackedIds
    let pendingAcks = do a <- ackedIds2; where not (isLocalServer a.originServer); yield a
    ackOverflow <- *ackOverflow
    let pendingOverflow = do a <- ackOverflow; where not (isLocalServer a.originServer); yield a
    yield {pendingAcks: pendingAcks, pendingOverflow: pendingOverflow}
  refreshResult <- atomic do
    lastRefresh <- *lastPresenceRefresh
    let shouldRefresh = federationEnabled && t - lastRefresh >= presenceRefreshInterval
    -- Early return: skip expensive readAllPresence + readAllSessions on ~9/10 prune cycles
    if not shouldRefresh then yield {extendedActive: [], nearExpiryActive: [], refreshPeers: [], shouldRefresh: False {}}
    else do
      allPresence <- readAllPresence
      allSessions <- readAllSessions
      -- Extend presence for keys with active sessions nearing expiry (sliding window)
      let localNearExpiry = do p <- allPresence; where isLocalServer p.server && p.expiresAt > t && p.expiresAt - t < presenceRefreshThreshold; yield p
      let toExtend = do p <- localNearExpiry; where any allSessions (\s -> s.pubkey == p.pubkey && s.expiresAt > t); yield p
      let notExtended = do p <- localNearExpiry; where none allSessions (\s -> s.pubkey == p.pubkey && s.expiresAt > t); yield p
      when (count toExtend > 0) (do
        let updatedPresence = do pp <- allPresence; yield (if any toExtend (\e -> e.pubkey == pp.pubkey && isLocalServer pp.server) then {pubkey: pp.pubkey, server: pp.server, expiresAt: t + sessionExpiry, timestamp: t} else pp)
        writeAllPresence updatedPresence
        set *presenceVersion = t)
      knownPeers <- *knownPeerServers
      set *lastPresenceRefresh = t
      yield {extendedActive: toExtend, nearExpiryActive: notExtended, refreshPeers: knownPeers, shouldRefresh: True {}}
  -- Reset federation latency metrics periodically for windowed averages (prevents
  -- lifetime-cumulative average from masking current conditions)
  atomic do
    resetAt <- *federationLatencyResetAt
    when (t - resetAt >= federationLatencyWindowMs) (do
      set *federationLatencyTotal = 0
      set *federationLatencyCount = 0
      set *federationLatencyMax = 0
      set *federationLatencyResetAt = t)
  -- Process deferred ack cleanups: reclaim origin messages whose grace period has elapsed.
  -- These were queued by handleFederationAck instead of fork+sleep.
  readyCleanups <- atomic do
    cleanups <- *pendingAckCleanups
    let ready = do c <- cleanups; where t >= c.cleanupAfter; yield c
    let remaining = do c <- cleanups; where t < c.cleanupAfter; yield c
    set *pendingAckCleanups = remaining
    yield ready
  when (count readyCleanups > 0) (ackCleanupForwards readyCleanups t)
  let result = {pendingForwards: pendingForwards, pendingAcks: ackState.pendingAcks, pendingOverflow: ackState.pendingOverflow, extendedActive: refreshResult.extendedActive, nearExpiryActive: refreshResult.nearExpiryActive, refreshPeers: refreshResult.refreshPeers, shouldRefresh: refreshResult.shouldRefresh}
  -- Fork federation I/O so hung peers don't block next prune cycle
  fork (do
    broadcastOfflineGossip t pr.peerServers pr.expiredLocal
    when federationEnabled (do
      retryPendingForwards result.pendingForwards
      sendAcksAndClean result.pendingAcks
      retryOverflowAcks result.pendingOverflow))
  -- Only gossip extended sessions; keys nearing expiry without active sessions will naturally
  -- trigger offline gossip when they expire (avoids wasted federation traffic)
  when result.shouldRefresh (do
    let refreshEvents = do p <- result.extendedActive; yield {eventType: GossipOnline {}, pubkey: p.pubkey, server: serverHostN, timestamp: t, ttl: clampTtl (sessionExpiry / 1000)}
    when (count result.refreshPeers > 0 && count refreshEvents > 0)
      (fork (sendBatchedGossip result.refreshPeers refreshEvents gossipOriginHops)))

hexCharIndex : Text -> Int
hexCharIndex = \c ->
  if c == "0" then 0 else if c == "1" then 1 else if c == "2" then 2 else if c == "3" then 3
  else if c == "4" then 4 else if c == "5" then 5 else if c == "6" then 6 else if c == "7" then 7
  else if c == "8" then 8 else if c == "9" then 9 else if c == "a" then 10 else if c == "b" then 11
  else if c == "c" then 12 else if c == "d" then 13 else if c == "e" then 14 else 15

-- Map pubkey to one of 16 signal buckets based on first hex digit.
-- This partitions the signal space so storing a message for one pubkey
-- only wakes polls in the same bucket, not all active polls.
-- Defensive clamp ensures an invalid first char never indexes out of bounds
pubkeyBucket : PubkeyHex -> Int
pubkeyBucket = \pubkey -> clamp 0 15 (hexCharIndex (take 1 pubkey))

-- Update the signal timestamp for a pubkey's bucket, waking any blocked polls in that bucket
signalMessageForKey = \pubkey ts ->
  let b = pubkeyBucket pubkey in
  if b == 0 then set *messageSignal0 = ts
  else if b == 1 then set *messageSignal1 = ts
  else if b == 2 then set *messageSignal2 = ts
  else if b == 3 then set *messageSignal3 = ts
  else if b == 4 then set *messageSignal4 = ts
  else if b == 5 then set *messageSignal5 = ts
  else if b == 6 then set *messageSignal6 = ts
  else if b == 7 then set *messageSignal7 = ts
  else if b == 8 then set *messageSignal8 = ts
  else if b == 9 then set *messageSignal9 = ts
  else if b == 10 then set *messageSignal10 = ts
  else if b == 11 then set *messageSignal11 = ts
  else if b == 12 then set *messageSignal12 = ts
  else if b == 13 then set *messageSignal13 = ts
  else if b == 14 then set *messageSignal14 = ts
  else set *messageSignal15 = ts

readMessageSignal = \pubkey ->
  let b = pubkeyBucket pubkey in
  if b == 0 then do s <- *messageSignal0; yield s
  else if b == 1 then do s <- *messageSignal1; yield s
  else if b == 2 then do s <- *messageSignal2; yield s
  else if b == 3 then do s <- *messageSignal3; yield s
  else if b == 4 then do s <- *messageSignal4; yield s
  else if b == 5 then do s <- *messageSignal5; yield s
  else if b == 6 then do s <- *messageSignal6; yield s
  else if b == 7 then do s <- *messageSignal7; yield s
  else if b == 8 then do s <- *messageSignal8; yield s
  else if b == 9 then do s <- *messageSignal9; yield s
  else if b == 10 then do s <- *messageSignal10; yield s
  else if b == 11 then do s <- *messageSignal11; yield s
  else if b == 12 then do s <- *messageSignal12; yield s
  else if b == 13 then do s <- *messageSignal13; yield s
  else if b == 14 then do s <- *messageSignal14; yield s
  else do s <- *messageSignal15; yield s

-- Acknowledge messages up to the given cursor: remove from messages, cancel pending forwards,
-- and create ack entries for federated messages (to notify origin servers).
-- Returns pending acks and any evicted entries that exceeded ackedIds capacity.
ackPolledMessages = \pubkey cursor t -> do
  let b = pubkeyBucket pubkey
  bucket <- readMessageBucket b
  let toAck = do m <- bucket; where m.toKey == pubkey && m.receivedAt <= cursor; yield m
  let ackCount = count toAck
  if ackCount > 0
    then do
      writeMessageBucket b (diff bucket toAck)
      totalCount <- *totalMessageCount
      set *totalMessageCount = max 0 (totalCount - ackCount)
      recipientCounts <- *recipientMsgCounts
      set *recipientMsgCounts = adjustRecipientCount recipientCounts pubkey (0 - ackCount)
      let ackedMsgIds = do m <- toAck; yield m.messageId
      forwards <- *forwards
      set *forwards = do f <- forwards; where none ackedMsgIds (\mid -> f.messageId == mid && f.toKey == pubkey); yield f
      let ackedFederated = federatedAckEntries toAck t
      ackedIds <- *ackedIds
      let combinedAckedIds = union ackedIds ackedFederated
      let excessCount = max 0 (count combinedAckedIds - maxAckedIds)
      let eviction = evictSmallest combinedAckedIds excessCount (\a -> a.ackedAt)
      set *ackedIds = eviction.kept
      yield {pendingAcks: ackedFederated, evictedEntries: eviction.evicted}
    else yield {pendingAcks: [], evictedEntries: []}

pollNewEvents = \pubkey clampedCursor t -> do
  bucket <- readMessageBucket (pubkeyBucket pubkey)
  let limitedMsgs = takeRelation maxPollEvents (sortBy (\m -> m.receivedAt) (pollableMessages bucket pubkey clampedCursor t))
  let evts = do
    m <- limitedMsgs
    yield {id: m.messageId, eventType: "message",
           payload: {toKey: m.toKey,
                      encryptedBlob: m.encryptedBlob,
                      timestamp: m.timestamp}}
  let lastReceivedAt = fold (\acc m -> max acc m.receivedAt) clampedCursor limitedMsgs
  yield {events: evts, cursor: lastReceivedAt}

-- Execute a single long-poll cycle:
-- 1. Authenticate and ack messages up to cursor (atomic)
-- 2. Acquire a poll slot (limit concurrent polls per key)
-- 3. Check for existing messages; if none, block on signal/heartbeat (retry-based wait)
-- 4. Re-authenticate after waking (session may have expired during wait)
-- 5. Return new events and release the poll slot
pollOnce = \token cursor clientIp -> do
  t <- now
  let bucket = tokenBucket token
  setup <- atomic do
    sessions <- readSessionBucket bucket
    case authenticateSession sessions token t of
      Unauthorized {} -> yield (Nothing {})
      Authorized {pubkey, ip} ->
        if not (matchIp clientIp ip)
          then yield (Nothing {})
          else do
        -- Refresh session expiry (sliding window keeps active sessions alive)
        writeSessionBucket bucket (do s <- sessions; yield (if safeCompare s.token token then {token: s.token, pubkey: s.pubkey, expiresAt: t + sessionExpiry, ip: s.ip, createdAt: s.createdAt} else s))
        seqCounter <- *seqCounter
        let clampedCursor = clamp 0 (max seqCounter t) cursor
        ackResult <- if clampedCursor > 0
          then ackPolledMessages pubkey clampedCursor t
          else yield {pendingAcks: [], evictedEntries: []}
        startWakeup <- *pollWakeup
        startSignal <- readMessageSignal pubkey
        yield (Just {value: {pubkey: pubkey, clampedCursor: clampedCursor, startWakeup: startWakeup, startSignal: startSignal, pendingAcks: ackResult.pendingAcks, evictedEntries: ackResult.evictedEntries}})
  case setup of
    Nothing {} -> yield {authorized: False {}, events: [], cursor: 0, pendingAcks: [], evictedEntries: []}
    Just {value: s} -> do
      -- Acquire poll slot (limit concurrent polls per key)
      acquired <- atomic do
        activePolls <- *activePolls
        let pollsForKey = count (do p <- activePolls; where p.pubkey == s.pubkey; yield p)
        if pollsForKey >= maxPollsPerKey
          then yield (False {})
          else do
            set *activePolls = if count activePolls >= maxActivePolls
              then union (evictOneOldest activePolls (\p -> p.startedAt)) [{pubkey: s.pubkey, startedAt: t}]
              else union activePolls [{pubkey: s.pubkey, startedAt: t}]
            yield (True {})
      if not acquired
        then yield {authorized: True {}, events: [], cursor: cursor, pendingAcks: s.pendingAcks, evictedEntries: s.evictedEntries}
        else do
          pollResult <- do
            -- Phase 1: check for existing messages (atomic read)
            initialResult <- atomic do
              bucket <- readMessageBucket (pubkeyBucket s.pubkey)
              if count (pollableMessages bucket s.pubkey s.clampedCursor t) > 0
                then do
                  r <- pollNewEvents s.pubkey s.clampedCursor t
                  yield (Just {value: {events: r.events, cursor: r.cursor}})
                else yield (Nothing {})
            case initialResult of
              Just {value: result} ->
                yield {authorized: True {}, events: result.events, cursor: result.cursor}
              Nothing {} -> do
                -- Phase 2: wait for signal or heartbeat
                atomic do
                  wakeup <- *pollWakeup
                  signal <- readMessageSignal s.pubkey
                  if wakeup > s.startWakeup || signal > s.startSignal
                    then yield {}
                    else retry
                -- Phase 3: re-authenticate and read messages after waking.
                -- Check drain flag (server may have started draining during our wait).
                -- Uses reauthenticateSession (pre-filters by pubkey) instead of full
                -- authenticateSession to skip safeCompare on unrelated sessions.
                t2 <- now
                result <- atomic do
                  isDraining <- *draining
                  if isDraining then yield {authorized: True {}, events: [], cursor: s.clampedCursor}
                  else do
                    sessions2 <- readSessionBucket bucket
                    if not (reauthenticateSession sessions2 token s.pubkey t2)
                      then yield {authorized: False {}, events: [], cursor: s.clampedCursor}
                      else do
                        r <- pollNewEvents s.pubkey s.clampedCursor t2
                        yield {authorized: True {}, events: r.events, cursor: r.cursor}
                yield {authorized: result.authorized, events: result.events, cursor: result.cursor}
          -- Release poll slot. Safety: the code between acquire and release only contains
          -- atomic reads and STM retry (no IO that can throw), so this path is always reached.
          -- If it ever isn't (e.g., runtime panic), pruneExpired cleans stale entries
          -- after pollTimeoutMs * 3 as a safety net.
          atomic do
            activePolls <- *activePolls
            set *activePolls = removeOneForKey activePolls s.pubkey
          yield {authorized: pollResult.authorized, events: pollResult.events, cursor: pollResult.cursor, pendingAcks: s.pendingAcks, evictedEntries: s.evictedEntries}

-- ============================================
-- Derived Relations
-- ============================================
-- Pure query functions over in-memory state. No side effects.

-- All non-expired presence entries for a given pubkey
presenceForKey = \presence pubkey t ->
  do p <- presence; where p.pubkey == pubkey && p.expiresAt > t; yield p

-- Pubkeys that are online on this server
localOnlineKeys = \presence t ->
  do p <- presence; where isLocalServer p.server && p.expiresAt > t; yield p.pubkey

-- Remove the local presence entry for a pubkey (used before re-inserting on auth)
presenceWithoutLocalKey = \presence pubkey ->
  do p <- presence; where p.pubkey != pubkey || not (isLocalServer p.server); yield p

-- Local presence entries that expired during this prune cycle (for offline gossip)
expiredLocalPresence = \before after t ->
  do p <- before; where p.expiresAt <= t && isLocalServer p.server && none after (\q -> q.pubkey == p.pubkey && isLocalServer q.server); yield p

-- Resolve the best server for a pubkey: prefer local, otherwise pick the remote with latest expiry
bestServerForKey = \entries ->
  if any entries (\p -> isLocalServer p.server) then serverHostN
  else case maxBy (do p <- entries; where not (isLocalServer p.server); yield p) (\p -> p.expiresAt) of
    Just {value: p} -> p.server
    Nothing {} -> ""

-- Messages for a pubkey newer than cursor and within messageMaxAge
pollableMessages = \messages pubkey cursor t ->
  do m <- messages; where m.toKey == pubkey && m.receivedAt >= t - messageMaxAge && m.receivedAt > cursor; yield m

-- Build ack entries for messages that came from a remote origin server (need federation ack)
federatedAckEntries = \ackedMessages t ->
  do m <- ackedMessages; where m.originServer != ""; yield {messageId: m.messageId, toKey: m.toKey, ackedAt: t, originServer: m.originServer, retries: 0}

-- Remove forwards for specific message IDs destined to a given server
forwardsExcluding = \forwards server messageIds ->
  do f <- forwards; where not (f.toServer == server && any messageIds (\mid -> f.messageId == mid)); yield f

-- Find messages that haven't been forwarded yet to each target's server.
-- Includes relay: messages received via federation (originServer != "") can be
-- re-forwarded when the recipient moves to a different server. Cascade is bounded
-- by dedup (same messageId won't be forwarded to the same server twice).
forwardCandidates = \targets messages forwards t ->
  fold (\acc target ->
    let serverFwdIds = do f <- forwards; where f.toServer == target.server; yield f.messageId in
    union acc (do
      m <- messages
      where m.toKey == target.pubkey
      where none serverFwdIds (\fid -> fid == m.messageId)
      let origin = if m.originServer == "" then serverHostN else m.originServer
      yield {messageId: m.messageId, toServer: target.server, createdAt: t,
             toKey: m.toKey, encryptedBlob: m.encryptedBlob, timestamp: m.timestamp,
             originServer: origin, retries: 0})) [] targets


challengeMatch = \challenges pubkey challenge ip t ->
  any challenges (\c -> c.pubkey == pubkey && safeCompare c.challenge challenge && c.expiresAt > t && (ip == "" || c.ip == "" || c.ip == ip))

challengesExcluding = \challenges pubkey challenge ->
  do c <- challenges; where c.pubkey != pubkey || c.challenge != challenge; yield c

hasLocalPresence = \entries -> any entries (\p -> isLocalServer p.server)

ackedIdsExcludingBatch = \ackedIds server batch ->
  do a <- ackedIds; where not (a.originServer == server && hasMessage a.messageId a.toKey batch); yield a

retriableEvictedAcks = \evictedEntries pendingAcks ->
  do a <- evictedEntries; where not (hasMessage a.messageId a.toKey pendingAcks); yield a

acksForServer = \acks server -> do a <- acks; where a.originServer == server; yield a

forwardsForServer = \forwards server -> do f <- forwards; where f.toServer == server; yield f

-- Only trust offline events that claim to be from the sending server itself
trustedOfflineEvents = \events fromServer ->
  do e <- events; where e.server == fromServer; yield e

-- Peer servers to re-gossip to, excluding the server that sent us the gossip
gossipTargets = \peerServers fromServer ->
  do s <- peerServers; where s != fromServer; yield s

-- Remote keys that just came online (triggers forwarding of queued messages)
newlyOnlineRemoteKeys = \events appliedKeys ->
  do e <- events; where any appliedKeys (\a -> samePubkeyServer a e); where not (isLocalServer e.server); yield {pubkey: e.pubkey, server: e.server}

-- Trust gossip entries if they're first-party (server == fromServer) or updating
-- an existing (pubkey, server) presence entry. Third-party gossip cannot create
-- new entries for keys we haven't seen — only the key's home server can do that.
-- Additional constraint: third-party updates must carry a strictly newer timestamp
-- than the existing entry — prevents stale relays from refreshing presence TTLs
-- beyond what the original server intended.
trustedGossipEntries = \deduped presence fromServer t ->
  do e <- deduped; where
    if e.server == fromServer then True {} -- first-party: always trusted
    else any presence (\p -> samePubkeyServer p e && p.expiresAt > t && e.timestamp > p.timestamp)
    -- third-party: only update existing entries with strictly newer timestamps
  ; yield {expiresAt: e.expiresAt, pubkey: e.pubkey, server: e.server, timestamp: e.timestamp}

-- Keys whose presence was actually updated (new or extended expiry)
appliedOnlineKeys = \entries presence ->
  do e <- entries; where none presence (\p -> samePubkeyServer p e && p.expiresAt >= e.expiresAt); yield (pubkeyServer e)

-- Gossip entries that update existing presence (vs. creating new entries)
existingPresenceUpdates = \entries presence ->
  do e <- entries; where any presence (\p -> samePubkeyServer p e); yield e

-- Gossip entries for keys not yet in the presence table
newPresenceEntries = \entries presence ->
  do e <- entries; where none presence (\p -> samePubkeyServer p e); yield e

-- Generate offline gossip events for locally-expired presence entries
offlineGossipEvents = \expiredLocal -> do
  p <- expiredLocal
  let ttl = clamp offlineGossipMinTtl maxPresenceTtl ((p.expiresAt - p.timestamp) / 1000)
  yield {eventType: GossipOffline {}, pubkey: p.pubkey, server: serverHostN, timestamp: p.expiresAt, ttl: ttl}

-- Filter targets to only those not locally online (avoid forwarding to keys that can poll directly)
remoteOnlyTargets = \targets localOnline ->
  do target <- targets; where none localOnline (\pk -> pk == target.pubkey); yield target

-- ============================================
-- Request Handler
-- ============================================

-- POST /auth/challenge: Generate a random challenge for Ed25519 authentication.
-- Rate-limited per key; globally capped. Challenge expires in 1 minute.
handleChallenge = \pubkey clientIp respond -> do
  t <- now
  preAuth <- checkPreAuth clientIp t
  if preAuth != ""
    then do
      when (preAuth == "ip_rate_limited") (logWarn ("challenge: IP rate limited for " ++ clientIp))
      yield (respond {challenge: "", ok: False {}, expiresAt: 0, retryAfterMs: 0})
    else do
      authLimited <- checkAuthGlobalRate t
      if authLimited then yield (respond {challenge: "", ok: False {}, expiresAt: 0, retryAfterMs: 0})
      else do
      challenge <- genToken
      result <- atomic do
        challenges <- *challenges
        let active = do c <- challenges; where c.expiresAt > t; yield c
        let activeForKey = count (do c <- active; where c.pubkey == pubkey; yield c)
        let cappedActive = if activeForKey >= maxChallengesPerKey
          then let forKey = do c <- active; where c.pubkey == pubkey; yield c in
               let others = do c <- active; where c.pubkey != pubkey; yield c in
               union others (evictOneOldest forKey (\c -> c.expiresAt))
          else active
        if count cappedActive >= maxChallenges
          then yield {accepted: False {}, rateLimited: False {}, retryAfterMs: 0}
          else do
            challengeRates <- *challengeRates
            let rateResult = checkPubkeyRate challengeRates pubkey maxChallengeRatePerKey challengeRateWindowMs maxChallengeRateEntries t
            if rateResult.limited
              then yield {accepted: False {}, rateLimited: True {}, retryAfterMs: rateResult.retryAfterMs}
              else do
                set *challengeRates = rateResult.entries
                set *challenges = union cappedActive [{pubkey: pubkey, challenge: challenge, expiresAt: t + challengeExpiry, ip: clientIp}]
                yield {accepted: True {}, rateLimited: False {}, retryAfterMs: 0}
      when result.rateLimited
        (logWarn ("challenge: rate limited (" ++ show maxChallengeRatePerKey ++ "/s per key), rejecting for " ++ pubkey))
      when (not result.accepted && not result.rateLimited)
        (logWarn ("challenge: at capacity (" ++ show maxChallenges ++ "), rejecting for " ++ pubkey))
      yield (respond {challenge: if result.accepted then challenge else "", ok: result.accepted, expiresAt: if result.accepted then t + challengeExpiry else 0, retryAfterMs: result.retryAfterMs})

-- POST /auth/verify: Verify Ed25519 signature over challenge string.
-- On success: creates a session, registers local presence, and gossips online status.
-- Rate-limited globally and per-key (shares auth rate window with challenge requests).
handleVerifyAuth = \pubkey challenge signature revokeOthers clientIp respond -> do
  t <- now
  preAuth <- checkPreAuth clientIp t
  if preAuth != ""
    then do
      when (preAuth == "ip_rate_limited") (logWarn ("verify: IP rate limited for " ++ clientIp))
      yield (respond {token: "", expiresAt: 0})
    else do
      authRateLimited <- atomic do
        challengeRates <- *challengeRates
        let rateResult = checkPubkeyRate challengeRates pubkey maxChallengeRatePerKey challengeRateWindowMs maxChallengeRateEntries t
        set *challengeRates = rateResult.entries
        yield rateResult.limited
      if authRateLimited then do
        logWarn ("verify: rate limited (" ++ show maxChallengeRatePerKey ++ "/s per key), rejecting for " ++ pubkey)
        yield (respond {token: "", expiresAt: 0})
      else do
        authGlobalLimited <- checkAuthGlobalRate t
        if authGlobalLimited then yield (respond {token: "", expiresAt: 0})
        else verifyAuthInner pubkey challenge signature revokeOthers clientIp respond t

verifyAuthInner = \pubkey challenge signature revokeOthers clientIp respond t -> do
  let expiry = t + sessionExpiry
  validation <- atomic do
    challenges <- *challenges
    let hasMatch = challengeMatch challenges pubkey challenge clientIp t
    -- Only consume the challenge on full success (match AND valid signature).
    -- This prevents an attacker who intercepts the challenge string from burning it
    -- by submitting a bad signature from the same IP. Rate limiter still constrains
    -- brute-force attempts; not consuming on IP mismatch prevents remote attackers
    -- from burning challenges.
    -- verify() is inside the atomic block to prevent a TOCTOU gap between challenge
    -- validation and consumption. It's pure (no IO) so safe in STM.
    if not hasMatch
      then yield {valid: False {}}
      else do
        let sigValid = verify (bytesFromHex pubkey) (textToBytes challenge) (bytesFromHex signature)
        if not sigValid
          then yield {valid: False {}}
          else do
            set *challenges = challengesExcluding challenges pubkey challenge
            yield {valid: True {}}
  if validation.valid
    then do
      token <- genToken
      let newBucket = tokenBucket token
      authResult <- atomic do
        isDraining <- *draining
        if isDraining then yield (Nothing {})
        else do
          tpc <- *totalPresenceCount
          knownPeers <- *knownPeerServers
          -- Count per-key sessions without materializing all sessions (O(sessions) but no union)
          sessionsForKey <- countSessionsForKey pubkey
          tsc <- *totalSessionCount
          let newSession = {token: token, pubkey: pubkey, expiresAt: expiry, ip: clientIp, createdAt: t}
          -- Update presence: replace local entry for this pubkey, evict oldest if over capacity
          let pb = pubkeyBucket pubkey
          presenceBkt <- readPresenceBucket pb
          let bucketWithout = do p <- presenceBkt; where p.pubkey != pubkey || not (isLocalServer p.server); yield p
          let hadLocalEntry = count presenceBkt > count bucketWithout
          let bucketEvicted = if not hadLocalEntry && tpc >= maxPresenceEntries then evictOneOldest bucketWithout (\p -> p.expiresAt) else bucketWithout
          let newPresenceEntry = {pubkey: pubkey, server: serverHostN, expiresAt: expiry, timestamp: t}
          writePresenceBucket pb (union bucketEvicted [newPresenceEntry])
          let presenceDelta = count (union bucketEvicted [newPresenceEntry]) - count presenceBkt
          set *totalPresenceCount = tpc + presenceDelta
          set *presenceVersion = t
          let peerServers = if federationEnabled then knownPeers else []
          -- Fast path: no revocation, under per-key and global limits — only write one bucket
          if not revokeOthers && sessionsForKey < maxSessionsPerKey && tsc < maxSessions
            then do
              let nb = tokenBucket token
              currentBucket <- readSessionBucket nb
              writeSessionBucket nb (union currentBucket [newSession])
              set *totalSessionCount = tsc + 1
              yield (Just {value: {peerServers: peerServers, revokedCount: 0}})
            else do
              -- Slow path: revocation or capacity pressure — need all sessions
              allSessions <- readAllSessions
              let revokedCount = if revokeOthers then sessionsForKey else 0
              let afterRevoke = if revokeOthers then do s <- allSessions; where s.pubkey != pubkey; yield s else allSessions
              let capped = capPerKeyAndGlobal afterRevoke (\s -> s.pubkey == pubkey) maxSessionsPerKey (\s -> s.expiresAt) t maxSessions
              let sessionsWithNew = union capped [newSession]
              set *totalSessionCount = count sessionsWithNew
              writeAllSessions sessionsWithNew
              yield (Just {value: {peerServers: peerServers, revokedCount: revokedCount}})
      case authResult of
        Nothing {} -> yield (respond {token: "", expiresAt: 0})
        Just {value: result} -> do
          when (revokeOthers && result.revokedCount > 0)
            (logInfo ("verify: revokeOthers revoked " ++ show result.revokedCount ++ " sessions for " ++ pubkey))
          fork (when federationEnabled
            (sendBatchedGossip result.peerServers [{eventType: GossipOnline {}, pubkey: pubkey, server: serverHostN, timestamp: t, ttl: onlineGossipTtl}] gossipOriginHops))
          yield (respond {token: token, expiresAt: expiry})
    else yield (respond {token: "", expiresAt: 0})

-- POST /poll: Long-poll for new messages. Cursor-based: messages at or before cursor
-- are acked (removed from mailbox). Blocks until new messages arrive or heartbeat fires.
-- Acks for federated messages are sent to origin servers in the background.
handlePoll = \cursor generation watchKeys authorization clientIp respond -> do
  t <- now
  serverGen <- *serverGeneration
  let effectiveCursor = if generation == serverGen then cursor else 0
  let cappedWatchKeys = takeRelation maxWatchKeys watchKeys
  draining <- *draining
  if draining then yield (respond {events: [], cursor: 0, authorized: True {}, rateLimited: False {}, draining: True {}, generation: serverGen, presenceUpdates: [], heartbeat: False {}, retryAfterMs: 0})
  else do
  globalRateLimited <- checkGlobalRate t
  if globalRateLimited then yield (respond {events: [], cursor: 0, authorized: False {}, rateLimited: True {}, draining: False {}, generation: serverGen, presenceUpdates: [], heartbeat: False {}, retryAfterMs: globalRateWindowMs})
  else do
    -- Snapshot presenceVersion before long-poll wait to skip unchanged lookups
    startPresenceVersion <- *presenceVersion
    result <- case extractToken authorization of
      Nothing {} -> yield {authorized: False {}, events: [], cursor: 0, pendingAcks: [], evictedEntries: []}
      Just {value: token} -> pollOnce token effectiveCursor clientIp
    -- Check presence for watched keys (piggybacks on poll cycle; max latency = pollTimeoutMs).
    -- Skip the expensive bucket reads if presenceVersion hasn't changed since poll start.
    presenceUpdates <- if result.authorized && count cappedWatchKeys > 0 then do
      currentPresenceVersion <- *presenceVersion
      if currentPresenceVersion == startPresenceVersion then yield []
      else do
        t2 <- now
        atomic do
          let neededBuckets = uniqueBucketsFor cappedWatchKeys (\k -> k)
          relevantPresence <- readSelectedPresenceBuckets neededBuckets
          yield (do key <- cappedWatchKeys; yield {pubkey: key, online: count (presenceForKey relevantPresence key t2) > 0})
    else yield []
    fork (when federationEnabled (do
      sendAcksAndClean result.pendingAcks
      retryEvictedAcks result.evictedEntries result.pendingAcks))
    let isHeartbeat = result.authorized && count result.events == 0
    yield (respond {events: result.events, cursor: result.cursor, authorized: result.authorized, rateLimited: False {}, draining: False {}, generation: serverGen, presenceUpdates: presenceUpdates, heartbeat: isHeartbeat, retryAfterMs: 0})

-- Core send logic: dedup, rate limiting, store message, create forwards.
-- Called inside an atomic block by both handleSendMessage and sendBatchInner.
-- Caller handles auth, drain checks, and messageId generation.
sendMessageCore = \senderKey to encryptedBlob clampedTs effectiveMsgId t ->
  if senderKey == to then yield {status: MsRejected {}, remoteServers: [], retryAfterMs: 0}
  else do
    let msgBucket = pubkeyBucket to
    bucket <- readMessageBucket msgBucket
    ackedIds <- *ackedIds
    deliveredIds <- *deliveredIds
    let isDup = checkMessageDup bucket effectiveMsgId to || hasMessage effectiveMsgId to ackedIds || hasMessage effectiveMsgId to deliveredIds
    if isDup then yield {status: MsDuplicate {}, remoteServers: [], retryAfterMs: 0}
    else do
      sendRates <- *sendRates
      let rateResult = checkPubkeyRate sendRates senderKey maxSendRatePerKey sendRateWindowMs maxSendRateEntries t
      if rateResult.limited then yield {status: MsRateLimited {}, remoteServers: [], retryAfterMs: rateResult.retryAfterMs}
      else do
        set *sendRates = rateResult.entries
        pairRates <- *pairRates
        let pairResult = checkPairRate pairRates senderKey to maxPairRatePerPair pairRateWindowMs maxPairRateEntries t
        set *pairRates = pairResult.entries
        if pairResult.limited then yield {status: MsRateLimited {}, remoteServers: [], retryAfterMs: pairResult.retryAfterMs}
        else do
          recvRates <- *recvRates
          let recvResult = checkPubkeyRate recvRates to maxRecvRatePerKey recvRateWindowMs maxRecvRateEntries t
          if recvResult.limited then yield {status: MsRateLimited {}, remoteServers: [], retryAfterMs: recvResult.retryAfterMs}
          else do
            set *recvRates = recvResult.entries
            totalMsgCount <- *totalMessageCount
            if totalMsgCount >= maxMessages then yield {status: MsRejected {}, remoteServers: [], retryAfterMs: 0}
            else do
              recipientCounts <- *recipientMsgCounts
              let recipientCount = getRecipientCount to recipientCounts
              if recipientCount >= maxMessagesPerRecipient then yield {status: MsRejected {}, remoteServers: [], retryAfterMs: 0}
              else do
                recipientPresence <- readPresenceBucket (pubkeyBucket to)
                seqCounter <- *seqCounter
                let seqTs = nextSeqTs t seqCounter
                set *seqCounter = seqTs
                writeMessageBucket msgBucket (union bucket
                  [{messageId: effectiveMsgId, toKey: to,
                    encryptedBlob: encryptedBlob, timestamp: clampedTs, originServer: "", receivedAt: seqTs}])
                set *totalMessageCount = totalMsgCount + 1
                set *recipientMsgCounts = adjustRecipientCount recipientCounts to 1
                signalMessageForKey to seqTs
                let toPresence = presenceForKey recipientPresence to t
                let localOnline = hasLocalPresence toPresence
                let remoteServers = collectPeerServers toPresence (\p -> p.server)
                when (federationEnabled && count remoteServers > 0) (do
                  forwards <- *forwards
                  let newFwds = do s <- remoteServers; where none forwards (\f -> f.messageId == effectiveMsgId && f.toServer == s); yield {messageId: effectiveMsgId, toServer: s, createdAt: t, toKey: to, encryptedBlob: encryptedBlob, timestamp: clampedTs, originServer: serverHostN, retries: 0}
                  let cappedFwds = takeRelation (maxForwardsEntries - count forwards) newFwds
                  set *forwards = union forwards cappedFwds)
                let status = if localOnline then MsDelivered {}
                  else if federationEnabled && count remoteServers > 0 then MsFederated {}
                  else MsQueued {}
                yield {status: status, remoteServers: remoteServers, retryAfterMs: 0}

-- Fork federation forwards for messages that need to be delivered to remote servers
forkSendForwards = \effectiveMsgId to encryptedBlob clampedTs remoteServers ->
  when (count remoteServers > 0 && federationEnabled) (
    fork (sendToEach remoteServers (\server -> do
      stillPending <- atomic do
        forwards <- *forwards
        yield (any forwards (\f -> f.messageId == effectiveMsgId && f.toServer == server))
      when stillPending (do
        fwdT <- now
        fwdAuth <- generateFederationAuth "forward"
        fwdResult <- fetchFederation server (ForwardMessage {
          toKey: to, encryptedBlob: encryptedBlob,
          timestamp: clampedTs, originServer: serverHostN, messageId: effectiveMsgId,
          fromServer: serverHostN, requestTimestamp: fwdT,
          authorization: fwdAuth})
        case fwdResult of
          Err e -> do
            logWarn ("federation: forward to " ++ server ++ " failed for " ++ effectiveMsgId ++ ": " ++ show e)
            recordFailure server
          Ok response ->
            if response.ok then do
              removeForward effectiveMsgId server
              clearFailure server
            else
              logWarn ("federation: forward to " ++ server ++ " rejected for " ++ effectiveMsgId ++ ": " ++ response.error)))))

-- POST /messages: Send an encrypted message to a recipient.
-- Deduplicates by messageId across messages, ackedIds, and deliveredIds.
-- Rate-limited per sender key. If recipient is known on a remote server, forwards via federation.
handleSendMessage = \to encryptedBlob timestamp messageId authorization clientIp respond -> do
  t <- now
  globalRateLimited <- checkGlobalRate t
  if globalRateLimited then yield (respond {status: MsRateLimited {}, messageId: "", retryAfterMs: 0})
  else do
    effectiveMsgId <- if messageId != "" then yield messageId else genToken
    if t - timestamp > messageMaxAge
      then yield (respond {status: MsRejected {}, messageId: "", retryAfterMs: 0})
      else do
    when (timestamp > t + clockSkewTolerance)
      (logWarn ("sendMessage: future timestamp detected (+" ++ show (timestamp - t) ++ "ms ahead), clamping to now"))
    when (timestamp < t - messageMaxAge / 2)
      (logWarn ("sendMessage: stale timestamp (" ++ show ((t - timestamp) / 86400000) ++ " days old) for " ++ effectiveMsgId))
    let clampedTs = clampTimestamp timestamp t
    result <- atomic do
      draining <- *draining
      if draining then yield {status: MsDraining {}, remoteServers: [], retryAfterMs: 0}
      else withSessionAuth authorization t clientIp
        (yield {status: MsUnauthorized {}, remoteServers: [], retryAfterMs: 0})
        (\senderKey -> sendMessageCore senderKey to encryptedBlob clampedTs effectiveMsgId t)
    case result.status of
      MsRateLimited {} -> logWarn ("sendMessage: rate limited for " ++ effectiveMsgId)
      MsRejected {} -> when (result.retryAfterMs == 0) (logWarn ("sendMessage: rejected for " ++ effectiveMsgId ++ " (capacity or mailbox full)"))
      _ -> yield {}
    forkSendForwards effectiveMsgId to encryptedBlob clampedTs result.remoteServers
    yield (case result.status of
      MsDuplicate {} -> respond {status: MsDuplicate {}, messageId: effectiveMsgId, retryAfterMs: 0}
      MsDelivered {} -> respond {status: MsDelivered {}, messageId: effectiveMsgId, retryAfterMs: 0}
      MsFederated {} -> respond {status: MsFederated {}, messageId: effectiveMsgId, retryAfterMs: 0}
      MsQueued {} -> respond {status: MsQueued {}, messageId: effectiveMsgId, retryAfterMs: 0}
      _ -> respond {status: result.status, messageId: "", retryAfterMs: result.retryAfterMs})

-- GET /lookup/:pubkey: Look up the best known server for a pubkey.
-- Returns local server if key is online locally, otherwise the remote with latest expiry.
handleLookupPresence = \pubkey authorization clientIp respond -> do
  t <- now
  globalRateLimited <- checkGlobalRate t
  if globalRateLimited then yield (respond {server: "", authorized: False {}})
  else do
    result <- atomic do
      draining <- *draining
      if draining then yield {server: "", authorized: False {}}
      else withSessionAuth authorization t clientIp
        (yield {server: "", authorized: False {}})
        (\senderKey -> do
          lookupRates <- *lookupRates
          let rateResult = checkPubkeyRate lookupRates senderKey maxLookupRatePerKey lookupRateWindowMs maxLookupRateEntries t
          set *lookupRates = rateResult.entries
          if rateResult.limited
            then yield {server: "", authorized: True {}}
            else do
              -- Hot path: read only the target key's presence bucket
              lookupBkt <- readPresenceBucket (pubkeyBucket pubkey)
              let foundServer = bestServerForKey (presenceForKey lookupBkt pubkey t)
              -- Mask remote server names: clients only need to know local/remote/unknown,
              -- not which specific peer server a key is homed on (prevents metadata leakage)
              let maskedServer = if foundServer == "" then "" else if isLocalServer foundServer then foundServer else "remote"
              yield {server: maskedServer, authorized: True {}})
    yield (respond {server: result.server, authorized: result.authorized})

-- POST /messages/status: Check delivery status of a previously sent message.
-- Caller must provide both messageId and recipient pubkey (proves they know the recipient).
-- Returns: "pending" (in mailbox), "forwarding" (federation in progress),
-- "delivered" (acked by recipient), "unknown" (expired or never existed).
handleMessageStatus = \to messageId authorization clientIp respond -> do
  t <- now
  globalRateLimited <- checkGlobalRate t
  if globalRateLimited then yield (respond {status: "", authorized: False {}})
  else
    withSessionAuth authorization t clientIp
      (yield (respond {status: "", authorized: False {}}))
      (\senderKey -> do
        -- Per-key rate limiting (reuses lookup rate limiter — both are info lookups)
        statusRateLimited <- atomic do
          lookupRates <- *lookupRates
          let rateResult = checkPubkeyRate lookupRates senderKey maxLookupRatePerKey lookupRateWindowMs maxLookupRateEntries t
          set *lookupRates = rateResult.entries
          yield rateResult.limited
        if statusRateLimited then yield (respond {status: "", authorized: True {}})
        else do
          result <- atomic do
            let msgBucket = pubkeyBucket to
            bucket <- readMessageBucket msgBucket
            -- Check if message is still in mailbox (pending delivery)
            let inMailbox = any bucket (\m -> m.messageId == messageId && m.toKey == to)
            if inMailbox then yield "pending"
            else do
              -- Check if being forwarded to a remote server
              forwards <- *forwards
              let inForwards = any forwards (\f -> f.messageId == messageId && f.toKey == to)
              if inForwards then yield "forwarding"
              else do
                -- Check if already delivered (acked or in terminal delivered set)
                ackedIds <- *ackedIds
                deliveredIds <- *deliveredIds
                let inAcked = hasMessage messageId to ackedIds
                let inDelivered = hasMessage messageId to deliveredIds
                if inAcked || inDelivered then yield "delivered"
                else do
                  -- Extended check: forward nonces have 60-day retention (2x message lifetime)
                  -- and 100k capacity, providing delivery evidence after ackedIds/deliveredIds are pruned
                  forwardNonces <- *forwardNonces
                  let inNonces = any forwardNonces (\n -> n.messageId == messageId && n.toKey == to)
                  if inNonces then yield "delivered"
                  else yield "unknown"
          yield (respond {status: result, authorized: True {}}))

-- POST /auth/revoke: Revoke a specific session token.
-- Caller authenticates via Authorization header, then specifies the target token to remove.
-- Only removes the target if it belongs to the same pubkey as the caller (prevents cross-user revocation).
handleRevoke = \targetToken authorization clientIp respond -> do
  t <- now
  globalRateLimited <- checkGlobalRate t
  if globalRateLimited then yield (respond {ok: False {}, authorized: False {}})
  else
    withSessionAuth authorization t clientIp
      (yield (respond {ok: False {}, authorized: False {}}))
      (\callerPubkey -> do
        authLimited <- checkAuthGlobalRate t
        if authLimited then yield (respond {ok: False {}, authorized: True {}})
        else do
        revokeLimited <- atomic do
          challengeRates <- *challengeRates
          let rateResult = checkPubkeyRate challengeRates callerPubkey maxChallengeRatePerKey challengeRateWindowMs maxChallengeRateEntries t
          set *challengeRates = rateResult.entries
          yield rateResult.limited
        if revokeLimited then yield (respond {ok: False {}, authorized: True {}})
        else do
        let targetBucket = tokenBucket targetToken
        removed <- atomic do
          sessions <- readSessionBucket targetBucket
          let hasTarget = any sessions (\s -> safeCompare s.token targetToken && s.pubkey == callerPubkey)
          if hasTarget
            then do
              writeSessionBucket targetBucket (do s <- sessions; where not (safeCompare s.token targetToken && s.pubkey == callerPubkey); yield s)
              sc <- *totalSessionCount
              set *totalSessionCount = max 0 (sc - 1)
              yield (True {})
            else yield (False {})
        when removed (logInfo ("revoke: session revoked for " ++ callerPubkey))
        yield (respond {ok: removed, authorized: True {}}))

-- POST /auth/logout: Voluntary disconnect. Removes the caller's session and, if it was
-- the last active session for this pubkey, clears local presence and gossips offline.
-- This gives faster offline detection than waiting for session expiry (1 hour).
handleLogout = \authorization clientIp respond -> do
  t <- now
  globalRateLimited <- checkGlobalRate t
  if globalRateLimited then yield (respond {ok: False {}, authorized: False {}})
  else do
  authLimited <- checkAuthGlobalRate t
  if authLimited then yield (respond {ok: False {}, authorized: False {}})
  else
    case extractToken authorization of
      Nothing {} -> yield (respond {ok: False {}, authorized: False {}})
      Just {value: token} -> do
        let bucket = tokenBucket token
        result <- atomic do
          sessions <- readSessionBucket bucket
          case authenticateSession sessions token t of
            Unauthorized {} -> yield (Nothing {})
            Authorized {pubkey, ip} ->
              if not (matchIp clientIp ip)
                then yield (Nothing {})
                else do
                  -- Remove the caller's session
                  writeSessionBucket bucket (do s <- sessions; where not (safeCompare s.token token); yield s)
                  sc <- *totalSessionCount
                  set *totalSessionCount = max 0 (sc - 1)
                  -- Check if this was the last session for this key.
                  -- Short-circuit scan: reads buckets one at a time, stopping as soon as
                  -- a matching session is found. Avoids reading all 16 buckets when the
                  -- user has sessions in other buckets (common case: multi-device).
                  hasRemaining <- hasSessionForKey pubkey 0
                  if not hasRemaining
                    then do
                      -- Remove local presence immediately (only this key's bucket)
                      let pb = pubkeyBucket pubkey
                      presenceBkt <- readPresenceBucket pb
                      writePresenceBucket pb (do p <- presenceBkt; where p.pubkey != pubkey || not (isLocalServer p.server); yield p)
                      let removedCount = count presenceBkt - count (do p <- presenceBkt; where p.pubkey != pubkey || not (isLocalServer p.server); yield p)
                      tpc <- *totalPresenceCount
                      set *totalPresenceCount = max 0 (tpc - removedCount)
                      set *presenceVersion = t
                      peerServers <- *knownPeerServers
                      yield (Just {value: {pubkey: pubkey, gossipOffline: True {}, peerServers: peerServers}})
                    else yield (Just {value: {pubkey: pubkey, gossipOffline: False {}, peerServers: []}})
        case result of
          Nothing {} -> yield (respond {ok: False {}, authorized: False {}})
          Just {value: r} -> do
            when r.gossipOffline (do
              logInfo ("logout: last session for " ++ r.pubkey ++ ", gossiping offline")
              when (federationEnabled && count r.peerServers > 0)
                (fork (sendBatchedGossip r.peerServers [{eventType: GossipOffline {}, pubkey: r.pubkey, server: serverHostN, timestamp: t, ttl: offlineGossipMinTtl}] gossipOriginHops)))
            yield (respond {ok: True {}, authorized: True {}})

-- POST /federation/verify: Confirm a token was issued by this server.
-- Called by the receiving server during federation callback verification.
-- Tokens are single-use and expire after verificationTokenExpiry.
handleVerifyToken = \token scope clientIp respond -> do
  t <- now
  globalRateLimited <- checkGlobalRate t
  if globalRateLimited then yield (respond {ok: False {}})
  else do
  ipLimited <- checkClientIpRate clientIp t
  if ipLimited then yield (respond {ok: False {}})
  else do
  -- Dedicated verify rate limit (tighter than general IP rate to limit token probing)
  verifyLimited <- if clientIp == "" then yield (False {})
    else atomic do
      verifyIpRates <- *verifyIpRates
      let result = checkIpRate verifyIpRates clientIp maxVerifyRatePerIp verifyRateWindowMs maxVerifyRateEntries t
      set *verifyIpRates = result.entries
      yield result.limited
  if verifyLimited then do
    logWarn ("federation/verify: rate limited for IP " ++ clientIp)
    yield (respond {ok: False {}})
  else do
  found <- atomic do
    pending <- *pendingVerifications
    -- Scope is required: callers must specify the operation type (gossip/forward/ack)
    let match = any pending (\p -> safeCompare p.token token && p.scope == scope && t - p.createdAt < verificationTokenExpiry)
    when match (set *pendingVerifications = do p <- pending; where not (safeCompare p.token token); yield p)
    yield match
  -- Omit scope from log to prevent scope enumeration by attackers probing the endpoint
  when (not found) (logWarn ("federation/verify: failed attempt from " ++ clientIp))
  yield (respond {ok: found})

-- POST /federation/gossip: Receive presence gossip from a peer server.
-- Validates events, merges into presence table (last-write-wins), and re-gossips
-- to other known peers with decremented hop count. Triggers message forwarding
-- when a remote key comes online.
handleRecvGossip = \events hopsRemaining fromServer requestTimestamp authorization respond -> do
  t <- now
  let cappedHops = clamp 0 maxGossipHops hopsRemaining
  withFederationAuth authorization t respond fromServer "gossip" requestTimestamp (cappedHops >= 1 && not (isLocalServer fromServer) && count events <= maxGossipEvents) (do
    -- Per-peer gossip event volume limiting: counts total events (not just requests) per server.
    -- A single gossip request carries up to maxGossipEvents entries; without this, a peer
    -- sending 50 req/s * 100 events = 5000 presence mutations/second.
    eventRateLimited <- atomic do
      ger <- *gossipEventRates
      let eventCount = count events
      let entry = headOf (do r <- ger; where r.server == fromServer; yield r)
      let isNewWindow = case entry of Nothing {} -> True {}; Just {value: r} -> t - r.windowStart >= gossipEventRateWindowMs
      let currentCount = case entry of Nothing {} -> 0; Just {value: r} -> if isNewWindow then 0 else r.count
      if currentCount + eventCount > maxGossipEventsPerServer
        then yield (True {})
        else do
          let newEntries = if isNewWindow
            then union (do r <- ger; where r.server != fromServer; yield r) [{server: fromServer, windowStart: t, count: eventCount}]
            else do r <- ger; yield (if r.server == fromServer then {server: r.server, windowStart: r.windowStart, count: r.count + eventCount} else r)
          set *gossipEventRates = if count newEntries > maxGossipEventRateEntries then (do r <- newEntries; where t - r.windowStart < gossipEventRateWindowMs; yield r) else newEntries
          yield (False {})
    if eventRateLimited then do
      logWarn ("gossip: event volume rate limited for " ++ fromServer ++ " (" ++ show maxGossipEventsPerServer ++ " events/" ++ show gossipEventRateWindowMs ++ "ms)")
      yield (respond {ok: False {}, error: "event_rate_limited"})
    else do
    let validated = validGossipEvents events t
    let onlineEntries = validated.online
    let trustedOffline = trustedOfflineEvents validated.offline fromServer
    -- Warn if a peer sends both online and offline for the same key in one batch (suspicious)
    let conflictingKeys = do on <- onlineEntries; off <- trustedOffline; where on.pubkey == off.pubkey && on.server == off.server; yield on.pubkey
    when (count conflictingKeys > 0)
      (logWarn ("gossip: " ++ fromServer ++ " sent conflicting online+offline for same key(s)"))
    let filteredOnline = resolveByTimestamp onlineEntries trustedOffline
    let filteredOffline = resolveByTimestamp trustedOffline onlineEntries
    let deduped = mergeByPubkeyServer [] filteredOnline
    -- Warn when a peer claims keys that are locally authenticated (potential presence hijack)
    localClashes <- atomic do
      let firstParty = do e <- deduped; where e.server == fromServer; yield e
      let targetBuckets = uniqueBucketsFor firstParty (\e -> e.pubkey)
      localPresence <- readSelectedPresenceBuckets targetBuckets
      yield (do e <- firstParty; where any localPresence (\p -> p.pubkey == e.pubkey && isLocalServer p.server && p.expiresAt > t); yield e.pubkey)
    when (count localClashes > 0)
      (logWarn ("gossip: " ++ fromServer ++ " claims " ++ show (count localClashes) ++ " locally-authenticated key(s) — ignoring for local routing"))
    gossipResult <- atomic do
      allPresence <- readAllPresence
      tpc <- *totalPresenceCount
      -- Pre-filter: when near capacity, reject gossip entries for pubkeys not already in presence.
      -- This prevents a malicious peer from spiking presence above maxPresenceEntries via large batches.
      let capacityDeduped = if tpc >= maxPresenceEntries
        then do d <- deduped; where any allPresence (\p -> p.pubkey == d.pubkey); yield d
        else deduped
      let gm = mergeGossipPresence allPresence capacityDeduped trustedOffline fromServer t
      writeAllPresence gm.finalPresence
      set *totalPresenceCount = count gm.finalPresence
      set *knownPeerServers = gm.gossipPeerServers
      set *presenceVersion = t
      yield {gm: gm, preFiltered: count deduped - count capacityDeduped}
    let effectiveEvents = union (effectiveGossipEvents filteredOnline gossipResult.gm.appliedKeys (GossipOnline {})) (effectiveGossipEvents filteredOffline gossipResult.gm.appliedKeys (GossipOffline {}))
    when (not gossipResult.gm.withinCapacity || gossipResult.preFiltered > 0)
      (logWarn ("gossip: presence at capacity (" ++ show maxPresenceEntries ++ "), limiting new entries from " ++ fromServer ++ " (pre-filtered: " ++ show gossipResult.preFiltered ++ ")"))
    -- Suppress re-broadcast of events we've already gossiped recently (prevents amplification)
    freshEvents <- atomic do
      recentGossip <- *recentGossip
      let active = do r <- recentGossip; where t - r.seenAt < gossipDedupWindow; yield r
      -- Pre-filter active entries to only those matching pubkeys in this batch (reduces O(n*m) inner scan)
      let batchPubkeys = fold (\acc e -> if any acc (\a -> a == e.pubkey) then acc else union acc [e.pubkey]) [] effectiveEvents
      let relevantActive = do r <- active; where any batchPubkeys (\pk -> pk == r.pubkey); yield r
      let fresh = do e <- effectiveEvents; where none relevantActive (\r -> r.pubkey == e.pubkey && r.server == e.server && r.timestamp == e.timestamp); yield e
      let newRecent = do e <- fresh; yield {pubkey: e.pubkey, server: e.server, timestamp: e.timestamp, seenAt: t}
      let updated = union active newRecent
      set *recentGossip = if count updated > maxRecentGossip then do r <- updated; where t - r.seenAt < gossipDedupWindow; yield r else updated
      yield fresh
    let newlyOnlineRemote = newlyOnlineRemoteKeys filteredOnline gossipResult.gm.appliedKeys
    fork (do
      when (cappedHops > 1 && federationEnabled && count freshEvents > 0) (do
        let targets = gossipTargets gossipResult.gm.gossipPeerServers fromServer
        -- Split first-party (from the sender) vs third-party (relayed) events.
        -- Third-party events get fewer hops to limit amplification from inflated hopsRemaining.
        let firstPartyEvents = do e <- freshEvents; where e.server == fromServer; yield e
        let thirdPartyEvents = do e <- freshEvents; where e.server != fromServer; yield e
        when (count firstPartyEvents > 0) (sendBatchedGossip targets firstPartyEvents (cappedHops - 1))
        let thirdPartyHops = min (cappedHops - 1) maxThirdPartyGossipHops
        when (thirdPartyHops > 1 && count thirdPartyEvents > 0) (sendBatchedGossip targets thirdPartyEvents thirdPartyHops))
      when (federationEnabled && count newlyOnlineRemote > 0)
        (forwardQueuedMessages newlyOnlineRemote t))
    yield (respond {ok: True {}, error: ""}))

-- POST /federation/forward: Receive a message forwarded from a peer server.
-- Accepts both direct forwards (fromServer == originServer) and relay forwards
-- (fromServer != originServer) where an intermediate server re-forwards because
-- the recipient moved. Cascade is bounded by dedup (same messageId won't be stored
-- twice) and forwardCandidates (won't re-forward to the same server).
handleForwardMessage = \toKey encryptedBlob timestamp originServer messageId fromServer requestTimestamp authorization respond -> do
  t <- now
  withFederationAuth authorization t respond fromServer "forward" requestTimestamp (not (isLocalServer originServer) && not (isLocalServer fromServer)) (do
    when (fromServer != originServer)
      (logInfo ("forward: relay from " ++ fromServer ++ " (origin: " ++ originServer ++ ") for " ++ toKey))
    -- Relay origin verification: for relay forwards, verify originServer is a known peer
    -- to prevent ack routing (and metadata leakage) to arbitrary servers.
    originOk <- if fromServer == originServer then yield (True {})
      else do
        knownPeers <- *knownPeerServers
        yield (any knownPeers (\p -> p == originServer))
    if not originOk
      then do
        logWarn ("forward: rejected relay with unknown origin " ++ originServer ++ " from " ++ fromServer)
        yield (respond {ok: False {}, error: "unknown_origin"})
      else do
    -- Replay protection: reject forwards with timestamps older than messageMaxAge.
    -- Legitimate queued messages have timestamps within this window. Replayed captures
    -- become stale once dedup state (messages + ackedIds + deliveredIds) is pruned (~30 days).
    if t - timestamp > messageMaxAge
      then yield (respond {ok: False {}, error: "stale_timestamp"})
      else do
    -- Verify recipient has active presence on this server. Peers should only forward
    -- to us if gossip indicated the key is here. Accepting messages for completely
    -- unknown keys wastes mailbox slots that will never be drained by polling.
    hasPresence <- atomic do
      bkt <- readPresenceBucket (pubkeyBucket toKey)
      yield (any bkt (\p -> p.pubkey == toKey && p.expiresAt > t))
    if not hasPresence then do
      logWarn ("forward: rejected for " ++ toKey ++ " — no active presence on this server (from " ++ fromServer ++ ")")
      yield (respond {ok: False {}, error: "no_presence"})
    else do
    let clampedTs = clampTimestamp timestamp t
    result <- atomic do
      let msgBucket = pubkeyBucket toKey
      bucket <- readMessageBucket msgBucket
      ackedIds <- *ackedIds
      deliveredIds <- *deliveredIds
      forwardNonces <- *forwardNonces
      let isDup = checkMessageDup bucket messageId toKey || hasMessage messageId toKey ackedIds || hasMessage messageId toKey deliveredIds || any forwardNonces (\n -> n.messageId == messageId && n.toKey == toKey && n.originServer == originServer)
      if isDup
        then yield {forward: ForwardDuplicate {}, globalCapReached: False {}, recvRateLimited: False {}}
        else do
          totalMsgCount <- *totalMessageCount
          if totalMsgCount >= maxMessages
            then yield {forward: ForwardRejected {}, globalCapReached: True {}, recvRateLimited: False {}}
            else do
              recipientCounts <- *recipientMsgCounts
              let recipientCount = getRecipientCount toKey recipientCounts
              if recipientCount >= maxMessagesPerRecipient
                then yield {forward: ForwardRejected {}, globalCapReached: False {}, recvRateLimited: False {}}
                else do
                  recvRates <- *recvRates
                  let recvResult = checkPubkeyRate recvRates toKey maxRecvRatePerKey recvRateWindowMs maxRecvRateEntries t
                  if recvResult.limited
                    then yield {forward: ForwardRejected {}, globalCapReached: False {}, recvRateLimited: True {}}
                    else do
                      set *recvRates = recvResult.entries
                      federationPairRates <- *federationPairRates
                      let fedPairResult = checkServerRecipientRate federationPairRates fromServer toKey maxFederationPairRatePerPair federationPairRateWindowMs maxFederationPairRateEntries t
                      if fedPairResult.limited
                        then yield {forward: ForwardRejected {}, globalCapReached: False {}, recvRateLimited: False {}}
                        else do
                      set *federationPairRates = fedPairResult.entries
                      seqCounter <- *seqCounter
                      let seqTs = nextSeqTs t seqCounter
                      set *seqCounter = seqTs
                      writeMessageBucket msgBucket (union bucket
                        [{messageId: messageId, toKey: toKey,
                          encryptedBlob: encryptedBlob, timestamp: clampedTs, originServer: originServer, receivedAt: seqTs}])
                      set *totalMessageCount = totalMsgCount + 1
                      set *recipientMsgCounts = adjustRecipientCount recipientCounts toKey 1
                      signalMessageForKey toKey seqTs
                      -- Record forward nonce for replay protection beyond message/ack dedup lifetime
                      fwdNonces <- *forwardNonces
                      let updatedNonces = union fwdNonces [{messageId: messageId, toKey: toKey, originServer: originServer, seenAt: t}]
                      -- Global age-based eviction: evict oldest nonces regardless of origin.
                      -- Previous per-originServer partitioning could be gamed by a relay peer
                      -- forging varied originServer values to spread nonces across partitions
                      -- and crowd out legitimate entries.
                      set *forwardNonces = if count updatedNonces > maxForwardNonces
                        then let evictCount = max 1 (count updatedNonces / 10) in
                             (evictSmallest updatedNonces evictCount (\n -> n.seenAt)).kept
                        else updatedNonces
                      yield {forward: ForwardStored {}, globalCapReached: False {}, recvRateLimited: False {}}
    case result.forward of
      ForwardRejected {} ->
        if result.globalCapReached
          then logWarn ("forward: global message cap reached (" ++ show maxMessages ++ "), rejecting for " ++ toKey)
          else if result.recvRateLimited
          then logWarn ("forward: recv rate limited (" ++ show maxRecvRatePerKey ++ "/s per key), rejecting for " ++ toKey)
          else logWarn ("forward: rejected for " ++ toKey ++ " (mailbox full, max " ++ show maxMessagesPerRecipient ++ ")")
      _ -> yield {}
    yield (case result.forward of
      ForwardRejected {} -> respond {ok: False {}, error: "mailbox_full"}
      _ -> respond {ok: True {}, error: ""}))

-- POST /federation/ack: Peer server confirms delivery of messages we originated.
-- Removes corresponding forward entries. Also cleans up the original message if the
-- recipient has no local presence and no other pending forwards for that message.
handleFederationAck = \messageIds originServer fromServer requestTimestamp authorization respond -> do
  t <- now
  -- Wrap respond to add ackedCount default for withFederationAuth error paths
  let ackRespond = \r -> respond {ok: r.ok, error: r.error, ackedCount: 0}
  withFederationAuth authorization t ackRespond fromServer "ack" requestTimestamp (isLocalServer originServer && not (isLocalServer fromServer)) (do
    let dedupedIds = dedupMessageIds messageIds
    -- Clear forward entries for the acking server. Extract removed forwards' toKey
    -- so we can reclaim origin messages that are no longer needed.
    removedForwards <- atomic do
      forwards <- *forwards
      let removed = do f <- forwards; where f.toServer == fromServer && any dedupedIds (\mid -> f.messageId == mid); yield f
      set *forwards = forwardsExcluding forwards fromServer dedupedIds
      yield removed
    let ackedCount = count removedForwards
    -- Deferred origin message cleanup: queue for processing in the next prune cycle
    -- after ackGracePeriod elapses. Replaces fork+sleep which accumulated sleeping
    -- goroutines under high federation ack volume.
    when (ackedCount > 0) (atomic do
      cleanups <- *pendingAckCleanups
      let newCleanups = do f <- removedForwards; yield {messageId: f.messageId, toKey: f.toKey, cleanupAfter: t + ackGracePeriod}
      -- Per-key cap: limit cleanups per recipient to prevent one noisy key from dominating the queue
      let perKeyCapped = fold (\acc c ->
        let existingForKey = count (do x <- acc; where x.toKey == c.toKey; yield x)
        in if existingForKey >= maxPendingAckCleanupsPerKey then acc else union acc [c])
        cleanups newCleanups
      set *pendingAckCleanups = if count perKeyCapped > maxPendingAckCleanups then takeRelation maxPendingAckCleanups perKeyCapped else perKeyCapped)
    yield (respond {ok: True {}, error: "", ackedCount: ackedCount}))

-- POST /maintenance/drain: Broadcast offline gossip for all local keys (graceful shutdown).
-- Call before stopping the server so peers learn keys went offline immediately.
-- Gossip is sent via fork; allow a few seconds after response before process exit.
handleDrain = \authorization respond -> do
  t <- now
  let authorized = verifyMaintenanceAuth authorization
  if not authorized then yield (respond {ok: False {}, drained: 0})
  else do
    drainResult <- atomic do
      set *draining = True {}
      allPresence <- readAllPresence
      let localEntries = do p <- allPresence; where isLocalServer p.server && p.expiresAt > t; yield p
      let remainingPresence = do p <- allPresence; where not (isLocalServer p.server) || p.expiresAt <= t; yield p
      writeAllPresence remainingPresence
      set *totalPresenceCount = count remainingPresence
      set *presenceVersion = t
      set *pollWakeup = t
      yield {localEntries: localEntries, peerServers: collectPeerServers allPresence (\p -> p.server)}
    let drainedCount = count drainResult.localEntries
    -- Read pending federation state atomically (fix: was read outside atomic)
    flushState <- atomic do
      f <- *forwards
      a <- *ackedIds
      let pa = do x <- a; where not (isLocalServer x.originServer); yield x
      yield {forwards: f, pendingAcks: pa}
    let pendingForwardCount = count flushState.forwards
    let pendingAckCount = count flushState.pendingAcks
    -- Fork best-effort flush of pending federation ops, then gossip, then wait for in-flight.
    -- Operator polls /stats for drainCompletedAt > 0 to know when safe to stop.
    atomic do set *drainCompletedAt = 0
    fork (do
      -- Best-effort flush of pending forwards and acks before stopping
      when (federationEnabled && pendingForwardCount > 0) (do
        logInfo ("drain: flushing " ++ show pendingForwardCount ++ " pending forwards")
        retryPendingForwards flushState.forwards)
      when (federationEnabled && pendingAckCount > 0) (do
        logInfo ("drain: flushing " ++ show pendingAckCount ++ " pending acks")
        sendAcksAndClean flushState.pendingAcks)
      when (federationEnabled && drainedCount > 0 && count drainResult.peerServers > 0) (do
        let gossipEvents = do p <- drainResult.localEntries; yield {eventType: GossipOffline {}, pubkey: p.pubkey, server: serverHostN, timestamp: t, ttl: offlineGossipMinTtl}
        sendBatchedGossip drainResult.peerServers gossipEvents gossipOriginHops)
      -- Wait for in-flight federation requests to complete (timeout: 2x fetch timeout)
      when federationEnabled (waitForInFlightDrain (t + federationFetchTimeoutMs * 2))
      t2 <- now
      atomic do set *drainCompletedAt = t2)
    logInfo ("drain: broadcast offline for " ++ show drainedCount ++ " local keys")
    when (pendingForwardCount > 0)
      (logInfo ("drain: flushing " ++ show pendingForwardCount ++ " pending forwards"))
    when (pendingAckCount > 0)
      (logInfo ("drain: flushing " ++ show pendingAckCount ++ " pending acks"))
    yield (respond {ok: True {}, drained: drainedCount})

-- POST /maintenance/undrain: Resume accepting requests after a drain.
-- Background loops (prune, heartbeat) automatically resume on next iteration.
handleUndrain = \authorization respond -> do
  let authorized = verifyMaintenanceAuth authorization
  if not authorized then yield (respond {ok: False {}})
  else do
    wasDraining <- atomic do
      d <- *draining
      set *draining = False {}
      set *drainCompletedAt = 0
      yield d
    when wasDraining (logInfo "undrain: server resumed, accepting new requests")
    when (not wasDraining) (logInfo "undrain: server was not draining")
    yield (respond {ok: True {}})

-- POST /maintenance/prune: Trigger a full maintenance cycle (prune + retry all pending ops).
-- Accepts either federation or maintenance secret.
handlePrune = \authorization respond -> do
  t <- now
  draining <- *draining
  let authorized = verifyMaintenanceAuth authorization && not draining
  when authorized (fork (pruneAndRetry t))
  yield (respond {ok: authorized})

handleHealth = \authorization respond -> do
  t <- now
  let isAuthed = verifyMaintenanceAuth authorization
  -- Health checks exempt from global rate limiting (monitoring traffic shouldn't starve real requests)
  result <- atomic do
    lastPrune <- *lastPrunedAt
    lastHb <- *lastHeartbeatAt
    lastWd <- *lastWatchdogAt
    sa <- *startedAt
    presenceCount <- *totalPresenceCount
    forwards <- *forwards
    sessionCount <- *totalSessionCount
    activePolls <- *activePolls
    tmc <- *totalMessageCount
    lastFedSuccess <- *lastFederationSuccessAt
    forwardFailures <- *forwardFailures
    pruneRun <- *pruneRunning
    lastSnap <- *lastSnapshotExportAt
    let warmup = t - sa < healthPruneMaxAge
    let pruneStuck = pruneRun > 0 && t - pruneRun > backgroundPruneInterval * 2
    -- Capacity pressure: flag when any capped collection exceeds 90% full
    let capacityOk = tmc * 10 <= maxMessages * 9
      && presenceCount * 10 <= maxPresenceEntries * 9
      && count forwards * 10 <= maxForwardsEntries * 9
      && sessionCount * 10 <= maxSessions * 9
      && count activePolls * 10 <= maxActivePolls * 9
    -- Federation: healthy if disabled, in warmup, no peer issues, or recent success
    let fedOk = not federationEnabled || warmup
      || count forwardFailures == 0
      || (lastFedSuccess > 0 && t - lastFedSuccess < backgroundPruneInterval * 5)
    -- Snapshot staleness: unhealthy if maintenance secret is configured but no snapshot
    -- has been exported within the staleness window (federation state will be lost on restart)
    let snapOk = maintenanceSecret == "" || snapshotStalenessWarning == 0 || warmup
      || (lastSnap > 0 && t - lastSnap <= snapshotStalenessWarning)
      || (tmc == 0 && presenceCount == 0 && count forwards == 0)
    -- Watchdog: healthy if recently bumped or in warmup (watchdog starts after 10x prune interval)
    let wdOk = warmup || t - sa < healthWatchdogMaxAge || (lastWd > 0 && t - lastWd < healthWatchdogMaxAge)
    yield {pruneOk: warmup || (t - lastPrune < healthPruneMaxAge && not pruneStuck),
           heartbeatOk: warmup || t - lastHb < healthHeartbeatMaxAge,
           capacityOk: capacityOk,
           federationOk: fedOk,
           snapshotOk: snapOk,
           watchdogOk: wdOk}
  let allOk = result.pruneOk && result.heartbeatOk && result.capacityOk && result.federationOk && result.snapshotOk && result.watchdogOk
  -- Unauthenticated: always return ok:true to prevent information leakage.
  -- Attackers could correlate ok:false transitions with targeted load to infer subsystem pressure.
  if isAuthed
    then yield (respond {ok: allOk, pruneHealthy: result.pruneOk,
                  heartbeatHealthy: result.heartbeatOk,
                  capacityHealthy: result.capacityOk,
                  federationHealthy: result.federationOk,
                  snapshotHealthy: result.snapshotOk,
                  watchdogHealthy: result.watchdogOk})
    else yield (respond {ok: True {}, pruneHealthy: True {},
                  heartbeatHealthy: True {},
                  capacityHealthy: True {},
                  federationHealthy: True {},
                  snapshotHealthy: True {},
                  watchdogHealthy: True {}})

zeroStats = {sessions: 0, sessionsMax: 0, messages: 0, messagesMax: 0, presence: 0, presenceMax: 0, forwards: 0, forwardsMax: 0, challenges: 0, challengesMax: 0, ackedIds: 0, ackedIdsMax: 0, ackOverflow: 0, ackOverflowMax: 0, deliveredIds: 0, deliveredIdsMax: 0, forwardFailures: 0, activePolls: 0, activePollsMax: 0, sendRates: 0, challengeRates: 0, federationRates: 0, globalRateCount: 0, ipRates: 0, lookupRates: 0, recvRates: 0, pairRates: 0, federationPairRates: 0, pruneCount: 0, pruneRunning: 0, heartbeatCount: 0, uptime: 0, lastPruneAt: 0, lastHeartbeatAt: 0, draining: False {}, federationEnabled: False {}, recentGossip: 0, totalMessageCount: 0, recipientCounts: 0, federationInFlight: 0, hungFederationSlots: 0, messagesPct: 0, presencePct: 0, forwardsPct: 0, sessionsPct: 0, federationAvgLatencyMs: 0, federationMaxLatencyMs: 0, federationCallCount: 0, drainCompletedAt: 0, oldestForwardAge: 0, oldestAckAge: 0, forwardNonces: 0, forwardNoncesMax: 0, pendingAckCleanups: 0, blockedPeers: 0, gossipEventRates: 0, verifyIpRates: 0, ok: False {}}

handleStats = \authorization respond -> do
  t <- now
  globalRateLimited <- checkGlobalRate t
  if globalRateLimited then yield (respond zeroStats)
  else do
  let authorized = verifyMaintenanceAuth authorization
  if authorized
    then do
      -- Split into two atomic reads: core capacity state (consistent) and counters/timing
      -- (slight inconsistency acceptable for monitoring). This narrows the lock window.
      core <- atomic do
        sc <- *totalSessionCount
        pc <- *totalPresenceCount
        f <- *forwards
        c <- *challenges
        a <- *ackedIds
        ao <- *ackOverflow
        d <- *deliveredIds
        ff <- *forwardFailures
        ap <- *activePolls
        tmc <- *totalMessageCount
        rc <- *recipientMsgCounts
        fi <- *federationInFlight
        rg <- *recentGossip
        fn <- *forwardNonces
        pac <- *pendingAckCleanups
        bp <- *blockedPeers
        ger <- *gossipEventRates
        vir <- *verifyIpRates
        yield {sc: sc, pc: pc, f: f, c: c, a: a, ao: ao, d: d, ff: ff, ap: ap, tmc: tmc, rc: rc, fi: fi, rg: rg, fn: fn, pac: pac, bp: bp, ger: ger, vir: vir}
      counters <- atomic do
        sr <- *sendRates
        cr <- *challengeRates
        fr <- *federationRates
        fpr <- *federationPairRates
        grc <- *globalRateCount
        ir <- *ipRates
        lr <- *lookupRates
        rr <- *recvRates
        prr <- *pairRates
        pc <- *pruneCount
        pr <- *pruneRunning
        hc <- *heartbeatCount
        sa <- *startedAt
        lp <- *lastPrunedAt
        lh <- *lastHeartbeatAt
        dr <- *draining
        flt <- *federationLatencyTotal
        flc <- *federationLatencyCount
        flm <- *federationLatencyMax
        dca <- *drainCompletedAt
        yield {sr: sr, cr: cr, fr: fr, fpr: fpr, grc: grc, ir: ir, lr: lr, rr: rr, prr: prr, pc: pc, pr: pr, hc: hc, sa: sa, lp: lp, lh: lh, dr: dr, flt: flt, flc: flc, flm: flm, dca: dca}
      let result = {sessions: core.sc, messages: core.tmc, presence: core.pc, forwards: count core.f, challenges: count core.c, ackedIds: count core.a, ackOverflow: count core.ao, deliveredIds: count core.d, forwardFailures: count core.ff, activePolls: count core.ap, sendRates: count counters.sr, challengeRates: count counters.cr, federationRates: count counters.fr, globalRateCount: counters.grc, ipRates: count counters.ir, lookupRates: count counters.lr, recvRates: count counters.rr, pairRates: count counters.prr, federationPairRates: count counters.fpr, pruneCount: counters.pc, pruneRunning: counters.pr, heartbeatCount: counters.hc, uptime: t - counters.sa, lastPruneAt: counters.lp, lastHeartbeatAt: counters.lh, draining: counters.dr, recentGossip: count core.rg, totalMessageCount: core.tmc, recipientCounts: count core.rc, federationInFlight: count core.fi, federationLatencyTotal: counters.flt, federationLatencyCount: counters.flc, federationLatencyMax: counters.flm, drainCompletedAt: counters.dca}
      let msgPct = if maxMessages > 0 then result.messages * 100 / maxMessages else 0
      let presPct = if maxPresenceEntries > 0 then result.presence * 100 / maxPresenceEntries else 0
      let fwdPct = if maxForwardsEntries > 0 then result.forwards * 100 / maxForwardsEntries else 0
      let sessPct = if maxSessions > 0 then result.sessions * 100 / maxSessions else 0
      let fedAvg = if result.federationLatencyCount > 0 then result.federationLatencyTotal / result.federationLatencyCount else 0
      let hungFedSlots = count (do r <- core.fi; where r.count > 0 && r.firstStartedAt > 0 && t - r.firstStartedAt >= federationFetchTimeoutMs; yield r)
      let oldestFwdAge = case minBy core.f (\x -> x.createdAt) of Nothing {} -> 0; Just {value: x} -> t - x.createdAt
      let oldestAckAge = case minBy core.a (\x -> x.ackedAt) of Nothing {} -> 0; Just {value: x} -> t - x.ackedAt
      yield (respond {sessions: result.sessions, sessionsMax: maxSessions, messages: result.messages, messagesMax: maxMessages, presence: result.presence, presenceMax: maxPresenceEntries, forwards: result.forwards, forwardsMax: maxForwardsEntries, challenges: result.challenges, challengesMax: maxChallenges, ackedIds: result.ackedIds, ackedIdsMax: maxAckedIds, ackOverflow: result.ackOverflow, ackOverflowMax: maxAckOverflow, deliveredIds: result.deliveredIds, deliveredIdsMax: maxDeliveredIds, forwardFailures: result.forwardFailures, activePolls: result.activePolls, activePollsMax: maxActivePolls, sendRates: result.sendRates, challengeRates: result.challengeRates, federationRates: result.federationRates, globalRateCount: result.globalRateCount, ipRates: result.ipRates, lookupRates: result.lookupRates, recvRates: result.recvRates, pairRates: result.pairRates, federationPairRates: result.federationPairRates, pruneCount: result.pruneCount, pruneRunning: result.pruneRunning, heartbeatCount: result.heartbeatCount, uptime: result.uptime, lastPruneAt: result.lastPruneAt, lastHeartbeatAt: result.lastHeartbeatAt, draining: result.draining, federationEnabled: federationEnabled, recentGossip: result.recentGossip, totalMessageCount: result.totalMessageCount, recipientCounts: result.recipientCounts, federationInFlight: result.federationInFlight, hungFederationSlots: hungFedSlots, messagesPct: msgPct, presencePct: presPct, forwardsPct: fwdPct, sessionsPct: sessPct, federationAvgLatencyMs: fedAvg, federationMaxLatencyMs: result.federationLatencyMax, federationCallCount: result.federationLatencyCount, drainCompletedAt: result.drainCompletedAt, oldestForwardAge: oldestFwdAge, oldestAckAge: oldestAckAge, forwardNonces: count core.fn, forwardNoncesMax: maxForwardNonces, pendingAckCleanups: count core.pac, blockedPeers: count core.bp, gossipEventRates: count core.ger, verifyIpRates: count core.vir, ok: True {}})
    else yield (respond zeroStats)

handleStatsPeers = \authorization respond -> do
  t <- now
  globalRateLimited <- checkGlobalRate t
  if globalRateLimited then yield (respond {peers: [], ok: False {}})
  else do
  let authorized = verifyMaintenanceAuth authorization
  if authorized
    then do
      failures <- *forwardFailures
      let peers = do f <- failures; yield {server: f.server, failures: f.failures, lastFailedAt: f.failedAt, firstFailedAt: f.firstFailedAt, backoffMs: retryBackoff f.failures, retriable: shouldRetryServer f.server t failures}
      yield (respond {peers: peers, ok: True {}})
    else yield (respond {peers: [], ok: False {}})

handleStatsKey = \pubkey authorization respond -> do
  t <- now
  globalRateLimited <- checkGlobalRate t
  if globalRateLimited then yield (respond {messages: 0, presence: [], sessions: 0, forwards: 0, activePolls: 0, ok: False {}})
  else do
  let authorized = verifyMaintenanceAuth authorization
  if authorized
    then do
      result <- atomic do
        keyBucket <- readMessageBucket (pubkeyBucket pubkey)
        -- Single bucket read: all entries for this pubkey are in the same presence bucket
        keyPresenceBkt <- readPresenceBucket (pubkeyBucket pubkey)
        allSessions <- readAllSessions
        forwards <- *forwards
        activePolls <- *activePolls
        let keyMessages = count (do m <- keyBucket; where m.toKey == pubkey; yield m)
        let keyPresence = do p <- keyPresenceBkt; where p.pubkey == pubkey && p.expiresAt > t; yield {server: p.server, expiresAt: p.expiresAt}
        let keySessions = count (do s <- allSessions; where s.pubkey == pubkey; yield s)
        let keyForwards = count (do f <- forwards; where f.toKey == pubkey; yield f)
        let keyPolls = count (do p <- activePolls; where p.pubkey == pubkey; yield p)
        yield {messages: keyMessages, presence: keyPresence, sessions: keySessions, forwards: keyForwards, activePolls: keyPolls}
      yield (respond {messages: result.messages, presence: result.presence, sessions: result.sessions, forwards: result.forwards, activePolls: result.activePolls, ok: True {}})
    else yield (respond {messages: 0, presence: [], sessions: 0, forwards: 0, activePolls: 0, ok: False {}})

emptySnapshot = {ok: False {}, version: 0, presence: [], ackedIds: [], ackOverflow: [], deliveredIds: [], forwardFailures: [], forwards: [], forwardNonces: [], blockedPeers: []}

-- GET /maintenance/snapshot: Export federation metadata for persistence.
-- Reads all dedup state (ackedIds, deliveredIds), presence, peer failure records,
-- and pending forwards in a single atomic snapshot. Forward retry counters are
-- preserved so they survive restarts (prevents re-trying permanently-failing forwards).
handleSnapshot = \authorization respond -> do
  let authorized = verifyMaintenanceAuth authorization
  if not authorized then yield (respond emptySnapshot)
  else do
    t <- now
    result <- atomic do
      p <- readAllPresence
      a <- *ackedIds
      ao <- *ackOverflow
      d <- *deliveredIds
      ff <- *forwardFailures
      f <- *forwards
      fn <- *forwardNonces
      bp <- *blockedPeers
      yield {presence: p, ackedIds: a, ackOverflow: ao, deliveredIds: d, forwardFailures: ff, forwards: f, forwardNonces: fn, blockedPeers: bp}
    atomic do set *lastSnapshotExportAt = t
    logInfo ("snapshot: exported " ++ show (count result.presence) ++ " presence, " ++ show (count result.ackedIds) ++ " ackedIds, " ++ show (count result.deliveredIds) ++ " deliveredIds, " ++ show (count result.forwards) ++ " forwards, " ++ show (count result.forwardNonces) ++ " forwardNonces, " ++ show (count result.blockedPeers) ++ " blockedPeers")
    yield (respond {ok: True {}, version: snapshotVersion, presence: result.presence, ackedIds: result.ackedIds, ackOverflow: result.ackOverflow, deliveredIds: result.deliveredIds, forwardFailures: result.forwardFailures, forwards: result.forwards, forwardNonces: result.forwardNonces, blockedPeers: result.blockedPeers})

-- POST /maintenance/restore: Import a previously-exported snapshot.
-- Requires drain mode to prevent conflicts with live state. Merges imported data
-- with existing state (dedup entries are unioned, presence is merged by freshness).
-- After restore, call /maintenance/undrain to resume, then /maintenance/prune to
-- trigger federation forward creation from messages + restored presence.
handleRestore = \version presenceData ackedIdsData ackOverflowData deliveredIdsData forwardFailuresData forwardsData forwardNoncesData blockedPeersData authorization respond -> do
  let authorized = verifyMaintenanceAuth authorization
  if not authorized then yield (respond {ok: False {}, error: "unauthorized", presenceCount: 0, ackedIdsCount: 0, deliveredIdsCount: 0})
  else do
    -- Version 0 = pre-versioning snapshot, version 1 = pre-forwardNonces, version 2 = pre-blockedPeers
    -- (accept all for backwards compatibility; missing fields default to empty list)
    if version != 0 && version != 1 && version != 2 && version != snapshotVersion then do
      logError ("restore: incompatible snapshot version " ++ show version ++ " (expected " ++ show snapshotVersion ++ ")")
      yield (respond {ok: False {}, error: "incompatible_version", presenceCount: 0, ackedIdsCount: 0, deliveredIdsCount: 0})
    else do
    t <- now
    isDraining <- *draining
    if not isDraining then yield (respond {ok: False {}, error: "server_must_be_draining", presenceCount: 0, ackedIdsCount: 0, deliveredIdsCount: 0})
    else do
      -- Validate imported data: reject entries with invalid or self-referencing server names.
      -- originServer in ForwardEntry is untyped Text (not ServerName), so not validated by the type system.
      -- Also reject entries pointing to the local server (nonsensical: we don't forward to ourselves
      -- or ack to ourselves).
      let validForwards = do f <- forwardsData; where not (isLocalServer f.toServer) && (f.originServer == "" || not (isBadServerName f.originServer)) && not (isLocalServer f.originServer); yield f
      let validAcked = do a <- ackedIdsData; where not (isLocalServer a.originServer); yield a
      let validOverflow = do a <- ackOverflowData; where not (isLocalServer a.originServer); yield a
      let rejectedCount = (count forwardsData - count validForwards) + (count ackedIdsData - count validAcked) + (count ackOverflowData - count validOverflow)
      when (rejectedCount > 0) (logWarn ("restore: rejected " ++ show rejectedCount ++ " imported entries with invalid or local server references"))
      result <- atomic do
        -- Merge presence (existing entries win on conflict via freshness)
        allPresence <- readAllPresence
        let mergedPresence = mergeByPubkeyServer allPresence (do p <- presenceData; where p.expiresAt > t; yield p)
        let cappedPresence = takeRelation maxPresenceEntries mergedPresence
        writeAllPresence cappedPresence
        set *totalPresenceCount = count cappedPresence
        set *knownPeerServers = collectPeerServers cappedPresence (\p -> p.server)
        set *presenceVersion = t
        -- Union dedup state, respecting capacity limits (using validated data)
        ackedIds <- *ackedIds
        let mergedAcked = union ackedIds validAcked
        let cappedAcked = takeRelation maxAckedIds mergedAcked
        set *ackedIds = cappedAcked
        ackOverflow <- *ackOverflow
        let mergedOverflow = union ackOverflow validOverflow
        set *ackOverflow = takeRelation maxAckOverflow mergedOverflow
        deliveredIds <- *deliveredIds
        let mergedDelivered = union deliveredIds deliveredIdsData
        let cappedDelivered = takeRelation maxDeliveredIds mergedDelivered
        set *deliveredIds = cappedDelivered
        -- Restore peer failure records
        forwardFailures <- *forwardFailures
        let mergedFailures = mergeByKey (\a b -> a.server == b.server) (\x -> x.failedAt) forwardFailures forwardFailuresData
        let cappedFailures = takeRelation maxForwardFailures mergedFailures
        set *forwardFailures = cappedFailures
        -- Restore forward entries (dedup by messageId + toServer, keep fresher on conflict; using validated data)
        forwards <- *forwards
        let mergedForwards = mergeByKey (\a b -> a.messageId == b.messageId && a.toServer == b.toServer) (\x -> x.createdAt) forwards validForwards
        let cappedForwards = takeRelation maxForwardsEntries mergedForwards
        set *forwards = cappedForwards
        -- Restore forward nonces (dedup by messageId + toKey + originServer, keep fresher on conflict)
        forwardNonces <- *forwardNonces
        let validNonces = do n <- forwardNoncesData; where t - n.seenAt < forwardNonceRetention; yield n
        let mergedNonces = mergeByKey (\a b -> a.messageId == b.messageId && a.toKey == b.toKey && a.originServer == b.originServer) (\x -> x.seenAt) forwardNonces validNonces
        let cappedNonces = takeRelation maxForwardNonces mergedNonces
        set *forwardNonces = cappedNonces
        -- Restore blocked peers (union with existing, cap at maxBlockedPeers)
        blocked <- *blockedPeers
        let mergedBlocked = fold (\acc b -> if any acc (\x -> x == b) then acc else union acc [b]) blocked blockedPeersData
        let cappedBlocked = takeRelation maxBlockedPeers mergedBlocked
        set *blockedPeers = cappedBlocked
        yield {presenceCount: count cappedPresence, ackedIdsCount: count cappedAcked, deliveredIdsCount: count cappedDelivered}
      logInfo ("restore: imported " ++ show result.presenceCount ++ " presence, " ++ show result.ackedIdsCount ++ " ackedIds, " ++ show result.deliveredIdsCount ++ " deliveredIds")
      yield (respond {ok: True {}, error: "", presenceCount: result.presenceCount, ackedIdsCount: result.ackedIdsCount, deliveredIdsCount: result.deliveredIdsCount})

-- POST /messages/ack: Explicitly acknowledge received messages by ID.
-- Alternative to the implicit cursor-based ack in poll. Benefits:
-- 1. Reduces the window for duplicate delivery (ack immediately without waiting for next poll)
-- 2. Selective ack: acknowledge specific messages without acking all messages up to a cursor
-- Rate-limited via global rate limiter; requires session auth.
handleAckMessages = \messageIds authorization clientIp respond -> do
  t <- now
  globalRateLimited <- checkGlobalRate t
  if globalRateLimited then yield (respond {ok: False {}, authorized: False {}, ackedCount: 0})
  else
    withSessionAuth authorization t clientIp
      (yield (respond {ok: False {}, authorized: False {}, ackedCount: 0}))
      (\pubkey -> do
        ackRateLimited <- atomic do
          lookupRates <- *lookupRates
          let rateResult = checkPubkeyRate lookupRates pubkey maxLookupRatePerKey lookupRateWindowMs maxLookupRateEntries t
          set *lookupRates = rateResult.entries
          yield rateResult.limited
        if ackRateLimited then yield (respond {ok: False {}, authorized: True {}, ackedCount: 0})
        else do
        let dedupedIds = dedupMessageIds messageIds
        result <- atomic do
          let b = pubkeyBucket pubkey
          bucket <- readMessageBucket b
          let toAck = do m <- bucket; where m.toKey == pubkey && any dedupedIds (\mid -> m.messageId == mid); yield m
          let ackCount = count toAck
          if ackCount > 0 then do
            writeMessageBucket b (diff bucket toAck)
            totalCount <- *totalMessageCount
            set *totalMessageCount = max 0 (totalCount - ackCount)
            recipientCounts <- *recipientMsgCounts
            set *recipientMsgCounts = adjustRecipientCount recipientCounts pubkey (0 - ackCount)
            let ackedMsgIds = do m <- toAck; yield m.messageId
            forwards <- *forwards
            set *forwards = do f <- forwards; where none ackedMsgIds (\mid -> f.messageId == mid && f.toKey == pubkey); yield f
            let ackedFederated = federatedAckEntries toAck t
            ackedIds <- *ackedIds
            let combinedAckedIds = union ackedIds ackedFederated
            let excessCount = max 0 (count combinedAckedIds - maxAckedIds)
            let eviction = evictSmallest combinedAckedIds excessCount (\a -> a.ackedAt)
            set *ackedIds = eviction.kept
            yield {ackedCount: ackCount, pendingAcks: ackedFederated, evictedEntries: eviction.evicted}
          else yield {ackedCount: 0, pendingAcks: [], evictedEntries: []}
        fork (when federationEnabled (do
          sendAcksAndClean result.pendingAcks
          retryEvictedAcks result.evictedEntries result.pendingAcks))
        yield (respond {ok: True {}, authorized: True {}, ackedCount: result.ackedCount}))

-- GET /messages/list: List pending messages without acking.
-- Useful after cursor loss (app reinstall, new device) to see what's pending.
-- Rate-limited via lookup rate limiter (read-only info lookup).
handleListMessages = \authorization clientIp respond -> do
  t <- now
  globalRateLimited <- checkGlobalRate t
  if globalRateLimited then yield (respond {messages: [], authorized: False {}, count: 0})
  else
    withSessionAuth authorization t clientIp
      (yield (respond {messages: [], authorized: False {}, count: 0}))
      (\pubkey -> do
        listRateLimited <- atomic do
          lookupRates <- *lookupRates
          let rateResult = checkPubkeyRate lookupRates pubkey maxLookupRatePerKey lookupRateWindowMs maxLookupRateEntries t
          set *lookupRates = rateResult.entries
          yield rateResult.limited
        if listRateLimited then yield (respond {messages: [], authorized: True {}, count: 0})
        else do
          result <- atomic do
            bucket <- readMessageBucket (pubkeyBucket pubkey)
            let myMsgs = sortBy (\m -> m.receivedAt) (do m <- bucket; where m.toKey == pubkey && m.receivedAt >= t - messageMaxAge; yield m)
            let capped = takeRelation maxPollEvents myMsgs
            yield {msgs: do m <- capped; yield {messageId: m.messageId, timestamp: m.timestamp, receivedAt: m.receivedAt}, total: count myMsgs}
          yield (respond {messages: result.msgs, authorized: True {}, count: result.total}))

-- POST /messages/batch: Send multiple messages in one request.
-- Auth checked once; each message processed independently with its own rate limiting.
-- Partial success is possible — check per-message status in results.
handleSendBatch = \messages authorization clientIp respond -> do
  t <- now
  globalRateLimited <- checkGlobalRate t
  if globalRateLimited then yield (respond {results: [], authorized: False {}, retryAfterMs: 0})
  else
    withSessionAuth authorization t clientIp
      (yield (respond {results: [], authorized: False {}, retryAfterMs: 0}))
      (\senderKey -> do
        let capped = takeRelation maxMessageIds messages
        results <- sendBatchInner senderKey capped t []
        -- Fork federation forwarding for all successful sends
        let forwardTargets = do r <- results; where count r.remoteServers > 0; yield r
        fork (when (federationEnabled && count forwardTargets > 0)
          (sendToEach (collectPeerServers forwardTargets (\r -> case headOf r.remoteServers of Nothing {} -> ""; Just {value: s} -> s)) (\server -> do
            let serverMsgs = do r <- forwardTargets; where any r.remoteServers (\s -> s == server); yield r
            forEachBatch serverMsgs maxMessageIds (\batch -> do
              forEachBatch batch 1 (\single -> case headOf single of
                Nothing {} -> yield {}
                Just {value: r} -> forkSendForwards r.messageId r.toKey r.blob r.ts (do s <- r.remoteServers; where s == server; yield s))))))
        let batchRetryMs = fold (\acc r -> max acc r.retryAfterMs) 0 results
        yield (respond {results: do r <- results; yield {messageId: r.messageId, status: r.status}, authorized: True {}, retryAfterMs: batchRetryMs}))

sendBatchInner = \senderKey messages t acc ->
  let split = splitAtN messages 1 in
  case headOf split.batch of
    Nothing {} -> yield acc
    Just {value: msg} -> do
      effectiveMsgId <- if msg.messageId != "" then yield msg.messageId else genToken
      when (msg.timestamp > t + clockSkewTolerance)
        (logWarn ("sendBatch: future timestamp detected (+" ++ show (msg.timestamp - t) ++ "ms ahead) for " ++ effectiveMsgId))
      when (msg.timestamp < t - messageMaxAge / 2 && t - msg.timestamp <= messageMaxAge)
        (logWarn ("sendBatch: stale timestamp (" ++ show ((t - msg.timestamp) / 86400000) ++ " days old) for " ++ effectiveMsgId))
      result <- if t - msg.timestamp > messageMaxAge
        then yield {messageId: "", status: MsRejected {}, remoteServers: [], toKey: "", blob: "", ts: 0, retryAfterMs: 0}
        else do
          let clampedTs = clampTimestamp msg.timestamp t
          sendResult <- atomic do
            draining <- *draining
            if draining then yield {status: MsDraining {}, remoteServers: [], retryAfterMs: 0}
            else sendMessageCore senderKey msg.to msg.encryptedBlob clampedTs effectiveMsgId t
          case sendResult.status of
            MsRateLimited {} -> logWarn ("sendBatch: rate limited for " ++ effectiveMsgId)
            MsRejected {} -> logWarn ("sendBatch: rejected for " ++ effectiveMsgId ++ " (capacity or mailbox full)")
            _ -> yield {}
          yield {messageId: effectiveMsgId, status: sendResult.status, remoteServers: sendResult.remoteServers, toKey: msg.to, blob: msg.encryptedBlob, ts: clampedTs, retryAfterMs: sendResult.retryAfterMs}
      sendBatchInner senderKey split.rest t (union acc [result])

-- POST /maintenance/block: Add a server to the federation blocklist.
-- Blocked peers are rejected from all inbound and outbound federation operations.
handleBlockPeer = \server authorization respond -> do
  let authorized = verifyMaintenanceAuth authorization
  if not authorized then yield (respond {ok: False {}, blocked: 0})
  else do
    result <- atomic do
      blocked <- *blockedPeers
      if isBlockedPeer server blocked then yield {alreadyBlocked: True {}, total: count blocked}
      else do
        -- FIFO eviction: remove the oldest entry (head of list) since union appends
        let updated = if count blocked >= maxBlockedPeers
          then case headOf blocked of
            Nothing {} -> [server]
            Just {value: oldest} -> union (do b <- blocked; where b != oldest; yield b) [server]
          else union blocked [server]
        set *blockedPeers = updated
        yield {alreadyBlocked: False {}, total: count updated}
    when (not result.alreadyBlocked) (logInfo ("block: added " ++ server ++ " to blocklist (" ++ show result.total ++ " total)"))
    yield (respond {ok: True {}, blocked: result.total})

-- POST /maintenance/unblock: Remove a server from the federation blocklist.
handleUnblockPeer = \server authorization respond -> do
  let authorized = verifyMaintenanceAuth authorization
  if not authorized then yield (respond {ok: False {}, unblocked: False {}})
  else do
    removed <- atomic do
      blocked <- *blockedPeers
      let had = isBlockedPeer server blocked
      set *blockedPeers = do b <- blocked; where b != server; yield b
      yield had
    when removed (logInfo ("unblock: removed " ++ server ++ " from blocklist"))
    yield (respond {ok: True {}, unblocked: removed})

-- GET /maintenance/blocked: List currently blocked federation peers.
handleListBlocked = \authorization respond -> do
  let authorized = verifyMaintenanceAuth authorization
  if not authorized then yield (respond {peers: [], ok: False {}})
  else do
    blocked <- *blockedPeers
    yield (respond {peers: blocked, ok: True {}})

-- POST /maintenance/ping: Test federation connectivity to a specific peer.
-- Sends an empty gossip request via fetchFederation, triggering a full verify callback
-- round-trip (peer calls back to our /federation/verify to authenticate the request).
-- This exercises the real federation auth path and tracks in-flight/latency metrics.
handlePingPeer = \server authorization respond -> do
  let authorized = verifyMaintenanceAuth authorization
  if not authorized then yield (respond {ok: False {}, latencyMs: 0, error: "unauthorized"})
  else do
    startTime <- now
    auth <- generateFederationAuth "gossip"
    result <- fetchFederation server (RecvGossip {
      authorization: auth,
      events: [], hopsRemaining: 1, fromServer: serverHostN,
      requestTimestamp: startTime})
    endTime <- now
    let latency = endTime - startTime
    case result of
      Err e -> do
        logWarn ("ping: " ++ server ++ " failed: " ++ show e)
        yield (respond {ok: False {}, latencyMs: latency, error: show e})
      Ok r -> yield (respond {ok: r.ok, latencyMs: latency, error: r.error})

-- GET /maintenance/sessions/{pubkey}: List sessions for a specific pubkey.
-- Returns masked tokens (first 8 chars only) for identification without exposing full tokens.
handleAdminListSessions = \pubkey authorization respond -> do
  let authorized = verifyMaintenanceAuth authorization
  if not authorized then yield (respond {sessions: [], count: 0, ok: False {}})
  else do
    result <- atomic do
      allSessions <- readAllSessions
      let keySessions = do s <- allSessions; where s.pubkey == pubkey; yield {token: take 8 s.token ++ "...", expiresAt: s.expiresAt, ip: s.ip, createdAt: s.createdAt}
      yield {sessions: keySessions, total: count keySessions}
    yield (respond {sessions: result.sessions, count: result.total, ok: True {}})

-- POST /maintenance/sessions/revoke-all: Revoke all sessions for a pubkey (abuse response).
-- Also clears local presence and gossips offline if federation is enabled.
handleAdminRevokeSessions = \pubkey authorization respond -> do
  let authorized = verifyMaintenanceAuth authorization
  if not authorized then yield (respond {ok: False {}, revokedCount: 0})
  else do
    t <- now
    result <- atomic do
      allSessions <- readAllSessions
      let revokedCount = count (do s <- allSessions; where s.pubkey == pubkey; yield s)
      let remaining = do s <- allSessions; where s.pubkey != pubkey; yield s
      writeAllSessions remaining
      set *totalSessionCount = count remaining
      -- Clear local presence
      let pb = pubkeyBucket pubkey
      presenceBkt <- readPresenceBucket pb
      let presenceRemoved = count presenceBkt - count (do p <- presenceBkt; where p.pubkey != pubkey || not (isLocalServer p.server); yield p)
      writePresenceBucket pb (do p <- presenceBkt; where p.pubkey != pubkey || not (isLocalServer p.server); yield p)
      tpc <- *totalPresenceCount
      set *totalPresenceCount = max 0 (tpc - presenceRemoved)
      when (presenceRemoved > 0) (set *presenceVersion = t)
      peerServers <- *knownPeerServers
      yield {revokedCount: revokedCount, peerServers: peerServers, hadPresence: presenceRemoved > 0}
    when (result.revokedCount > 0)
      (logInfo ("admin: revoked " ++ show result.revokedCount ++ " sessions for " ++ pubkey))
    when (result.hadPresence && federationEnabled && count result.peerServers > 0)
      (fork (sendBatchedGossip result.peerServers [{eventType: GossipOffline {}, pubkey: pubkey, server: serverHostN, timestamp: t, ttl: offlineGossipMinTtl}] gossipOriginHops))
    yield (respond {ok: True {}, revokedCount: result.revokedCount})

serve = \req -> case req of
  ReqChallenge {pubkey, clientIp, respond} -> handleChallenge pubkey clientIp respond
  VerifyAuth {pubkey, challenge, signature, revokeOthers, clientIp, respond} -> handleVerifyAuth pubkey challenge signature revokeOthers clientIp respond
  RevokeSession {targetToken, authorization, clientIp, respond} -> handleRevoke targetToken authorization clientIp respond
  Logout {authorization, clientIp, respond} -> handleLogout authorization clientIp respond
  Poll {cursor, generation, watchKeys, authorization, clientIp, respond} -> handlePoll cursor generation watchKeys authorization clientIp respond
  SendMessage {to, encryptedBlob, timestamp, messageId, authorization, clientIp, respond} -> handleSendMessage to encryptedBlob timestamp messageId authorization clientIp respond
  MessageStatus {to, messageId, authorization, clientIp, respond} -> handleMessageStatus to messageId authorization clientIp respond
  AckMessages {messageIds, authorization, clientIp, respond} -> handleAckMessages messageIds authorization clientIp respond
  SendBatch {messages, authorization, clientIp, respond} -> handleSendBatch messages authorization clientIp respond
  ListMessages {authorization, clientIp, respond} -> handleListMessages authorization clientIp respond
  LookupPresence {pubkey, authorization, clientIp, respond} -> handleLookupPresence pubkey authorization clientIp respond
  RecvGossip {events, hopsRemaining, fromServer, requestTimestamp, authorization, respond} -> handleRecvGossip events hopsRemaining fromServer requestTimestamp authorization respond
  ForwardMessage {toKey, encryptedBlob, timestamp, originServer, messageId, fromServer, requestTimestamp, authorization, respond} -> handleForwardMessage toKey encryptedBlob timestamp originServer messageId fromServer requestTimestamp authorization respond
  FederationAck {messageIds, originServer, fromServer, requestTimestamp, authorization, respond} -> handleFederationAck messageIds originServer fromServer requestTimestamp authorization respond
  VerifyToken {token, scope, clientIp, respond} -> handleVerifyToken token scope clientIp respond
  Prune {authorization, respond} -> handlePrune authorization respond
  Drain {authorization, respond} -> handleDrain authorization respond
  Undrain {authorization, respond} -> handleUndrain authorization respond
  Snapshot {authorization, respond} -> handleSnapshot authorization respond
  Restore {version, presence, ackedIds, ackOverflow, deliveredIds, forwardFailures, forwards, forwardNonces, blockedPeers, authorization, respond} -> handleRestore version presence ackedIds ackOverflow deliveredIds forwardFailures forwards forwardNonces blockedPeers authorization respond
  BlockPeer {server, authorization, respond} -> handleBlockPeer server authorization respond
  UnblockPeer {server, authorization, respond} -> handleUnblockPeer server authorization respond
  ListBlocked {authorization, respond} -> handleListBlocked authorization respond
  PingPeer {server, authorization, respond} -> handlePingPeer server authorization respond
  AdminListSessions {pubkey, authorization, respond} -> handleAdminListSessions pubkey authorization respond
  AdminRevokeSessions {pubkey, authorization, respond} -> handleAdminRevokeSessions pubkey authorization respond
  Health {authorization, respond} -> handleHealth authorization respond
  Stats {authorization, respond} -> handleStats authorization respond
  StatsPeers {authorization, respond} -> handleStatsPeers authorization respond
  StatsKey {pubkey, authorization, respond} -> handleStatsKey pubkey authorization respond

-- ============================================
-- Entry Point
-- ============================================

-- Background loop: periodically prunes expired state and retries pending federation ops.
-- Jitter prevents thundering herd when multiple servers restart simultaneously.
-- NOTE: This function (and all background loops below) recurse via tail calls.
-- Knot compiles tail calls to loops, so stack growth is bounded. If Knot's tail-call
-- optimization is ever disabled, these loops will overflow the stack over time.
backgroundPrune = do
  jitter <- randomInt 5000
  sleep (backgroundPruneInterval + jitter)
  draining <- *draining
  if draining then do
    sleep backgroundPruneInterval
    backgroundPrune
  else do
  t <- now
  -- Detect backward clock jump: if seqCounter is far ahead of now, reset to prevent
  -- all messages getting unreachable receivedAt values for an extended period
  atomic do
    sc <- *seqCounter
    when (sc > t + clockSkewTolerance) (do
      logWarn ("clock jump detected — seqCounter " ++ show (sc - t) ++ "ms ahead of now, resetting")
      set *seqCounter = t)
  -- Heartbeat watchdog: bump pollWakeup if heartbeat loop appears dead
  sa <- *startedAt
  lastHb <- *lastHeartbeatAt
  when (t - sa > healthHeartbeatMaxAge && t - lastHb > healthHeartbeatMaxAge) (do
    logWarn "backgroundPrune: heartbeat appears dead, bumping pollWakeup"
    atomic do
      set *pollWakeup = t
      set *lastHeartbeatAt = t)
  status <- atomic do
    running <- *pruneRunning
    if running > 0 && t - running < backgroundPruneInterval * 2
      then yield {canRun: False {}, recovered: False {}, gen: 0, stuckSince: 0}
      else do
        set *pruneRunning = t
        gen <- *pruneGeneration
        let newGen = gen + 1
        set *pruneGeneration = newGen
        pc <- *pruneCount
        set *pruneCount = pc + 1
        yield {canRun: True {}, recovered: running > 0, gen: newGen, stuckSince: running}
  when status.recovered (do
    logWarn ("backgroundPrune: previous cycle stuck for " ++ show (t - status.stuckSince) ++ "ms, forcing recovery")
    -- Reset fork counter: the stuck fork leaked its slot, so reclaim it to prevent permanent lockout
    atomic do set *activePruneForks = 0)
  if status.canRun
    then do
      -- Guard against unbounded concurrent prune forks from repeated stuck recovery
      forks <- *activePruneForks
      if forks >= 2
        then logWarn "backgroundPrune: skipping (max concurrent prune forks reached)"
        else do
          atomic do
            af <- *activePruneForks
            set *activePruneForks = af + 1
          fork (do
            pruneAndRetry t
            -- Only clear running flag if this is still the latest generation
            -- (prevents a stuck old fork from clearing the flag after a recovery cycle started)
            atomic do
              currentGen <- *pruneGeneration
              when (currentGen == status.gen) (set *pruneRunning = 0)
              af <- *activePruneForks
              set *activePruneForks = max 0 (af - 1))
    else logWarn "backgroundPrune: skipping (previous cycle still running)"
  backgroundPrune

-- Background loop: periodically bumps pollWakeup to unblock long-polls that have been
-- waiting too long (heartbeat). Ensures polls return within pollTimeoutMs even if no messages arrive.
pollHeartbeat = do
  jitter <- randomInt 2000
  sleep (pollTimeoutMs + jitter)
  draining <- *draining
  if draining then do
    t <- now
    atomic do set *pollWakeup = t
    -- Don't exit; sleep and retry so undrain can resume the loop
    sleep pollTimeoutMs
    pollHeartbeat
  else do
    t <- now
    atomic do
      set *pollWakeup = t
      set *lastHeartbeatAt = t
      hc <- *heartbeatCount
      set *heartbeatCount = hc + 1
    pollHeartbeat

-- Background loop: periodically logs a state summary to stdout.
-- Operators can capture stdout to detect state drift; use /maintenance/snapshot for full export.
-- TODO: If Knot adds file I/O primitives, auto-export snapshots to a file
-- (e.g., /var/lib/skrepka/snapshot.json) in addition to logging. Currently
-- a crash between manual snapshot exports loses all federation state.
backgroundSnapshot = do
  sleep autoSnapshotInterval
  draining <- *draining
  if not draining then do
    result <- atomic do
      tmc <- *totalMessageCount
      sc <- *totalSessionCount
      pc <- *totalPresenceCount
      f <- *forwards
      a <- *ackedIds
      ao <- *ackOverflow
      d <- *deliveredIds
      ff <- *forwardFailures
      pac <- *pendingAckCleanups
      yield {messages: tmc, sessions: sc, presence: pc, forwards: count f, ackedIds: count a, ackOverflow: count ao, deliveredIds: count d, forwardFailures: count ff, pendingAckCleanups: count pac}
    logInfo ("snapshot: messages=" ++ show result.messages ++ " sessions=" ++ show result.sessions ++ " presence=" ++ show result.presence ++ " forwards=" ++ show result.forwards ++ " ackedIds=" ++ show result.ackedIds ++ " ackOverflow=" ++ show result.ackOverflow ++ " deliveredIds=" ++ show result.deliveredIds ++ " forwardFailures=" ++ show result.forwardFailures ++ " pendingAckCleanups=" ++ show result.pendingAckCleanups)
    -- Warn if federation state hasn't been exported recently (will be lost on restart)
    t <- now
    lastExport <- *lastSnapshotExportAt
    when (maintenanceSecret != "" && snapshotStalenessWarning > 0
      && (lastExport == 0 || t - lastExport > snapshotStalenessWarning)
      && (result.ackedIds > 0 || result.deliveredIds > 0 || result.forwards > 0 || result.presence > 0))
      (do
        logError ("no snapshot exported in " ++ show (if lastExport == 0 then 0 else (t - lastExport) / 1000) ++ "s — federation state will be lost on restart (presence=" ++ show result.presence ++ " forwards=" ++ show result.forwards ++ " ackedIds=" ++ show result.ackedIds ++ " deliveredIds=" ++ show result.deliveredIds ++ ")")
        logError "ACTION REQUIRED: run GET /maintenance/snapshot to persist federation state before restart")
  else yield {}
  backgroundSnapshot

-- Background watchdog: monitors prune and heartbeat loops, restarts if they appear dead.
-- Knot lacks try/catch, so panicked loops can't self-recover. This watchdog detects
-- liveness by checking counter freshness and forks a new loop instance as needed.
backgroundWatchdog = do
  sleep (backgroundPruneInterval * 5)
  t <- now
  atomic do set *lastWatchdogAt = t
  sa <- *startedAt
  let warmup = t - sa < backgroundPruneInterval * 10
  if warmup then backgroundWatchdog
  else do
    -- Check prune loop health
    lastPrune <- *lastPrunedAt
    when (t - lastPrune > healthPruneMaxAge * 3) (do
      logError "watchdog: prune loop appears dead, restarting"
      atomic do set *pruneRunning = 0
      fork backgroundPrune)
    -- Check heartbeat loop health
    lastHb <- *lastHeartbeatAt
    when (t - lastHb > healthHeartbeatMaxAge * 3) (do
      logError "watchdog: heartbeat loop appears dead, restarting"
      fork pollHeartbeat)
    -- Recover leaked federation slots: if prune is alive but in-flight counters
    -- are stuck, force-reconcile. This catches edge cases where panicked fetches
    -- leaked slots but prune's stale threshold hasn't reclaimed them yet.
    fedActive <- *federationActiveConnections
    when (fedActive > maxGlobalFederationConcurrency) (do
      logWarn ("watchdog: federation connection counter (" ++ show fedActive ++ ") exceeds max (" ++ show maxGlobalFederationConcurrency ++ "), reconciling")
      atomic do
        inFlight <- *federationInFlight
        set *federationActiveConnections = fold (\acc r -> acc + r.count) 0 inFlight)
    backgroundWatchdog

main = do
  let configOk = maxMessages > 0 && maxMessagesPerRecipient > 0 && maxPresenceEntries > 0
        && maxSessions > 0 && maxChallenges > 0 && backgroundPruneInterval > 0
        && pollTimeoutMs > 0 && challengeExpiry > 0 && sessionExpiry > 0
        && maxSessionLifetime > 0
        && maxPresenceTtl > 0 && maxForwardsEntries > 0 && maxAckedIds > 0
        && maxForwardRetries > 0 && maxGossipHops > 0 && maxPollsPerKey > 0
        && gossipOriginHops > 0 && maxThirdPartyGossipHops > 0
        && verificationTokenExpiry > 0
        && maxAckRetries > 0 && maxPairRatePerPair > 0 && pairRateWindowMs > 0
        && maxFederationPairRatePerPair > 0 && federationPairRateWindowMs > 0
        && reconciliationFrequency > 0 && maxForwardNonces > 0
        && maxGossipEventsPerServer > 0 && gossipEventRateWindowMs > 0
        && maxGlobalFederationConcurrency > 0
  -- Relationship invariants: these misconfigurations cause subtle bugs
  -- (e.g., messages pruned before their stated max age, backoff that never increases)
  let configRelationsOk = unackedMessageMaxAge <= messageMaxAge
        && challengeExpiry < sessionExpiry
        && sessionExpiry <= maxSessionLifetime
        && retryBackoffBase <= retryBackoffMax
        && backgroundPruneInterval < healthPruneMaxAge
        && ackGracePeriod < unackedMessageMaxAge
        && clockSkewTolerance < challengeExpiry
        && maxMessagesPerRecipient <= maxMessages
        && maxSessionsPerKey <= maxSessions
        && maxChallengesPerKey <= maxChallenges
        && maxPollsPerKey <= maxActivePolls
        && pollTimeoutMs < sessionExpiry
        && gossipDedupWindow < presenceRefreshInterval
        && federationFetchTimeoutMs <= backgroundPruneInterval
        && maxAckOverflow <= maxAckedIds
        && gossipOriginHops <= maxGossipHops
        && maxThirdPartyGossipHops <= maxGossipHops
        && verificationTokenExpiry <= federationFetchTimeoutMs
        && forwardNonceRetention >= messageMaxAge
        && maxGlobalFederationConcurrency >= maxFederationConcurrency
        && maxGossipEventsPerServer > maxGossipEvents
  if not configOk
    then logError "FATAL: invalid configuration — capacity limits and intervals must be > 0, server not started"
    else if not configRelationsOk
    then logError "FATAL: invalid configuration — relationship invariants violated (check: unackedMessageMaxAge <= messageMaxAge, challengeExpiry < sessionExpiry, sessionExpiry <= maxSessionLifetime, retryBackoffBase <= retryBackoffMax, backgroundPruneInterval < healthPruneMaxAge, pollTimeoutMs < sessionExpiry, gossipDedupWindow < presenceRefreshInterval, federationFetchTimeoutMs <= backgroundPruneInterval, maxAckOverflow <= maxAckedIds, gossipOriginHops <= maxGossipHops, maxThirdPartyGossipHops <= maxGossipHops, verificationTokenExpiry <= federationFetchTimeoutMs, forwardNonceRetention >= messageMaxAge, maxGlobalFederationConcurrency >= maxFederationConcurrency, maxGossipEventsPerServer > maxGossipEvents, per-key limits <= global limits), server not started"
    else do
      t <- now
      atomic do
        set *startedAt = t
        set *serverGeneration = t
      when (maintenanceSecret == "")
        (logWarn "maintenanceSecret is empty — /maintenance/* and /stats endpoints are disabled")
      when (matchesHostnameOrSubdomain serverHostN "localhost")
        (logWarn ("serverHost is " ++ serverHost ++ " — peers cannot reach this server for federation"))
      logInfo "IP binding is active — sessions created with a ClientIp header will reject requests without one"
      logInfo "Skrepka relay server starting on port 8080..."
      logInfo ("  federation: " ++ if federationEnabled then "enabled" else "disabled")
      logInfo ("  prune interval: " ++ show backgroundPruneInterval ++ "ms")
      logInfo ("  poll timeout: " ++ show pollTimeoutMs ++ "ms")
      logInfo ("  max messages: " ++ show maxMessages ++ " (per recipient: " ++ show maxMessagesPerRecipient ++ ")")
      logInfo ("  max sessions: " ++ show maxSessions ++ " (per key: " ++ show maxSessionsPerKey ++ ")")
      logInfo ("  max presence: " ++ show maxPresenceEntries)
      logInfo ("  max forwards: " ++ show maxForwardsEntries)
      logInfo ("  session expiry: " ++ show sessionExpiry ++ "ms (max lifetime: " ++ show maxSessionLifetime ++ "ms)")
      logInfo ("  message max age: " ++ show messageMaxAge ++ "ms")
      logInfo ("  global rate limit: " ++ show maxGlobalRequestRate ++ "/" ++ show globalRateWindowMs ++ "ms")
      logInfo ("  auth rate limit: " ++ show maxAuthGlobalRate ++ "/" ++ show authGlobalRateWindowMs ++ "ms")
      logInfo ("  pair rate limit: " ++ show maxPairRatePerPair ++ "/" ++ show pairRateWindowMs ++ "ms per sender-recipient")
      logInfo ("  federation pair rate limit: " ++ show maxFederationPairRatePerPair ++ "/" ++ show federationPairRateWindowMs ++ "ms per server-recipient")
      logInfo ("  gossip event rate limit: " ++ show maxGossipEventsPerServer ++ " events/" ++ show gossipEventRateWindowMs ++ "ms per server")
      logInfo ("  global federation concurrency: " ++ show maxGlobalFederationConcurrency)
      logInfo ("  ack retry limit: " ++ show maxAckRetries ++ " per entry")
      when (federationCircuitBreakerThreshold > 0)
        (logInfo ("  circuit breaker: " ++ show federationCircuitBreakerThreshold ++ " failing peers"))
      when (autoSnapshotInterval > 0)
        (logInfo ("  auto-snapshot: " ++ show autoSnapshotInterval ++ "ms"))
      fork backgroundPrune
      fork pollHeartbeat
      fork backgroundWatchdog
      when (autoSnapshotInterval > 0) (fork backgroundSnapshot)
      listen 8080 serve
