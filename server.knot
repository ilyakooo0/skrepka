-- GET /stats/peers: per-peer failure summary derived from `forwardFailures`,
-- including current backoff and pending forward queue depth.
handleStatsPeers : Text -> ({ok: Bool, peers: [{avgLatencyMs: Int, backoffMs: Int<Ms>, failures: Int, firstFailedAt: Int<Ms>, gossipEventsPerMin: Int, lastFailedAt: Int<Ms>, latencySamples: Int, maxLatencyMs: Int, pendingForwards: Int, retriable: Bool, server: Text}]} -> a) -> IO {reads *forwardFailures, reads *forwards, reads *runtimeMaintenanceSecret, clock} a
handleStatsPeers = \authorization respond -> withMaintAuth authorization (yield (respond {
  peers: [],
  ok: False {}
})) (do
  t <- now
  failures <- *forwardFailures
  fwds <- *forwards
  yield (respond {
    peers: pluck failures (\f -> {
      f.server,
      f.failures,
      lastFailedAt: f.failedAt,
      f.firstFailedAt,
      backoffMs: retryBackoff f.failures,
      retriable: shouldRetryServer f.server t failures,
      pendingForwards: countWhere fwds (\x -> x.toServer == f.server),
      avgLatencyMs: 0,
      maxLatencyMs: 0,
      latencySamples: 0,
      gossipEventsPerMin: 0
    }),
    ok: True {}
  }))

-- GET /stats/key/{pubkey}: per-key footprint — message count, presence rows,
-- session count, queued forwards (with details), and active long-poll count.
handleStatsKey : PubkeyHex -> Text -> ({activePolls: Int, forwardDetails: [{createdAt: Int<Ms>, retries: Int, server: ServerName}], forwards: Int, messages: Int, ok: Bool, presence: [{expiresAt: Int<Ms>, server: AnyServerName}], sessions: Int} -> a) -> IO {reads *activePolls, reads *forwards, reads *messages, reads *presence, reads *runtimeMaintenanceSecret, reads *sessions, clock} a
handleStatsKey = \pubkey authorization respond -> withMaintAuth authorization (yield (respond {
  messages: 0,
  presence: [],
  sessions: 0,
  forwards: 0,
  forwardDetails: [],
  activePolls: 0,
  ok: False {}
})) (do
  t <- now
  msgs <- *messages
  pres <- *presence
  ses <- *sessions
  fwds <- *forwards
  aps <- *activePolls
  let myFwds = filter fwds (\x -> x.toKey == pubkey)
  yield (respond {
    messages: countWhere msgs (\x -> x.toKey == pubkey),
    presence: mapWhere pres (\x -> x.pubkey == pubkey && x.expiresAt > t) (\x -> {
      x.server,
      x.expiresAt
    }),
    sessions: countWhere ses (\x -> x.pubkey == pubkey),
    forwards: count myFwds,
    forwardDetails: pluck myFwds (\x -> {server: x.toServer, x.retries, x.createdAt}),
    activePolls: countWhere aps (\x -> x.pubkey == pubkey),
    ok: True {}
  }))

-- POST /stats/top-recipients: ranked list of pubkeys by mailbox depth.
-- `limit` defaults to 20, capped at 100, used to spot hot-spots / abuse.
handleTopRecipients : Int -> Text -> ({ok: Bool, recipients: [{count: Int, pubkey: PubkeyHex}], total: Int} -> a) -> IO {reads *messages, reads *runtimeMaintenanceSecret} a
handleTopRecipients = \limit authorization respond -> withMaintAuth authorization (yield (respond {
  recipients: [],
  ok: False {},
  total: 0
})) (do
  msgs <- *messages
  let counts = pluck (unique (pluck msgs (\m -> m.toKey))) (\pk -> {
    pubkey: pk,
    count: countWhere msgs (\m -> m.toKey == pk)
  })
  let cap = clamp 1 100 (if limit <= 0 then 20 else limit)
  let top = takeRelation cap (sortBy (\c -> 0 - c.count) counts)
  yield (respond {recipients: top, ok: True {}, total: count counts}))

-- GET /stats/forwards: per-destination forward queue summary — count, age of
-- oldest pending entry, and total accumulated retries.
handleStatsForwards : Text -> ({ok: Bool, servers: [{count: Int<u>, oldestAge: Int<Ms>, server: ServerName, totalRetries: Int}], total: Int} -> a) -> IO {reads *forwards, reads *runtimeMaintenanceSecret, clock} a
handleStatsForwards = \authorization respond -> withMaintAuth authorization (yield (respond {
  servers: [],
  ok: False {},
  total: 0
})) (do
  t <- now
  fwds <- *forwards
  yield (respond {
    servers: pluck (collectPeers fwds (\f -> f.toServer)) (\s -> (\svFwds -> {server: s, count: count svFwds, oldestAge: t - fold (\acc f -> min acc f.createdAt) t svFwds, totalRetries: fold (\acc f -> acc + f.retries) 0 svFwds}) (filter fwds (\f -> f.toServer == s))),
    ok: True {},
    total: count fwds
  }))

-- GET /stats/rates: same shape as /maintenance/rate-limits with an extra
-- scalePct field. Kept separate for backwards compatibility with older clients.
handleStatsRates : Text -> ({authGlobal: Int, challengeRate: Int, clientWriteRate: Int, federationRate: Int, globalRequest: Int, ipRate: Int, lookupRate: Int, ok: Bool, pairRate: Int, recvRate: Int, scalePct: Int, sendRate: Int} -> a) -> IO {reads *runtimeMaintenanceSecret} a
handleStatsRates = \authorization respond -> do
  ok <- verifyMaintenanceAuth authorization
  let v = \x -> if ok then x else 0
  yield (respond {
    ok,
    scalePct: v 100,
    globalRequest: v maxGlobalRequestRate,
    ipRate: v maxIpRatePerIp,
    sendRate: v maxSendRatePerKey,
    federationRate: v maxFederationRatePerServer,
    authGlobal: v maxAuthGlobalRate,
    recvRate: v maxRecvRatePerKey,
    challengeRate: v maxChallengeRatePerKey,
    pairRate: v maxPairRatePerPair,
    lookupRate: v maxLookupRatePerKey,
    clientWriteRate: v maxClientWriteRatePerKey
  })

-- GET /metrics: Prometheus-style text exposition of the most useful gauges.
-- The `authorization` header is accepted but not validated here — operators
-- relying on auth must front this endpoint with a reverse proxy that enforces it.
handleMetrics : a -> ({metrics: Text, ok: Bool} -> b) -> IO {reads *activePolls, reads *drainPhase, reads *forwards, reads *messages, reads *presence, reads *sessions, reads *startedAt, clock} b
handleMetrics = \authorization respond -> do
  t <- now
  msgs <- *messages
  ses <- *sessions
  pres <- *presence
  fwds <- *forwards
  aps <- *activePolls
  sa <- *startedAt
  dp <- *drainPhase
  yield (respond {
    metrics: fold (\acc r -> acc ++ r.k ++ " " ++ show r.v ++ "\n") "" [
      {k: "skrepka_messages_total", v: count msgs},
      {k: "skrepka_sessions_total", v: count ses},
      {k: "skrepka_presence_total", v: count pres},
      {k: "skrepka_forwards_total", v: count fwds},
      {k: "skrepka_active_polls", v: count aps},
      {k: "skrepka_uptime_seconds", v: (t - sa) / 1000},
      {k: "skrepka_draining", v: if dp > 0 then 1 else 0}
    ],
    ok: True {}
  })

-- ============================================
-- Dispatch
-- ============================================
-- Single match from generated request constructor (one per route entry above)
-- to the corresponding `handleXxx` function. Adding a new route means adding
-- a `route ... = NewReq` line, a `handleNewReq` definition, and a clause here.

serve : <AckMessages {authorization: Text, clientIp: Text, messageIds: [MessageIdHex], respond: {ackedCount: Int, authorized: Bool, error: Text, ok: Bool} -> Response} | AdminListAllSessions {authorization: Text, limit: Int, respond: {ok: Bool, sessions: [{count: Int, ips: [Text], latestExpiry: Timestamp, pubkey: PubkeyHex}], total: Int} -> Response} | AdminListSessions {authorization: Text, pubkey: PubkeyHex, respond: {count: Int, ok: Bool, sessions: [{createdAt: Timestamp, expiresAt: Timestamp, ip: Text, token: Text}]} -> Response} | AdminPurgeMessages {authorization: Text, pubkey: PubkeyHex, respond: {ok: Bool, purgedCount: Int} -> Response} | AdminRevokeIp {authorization: Text, ip: Text, respond: {affectedKeys: Int, ok: Bool, revokedCount: Int} -> Response} | AdminRevokeSessions {authorization: Text, pubkey: PubkeyHex, respond: {ok: Bool, revokedCount: Int} -> Response} | AllowPeer {authorization: Text, respond: {allowed: Int, ok: Bool} -> Response, server: ServerName} | BatchLookupPresence {authorization: Text, clientIp: Text, pubkeys: [PubkeyHex], respond: {authorized: Bool, error: Text, results: [{pubkey: PubkeyHex, server: AnyServerName}]} -> Response} | BlockPeer {authorization: Text, respond: {blocked: Int, ok: Bool} -> Response, server: ServerName} | CancelBatch {authorization: Text, cancels: [BatchCancelEntry], clientIp: Text, respond: {authorized: Bool, error: Text, results: [BatchCancelResult]} -> Response} | CancelMessage {authorization: Text, clientIp: Text, messageId: MessageIdHex, respond: {authorized: Bool, cancelled: Bool, error: Text, ok: Bool} -> Response, to: PubkeyHex} | DeleteMessages {authorization: Text, clientIp: Text, messageIds: [MessageIdHex], respond: {authorized: Bool, deletedCount: Int, error: Text, ok: Bool} -> Response} | Drain {authorization: Text, phase: Int, respond: {drained: Int, ok: Bool, phase: Int} -> Response} | FederationAck {authorization: Text, correlationId: Text, fromServer: ServerName, messageIds: [MessageIdHex], originServer: ServerName, protocolVersion: Int, requestTimestamp: Timestamp, respond: {ackedCount: Int, error: Text, ok: Bool, results: [{found: Bool, messageId: MessageIdHex}], retryAfterMs: Int} -> Response} | FederationBatchCancel {authorization: Text, cancels: [{messageId: MessageIdHex, toKey: PubkeyHex}], correlationId: Text, fromServer: ServerName, protocolVersion: Int, requestTimestamp: Timestamp, respond: {error: Text, ok: Bool, results: [BatchCancelResult], retryAfterMs: Int} -> Response} | FederationBatchForward {authorization: Text, correlationId: Text, forwards: [{encryptedBlob: BlobHex, expiresAt: Timestamp, messageId: MessageIdHex, originServer: ServerName, priority: Int, timestamp: Timestamp, toKey: PubkeyHex}], fromServer: ServerName, protocolVersion: Int, requestTimestamp: Timestamp, respond: {error: Text, ok: Bool, results: [{messageId: MessageIdHex, ok: Bool}], retryAfterMs: Int} -> Response} | FederationCancel {authorization: Text, correlationId: Text, fromServer: ServerName, messageId: MessageIdHex, protocolVersion: Int, requestTimestamp: Timestamp, respond: {cancelled: Bool, error: Text, ok: Bool, retryAfterMs: Int} -> Response, toKey: PubkeyHex} | FederationDeliveryReceipt {authorization: Text, correlationId: Text, fromServer: ServerName, messageIds: [MessageIdHex], protocolVersion: Int, requestTimestamp: Timestamp, respond: {error: Text, ok: Bool, receivedCount: Int, retryAfterMs: Int} -> Response, toKeys: [PubkeyHex]} | FederationPubkey {respond: {ok: Bool, pubkey: Text} -> Response} | FlushNonces {authorization: Text, respond: {flushedCount: Int, ok: Bool} -> Response} | ForwardMessage {authorization: Text, correlationId: Text, encryptedBlob: BlobHex, expiresAt: Timestamp, fromServer: ServerName, messageId: MessageIdHex, originServer: ServerName, priority: Int, protocolVersion: Int, requestTimestamp: Timestamp, respond: {error: Text, ok: Bool, retryAfterMs: Int} -> Response, timestamp: Timestamp, toKey: PubkeyHex} | GetConfig {authorization: Text, respond: {ackGracePeriod: Int, maxGossipHops: Int, maxMessagesPerRecipient: Int, ok: Bool, pollTimeoutMs: Int} -> Response} | GetRateLimits {authorization: Text, respond: {authGlobal: Int, challengeRate: Int, clientWriteRate: Int, federationRate: Int, globalRequest: Int, ipRate: Int, lookupRate: Int, ok: Bool, pairRate: Int, recvRate: Int, sendRate: Int} -> Response} | Health {authorization: Text, respond: {capacityHealthy: Bool, capacityWarning: Bool, degradedPeers: Int, draining: Bool, federationHealthy: Bool, forwardQueueHealthy: Bool, heartbeatHealthy: Bool, nonceHealthy: Bool, ok: Bool, pruneHealthy: Bool, requestPressureHealthy: Bool, version: Text, watchdogHealthy: Bool} -> Response} | ListAllowed {authorization: Text, respond: {ok: Bool, peers: [Text]} -> Response} | ListBlocked {authorization: Text, respond: {ok: Bool, peers: [Text]} -> Response} | ListMessages {authorization: Text, clientIp: Text, offset: Int, respond: {authorized: Bool, count: Int, error: Text, messages: [{messageId: MessageIdHex, receivedAt: Timestamp, timestamp: Timestamp}]} -> Response} | Logout {authorization: Text, clientIp: Text, respond: {authorized: Bool, ok: Bool} -> Response} | LookupPresence {authorization: Text, clientIp: Text, pubkey: PubkeyHex, respond: {authorized: Bool, error: Text, server: AnyServerName} -> Response} | MessageStatus {authorization: Text, clientIp: Text, messageId: MessageIdHex, respond: {authorized: Bool, status: Text} -> Response, to: PubkeyHex} | Metrics {authorization: Text, respond: {metrics: Text, ok: Bool} -> Response} | PingPeer {authorization: Text, respond: {error: Text, latencyMs: Int, ok: Bool} -> Response, server: ServerName} | Poll {authorization: Text, clientIp: Text, cursor: Timestamp, generation: Int, respond: {authorized: Bool, cursor: Timestamp, cursorReset: Bool, cursorStale: Bool, draining: Bool, droppedDeliveryReceipts: Int, droppedExpirationNotifs: Int, events: [PollEvent], generation: Int, hasMore: Bool, heartbeat: Bool, loadPct: Int, messageCancellations: [{cancelledAt: Timestamp, messageId: MessageIdHex}], messageDeliveries: [{deliveredAt: Timestamp, messageId: MessageIdHex, toKey: PubkeyHex}], messageExpirations: [{expiredAt: Timestamp, messageId: MessageIdHex, toKey: PubkeyHex}], presenceUpdates: [{online: Bool, pubkey: PubkeyHex}], rateLimited: Bool, retryAfterMs: Int} -> Response, watchKeys: [PubkeyHex]} | Prune {authorization: Text, respond: {ok: Bool} -> Response} | Ready {respond: {ready: Bool} -> Response} | Reconcile {authorization: Text, respond: {messageDrift: Int, ok: Bool, presenceDrift: Int, sessionDrift: Int} -> Response} | RecvGossip {authorization: Text, correlationId: Text, events: [GossipEvent], fromServer: ServerName, hopsRemaining: Int, protocolVersion: Int, requestTimestamp: Timestamp, respond: {error: Text, ok: Bool, retryAfterMs: Int} -> Response} | ReqChallenge {clientIp: Text, pubkey: PubkeyHex, respond: {challenge: Text, error: Text, expiresAt: Timestamp, ok: Bool, retryAfterMs: Int} -> Response} | RevokeSession {authorization: Text, clientIp: Text, respond: {authorized: Bool, ok: Bool} -> Response, targetToken: Text} | RotateSecret {authorization: Text, newSecret: Text, respond: {error: Text, ok: Bool} -> Response} | SendBatch {authorization: Text, clientIp: Text, messages: [BatchMessage], respond: {authorized: Bool, results: [BatchResult], retryAfterMs: Int} -> Response} | SendMessage {authorization: Text, clientIp: Text, encryptedBlob: BlobHex, expiresInMs: Int, messageId: OptionalMessageId, priority: Int, respond: {error: Text, loadPct: Int, messageId: OptionalMessageId, retryAfterMs: Int, status: MessageStatus} -> Response, timestamp: Timestamp, to: PubkeyHex} | SetRateLimits {authGlobal: Int, authorization: Text, challengeRate: Int, clientWriteRate: Int, federationRate: Int, globalRequest: Int, ipRate: Int, lookupRate: Int, pairRate: Int, recvRate: Int, respond: {ok: Bool} -> Response, sendRate: Int} | Shutdown {authorization: Text, respond: {drained: Int, ok: Bool} -> Response} | Stats {authorization: Text, respond: {capacity: {ackOverflow: Int, ackOverflowMax: Int, ackedIds: Int, ackedIdsMax: Int, activePolls: Int, activePollsMax: Int, challenges: Int, challengesMax: Int, deliveredIds: Int, deliveredIdsMax: Int, forwardNonces: Int, forwardNoncesMax: Int, forwards: Int, forwardsMax: Int, forwardsPct: Int, messageBucketMax: Int, messageBucketMin: Int, messages: Int, messagesMax: Int, messagesPct: Int, nonceEvictions: Int, presence: Int, presenceMax: Int, presencePct: Int, recipientCounts: Int, sessions: Int, sessionsMax: Int, sessionsPct: Int, totalMessageCount: Int}, federation: {avgLatencyMs: Int, blockedPeers: Int, callCount: Int, drainCompletedAt: Timestamp, enabled: Bool, forwardFailures: Int, forwardServers: Int, gossipFail: Int, gossipSuccess: Int, hungSlots: Int, inFlight: Int, latencyBuckets: {gte2000: Int, lt100: Int, lt2000: Int, lt500: Int}, maxForwardQueueDepth: Int, maxLatencyMs: Int, oldestAckAge: Int, oldestForwardAge: Int, pendingCancels: Int, recentGossip: Int, slowVerifies: Int, topFailingPeers: [{failures: Int, server: Text}], verifyFailures: Int}, ok: Bool, rates: {challenge: Int, clientCancels: Int, federation: Int, federationCancels: Int, federationPair: Int, global: Int, gossipEvent: Int, ip: Int, lookup: Int, pair: Int, pendingAckCleanups: Int, recv: Int, rejectedAuth: Int, rejectedFederation: Int, rejectedGlobal: Int, rejectedIp: Int, rejectedPerKey: Int, send: Int, senderDeliveries: Int, senderExpirations: Int, uniqueKeyIp: Int, verifyIp: Int}, timing: {activeRequests: Int, authAvgMs: Int, authCount: Int, authMaxMs: Int, drainPhase: Int, draining: Bool, heartbeatCount: Int, lastHeartbeatAt: Timestamp, lastPruneAt: Timestamp, peakActiveRequests: Int, pollAvgMs: Int, pollCount: Int, pollLatencyBuckets: {gte1000: Int, lt1000: Int, lt200: Int, lt50: Int}, pollMaxMs: Int, pruneCount: Int, pruneRunning: Timestamp, sendAvgMs: Int, sendCount: Int, sendLatencyBuckets: {gte1000: Int, lt1000: Int, lt200: Int, lt50: Int}, sendMaxMs: Int, totalEntries: Int, uptime: Int}, version: Text} -> Response} | StatsForwards {authorization: Text, respond: {ok: Bool, servers: [{count: Int, oldestAge: Int, server: Text, totalRetries: Int}], total: Int} -> Response} | StatsKey {authorization: Text, pubkey: PubkeyHex, respond: {activePolls: Int, forwardDetails: [{createdAt: Timestamp, retries: Int, server: Text}], forwards: Int, messages: Int, ok: Bool, presence: [KeyPresenceEntry], sessions: Int} -> Response} | StatsPeers {authorization: Text, respond: {ok: Bool, peers: [PeerStatus]} -> Response} | StatsRates {authorization: Text, respond: {authGlobal: Int, challengeRate: Int, clientWriteRate: Int, federationRate: Int, globalRequest: Int, ipRate: Int, lookupRate: Int, ok: Bool, pairRate: Int, recvRate: Int, scalePct: Int, sendRate: Int} -> Response} | TopRecipients {authorization: Text, limit: Int, respond: {ok: Bool, recipients: [RecipientCount], total: Int} -> Response} | UnallowPeer {authorization: Text, respond: {ok: Bool, removed: Bool} -> Response, server: ServerName} | UnblockPeer {authorization: Text, respond: {ok: Bool, unblocked: Bool} -> Response, server: ServerName} | Undrain {authorization: Text, respond: {ok: Bool} -> Response} | VerifyAuth {challenge: Text, clientIp: Text, pubkey: PubkeyHex, respond: {error: Text, expiresAt: Timestamp, token: Text} -> Response, revokeOthers: Bool, signature: SignatureHex} | VerifyToken {clientIp: Text, respond: {ok: Bool} -> Response, scope: Text, token: Text}> -> IO {reads *ackedIds, reads *activePolls, reads *allowedPeers, reads *authGlobalRateCount, reads *authGlobalRateWindowStart, reads *blockedPeers, reads *cancelNotifications, reads *challengeRates, reads *challenges, reads *deliveredIds, reads *drainCompletedAt, reads *drainPhase, reads *federationRates, reads *forwardFailures, reads *forwards, reads *globalRateCount, reads *globalRateWindowStart, reads *heartbeatCount, reads *ipRates, reads *lastHeartbeatAt, reads *lastPresenceRefresh, reads *lastPrunedAt, reads *messages, reads *pendingFederationCancels, reads *pendingVerifications, reads *pollWakeup, reads *presence, reads *pruneCount, reads *recvRates, reads *runtimeMaintenanceSecret, reads *senderDeliveries, reads *senderExpirations, reads *seqCounter, reads *serverGeneration, reads *sessions, reads *startedAt, writes *ackedIds, writes *activePolls, writes *allowedPeers, writes *authGlobalRateCount, writes *authGlobalRateWindowStart, writes *blockedPeers, writes *cancelNotifications, writes *challengeRates, writes *challenges, writes *deliveredIds, writes *drainCompletedAt, writes *drainPhase, writes *federationRates, writes *forwardFailures, writes *forwards, writes *globalRateCount, writes *globalRateWindowStart, writes *ipRates, writes *lastPresenceRefresh, writes *lastPrunedAt, writes *messages, writes *pendingFederationCancels, writes *pendingVerifications, writes *pollWakeup, writes *presence, writes *recvRates, writes *runtimeMaintenanceSecret, writes *senderDeliveries, writes *senderExpirations, writes *seqCounter, writes *sessions, network, clock, random} Response
serve = \req -> case req of
  ReqChallenge {pubkey, clientIp, respond} -> handleChallenge pubkey clientIp respond
  VerifyAuth {pubkey, challenge, signature, revokeOthers, clientIp, respond} -> handleVerifyAuth pubkey challenge signature revokeOthers clientIp respond
  RevokeSession {targetToken, authorization, clientIp, respond} -> handleRevoke targetToken authorization clientIp respond
  Logout {authorization, clientIp, respond} -> handleLogout authorization clientIp respond
  Poll {cursor, generation, watchKeys, authorization, clientIp, respond} -> handlePoll cursor generation watchKeys authorization clientIp respond
  SendMessage {to, encryptedBlob, timestamp, messageId, expiresInMs, priority, authorization, clientIp, respond} -> handleSendMessage to encryptedBlob timestamp messageId expiresInMs priority authorization clientIp respond
  MessageStatus {to, messageId, authorization, clientIp, respond} -> handleMessageStatus to messageId authorization clientIp respond
  AckMessages {messageIds, authorization, clientIp, respond} -> handleAckMessages messageIds authorization clientIp respond
  SendBatch {messages, authorization, clientIp, respond} -> handleSendBatch messages authorization clientIp respond
  ListMessages {offset, authorization, clientIp, respond} -> handleListMessages offset authorization clientIp respond
  DeleteMessages {messageIds, authorization, clientIp, respond} -> handleDeleteMessages messageIds authorization clientIp respond
  CancelMessage {messageId, to, authorization, clientIp, respond} -> handleCancelMessage messageId to authorization clientIp respond
  CancelBatch {cancels, authorization, clientIp, respond} -> handleCancelBatch cancels authorization clientIp respond
  LookupPresence {pubkey, authorization, clientIp, respond} -> handleLookupPresence pubkey authorization clientIp respond
  BatchLookupPresence {pubkeys, authorization, clientIp, respond} -> handleBatchLookupPresence pubkeys authorization clientIp respond
  RecvGossip {events, hopsRemaining, fromServer, requestTimestamp, authorization, respond} -> handleRecvGossip events hopsRemaining fromServer requestTimestamp authorization respond
  ForwardMessage {toKey, encryptedBlob, timestamp, originServer, messageId, fromServer, requestTimestamp, expiresAt, priority, authorization, respond} -> handleForwardMessage toKey encryptedBlob timestamp originServer messageId fromServer requestTimestamp expiresAt priority authorization respond
  FederationAck {messageIds, originServer, fromServer, requestTimestamp, authorization, respond} -> handleFederationAck messageIds originServer fromServer requestTimestamp authorization respond
  FederationCancel {messageId, toKey, fromServer, requestTimestamp, authorization, respond} -> handleFederationCancel messageId toKey fromServer requestTimestamp authorization respond
  FederationBatchCancel {cancels, fromServer, requestTimestamp, authorization, respond} -> handleFederationBatchCancel cancels fromServer requestTimestamp authorization respond
  FederationBatchForward {forwards, fromServer, requestTimestamp, authorization, respond} -> handleFederationBatchForward forwards fromServer requestTimestamp authorization respond
  FederationDeliveryReceipt {messageIds, toKeys, fromServer, requestTimestamp, authorization, respond} -> handleFederationDeliveryReceipt messageIds toKeys fromServer requestTimestamp authorization respond
  VerifyToken {token, scope, clientIp, respond} -> handleVerifyToken token scope clientIp respond
  FederationPubkey {respond} -> handleFederationPubkey respond
  Prune {authorization, respond} -> handlePrune authorization respond
  Drain {phase, authorization, respond} -> handleDrain phase authorization respond
  Shutdown {authorization, respond} -> handleShutdown authorization respond
  Undrain {authorization, respond} -> handleUndrain authorization respond
  BlockPeer {server, authorization, respond} -> handleBlockPeer server authorization respond
  UnblockPeer {server, authorization, respond} -> handleUnblockPeer server authorization respond
  ListBlocked {authorization, respond} -> handleListBlocked authorization respond
  PingPeer {server, authorization, respond} -> handlePingPeer server authorization respond
  AdminListSessions {pubkey, authorization, respond} -> handleAdminListSessions pubkey authorization respond
  AdminRevokeSessions {pubkey, authorization, respond} -> handleAdminRevokeSessions pubkey authorization respond
  AdminListAllSessions {limit, authorization, respond} -> handleAdminListAllSessions limit authorization respond
  AdminPurgeMessages {pubkey, authorization, respond} -> handleAdminPurgeMessages pubkey authorization respond
  AdminRevokeIp {ip, authorization, respond} -> handleAdminRevokeIp ip authorization respond
  GetRateLimits {authorization, respond} -> handleGetRateLimits authorization respond
  SetRateLimits {globalRequest, ipRate, sendRate, federationRate, authGlobal, recvRate, challengeRate, pairRate, lookupRate, clientWriteRate, authorization, respond} -> handleSetRateLimits globalRequest ipRate sendRate federationRate authGlobal recvRate challengeRate pairRate lookupRate clientWriteRate authorization respond
  FlushNonces {authorization, respond} -> handleFlushNonces authorization respond
  AllowPeer {server, authorization, respond} -> handleAllowPeer server authorization respond
  UnallowPeer {server, authorization, respond} -> handleUnallowPeer server authorization respond
  ListAllowed {authorization, respond} -> handleListAllowed authorization respond
  Reconcile {authorization, respond} -> handleReconcile authorization respond
  RotateSecret {newSecret, authorization, respond} -> handleRotateSecret newSecret authorization respond
  GetConfig {authorization, respond} -> handleGetConfig authorization respond
  Health {authorization, respond} -> handleHealth authorization respond
  Stats {authorization, respond} -> handleStats authorization respond
  StatsPeers {authorization, respond} -> handleStatsPeers authorization respond
  StatsKey {pubkey, authorization, respond} -> handleStatsKey pubkey authorization respond
  TopRecipients {limit, authorization, respond} -> handleTopRecipients limit authorization respond
  StatsForwards {authorization, respond} -> handleStatsForwards authorization respond
  StatsRates {authorization, respond} -> handleStatsRates authorization respond
  Metrics {authorization, respond} -> handleMetrics authorization respond
  Ready {respond} -> handleReady respond

-- ============================================
-- Background loops
-- ============================================
-- `backgroundPrune` runs `pruneAndRetry` every `backgroundPruneInterval` ms
-- (skipped while drain phase >= 2). `pollHeartbeat` bumps `pollWakeup` every
-- `pollTimeoutMs` so long-poll holders unblock and return an empty heartbeat
-- response, keeping connections fresh.

backgroundPrune : IO {reads *drainPhase, clock, reads *ackedIds, reads *activePolls, reads *blockedPeers, reads *cancelNotifications, reads *challenges, reads *deliveredIds, reads *forwardFailures, reads *forwards, reads *lastPresenceRefresh, reads *lastPrunedAt, reads *messages, reads *pendingFederationCancels, reads *pendingVerifications, reads *presence, reads *pruneCount, reads *senderDeliveries, reads *senderExpirations, reads *sessions, writes *ackedIds, writes *activePolls, writes *cancelNotifications, writes *challenges, writes *deliveredIds, writes *forwardFailures, writes *forwards, writes *lastPresenceRefresh, writes *lastPrunedAt, writes *messages, writes *pendingFederationCancels, writes *pendingVerifications, writes *presence, writes *pruneCount, writes *senderDeliveries, writes *senderExpirations, writes *sessions} a
backgroundPrune = do
  sleep backgroundPruneInterval
  dp <- *drainPhase
  when (dp < 2) (do
    t <- now
    atomic (do pc <- *pruneCount; *pruneCount = pc + 1)
    pruneAndRetry t)
  backgroundPrune

pollHeartbeat : IO {reads *heartbeatCount, reads *lastHeartbeatAt, reads *pollWakeup, writes *heartbeatCount, writes *lastHeartbeatAt, writes *pollWakeup, clock} a
pollHeartbeat = do
  sleep pollTimeoutMs
  t <- now
  atomic (do *pollWakeup = t; *lastHeartbeatAt = t; hc <- *heartbeatCount; *heartbeatCount = hc + 1)
  pollHeartbeat

-- ============================================
-- Entry Point
-- ============================================
-- Stamp `startedAt` and a fresh `serverGeneration` (used by clients to detect
-- server restarts and reset their poll cursor), spawn the two background
-- loops, and start the listener.

main : IO {| _} {}
main = do
  t <- now
  genJitter <- randomInt 1000000
  atomic (do *startedAt = t; *serverGeneration = t * 1000 + genJitter)
  logInfo ("Skrepka relay server starting on port " ++ show listenPort ++ "...")
  logInfo ("  federation: " ++ (if federationEnabled then "enabled" else "disabled"))
  fork backgroundPrune
  fork pollHeartbeat
  listen listenPort serve
